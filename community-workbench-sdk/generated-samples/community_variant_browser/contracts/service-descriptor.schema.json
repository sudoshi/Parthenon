{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parthenon.local/schemas/community-workbench-sdk/service-descriptor.schema.json",
  "title": "Workbench Service Descriptor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "service_name",
    "display_name",
    "description",
    "mode",
    "enabled",
    "healthy",
    "ui_hints",
    "capabilities"
  ],
  "properties": {
    "service_name": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "external-adapter",
        "native"
      ]
    },
    "enabled": {
      "type": "boolean"
    },
    "healthy": {
      "type": "boolean"
    },
    "unavailability_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "ui_hints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "summary",
        "accent",
        "workspace"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "accent": {
          "type": "string"
        },
        "workspace": {
          "type": "string"
        },
        "repository": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_scoped": {
          "type": "boolean"
        },
        "replay_supported": {
          "type": "boolean"
        },
        "export_supported": {
          "type": "boolean"
        },
        "write_operations": {
          "type": "boolean"
        }
      }
    }
  }
}
