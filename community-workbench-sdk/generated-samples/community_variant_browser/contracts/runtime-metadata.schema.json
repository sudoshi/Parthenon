{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parthenon.local/schemas/community-workbench-sdk/runtime-metadata.schema.json",
  "title": "Workbench Runtime Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "adapter_mode",
    "fallback_active",
    "upstream_ready",
    "dependency_issues",
    "notes"
  ],
  "properties": {
    "status": {
      "type": "string"
    },
    "adapter_mode": {
      "type": "string"
    },
    "fallback_active": {
      "type": "boolean"
    },
    "upstream_ready": {
      "type": "boolean"
    },
    "dependency_issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "timings": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "number",
          "integer"
        ]
      }
    },
    "last_error": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
