{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parthenon.local/schemas/community-workbench-sdk/artifact-manifest.schema.json",
  "title": "Workbench Artifact Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifacts"
  ],
  "properties": {
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "kind",
          "summary",
          "downloadable",
          "previewable"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "content_type": {
            "type": [
              "string",
              "null"
            ]
          },
          "path": {
            "type": [
              "string",
              "null"
            ]
          },
          "summary": {
            "type": "string"
          },
          "downloadable": {
            "type": "boolean"
          },
          "previewable": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
