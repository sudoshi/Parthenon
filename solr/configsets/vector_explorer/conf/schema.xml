<?xml version="1.0" encoding="UTF-8" ?>
<schema name="vector_explorer" version="1.6">

  <uniqueKey>point_id</uniqueKey>

  <!-- Field types -->
  <fieldType name="pint" class="solr.IntPointField" docValues="true"/>
  <fieldType name="plong" class="solr.LongPointField" docValues="true"/>
  <fieldType name="pfloat" class="solr.FloatPointField" docValues="true"/>
  <fieldType name="pdouble" class="solr.DoublePointField" docValues="true"/>
  <fieldType name="string" class="solr.StrField" sortMissingLast="true" docValues="true"/>
  <fieldType name="boolean" class="solr.BoolField" sortMissingLast="true"/>

  <fieldType name="text_general" class="solr.TextField" positionIncrementGap="100">
    <analyzer type="index">
      <tokenizer class="solr.StandardTokenizerFactory"/>
      <filter class="solr.LowerCaseFilterFactory"/>
      <filter class="solr.StopFilterFactory" ignoreCase="true" words="stopwords.txt"/>
    </analyzer>
    <analyzer type="query">
      <tokenizer class="solr.StandardTokenizerFactory"/>
      <filter class="solr.LowerCaseFilterFactory"/>
      <filter class="solr.StopFilterFactory" ignoreCase="true" words="stopwords.txt"/>
    </analyzer>
  </fieldType>

  <!-- Core projection fields -->
  <field name="point_id" type="string" indexed="true" stored="true" required="true"/>
  <field name="collection_name" type="string" indexed="true" stored="true" required="true"/>
  <field name="chroma_id" type="string" indexed="true" stored="true"/>
  <field name="x" type="pdouble" indexed="true" stored="true"/>
  <field name="y" type="pdouble" indexed="true" stored="true"/>
  <field name="z" type="pdouble" indexed="true" stored="true"/>
  <field name="cluster_id" type="pint" indexed="true" stored="true"/>
  <field name="cluster_label" type="string" indexed="true" stored="true"/>

  <!-- Quality flags (precomputed) -->
  <field name="is_outlier" type="boolean" indexed="true" stored="true"/>
  <field name="is_orphan" type="boolean" indexed="true" stored="true"/>
  <field name="duplicate_of" type="string" indexed="true" stored="true" multiValued="true"/>

  <!-- Metadata fields from ChromaDB documents -->
  <field name="source" type="string" indexed="true" stored="true"/>
  <field name="doc_type" type="string" indexed="true" stored="true"/>
  <field name="category" type="string" indexed="true" stored="true"/>
  <field name="title" type="text_general" indexed="true" stored="true"/>
  <field name="document_text" type="text_general" indexed="true" stored="true"/>

  <!-- Dynamic fields for arbitrary metadata -->
  <dynamicField name="meta_s_*" type="string" indexed="true" stored="true"/>
  <dynamicField name="meta_i_*" type="pint" indexed="true" stored="true"/>
  <dynamicField name="meta_f_*" type="pfloat" indexed="true" stored="true"/>
  <dynamicField name="meta_t_*" type="text_general" indexed="true" stored="true"/>

  <!-- Projection stats (stored once per collection as a special doc) -->
  <field name="is_stats_doc" type="boolean" indexed="true" stored="true"/>
  <field name="total_vectors" type="pint" indexed="false" stored="true"/>
  <field name="sampled" type="pint" indexed="false" stored="true"/>
  <field name="projection_time_ms" type="pint" indexed="false" stored="true"/>
  <field name="num_clusters" type="pint" indexed="false" stored="true"/>
  <field name="num_outliers" type="pint" indexed="false" stored="true"/>
  <field name="num_duplicates" type="pint" indexed="false" stored="true"/>
  <field name="num_orphans" type="pint" indexed="false" stored="true"/>
  <field name="num_edges" type="pint" indexed="false" stored="true"/>
  <field name="indexed_at" type="string" indexed="true" stored="true"/>

  <!-- Required by Solr -->
  <field name="_version_" type="plong" indexed="false" stored="false"/>

</schema>
