<?xml version="1.0" encoding="UTF-8" ?>
<schema name="imaging" version="1.6">

  <uniqueKey>study_id</uniqueKey>

  <!-- Field types -->
  <fieldType name="pint" class="solr.IntPointField" docValues="true"/>
  <fieldType name="plong" class="solr.LongPointField" docValues="true"/>
  <fieldType name="pfloat" class="solr.FloatPointField" docValues="true"/>
  <fieldType name="pdate" class="solr.DatePointField" docValues="true"/>
  <fieldType name="string" class="solr.StrField" sortMissingLast="true" docValues="true"/>
  <fieldType name="boolean" class="solr.BoolField" sortMissingLast="true"/>

  <fieldType name="text_general" class="solr.TextField" positionIncrementGap="100">
    <analyzer type="index">
      <tokenizer class="solr.StandardTokenizerFactory"/>
      <filter class="solr.LowerCaseFilterFactory"/>
      <filter class="solr.StopFilterFactory" ignoreCase="true" words="stopwords.txt"/>
    </analyzer>
    <analyzer type="query">
      <tokenizer class="solr.StandardTokenizerFactory"/>
      <filter class="solr.LowerCaseFilterFactory"/>
      <filter class="solr.StopFilterFactory" ignoreCase="true" words="stopwords.txt"/>
    </analyzer>
  </fieldType>

  <!-- Edge n-gram for autocomplete on descriptions -->
  <fieldType name="text_suggest" class="solr.TextField" positionIncrementGap="100">
    <analyzer type="index">
      <tokenizer class="solr.StandardTokenizerFactory"/>
      <filter class="solr.LowerCaseFilterFactory"/>
      <filter class="solr.EdgeNGramFilterFactory" minGramSize="2" maxGramSize="25"/>
    </analyzer>
    <analyzer type="query">
      <tokenizer class="solr.StandardTokenizerFactory"/>
      <filter class="solr.LowerCaseFilterFactory"/>
    </analyzer>
  </fieldType>

  <!-- Imaging study fields -->
  <field name="study_id" type="string" indexed="true" stored="true" required="true"/>
  <field name="study_instance_uid" type="string" indexed="true" stored="true"/>
  <field name="accession_number" type="string" indexed="true" stored="true"/>
  <field name="person_id" type="plong" indexed="true" stored="true"/>
  <field name="source_id" type="pint" indexed="true" stored="true"/>
  <field name="modality" type="string" indexed="true" stored="true"/>
  <field name="body_part_examined" type="string" indexed="true" stored="true"/>
  <field name="study_description" type="text_general" indexed="true" stored="true"/>
  <field name="study_description_exact" type="string" indexed="true" stored="false"/>
  <field name="study_description_suggest" type="text_suggest" indexed="true" stored="false"/>
  <field name="study_date" type="pdate" indexed="true" stored="true"/>
  <field name="num_series" type="pint" indexed="true" stored="true"/>
  <field name="num_images" type="pint" indexed="true" stored="true"/>
  <field name="status" type="string" indexed="true" stored="true"/>
  <field name="has_measurements" type="boolean" indexed="true" stored="true"/>
  <field name="measurement_count" type="pint" indexed="true" stored="true"/>

  <!-- Patient-level denormalized fields for cross-search -->
  <field name="patient_id_dicom" type="string" indexed="true" stored="true"/>
  <field name="patient_name_dicom" type="text_general" indexed="true" stored="true"/>

  <!-- Series-level summary (multi-valued) -->
  <field name="series_modalities" type="string" indexed="true" stored="true" multiValued="true"/>
  <field name="series_descriptions" type="text_general" indexed="true" stored="true" multiValued="true"/>

  <!-- Catch-all search field -->
  <field name="text" type="text_general" indexed="true" stored="false" multiValued="true"/>

  <!-- Required by Solr -->
  <field name="_version_" type="plong" indexed="false" stored="false"/>

  <!-- Copy fields for faceting and search -->
  <copyField source="study_description" dest="study_description_exact"/>
  <copyField source="study_description" dest="study_description_suggest"/>
  <copyField source="study_description" dest="text"/>
  <copyField source="patient_name_dicom" dest="text"/>
  <copyField source="series_descriptions" dest="text"/>
  <copyField source="modality" dest="text"/>
  <copyField source="body_part_examined" dest="text"/>

</schema>
