<?xml version="1.0" encoding="UTF-8" ?>
<config>
  <luceneMatchVersion>9.11.1</luceneMatchVersion>

  <dataDir>${solr.data.dir:}</dataDir>

  <directoryFactory name="DirectoryFactory" class="${solr.directoryFactory:solr.NRTCachingDirectoryFactory}"/>
  <codecFactory class="solr.SchemaCodecFactory"/>
  <schemaFactory class="ClassicIndexSchemaFactory"/>

  <indexConfig>
    <ramBufferSizeMB>64</ramBufferSizeMB>
    <maxBufferedDocs>500</maxBufferedDocs>
  </indexConfig>

  <updateHandler class="solr.DirectUpdateHandler2">
    <updateLog>
      <str name="dir">${solr.ulog.dir:}</str>
    </updateLog>
    <autoCommit>
      <maxTime>${solr.autoCommit.maxTime:5000}</maxTime>
      <openSearcher>false</openSearcher>
    </autoCommit>
    <autoSoftCommit>
      <maxTime>${solr.autoSoftCommit.maxTime:1000}</maxTime>
    </autoSoftCommit>
  </updateHandler>

  <!-- Query handler -->
  <requestHandler name="/select" class="solr.SearchHandler">
    <lst name="defaults">
      <str name="echoParams">explicit</str>
      <str name="wt">json</str>
      <int name="rows">50</int>
      <str name="df">source_description</str>
      <str name="defType">edismax</str>
      <str name="qf">source_code_text^3 source_description^2 target_concept_name^2 source_code^1</str>
      <str name="pf">source_description^3 target_concept_name^3</str>
      <str name="hl">true</str>
      <str name="hl.fl">source_description,target_concept_name</str>
      <str name="hl.simple.pre">&lt;mark&gt;</str>
      <str name="hl.simple.post">&lt;/mark&gt;</str>
    </lst>
  </requestHandler>

  <!-- Update handler -->
  <requestHandler name="/update" class="solr.UpdateRequestHandler"/>

  <!-- Admin handler -->
  <requestHandler name="/admin/ping" class="solr.PingRequestHandler">
    <lst name="invariants">
      <str name="q">*:*</str>
    </lst>
    <lst name="defaults">
      <str name="echoParams">all</str>
    </lst>
  </requestHandler>

  <!-- Query caches -->
  <query>
    <maxBooleanClauses>${solr.max.booleanClauses:1024}</maxBooleanClauses>
    <filterCache class="solr.CaffeineCache" size="128" initialSize="64" autowarmCount="0"/>
    <queryResultCache class="solr.CaffeineCache" size="128" initialSize="64" autowarmCount="0"/>
    <documentCache class="solr.CaffeineCache" size="128" initialSize="64" autowarmCount="0"/>
    <enableLazyFieldLoading>true</enableLazyFieldLoading>
    <queryResultWindowSize>20</queryResultWindowSize>
    <queryResultMaxDocsCached>200</queryResultMaxDocsCached>
  </query>

</config>
