# Parthenon Platform Configuration
APP_ENV=local
DB_PASSWORD=secret

# Read-only analytics user (abby_analyst) used by the AI service for
# DATABASE_URL and GIS_DATABASE_URL, and by the Laravel 'interrogation'
# connection. The installer auto-generates this; Laravel's abby:setup-analyst
# artisan command creates/updates the PG role with this password.
ABBY_ANALYST_PASSWORD=

# Host port mapping (change to avoid conflicts)
NGINX_PORT=8082
VITE_PORT=5175
POSTGRES_PORT=5480
REDIS_PORT=6381
AI_PORT=8002
JUPYTER_PORT=8888
JUPYTER_TOKEN=parthenon-local-jupyter

# Ollama (LLM for AI concept mapping)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=MedGemma:27b
# Separate Ollama endpoint for embedding model (can point to same host, different port)
OLLAMA_EMBED_BASE_URL=http://host.docker.internal:11434
ABBY_OLLAMA_BASE_URL=http://host.docker.internal:11435
ABBY_OLLAMA_MODEL=gemma4:26b
# Ollama session keepalive (seconds)
ABBY_OLLAMA_KEEP_ALIVE=3600

# HuggingFace token for gated model downloads (leave blank if not using gated models)
HF_TOKEN=

# Anthropic Claude API (used by Abby and other cloud LLM features)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_TIMEOUT=60

# AI safety & budget guardrails
PHI_DETECTION_ENABLED=true
CLOUD_MONTHLY_BUDGET_USD=500

# FinnGen (SP1 foundation)
FINNGEN_PG_RO_PASSWORD=replace_me_with_strong_password
FINNGEN_PG_RW_PASSWORD=replace_me_with_strong_password
FINNGEN_DARKSTAR_URL=http://darkstar:8787
FINNGEN_ARTIFACTS_PATH=/opt/finngen-artifacts

# Phase 14 regenie container resource limits (D-23)
# Biobank-scale default (8g/4cpu) fits PANCREAS (~361 cases) with margin.
# Override upward for UK-Biobank-scale deployments (e.g., 16g/8cpu).
REGENIE_MEM_LIMIT=8g
REGENIE_CPU_LIMIT=4
