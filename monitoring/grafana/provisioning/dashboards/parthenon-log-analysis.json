{
  "uid": "parthenon-log-analysis",
  "title": "Parthenon Log Analysis",
  "description": "Dedicated log analysis dashboard for the Parthenon platform.",
  "tags": [
    "parthenon",
    "logs",
    "loki"
  ],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "label": "Container",
        "datasource": {
          "type": "loki",
          "uid": "loki-parthenon"
        },
        "definition": "label_values({job=\"docker\"}, container_name)",
        "query": {
          "qryType": 1,
          "query": "label_values({job=\"docker\"}, container_name)"
        },
        "regex": "/parthenon-.*/",
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "includeAll": true,
        "allValue": "parthenon-.*",
        "multi": true,
        "options": [],
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "skipUrlSync": false
      },
      {
        "name": "search",
        "type": "textbox",
        "label": "Search",
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        },
        "options": [
          {
            "selected": false,
            "text": "",
            "value": ""
          }
        ],
        "hide": 0,
        "skipUrlSync": false
      },
      {
        "name": "level",
        "type": "custom",
        "label": "Level",
        "current": {
          "selected": true,
          "text": "all",
          "value": ".*"
        },
        "options": [
          {
            "selected": true,
            "text": "all",
            "value": ".*"
          },
          {
            "selected": false,
            "text": "error",
            "value": "error"
          },
          {
            "selected": false,
            "text": "warn",
            "value": "warn"
          },
          {
            "selected": false,
            "text": "info",
            "value": "info"
          },
          {
            "selected": false,
            "text": "debug",
            "value": "debug"
          }
        ],
        "query": ".*,error,warn,info,debug",
        "hide": 0,
        "multi": false,
        "includeAll": false,
        "skipUrlSync": false
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Logs",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-parthenon"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-parthenon"
          },
          "expr": "sum(count_over_time({job=\"docker\", container_name=~\"$container\"} [$__auto]))",
          "legendFormat": "__auto",
          "instant": false,
          "range": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
