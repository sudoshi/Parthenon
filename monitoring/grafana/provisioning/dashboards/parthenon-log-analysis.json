        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-parthenon"
          },
          "expr": "sum(count_over_time({job=\"docker\", container_name=~\"$container\"} |~ \"(?i)(error|critical|fatal|panic|exception)\" [$__auto]))",
          "legendFormat": "__auto",
          "instant": false,
          "range": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ],
          "fields": "",
          "values": false
