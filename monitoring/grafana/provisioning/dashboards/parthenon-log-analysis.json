            "type": "loki",
            "uid": "loki-parthenon"
          },
          "expr": "sum(count_over_time({job=\"docker\", container_name=~\"$container\"} |~ \"(?i)error\" [$__auto])) / sum(count_over_time({job=\"docker\", container_name=~\"$container\"} [$__auto])) * 100",
          "legendFormat": "__auto",
          "instant": false,
          "range": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
