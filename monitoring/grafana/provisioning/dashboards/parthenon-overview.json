        "y": 5,
        "w": 24,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-parthenon"
      },
      "targets": [
        {
          "refId": "CPU",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-parthenon"
          },
          "expr": "sum by (name)(rate(container_cpu_usage_seconds_total{name=~\"parthenon-(php|nginx|postgres|redis|node|horizon|reverb)\",job=\"cadvisor\"}[$interval])) * 100",
          "instant": true,
          "range": false,
          "legendFormat": "{{name}}"
        },
        {
          "refId": "RAM",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-parthenon"
          },
          "expr": "sum by (name)(container_memory_working_set_bytes{name=~\"parthenon-(php|nginx|postgres|redis|node|horizon|reverb)\",job=\"cadvisor\"})",
          "instant": true,
          "range": false,
          "legendFormat": "{{name}}"
        },
        {
          "refId": "RAMPCT",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-parthenon"
          },
          "expr": "sum by (name)(container_memory_working_set_bytes{name=~\"parthenon-(php|nginx|postgres|redis|node|horizon|reverb)\",job=\"cadvisor\"}) / sum by (name)(container_spec_memory_limit_bytes{name=~\"parthenon-(php|nginx|postgres|redis|node|horizon|reverb)\",job=\"cadvisor\"} != 0) * 100",
          "instant": true,
          "range": false,
          "legendFormat": "{{name}}"
        },
        {
          "refId": "NETRX",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-parthenon"
          },
          "expr": "sum by (name)(rate(container_network_receive_bytes_total{name=~\"parthenon-(php|nginx|postgres|redis|node|horizon|reverb)\",job=\"cadvisor\"}[$interval]))",
          "instant": true,
          "range": false,
          "legendFormat": "{{name}}"
        },
        {
          "refId": "NETTX",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-parthenon"
          },
          "expr": "sum by (name)(rate(container_network_transmit_bytes_total{name=~\"parthenon-(php|nginx|postgres|redis|node|horizon|reverb)\",job=\"cadvisor\"}[$interval]))",
          "instant": true,
          "range": false,
          "legendFormat": "{{name}}"
        },
        {
          "refId": "RESTARTS",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-parthenon"
          },
          "expr": "sum by (name)(increase(container_oom_events_total{name=~\"parthenon-(php|nginx|postgres|redis|node|horizon|reverb)\",job=\"cadvisor\"}[24h]))",
          "instant": true,
          "range": false,
          "legendFormat": "{{name}}"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "name": "Container",
              "Value #CPU": "CPU %",
              "Value #RAM": "RAM",
              "Value #RAMPCT": "RAM %",
              "Value #NETRX": "Net RX/s",
              "Value #NETTX": "Net TX/s",
              "Value #RESTARTS": "Restarts"
            },
            "indexByName": {
              "name": 0,
              "Value #CPU": 1,
              "Value #RAM": 2,
              "Value #RAMPCT": 3,
              "Value #NETRX": 4,
              "Value #NETTX": 5,
              "Value #RESTARTS": 6
            }
          }
        }
      ],
      "options": {
        "sortBy": [
          {
            "displayName": "CPU %",
            "desc": true
          }
        ],
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed"
          },
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "CPU %"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "decimals",
                "value": 2
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 50
                    },
                    {
                      "color": "red",
                      "value": 80
                    }
                  ]
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          },
          {
