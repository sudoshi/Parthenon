{
  "uid": "parthenon-logs",
  "title": "Parthenon Logs",
  "description": "Log stream and error/warning rates for all Parthenon containers.",
  "tags": [
    "parthenon",
    "logs"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "label": "Container",
        "datasource": {
          "type": "loki",
          "uid": "loki-parthenon"
        },
        "definition": "{job=\"docker\"}",
        "query": {
          "label": "container_name",
          "stream": "{job=\"docker\"}",
          "type": 2
        },
        "regex": "/parthenon-.*/",
        "current": {
          "selected": false,
          "text": "parthenon-.*",
          "value": "parthenon-.*"
        },
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "skipUrlSync": false
      },
      {
        "name": "level",
        "type": "custom",
        "label": "Level",
        "current": {
          "selected": true,
          "text": "all",
          "value": ".*"
        },
        "options": [
          {
            "selected": true,
            "text": "all",
            "value": ".*"
          },
          {
            "selected": false,
            "text": "error",
            "value": "error"
          },
          {
            "selected": false,
            "text": "warn",
            "value": "warn"
          },
          {
            "selected": false,
            "text": "info",
            "value": "info"
          }
        ],
        "query": ".*,error,warn,info",
        "hide": 0,
        "multi": false,
        "includeAll": false,
        "skipUrlSync": false
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Log Rate / min",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-parthenon"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-parthenon"
          },
          "expr": "sum(rate({job=\"docker\", container_name=~\"parthenon-.*\"}[1m]))",
          "legendFormat": "logs/s"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "showLegend": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Errors (1h)",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 6
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-parthenon"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-parthenon"
          },
          "expr": "sum(count_over_time({job=\"docker\", container_name=~\"parthenon-.*\"} |~ \"(?i)error\" [1h]))",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Warnings (1h)",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 6
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-parthenon"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-parthenon"
          },
          "expr": "sum(count_over_time({job=\"docker\", container_name=~\"parthenon-.*\"} |~ \"(?i)warn\" [1h]))",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Log Stream",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 24,
        "h": 18
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-parthenon"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-parthenon"
          },
          "expr": "{job=\"docker\", container_name=~\"$container\"} | json | line_format \"{{.log}}\" |~ \"(?i)$level\"",
          "legendFormat": "",
          "maxLines": 500
        }
      ],
      "options": {
        "dedupStrategy": "signature",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ],
  "links": [],
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "liveNow": false,
  "weekStart": ""
}