DOMAIN=acumenus.net
ALFRESCO_DB_PASSWORD=alfresco
ALFRESCO_AMQ_USER=admin
ALFRESCO_AMQ_PASSWORD=admin
ALFRESCO_SOLR_SHARED_SECRET=secret

# Optional SSO prerequisites overlay (docker-compose.sso-prereqs.yml)
ALFRESCO_KEYCLOAK_TAG=26.5.5
ALFRESCO_KEYCLOAK_DB_NAME=keycloak
ALFRESCO_KEYCLOAK_DB_USER=keycloak
ALFRESCO_KEYCLOAK_DB_PASSWORD=CHANGE_ME
ALFRESCO_KEYCLOAK_ADMIN_USER=admin
ALFRESCO_KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
ALFRESCO_AUTHENTIK_LDAP_TAG=2026.2.1
AUTHENTIK_OUTPOST_HOST=https://auth.acumenus.net
AUTHENTIK_LDAP_OUTPOST_TOKEN=CHANGE_ME

# Planned Alfresco identity settings for the later cutover
ALFRESCO_IDENTITY_HOST=ids.acumenus.net
ALFRESCO_IDENTITY_REALM=alfresco
ALFRESCO_IDENTITY_RESOURCE=alfresco
ALFRESCO_IDENTITY_CLIENT_SECRET=CHANGE_ME
ALFRESCO_SHARE_CLIENT_ID=share

# Planned LDAP sync settings when using an Authentik LDAP outpost
ALFRESCO_LDAP_SYNC_URL=ldap://alfresco-authentik-ldap:3389
ALFRESCO_LDAP_SYNC_BIND_DN=cn=alfresco-sync,ou=users,ou=alfresco,dc=ldap,dc=goauthentik,dc=io
ALFRESCO_LDAP_SYNC_BIND_PASSWORD=CHANGE_ME
ALFRESCO_LDAP_USER_SEARCH_BASE=ou=users,ou=alfresco,dc=ldap,dc=goauthentik,dc=io
ALFRESCO_LDAP_GROUP_SEARCH_BASE=ou=groups,ou=alfresco,dc=ldap,dc=goauthentik,dc=io
