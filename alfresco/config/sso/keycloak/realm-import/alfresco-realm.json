{
  "realm": "alfresco",
  "enabled": true,
  "displayName": "Alfresco",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "identityProviders": [
    {
      "alias": "authentik",
      "displayName": "Authentik",
      "providerId": "saml",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "validateSignature": "true",
        "signingCertificate": "",
        "postBindingLogout": "true",
        "nameIDPolicyFormat": "urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress",
        "postBindingResponse": "true",
        "singleLogoutServiceUrl": "https://auth.acumenus.net/application/saml/alfresco-keycloak-saml/slo/binding/post/",
        "idpEntityId": "https://auth.acumenus.net",
        "loginHint": "false",
        "metadataDescriptorUrl": "https://auth.acumenus.net/application/saml/alfresco-keycloak-saml/metadata/",
        "enabledFromMetadata": "true",
        "postBindingAuthnRequest": "true",
        "singleSignOnServiceUrl": "https://auth.acumenus.net/application/saml/alfresco-keycloak-saml/sso/binding/post/",
        "wantAuthnRequestsSigned": "true",
        "addExtensionsElementWithKeyInfo": "false",
        "artifactBindingResponse": "false"
      }
    }
  ],
  "clients": [
    {
      "clientId": "alfresco",
      "name": "Alfresco Content Services",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "${ALFRESCO_IDENTITY_CLIENT_SECRET}",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "rootUrl": "https://docs.acumenus.net",
      "baseUrl": "https://docs.acumenus.net/alfresco",
      "adminUrl": "https://docs.acumenus.net/alfresco",
      "redirectUris": [
        "https://docs.acumenus.net/*"
      ],
      "webOrigins": [
        "https://docs.acumenus.net"
      ],
      "attributes": {
        "post.logout.redirect.uris": "+"
      }
    },
    {
      "clientId": "share",
      "name": "Alfresco Share",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "rootUrl": "https://docs.acumenus.net",
      "baseUrl": "https://docs.acumenus.net/share",
      "adminUrl": "https://docs.acumenus.net/share",
      "redirectUris": [
        "https://docs.acumenus.net/share/*",
        "https://docs.acumenus.net/*"
      ],
      "webOrigins": [
        "https://docs.acumenus.net"
      ],
      "attributes": {
        "post.logout.redirect.uris": "+"
      }
    }
  ]
}
