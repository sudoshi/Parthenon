# Test DB — uses same Postgres server, separate database
# NOTE: DB name must NOT end in "_test" — Laravel parallel testing appends "_test_N"
# to create per-worker DBs. "parthenon_test" → "parthenon_test_test_N" (double test).
# "parthenon_testing" → "parthenon_testing_test_N" (clean).
DB_CONNECTION=pgsql
DB_HOST=pgsql.acumenus.net
DB_PORT=5432
DB_DATABASE=parthenon_testing
DB_USERNAME=smudoshi
DB_PASSWORD=acumenus

SESSION_DRIVER=array
CACHE_STORE=array
QUEUE_CONNECTION=sync

AI_SERVICE_URL=http://localhost:8000
R_SERVICE_URL=http://localhost:8787

MAIL_MAILER=log
