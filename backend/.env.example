APP_NAME=Parthenon
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
APP_VERSION=0.1.0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Single database — all schemas (app, omop, results, gis, eunomia) in one DB
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=parthenon
DB_USERNAME=parthenon
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=parthenon_

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:80,localhost:5173

AI_SERVICE_URL=http://python-ai:8000
R_SERVICE_URL=http://darkstar:8787
# JupyterHub
JUPYTER_JWT_SECRET=change-me-generate-a-real-secret
JUPYTER_HUB_API_KEY=change-me-generate-a-real-api-key
JUPYTER_DB_RESEARCHER_PASSWORD=jupyter_researcher_pass
JUPYTER_DB_ADMIN_PASSWORD=jupyter_admin_pass
JUPYTER_IDLE_TIMEOUT=1800
JUPYTER_MEM_LIMIT=2G
JUPYTER_CPU_LIMIT=1.0

# Grafana monitoring dashboard
GRAFANA_URL=http://grafana:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

HORIZON_DASHBOARD_ENABLED=true

MAIL_MAILER=log
# For Resend transactional email: set MAIL_MAILER=resend
RESEND_KEY=
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Laravel Reverb (WebSocket Server)
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=parthenon-commons
REVERB_APP_KEY=your-reverb-app-key
REVERB_APP_SECRET=your-reverb-app-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
