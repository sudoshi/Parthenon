{
    "id": 20,
    "name": "IRSF-005: Prediction of CSS Functional Decline in Rett Syndrome",
    "description": "Patient-level prediction model for clinically significant functional decline (>=5pt CSS decrease) in genotyped Rett syndrome patients with longitudinal follow-up. Uses LASSO logistic regression for interpretability. Target population is 848 genotyped patients with 4+ CSS measurements; outcome is 365 patients who experienced >=5pt CSS decline. 2-year prediction window with 1-year minimum observation requirement. Comprehensive OMOP covariate extraction. First validated PLP model for any rare neurogenetic disorder using OMOP CDM.",
    "design_json": {
        "model": {
            "seed": 42,
            "type": "lasso_logistic_regression",
            "variance": 0.01
        },
        "timeAtRisk": {
            "end": 730,
            "start": 1
        },
        "splitSettings": {
            "seed": 42,
            "type": "stratified",
            "nFold": 5,
            "testFraction": 0.25
        },
        "targetCohortId": 201,
        "outcomeCohortId": 212,
        "covariateSettings": {
            "endDays": 0,
            "longTermStartDays": -365,
            "shortTermStartDays": -30,
            "useDemographicsAge": true,
            "useDemographicsRace": true,
            "useDemographicsGender": true,
            "useVisitCountLongTerm": true,
            "useObservationLongTerm": true,
            "useVisitCountShortTerm": true,
            "useDrugGroupEraLongTerm": true,
            "useDrugGroupEraShortTerm": true,
            "useMeasurementValueLongTerm": true,
            "useConditionGroupEraLongTerm": true,
            "useMeasurementValueShortTerm": true,
            "useConditionGroupEraShortTerm": true
        },
        "populationSettings": {
            "minTimeAtRisk": 365,
            "washoutPeriod": 0,
