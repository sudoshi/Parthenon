{
    "id": 18,
    "name": "S8: Predict Drug Dependence from Opioid Baseline (Gradient Boosting)",
    "description": "Patient-level prediction model estimating 3-year risk of drug dependence among new opioid users using gradient boosting machine with demographics, conditions, drugs, measurements, and procedures.",
    "design_json": {
        "model": {
            "type": "gradient_boosting_machine",
            "hyperParameters": {
                "ntrees": 5000,
                "minRows": 20,
                "maxDepth": 4,
                "learnRate": 0.01
            }
        },
        "timeAtRisk": {
            "end": 1095,
            "start": 1,
            "endAnchor": "cohort start"
        },
        "splitSettings": {
            "splitSeed": 42,
            "testFraction": 0.25
        },
        "targetCohortId": 180,
        "outcomeCohortId": 182,
        "covariateSettings": {
            "timeWindows": [
                {
                    "end": 0,
                    "start": -365
                }
            ],
            "useMeasurement": true,
            "useDemographics": true,
            "useDrugExposure": true,
            "useConditionOccurrence": true,
            "useProcedureOccurrence": true
        },
        "populationSettings": {
            "minTimeAtRisk": 30,
            "washoutPeriod": 365,
            "requireTimeAtRisk": true,
            "removeSubjectsWithPriorOutcome": true
        }
    },
    "author_id": 117,
