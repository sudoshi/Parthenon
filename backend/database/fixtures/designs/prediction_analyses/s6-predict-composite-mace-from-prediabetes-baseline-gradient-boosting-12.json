{
    "id": 12,
    "name": "S6: Predict Composite MACE from Prediabetes Baseline (Gradient Boosting)",
    "description": "Patient-level prediction model estimating 5-year risk of composite MACE (major adverse cardiovascular events) among new prediabetes patients using gradient boosting machine with demographics, conditions, drugs, measurements, and procedures.",
    "design_json": {
        "model": {
            "type": "gradient_boosting_machine",
            "hyperParameters": {
                "ntrees": 5000,
                "minRows": 20,
                "maxDepth": 4,
                "learnRate": 0.01
            }
        },
        "timeAtRisk": {
            "end": 1825,
            "start": 1,
            "endAnchor": "cohort start"
        },
        "splitSettings": {
            "splitSeed": 42,
            "testFraction": 0.25
        },
        "targetCohortId": 166,
        "outcomeCohortId": 168,
        "covariateSettings": {
            "timeWindows": [
                {
                    "end": 0,
                    "start": -365
                }
            ],
            "useMeasurement": true,
            "useDemographics": true,
            "useDrugExposure": true,
            "useConditionOccurrence": true,
            "useProcedureOccurrence": true
        },
        "populationSettings": {
            "minTimeAtRisk": 365,
            "washoutPeriod": 365,
            "requireTimeAtRisk": true,
            "removeSubjectsWithPriorOutcome": true
        }
    },
    "author_id": 117,
