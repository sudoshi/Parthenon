{
    "id": 6,
    "name": "S6: Predict CKD Stage 4 from Prediabetes Baseline (LASSO)",
    "description": "Patient-level prediction model estimating 5-year risk of CKD Stage 4 progression among new prediabetes patients using LASSO logistic regression with demographics, conditions, drugs, measurements, and procedures.",
    "design_json": {
        "model": {
            "type": "lasso_logistic_regression",
            "hyperParameters": {
                "variance": 0.01
            }
        },
        "timeAtRisk": {
            "end": 1825,
            "start": 1,
            "endAnchor": "cohort start"
        },
        "splitSettings": {
            "splitSeed": 42,
            "testFraction": 0.25
        },
        "targetCohortId": 166,
        "outcomeCohortId": 167,
        "covariateSettings": {
            "timeWindows": [
                {
                    "end": 0,
                    "start": -365
                }
            ],
            "useMeasurement": true,
            "useDemographics": true,
            "useDrugExposure": true,
            "useConditionOccurrence": true,
            "useProcedureOccurrence": true
        },
        "populationSettings": {
            "minTimeAtRisk": 365,
            "washoutPeriod": 365,
            "requireTimeAtRisk": true,
            "removeSubjectsWithPriorOutcome": true
        }
    },
    "author_id": 117,
    "created_at": "2026-03-20T00:28:56.000000Z",
