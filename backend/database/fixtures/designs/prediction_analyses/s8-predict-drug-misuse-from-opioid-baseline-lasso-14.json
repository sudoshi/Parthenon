{
    "id": 14,
    "name": "S8: Predict Drug Misuse from Opioid Baseline (LASSO)",
    "description": "Patient-level prediction model estimating 3-year risk of drug misuse among new opioid users using LASSO logistic regression with demographics, conditions, drugs, measurements, and procedures.",
    "design_json": {
        "model": {
            "type": "lasso_logistic_regression",
            "hyperParameters": {
                "variance": 0.01
            }
        },
        "timeAtRisk": {
            "end": 1095,
            "start": 1,
            "endAnchor": "cohort start"
        },
        "splitSettings": {
            "splitSeed": 42,
            "testFraction": 0.25
        },
        "targetCohortId": 180,
        "outcomeCohortId": 183,
        "covariateSettings": {
            "timeWindows": [
                {
                    "end": 0,
                    "start": -365
                }
            ],
            "useMeasurement": true,
            "useDemographics": true,
            "useDrugExposure": true,
            "useConditionOccurrence": true,
            "useProcedureOccurrence": true
        },
        "populationSettings": {
            "minTimeAtRisk": 30,
            "washoutPeriod": 365,
            "requireTimeAtRisk": true,
            "removeSubjectsWithPriorOutcome": true
        }
    },
    "author_id": 117,
