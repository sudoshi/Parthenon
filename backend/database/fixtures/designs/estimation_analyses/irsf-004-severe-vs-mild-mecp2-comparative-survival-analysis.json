    "id": 61,
    "name": "IRSF-004: Severe vs Mild MECP2 Comparative Survival Analysis",
    "description": "Population-level estimation comparing mortality and seizure outcomes between severe MECP2 point mutations (R168X\/R255X\/R270X, cohort 198, N=313) and mild MECP2 point mutations (R294X\/R133C, cohort 199, N=187). Uses OHDSI CohortMethod with Cox proportional hazards, propensity score 1:1 matching (caliper 0.2 SD), and comprehensive covariate adjustment. Primary outcome is all-cause mortality (86 death events in dataset). Secondary outcome is seizure onset. This is the first PS-matched comparative survival study in Rett syndrome.",
    "design_json": {
        "model": {
            "type": "cox",
            "stratify": false,
            "priorVariance": 2
        },
        "targetCohortId": 198,
        "propensityScore": {
            "model": "logistic_regression",
            "enabled": true,
            "matching": {
                "ratio": 1,
                "caliper": 0.25,
                "enabled": true,
                "caliperScale": "standardized_logit",
                "maxCasesPerControl": 1
            },
            "trimming": {
                "lower": 0.1,
                "upper": 0.9,
                "enabled": true
            },
            "stratification": {
                "enabled": false
            }
        },
        "outcomeCohortIds": [
