            "timeAtRiskStart": 1
        },
        "targetCohortId": 70,
        "propensityScore": {
            "model": "logisticRegression",
            "enabled": true,
            "matching": {
                "ratio": 1,
                "caliper": 0.2,
                "enabled": true,
                "caliperScale": "standardizedLogit"
            },
            "trimming": {
                "enabled": true,
                "fraction": 0.05
            },
