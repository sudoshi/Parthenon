{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Parthenon Installer",
  "version": "0.1.0",
  "identifier": "io.acumenus.parthenon.installer",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Parthenon Community Installer",
        "width": 1060,
        "height": 760,
        "minWidth": 840,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Install Parthenon Community",
    "longDescription": "A cross-platform Rust GUI for launching the Python-based Parthenon Community installer.",
    "linux": {
      "deb": {
        "files": {
          "/usr/share/polkit-1/actions/io.acumenus.parthenon.installer.policy": "polkit/io.acumenus.parthenon.installer.policy",
          "/usr/libexec/parthenon-installer-helper": "helper/parthenon-installer-helper"
        }
      },
      "rpm": {
        "files": {
          "/usr/share/polkit-1/actions/io.acumenus.parthenon.installer.policy": "polkit/io.acumenus.parthenon.installer.policy",
          "/usr/libexec/parthenon-installer-helper": "helper/parthenon-installer-helper"
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/sudoshi/Parthenon/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI0MzUxMkRGMEY4MzIyRkEKUldUNklvTVAzeEkxdEVXYmJjc25jRTlqUVVSd1ErSXk5ZDFzdm5LWXZXR0dPcTNaNFNwakFmNWIK",
      "windows": { "installMode": "passive" }
    },
    "shell": { "open": true }
  }
}
