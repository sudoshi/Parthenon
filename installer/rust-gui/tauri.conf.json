{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Parthenon Installer",
  "version": "0.1.0",
  "identifier": "io.acumenus.parthenon.installer",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Parthenon Community Installer",
        "width": 1060,
        "height": 760,
        "minWidth": 840,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Install Parthenon Community",
    "longDescription": "A cross-platform Rust GUI for launching the Python-based Parthenon Community installer."
  }
}
