                    var icon = $('.authors-toggle').find("#text_field");

                    if($(this).attr("class") == "expand-button expand-all") {
                        $(this).attr("class", "expand-button collapse-all");
                        $(this).text('Collapse all');
                        $('.authors-details').collapse('show');
                        icon.text("- ");
                    }
                    else {
                        $(this).attr("class", "expand-button expand-all");
                        $(this).text('Expand all');
                        $('.authors-details').collapse('hide');
