            <div class="modal-header">
                <h1 class="modal-title">Report an update</h1>
                <button type="button" class="ajax-modal-close close focus focus--effect-wave" data-dismiss="modal" aria-hidden="true" aria-label="Close">×</button>
            </div>
            <div class="modal-body">
                <form id="report_update_form" autocomplete="on" action="/objects/uuid:8232670c-5f63-4d2d-84c6-3029dc6ff3d0/report_update" accept-charset="UTF-8" data-remote="true" method="post"><input name="utf8" type="hidden" value="&#x2713;" />
                <div class="form-group">
                    <label for="update_name">Your name</label>
                    <input type="text" class="form-control" id="update_name" name="name" autocomplete="name"
                           placeholder="Full name" 
                           data-validation="alphanumeric required"  
                           data-validation-error-msg="You have not provided your full name"
                           data-validation-allowing="-' ">
                </div>
                <div class="form-group">
                    <label for="update_email">Your Email</label>
                    <p><small>We require your email address in order to let you know the outcome of your enquiry.</small></p>
                    <input type="text" class="form-control" id="update_email" name="email" autocomplete="email"
                           data-validation="email required"
                           data-validation-error-msg="You have not provided a valid email address"
                           placeholder="email@example.com">
                </div>
                <label for="report-magiun" style="display: none">-</label>
                <input type="text" name="magiun" class="magiun" value="magiun" id="report-magiun"> 
                <div class="form-group">
                <fieldset>
                    <legend>Reason for update</legend>
                    <input type="radio" id="reason1" name="reason" value="PDF can now be made available" checked><label for="reason1" class="rfu_label_checkbox">PDF can now be made available</label><br>
                    <input type="radio" id="reason2" name="reason" value="Paper now published"><label for="reason2" class="rfu_label_checkbox">Paper now published</label><br>
                    <input type="radio" id="reason3" name="reason" value="Error in record"><label for="reason3" class="rfu_label_checkbox">Error in record</label><br>
                    <input type="radio" id="reason4" name="reason" value="Other"><label for="reason4" class="rfu_label_checkbox">Other</label><br>
                </fieldset>
                </div>
                <div class="form-group">
                    <label for="update_comment">Update details</label>
                    <p><small>Please add any additional information to be included within the email.</small></p>
                    <textarea class="form-control" rows="3" id="update_comment" name="details"
                              data-validation-error-msg="You have not provided any details about your request"
                              data-validation="required"></textarea>
                </div>
                <input type="hidden" name="title" id="title" value="Primary care recorded NAFLD and the risk of incident MI and stroke: findings from analyses of 18 million patients in the UK, the Netherlands, Spain, and Italy" />
                <input type="hidden" name="url" id="url" value="https://ora.ox.ac.uk/objects/uuid:8232670c-5f63-4d2d-84c6-3029dc6ff3d0" />

                <div class="modal-footer">
                    <div id="reportUpdateSubmitButtonCaptchaDiv"></div>
                    <button type        = "submit" 
                            id          = "reportUpdateSubmitButton" 
                            class       = "modal-submit submit-form" 
                            data-config = "#report-magiun" 
                            data-form   = "#report_update_form"> 
                        Request update
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 535.5 535.5" class="send-plane">
                            <path d="M0 497.25l535.5-229.5L0 38.25v178.5l382.5 51-382.5 51z"/>
                        </svg>
                    </button>
                </div>
</form>            </div>
        </div>
    </div>
</div>

</div>

