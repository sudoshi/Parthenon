<script type="441e96cab178a77d572d3d4a-text/javascript">
    $(document).ready(function(){
      function show_metrics_badge(target) {
        $(target).closest('.stats-block').find('h4').show();
      }

      const observer = new MutationObserver(mutationList =>  
        mutationList.filter(m => m.type === 'childList').forEach(m => {  
          m.addedNodes.forEach(show_metrics_badge);  
        })); 

    if ($('#altmetrics-body')[0] != undefined) {
      observer.observe($('#altmetrics-body')[0], {childList: true, subtree: true});
    }
    if ($('#dimensions-body')[0] != undefined) {
      observer.observe($('#dimensions-body')[0], {childList: true, subtree: true});
    }
    });
</script>
  </div>
 </div>

 <script type="441e96cab178a77d572d3d4a-text/javascript">
  $(document).ready(function() {
    $("#analytics-query").on('click', function(e) {
      // Invoke captcha, then ajax call to backend for validation and analytics results
      e.preventDefault();

      // Query analytics if opening section
      if ($(this).attr("aria-expanded") == "false") {
        var v3_captcha_key = $("meta[name='v3_captcha_public_key']").attr('content');
        try {
          grecaptcha.ready(function() {
            grecaptcha.execute(v3_captcha_key, {action: 'query_analytics'}).then(function(token) {
              base_path = $(location).attr('origin');
              analyticsUrl = new URL(base_path + "/objects/uuid:8232670c-5f63-4d2d-84c6-3029dc6ff3d0/query_analytics");
              analyticsUrl.searchParams.append('token', token);
              $.ajax({
                type:'GET',
                url: analyticsUrl,
              });
            });
          });
        } 
        catch(e) {
            console.log("Could not create analytics catpcha.");
        }
      }
    });
  });
 </script>

