<script type="441e96cab178a77d572d3d4a-text/javascript">
$('#print_link').click(function(e){
    e.stopImmediatePropagation();
    var read_less_list = [];
    $('.read-more-button').each(function(){
        $(this).click();
        var class_name = $(this).attr("class");
        class_name = class_name.replace('read-more-button', '');
        class_name = class_name.replace('more', 'less');
        read_less_list.push(class_name);
    });
    var target = "";
    $(".trigger-collapse").each(function(){
        target = $(this).data("target");
        $(".details-page").find(target+" > div").collapse("show");
    });
    target = "";
    window.print();
    $.each(read_less_list, function(index, value){
        $('.'+value).click();
    });
    
    
    return false;
});
</script>
