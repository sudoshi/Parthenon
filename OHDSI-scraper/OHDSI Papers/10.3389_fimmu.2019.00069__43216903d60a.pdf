0 (10–1,070)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2344,":@":2347},[2345],{"#text":2346},"40 (10–170)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2350,":@":2353},[2351],{"#text":2352},"230 (10–1,070)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2356,":@":2363},[2357,2358,2362],{"#text":1482},{"bold":2359},[2360],{"#text":2361},"0.001",{"#text":1475},{"@_valign":1489,"@_align":1507},{"#text":1471},{"#text":1471},{"tr":2367},[2368,2369,2371,2372,2381,2382,2387,2388,2393,2394,2399,2400,2409],{"#text":1475},{"td":2370},[],{"#text":1475},{"td":2373,":@":2380},[2374,2376,2379],{"#text":2375},"Leucocytes [10",{"sup":2377},[2378],{"#text":1135},{"#text":2106},{"@_valign":1489,"@_align":1490},{"#text":1475},{"td":2383,":@":2386},[2384],{"#text":2385},"9.81 (3.34–31.18)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2389,":@":2392},[2390],{"#text":2391},"7.01 (3.60–22.20)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2395,":@":2398},[2396],{"#text":2397},"15.09 (3.34–31.18)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2401,":@":2408},[2402,2403,2407],{"#text":1482},{"bold":2404},[2405],{"#text":2406},"0.004",{"#text":1475},{"@_valign":1489,"@_align":1507},{"#text":1471},{"#text":1471},{"tr":2412},[2413,2414,2416,2417,2426,2427,2432,2433,2438,2439,2444,2445,2450],{"#text":1475},{"td":2415},[],{"#text":1475},{"td":2418,":@":2425},[2419,2421,2424],{"#text":2420},"Monocytes [10",{"sup":2422},[2423],{"#text":1088},{"#text":2106},{"@_valign":1489,"@_align":1490},{"#text":1475},{"td":2428,":@":2431},[2429],{"#text":2430},"1.09 (0.24–12.80)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2434,":@":2437},[2435],{"#text":2436},"0.86 (0.24–1.90)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2440,":@":2443},[2441],{"#text":2442},"1.13 (0.26–12.80)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2446,":@":2449},[2447],{"#text":2448},"0.43",{"@_valign":1489,"@_align":1507},{"#text":1471},{"#text":1471},