"10.0 (1.0–44.0)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2563,":@":2566},[2564],{"#text":2565},"0.65",{"@_valign":1489,"@_align":1507},{"#text":1471},{"#text":1471},{"tr":2570},[2571,2572,2574,2575,2583,2584,2589,2590,2595,2596,2600,2601,2606],{"#text":1475},{"td":2573},[],{"#text":1475},{"td":2576,":@":2582},[2577,2578,2581],{"#text":2330},{"sup":2579},[2580],{"#text":1135},{"#text":2106},{"@_valign":1489,"@_align":1490},{"#text":1475},{"td":2585,":@":2588},[2586],{"#text":2587},"48 (2–2,333)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2591,":@":2594},[2592],{"#text":2593},"48 (7–250)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2597,":@":2599},[2598],{"#text":2587},{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2602,":@":2605},[2603],{"#text":2604},"0.97",{"@_valign":1489,"@_align":1507},{"#text":1471},{"#text":1471},{"tr":2609},[2610,2611,2613,2614,2622,2623,2628,2629,2634,2635,2640,2641,2646],{"#text":1475},{"td":2612},[],{"#text":1475},{"td":2615,":@":2621},[2616,2617,2620],{"#text":2375},{"sup":2618},[2619],{"#text":1088},{"#text":2106},{"@_valign":1489,"@_align":1490},{"#text":1475},{"td":2624,":@":2627},[2625],{"#text":2626},"256 (11–3,031)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2630,":@":2633},[2631],{"#text":2632},"467 (52–887)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2636,":@":2639},[2637],{"#text":2638},"218 (11–3,031)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2642,":@":2645},[2643],{"#text":2644},"0.40",{"@_valign":1489,"@_align":1507},{"#text":1471},{"#text":1471},{"tr":2649},[2650,2651,2653,2654,2663,2664,2669,2670,2675,2676,2681,2682,2687],{"#text":1475},{"td":2652},[],{"#text":1475},{"td":2655,":@":2662},[2656,2658,2661],{"#text":2657},"Lymphocytes/Monocytes [10",{"sup":2659},[2660],{"#text":1088},{"#text":2106},{"@_valign":1489,"@_align":1490},{"#text":1475},{"td":2665,":@":2668},[2666],{"#text":2667},"127 (5–740)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2671,":@":2674},[2672],{"#text":2673},"300 (39–740)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2677,":@":2680},[2678],{"#text":2679},"127 (5–698)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2683,":@":2686},[2684],{"#text":2685},"0.15",{"@_valign":1489,"@_align":1507},{"#text":1471},{"#text":1471},{"tr":2690},[2691,2692,2694,2695,2699,2700,2705,2706,2711,2712,2717,2718,2723],{"#text":1475},{"td":2693},[],{"#text":1475},{"td":2696,":@":2698},[2697],{"#text":2461},{"@_valign":1489,"@_align":1490},{"#text":1475},{"td":2701,":@":2704},[2702],{"#text":2703},"642.67 (7.87–1487.36)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2707,":@":2710},[2708],{"#text":2709},"596.15 (109.56–1226.54)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2713,":@":2716},[2714],{"#text":2715},"653.58 (7.87–1487.36)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2719,":@":2722},[2720],{"#text":2721},"0.45",{"@_valign":1489,"@_align":1507},{"#text":1471},{"#text":1471},{"tr":2726},[2727,2728,2730,2731,2735,2736,2741,2742,2747,2748,2753,2754,2758],{"#text":1475},{"td":2729},[],{"#text":1475},{"td":2732,":@":2734},[2733],{"#text":2501},{"@_valign":1489,"@_align":1490},{"#text":1475},{"td":2737,":@":2740},[2738],{"#text":2739},"83.75 (10.91–988.56)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2743,":@":2746},[2744],{"#text":2745},"44.91 (15.17–277.70)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2749,":@":2752},[2750],{"#text":2751},"95.55 (10.90–988.56)",{"@_valign":1489,"@_align":1507},{"#text":1475},{"td":2755,":@":2757},[2756],{"#text":2685},{"@_valign":1489,"@_align":1507},{"#text":1471},{"#text":1458},{"#text":932},{"@_frame":2762,"@_rules":2763},"hsides","groups",{"#text":932},{"table-wrap-foot":2766},[2767,2768,2777],{"#text":1458},{"p":2769},[2770,2771,2775],{"#text":1471},{"italic":2772},[2773],{"#text":2774},"Data are medians and (ranges). The results of Mann–Whitney test for metric variables and Chi-square test for nominal variables comparing patients with low CRP profile to those with high CRP profile are shown with P–value (significantly different comparisons are marked in bold)",{"#text":2776},".",{"#text":932},{"#text":938},{"@_position":2780,"@_id":1444},"float",{"#text":938},{"p":2783},[2784,2786,2790,2792,2795,2797,2801,2803,2807,2809,2813,2815,2819,2820,2823,2825,2828],{"#text":2785},"The median C-reactive protein (CRP) level of 48.8 mg/l in the blood were compatible with bacterial infections (upper limit of normal 5 mg/l), together with findings of SBP in 21% of the patients (",{"xref":2787,":@":2789},[2788],{"#text":1441},{"@_ref-type":1443,"@_rid":1444},{"#text":2791},"). CRP performed well to detect SBP using receiver operator characteristic curve analysis (AUC = 0.901, ",{"italic":2793},[2794],{"#text":1404},{"#text":2796}," ≤ 0.001). In blood cultures, we detected members of the bacterial genera ",{"italic":2798},[2799],{"#text":2800},"Enterococcus, Escherichia, Sporosarcina",{"#text":2802},", and ",{"italic":2804},[2805],{"#text":2806},"Staphylococcus",{"#text":2808}," in five patients. Additionally, we detected ",{"italic":2810},[2811],{"#text":2812},"Candida",{"#text":2814}," spp. in blood culture of one patient. In ascites, we detected the genera ",{"italic":2816},[2817],{"#text":2818},"Enterococcus, Serratia",{"#text":2802},{"italic":2821},[2822],{"#text":2806},{"#text":2824}," in five patients and ",{"italic":2826},[2827],{"#text":2812},{"#text":2829}," spp. in one patient. None of the patients presented with cultural evidence of bacteria in both, blood and ascites.",{"#text":938},{"p":2832},[2833,2835,2839,2841,2847,2848,2854],{"#text":2834},"There was also evidence of systemic inflammation with elevated levels of cytokines IL-6 (and IL-8, although not statistically significant), which are mainly produced by myeloid cells. The median levels assessed by ELISA assays were 33.53 and 68.78 pg/ml, respectively (",{"xref":2836,":@":2838},[2837],{"#text":1441},{"@_ref-type":1443,"@_rid":1444},{"#text":2840},"). Reported mean levels in healthy individuals are 1.46 and 12.9 pg/ml, respectively, assessed by the same technique (",{"xref":2842,":@":2845},[2843],{"#text":2844},"25",{"@_ref-type":1073,"@_rid":2846},"B25",{"#text":1131},{"xref":2849,":@":2852},[2850],{"#text":2851},"26",{"@_ref-type":1073,"@_rid":2853},"B26",{"#text":2855},"). Ascites fluid showed higher median levels of both cytokines, with an almost 20-fold increase of median IL-6 levels in ascites compared to blood from the same patient.",{"#text":1052},{"#text":1052},{"sec":2859},[2860,2861,2865,2866,2946,2947,2989,2990,2994],{"#text":938},{"title":2862},[2863],{"#text":2864},"Differences in Patients With Systemic Inflammation",{"#text":938},{"p":2867},[2868,2870,2874,2876,2879,2881,2884,2886,2889,2891,2894,2896,2899,2901,2904,2906,2909,2911,2915,2917,2924,2926,2931,2933,2938,2940,2945],{"#text":2869},"In order to decipher the role of systemic inflammation, we divided the cohort into two groups according to their CRP level. A cut-off of 25 mg/l (sensitivity = 1.0, specificity = 0.54 for detection of SBP) was used to divide the cohort into 12 patients with a low CRP profile and 21 patients with a high CRP profile. Patients with the high CRP profile showed higher MELD, CHILD, and Chronic Liver Failure Consortium (CLIF-C)-ACLF scores (",{"xref":2871,":@":2873},[2872],{"#text":1441},{"@_ref-type":1443,"@_rid":1444},{"#text":2875},"; ",{"italic":2877},[2878],{"#text":1404},{"#text":2880}," = 0.06, ",{"italic":2882},[2883],{"#text":1404},{"#text":2885}," = 0.03, and ",{"italic":2887},[2888],{"#text":1404},{"#text":2890}," = 0.002, respectively). SBP was detected in 50% of the patients (7 out of 14) with the high CRP profile, but in none of 12 patients with the low CRP profile (",{"italic":2892},[2893],{"#text":1404},{"#text":2895}," = 0.02). Therefore, the positive predictive value, the probability for patients with high CRP profile to have SBP, is 35%. In contrast, the negative predictive value, the chance for patients with low CRP profile to not have SBP, is 100%. A high negative predictive value in this regards is extremely important since CRP level may be elevated also in absence of infection. Furthermore, patients with the high CRP profile showed a significant increase in blood granulocyte counts (",{"italic":2897},[2898],{"#text":1404},{"#text":2900}," = 0.001), leucocyte counts (",{"italic":2902},[2903],{"#text":1404},{"#text":2905}," = 0.004), and IL-6 levels (",{"italic":2907},[2908],{"#text":1404},{"#text":2910}," = 0.002). However, there was no difference in ascitic cytokine levels between these two groups (",{"xref":2912,":@":2914},[2913],{"#text":1441},{"@_ref-type":1443,"@_rid":1444},{"#text":2916},"). Similarly, IL-6 levels in blood strongly correlate with MELD, CHILD score, and CLIF-C-ACLF score and surrogate markers of systemic inflammation (leucocytes and CRP). However, blood IL-8 levels only slightly reflected disease stage and did not correlate significantly with markers of inflammation (",{"xref":2918,":@":2921},[2919],{"#text":2920},"Figure 1A",{"@_ref-type":2922,"@_rid":2923},"fig","F1",{"#text":2925},"). Even though median cytokine levels were higher in ascites than in blood (",{"xref":2927,":@":2930},[2928],{"#text":2929},"Figure 1B",{"@_ref-type":2922,"@_rid":2923},{"#text":2932},"), ascitic cytokine levels reflected neither disease severity nor systemic inflammation (",{"xref":2934,":@":2937},[2935],{"#text":2936},"Figures 1A,C",{"@_ref-type":2922,"@_rid":2923},{"#text":2939},"). Therefore, ascites cytokine levels did not seem to be affected by systemic inflammation or by the presence of SBP, which was diagnosed in one third of the patients with the high CRP profile (",{"xref":2941,":@":2944},[2942],{"#text":2943},"Figure 1C",{"@_ref-type":2922,"@_rid":2923},{"#text":1106},{"#text":938},{"fig":2948,":@":2988},[2949,2950,2954,2955,2981,2982,2987],{"#text":932},{"label":2951},[2952],{"#text":2953},"Figure 1",{"#text":932},{"caption":2956},[2957,2958,2980],{"#text":1458},{"p":2959},[2960,2962,2966,2968,2972,2974,2978],{"#text":2961},"Pro-inflammatory cytokines. ",{"bold":2963},[2964],{"#text":2965},"(A)",{"#text":2967}," Correlation of clinical markers for disease progression and systemic inflammation with cytokines IL-6 and IL-8 in blood and ascites. ",{"bold":2969},[2970],{"#text":2971},"(B)",{"#text":2973}," Comparison between cytokines levels in ascites and peripheral blood. ",{"bold":2975},[2976],{"#text":2977},"(C)",{"#text":2979}," Comparison between cytokines levels in ascites and peripheral blood under different systemic inflammation status (low CRP profile vs. high CRP profile).",{"#text":932},{"#text":932},{"graphic":2983,":@":2984},[],{"@_xmlns:xlink":2985,"@_xlink:href":2986},"http://www.w3.org/1999/xlink","fimmu-10-00069-g0001.tif",{"#text":938},{"@_id":2923,"@_position":2780},{"#text":938},{"p":2991},[2992],{"#text":2993},"The rate of positive blood cultures was identical in patients with the low and high CRP profile. There were three positive blood and three positive ascites cultures in patients with a high CRP against two positive blood and one positive ascites cultures in the patients with lower CRP values.",{"#text":1052},{"#text":1052},{"sec":2997},[2998,2999,3003,3004,3026,3027,3983,3984,4040,4041,4068,4069,4094,4095,4127,4128,4151],{"#text":938},{"title":3000},[3001],{"#text":3002},"Characterizing the Microbiome in Ascites and Blood",{"#text":938},{"p":3005},[3006,3008,3011,3013,3016,3018,3024],{"#text":3007},"We selected a subset of 10 representative patients (accounting for etiology and inflammation markers in ascites) from the whole cohort and performed 16S rRNA gene sequencing of ascites and blood to identify differences in microbial composition and diversity between ascites and blood. These 10 patients were also divided into two groups based on CRP levels (",{"italic":3009},[3010],{"#text":1502},{"#text":3012}," = 4 for high CRP profile and ",{"italic":3014},[3015],{"#text":1502},{"#text":3017}," = 6 for low CRP profile, see ",{"xref":3019,":@":3022},[3020],{"#text":3021},"Table 2",{"@_ref-type":1443,"@_rid":3023},"T2",{"#text":3025},"). Their disease profiles with regard to stage of liver cirrhosis and inflammatory markers in blood were comparable to those of the respective subgroups and also of the whole cohort.",{"#text":938},{"table-wrap":3028,":@":3982},[3029,3030,3033,3034,3042,3043,3968,3969,3981],{"#text":932},{"label":3031},[3032],{"#text":3021},{"#text":932},{"caption":3035},[3036,3037,3041],{"#text":1458},{"p":3038},[3039],{"#text":3040},"Patient characteristics for the subpopulation in which 16S rRNA gene amplicon sequencing was performed in blood and ascites.",{"#text":932},{"#text":932},{"table":3044,":@":3967},[3045,3046,3106,3107,3966],{"#text":1458},{"thead":3047},[3048,3049,3105],{"#text":1471},{"tr":3050},[3051,3052,3054,3055,3063,3064,3077,3078,3091,3092,3104],{"#text":1475},{"th":3053},[],{"#text":1475},{"th":3056,":@":3062},[3057,3058,3061],{"#text":1482},{"bold":3059},[3060],{"#text":1486},{"#text":1475},{"@_valign":1489,"@_align":1490},{"#text":1475},{"th":3065,":@":3076},[3066,3067,3075],{"#text":1482},{"bold":3068},[3069,3070,3073],{"#text":1515},{"italic":3071},[3072],{"#text":1502},{"#text":3074}," = 6)",{"#text":1475},{"@_valign":1489,"@_align":1490},{"#text":1475},{"th":3079,":@":3090},[3080,3081,3089],{"#text":1482},{"bold":3082},[3083,3084,3087],{"#text":1530},{"italic":3085},[3086],{"#text":1502},{"#text":3088}," = 4)",{"#text":1475},{"@_valign":1489,"@_align":1490},{"#text":1475},{"th":3093,":@":3103},[3094,3095,3102],{"#text":1482},{"bold":3096},[3097,3098,3101],{"#text":1545},{"italic":3099},[3100],{"#text":1404},{"#text":1482},{"#text":1475},{"@_valign":1489,"@_align":1490},{"#text":1471},{"#text":1458},{"#text":1458},{"tbody":3108},[3109,3110,3141,3142,3170,3171,3200,3201,3230,3231,3260,3261,3289,3290,3318,3319,3347,3348,3375,3376,3404,3405,3434,3435,3463,3464,3494,3495,3527,3528,3556,3557,3586,3587,3615,3616,3649,3650,3683,3684,3716,3717,3746,3747,3775,3776,3807,3808,3840,3841,3873,3874,3906,3907,3936,3937,3965],{"#text":1471},{"tr":3111},[3112,3113,3117,3118,3122,3123,3128,3129,3134,3135,3140],{"#text":1475},{"td":3114,":@":3116},[3115],{"#text":1564},{"@_valign":1489,"@_align":1490},{"#text":1475},{"td":3119,":@":3121},[3120],{"#text":1570},{"@_valign":1489,"@_align":1490},{"#text":1475},{"td":3124,":@":3127},[3125],{"#text":3126},"5/1",{"@_valign":1489,"@_align":1490},{"#text":1475},{"td":3130,":@":3133},[3131],{"#text":3132},"2/2",{"@_valign":1489,"@_align":1490},{"#text":1475},{"td":3136,":@":3139},[3137],{"#text":3138},"0.26",{"@_valign":1489,"@_align":1490},{"#text":1471},{"#text":1471},{"tr":3143},[3144,3145,3147,3148,3152,3153,3158,3159,3164,3165,3169],{"#text":1475},{"td":3146},[],{"#text":1475},{"td":3149,":@":3151},[3150],{"#text":1607},{"@_valign":1489,"@_align":1490},{"#text":1475},{"td":3154,":@":3157},[3155],{"#text":3156},"52.5 (40.0–67.0)",{"@_valign":1489,"@_align":1490},{"#text":1475},{"td":3160,":@":3163},[3161],{"#text":3162},"56.0 (33–76)",{"@_valign":1489,"@_align":1490},{"#text":1475},{"td":3166,":@":3168},[3167],{"#text":2239},{"@_valign":1489,"@_align":1490},{"#text":1471},{"#text":1471},{"tr":3172},[3173,3174,3176,3177,3181,3182,3187,3188,3193,3194,3199],{"#text":1475},{"td":3175},[],{"#text":1475},{"td":3178,":@":3180},[3179],{"#text":1644},{"@_valign":1489,"@_align":1490},{"#text":1475},{"td":3183,":@":3186},[3184],{"#text":3185},"5/1/0",{"@_valign":1489,"@_align":1490},{"#text":1475},{"td":3189,":@":3192},[3190],{"#text":3191},"3/0/1",{"@_valign":1489,"@_align":1490},{"#text":1475},{"td":3195,":@":3198},[3196],{"#text":3197},"0.34",{"@_valign":1489,"@_align":1490},{"#text":1471},{"#text":1471},{"tr":3202},[3203,3204,3206,3207,3211,3212,3217,3218,3223,3224,3229],{"#text":1475},{"td":3205},[],{"#text":1475},{"td":3208,":@":3210},[3209],{"#text":1681},{"@_valign":1489,"@_align":1490},{"#text":1