Name":510,"cityName":19,"stateName":19,"zipCode":19},{"organizationName":609,"countryName":563,"cityName":19,"stateName":19,"zipCode":19},"Institute for Bioengineering of Catalonia",[611],{"id":612,"firstName":613,"middleName":19,"lastName":614,"givenNames":615,"isCorresponding":371,"isProfilePublic":13,"userId":612,"email":-1,"affiliations":616},100149,"Hannelie","Korf","Hannelie ",[617],{"organizationName":618,"countryName":619,"cityName":19,"stateName":19,"zipCode":19},"Laboratory of Hepatology, Department of Chronic Diseases, Metabolism and Ageing, Faculty of Medicine, KU Leuven","Belgium",[621,629],{"id":622,"firstName":623,"middleName":19,"lastName":624,"givenNames":625,"isCorresponding":371,"isProfilePublic":13,"userId":622,"email":-1,"affiliations":626},32365,"Edward","Sherwood","Edward ",[627],{"organizationName":628,"countryName":574,"cityName":19,"stateName":19,"zipCode":19},"Vanderbilt University Medical Center",{"id":630,"firstName":631,"middleName":19,"lastName":632,"givenNames":633,"isCorresponding":371,"isProfilePublic":13,"userId":630,"email":-1,"affiliations":634},622466,"Gautam","Mehta","Gautam ",[635],{"organizationName":636,"countryName":637,"cityName":19,"stateName":19,"zipCode":19},"University College London","United Kingdom",{"id":118,"slug":120,"name":119,"shortName":639,"electronicISSN":640,"field":641,"specialtyId":28,"journalSectionPaths":644},"Front. Immunol.","1664-3224",{"id":642,"domainId":643},35,2,[645],{"section":646},{"id":175,"name":176,"slug":177,"specialtyId":647},1276,{"views":649,"downloads":650,"citations":651},6099,2519,55,10,"Volume 10 - 2019",[],{"titleHtml":19,"fullTextHtml":19,"menuHtml":19},[657,662,668,671,677],{"name":658,"fileServerPackageEntryId":19,"fileServerId":659,"fileServerVersionNumber":386,"type":660},"EPUB.epub","433582/epub",{"code":661,"name":661},"EPUB",{"name":663,"fileServerPackageEntryId":664,"fileServerId":665,"fileServerVersionNumber":386,"type":666},"fimmu-10-00069.pdf","fimmu-10-00069/fimmu-10-00069.pdf","433582/pubmed-zip",{"code":667,"name":667},"PDF",{"name":663,"fileServerPackageEntryId":19,"fileServerId":669,"fileServerVersionNumber":386,"type":670},"433582/publishers-proof/pdf",{"code":667,"name":667},{"name":672,"fileServerPackageEntryId":673,"fileServerId":665,"fileServerVersionNumber":386,"type":674},"fimmu-10-00069.xml","fimmu-10-00069/fimmu-10-00069.xml",{"code":675,"name":676},"NLM_XML","XML",{"name":678,"fileServerPackageEntryId":19,"fileServerId":679,"fileServerVersionNumber":386,"type":680},"Provisional PDF.pdf","433582/provisional-pdf",{"code":667,"name":667},"v4",{"title":683,"link":684,"meta":688,"script":833},"Frontiers | Compartmentalization of Immune Response and Microbial Translocation in Decompensated Cirrhosis",[685],{"rel":686,"href":687},"canonical","https://www.frontiersin.org/journals/immunology/articles/10.3389/fimmu.2019.00069/full",[689,692,695,697,700,704,707,711,714,717,720,722,724,726,728,730,733,736,738,741,744,746,749,752,755,758,761,765,769,772,775,778,781,784,786,789,791,794,796,799,802,805,808,811,814,817,820,823,825,828,830],{"hid":690,"property":690,"name":690,"content":691},"description","BackgroundAcquired dysfunctional immunity in cirrhosis predisposes patients to frequent bacterial infections, especially spontaneous bacterial peritonitis (S...",{"hid":693,"property":693,"name":694,"content":683},"og:title","title",{"hid":696,"property":696,"name":690,"content":691},"og:description",{"hid":698,"name":698,"content":699},"keywords","Cytokines,Acute-on chronic liver failure,Ascites,cirrhosis,myeloid cell,systemic inflammation,microbiome",{"hid":701,"property":701,"name":702,"content":703},"og:site_name","site_name","Frontiers",{"hid":705,"property":705,"name":379,"content":706},"og:image","https://images-provider.frontiersin.org/api/ipx/w=1200&f=png/https://www.frontiersin.org/files/Articles/433582/fimmu-10-00069-HTML-r1/image_m/fimmu-10-00069-g001.jpg",{"hid":708,"property":708,"name":709,"content":710},"og:type","type","article",{"hid":712,"property":712,"name":713,"content":687},"og:url","url",{"hid":715,"name":715,"content":716},"twitter:card","summary_large_image",{"hid":718,"name":718,"content":719},"citation_volume","10",{"hid":721,"name":721,"content":119},"citation_journal_title",{"hid":723,"name":723,"content":703},"citation_publisher",{"hid":725,"name":725,"content":639},"citation_journal_abbrev",{"hid":727,"name":727,"content":640},"citation_issn",{"hid":729,"name":729,"content":475},"citation_doi",{"hid":731,"name":731,"content":732},"citation_firstpage","433582",{"hid":734,"name":734,"content":735},"citation_language","English",{"hid":737,"name":737,"content":476},"citation_title",{"hid":739,"name":739,"content":740},"citation_keywords","Cytokines; Acute-on chronic liver failure; Ascites; cirrhosis; myeloid cell; systemic inflammation; microbiome",{"hid":742,"name":742,"content":743},"citation_abstract","BackgroundAcquired dysfunctional immunity in cirrhosis predisposes patients to frequent bacterial infections, especially spontaneous bacterial peritonitis (SBP), leading to systemic inflammation that is associated with poor outcome. But systemic inflammation can also be found in the absence of a confirmed infection. Detection of bacterial DNA has been investigated as a marker of SBP and as a predictor of prognosis. Data is, however, contradictory. Here we investigated whether levels of IL-6 and IL-8 putatively produced by myeloid cells in ascites are associated with systemic inflammation and whether inflammation depends on the presence of specific bacterial DNA.Methods and materialWe enrolled 33 patients with decompensated liver cirrhosis from whom we collected paired samples of blood and ascites. IL-6 and IL-8 were measured in serum samples of all patients using ELISA. In a subset of 10 representative patients, bacterial DNA was extracted from ascites and whole blood, followed by 16S rRNA gene amplicon sequencing. ResultsThere were significantly higher levels of IL-6 in ascites fluid compared to blood samples in all patients. Interestingly, IL-6 levels in blood correlated tightly with disease severity and surrogates of systemic inflammation, while IL-6 levels in ascites did not. Moreover, patients with higher blood CRP levels showed greater SBP prevalence compared to patients with lower levels, despite similar positive culture results. Bacterial richness was also significantly higher in ascites compared to the corresponding patient blood. We identified differences in microbial composition and diversity between ascites and blood, but no tight relationship with surrogates of systemic inflammation could be observed.DiscussionIn decompensated cirrhosis, markers of systemic inflammation and microbiota composition seem to be dysregulated in ascites and blood. While a relationship between systemic inflammation and microbiota composition seems to exist in blood, this is not the case for ascites in our hands. These data may suggest compartmentalization of the immune response and interaction of the latter with the microbiota especially in the blood compartment. ",{"hid":745,"name":745,"content":490},"citation_article_type",{"hid":747,"name":747,"content":748},"citation_pdf_url","https://public-pages-files-2025.frontiersin.org/journals/immunology/articles/10.3389/fimmu.2019.00069/pdf",{"hid":750,"name":750,"content":751},"citation_xml_url","https://public-pages-files-2025.frontiersin.org/journals/immunology/articles/10.3389/fimmu.2019.00069/xml",{"hid":753,"name":753,"content":754},"citation_fulltext_world_readable","yes",{"hid":756,"name":756,"content":757},"citation_online_date","2019/01/11",{"hid":759,"name":759,"content":760},"citation_publication_date","2019/02/08",{"hid":762,"name":763,"content":764},"citation_author_0","citation_author","Alvarez-Silva, Camila ",{"hid":766,"name":767,"content":768},"citation_author_institution_0","citation_author_institution","Novo Nordisk Foundation Center for Basic Metabolic Research, Faculty of Health and Medical Sciences, University of Copenhagen, Denmark",{"hid":770,"name":763,"content":771},"citation_author_1","Schierwagen, Robert ",{"hid":773,"name":767,"content":774},"citation_author_institution_1","Department of Internal Medicine I, Goethe University Clinic Frankfurt, Germany",{"hid":776,"name":763,"content":777},"citation_author_2","Pohlmann, Alessandra ",{"hid":779,"name":767,"content":780},"citation_author_institution_2","Department of Internal Medicine I, University of Bonn, Germany",{"hid":782,"name":763,"content":783},"citation_author_3","Magdaleno, Fernando ",{"hid":785,"name":767,"content":780},"citation_author_institution_3",{"hid":787,"name":763,"content":788},"citation_author_4","Uschner, Frank E. ",{"hid":790,"name":767,"content":774},"citation_author_institution_4",{"hid":792,"name":763,"content":793},"citation_author_5","Ryan, Patrick ",{"hid":795,"name":767,"content":780},"citation_author_institution_5",{"hid":797,"name":763,"content":798},"citation_author_6","Vehreschild, Maria J. G. T. ",{"hid":800,"name":767,"content":801},"citation_author_institution_6","Medical Clinic II, University Center for Infectious Diseases, University Hospital Frankfurt, Germany",{"hid":803,"name":763,"content":804},"citation_author_7","Claria, Joan ",{"hid":806,"name":767,"content":807},"citation_author_institution_7","European Foundation for the Study of Chronic Liver Failure, Spain",{"hid":809,"name":763,"content":810},"citation_author_8","Latz, Eicke ",{"hid":812,"name":767,"content":813},"citation_author_institution_8","Institute of Innate Immunity, University of Bonn, Germany",{"hid":815,"name":763,"content":816},"citation_author_9","Lelouvier, Benjamin ",{"hid":818,"name":767,"content":819},"citation_author_institution_9","Vaiomer, France",{"hid":821,"name":763,"content":822},"citation_author_10","Arumugam, Manimozhiyan ",{"hid":824,"name":767,"content":768},"citation_author_institution_10",{"hid":826,"name":763,"content":827},"citation_author_11","Trebicka, Jonel ",{"hid":829,"name":767,"content":774},"citation_author_institution_11",{"hid":831,"name":831,"content":832},"dc.identifier","doi:10.3389/fimmu.2019.00069",[834,837,839,841,843],{"src":835,"body":13,"type":836,"async":13},"https://cdnjs.cloudflare.com/polyfill/v3/polyfill.min.js?features=es6","text/javascript",{"src":838,"body":13,"type":836,"async":13},"https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.1/MathJax.js?config=TeX-MML-AM_CHTML",{"src":840,"body":13,"type":836,"async":13},"https://d1bxh8uas1mnw7.cloudfront.net/assets/altmetric_badges-f0bc9b243ff5677d05460c1eb71834ca998946d764eb3bc244ab4b18ba50d21e.js",{"src":842,"body":13,"type":836,"async":13},"https://api.altmetric.com/v1/doi/10.3389/fimmu.2019.00069?callback=_altmetric.embed_callback&domain=www.frontiersin.org&key=3c130976ca2b8f2e88f8377633751ba1&cache_until=14-15",{"src":844,"body":13,"type":836,"async":13},"https://crossmark-cdn.crossref.org/widget/v2.0/widget.js",{"journal":846,"doi":475,"articleType":490,"title":848,"authors":850,"onBehalfOf":19,"affiliations":893,"authorNotes":926,"publicationDate":966,"acceptedDate":967,"receivedDate":968,"correctedDate":19,"retractedDate":19,"volume":652,"elocationId":969,"permissions":970,"keywords":990,"relatedArticles":1009,"abstractContent":1010,"bodyContent":1053,"appendixContent":5064,"statements":5065,"references":5142,"otherBackSections":9168,"figures":9169,"toc":11740,"correspondingAuthors":11759},{"title":119,"abbreviation":639,"issn":640,"publisherName":847},"Frontiers Media S.A.",[849],{"#text":476},[851,855,859,861,864,867,869,872,875,882,885,889],{"surname":505,"givenNames":504,"suffix":19,"affiliationsIndexes":852,"isCorresponding":371,"equalContrib":371,"hierarchySymbol":853,"footnoteSymbol":19,"loopUrl":854,"onBehalfOf":19},[386],"\r\n            †\r\n          ","http://loop.frontiersin.org/people/636195/overview",{"surname":514,"givenNames":513,"suffix":19,"affiliationsIndexes":856,"isCorresponding":371,"equalContrib":371,"hierarchySymbol":853,"footnoteSymbol":19,"loopUrl":858,"onBehalfOf":19},[643,857],3,"http://loop.frontiersin.org/people/96736/overview",{"surname":524,"givenNames":523,"suffix":19,"affiliationsIndexes":860,"isCorresponding":371,"equalContrib":371,"hierarchySymbol":853,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[857],{"surname":531,"givenNames":530,"suffix":19,"affiliationsIndexes":862,"isCorresponding":371,"equalContrib":371,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":863,"onBehalfOf":19},[857],"http://loop.frontiersin.org/people/614568/overview",{"surname":538,"givenNames":537,"suffix":19,"affiliationsIndexes":865,"isCorresponding":371,"equalContrib":371,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":866,"onBehalfOf":19},[643,857],"http://loop.frontiersin.org/people/652754/overview",{"surname":545,"givenNames":544,"suffix":19,"affiliationsIndexes":868,"isCorresponding":371,"equalContrib":371,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[857],{"surname":551,"givenNames":550,"suffix":19,"affiliationsIndexes":870,"isCorresponding":371,"equalContrib":371,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[871],4,{"surname":558,"givenNames":557,"suffix":19,"affiliationsIndexes":873,"isCorresponding":371,"equalContrib":371,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[874],5,{"surname":567,"givenNames":566,"suffix":19,"affiliationsIndexes":876,"isCorresponding":371,"equalContrib":371,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":881,"onBehalfOf":19},[877,878,879,880],6,7,8,9,"http://loop.frontiersin.org/people/648521/overview",{"surname":583,"givenNames":582,"suffix":19,"affiliationsIndexes":883,"isCorresponding":371,"equalContrib":371,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":884,"onBehalfOf":19},[652],"http://loop.frontiersin.org/people/438804/overview",{"surname":592,"givenNames":591,"suffix":19,"affiliationsIndexes":886,"isCorresponding":13,"equalContrib":371,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":888,"onBehalfOf":19},[386,887],11,"http://loop.frontiersin.org/people/294404/overview",{"surname":601,"givenNames":600,"suffix":19,"affiliationsIndexes":890,"isCorresponding":13,"equalContrib":371,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":892,"onBehalfOf":19},[643,857,874,887,891],12,"http://loop.frontiersin.org/people/46829/overview",[894,897,900,903,905,908,910,913,915,918,921,924],{"index":386,"baseText":19,"institution":509,"country":510,"address":895,"textContent":896},"Copenhagen","Novo Nordisk Foundation Center for Basic Metabolic Research, Faculty of Health and Medical Sciences, University of Copenhagen, Copenhagen, Denmark",{"index":643,"baseText":19,"institution":518,"country":519,"address":898,"textContent":899},"Frankfurt","Department of Internal Medicine I, Goethe University Clinic Frankfurt, Frankfurt, Germany",{"index":857,"baseText":19,"institution":521,"country":519,"address":901,"textContent":902},"Bonn","Department of Internal Medicine I, University of Bonn, Bonn, Germany",{"index":871,"baseText":19,"institution":555,"country":519,"address":898,"textContent":904},"Medical Clinic II, University Center for Infectious Diseases, University Hospital Frankfurt, Frankfurt, Germany",{"index":874,"baseText":19,"institution":562,"country":563,"address":906,"textContent":907},"Barcelona","European Foundation for the Study of Chronic Liver Failure, Barcelona, Spain",{"index":877,"baseText":19,"institution":571,"country":519,"address":901,"textContent":909},"Institute of Innate Immunity, University of Bonn, Bonn, Germany",{"index":878,"baseText":19,"institution":573,"country":574,"address":911,"textContent":912},"Worcester, MA","Division of Infectious Diseases and Immunology, University of Massachusetts Medical School, Worcester, MA, United States",{"index":879,"baseText":19,"institution":576,"country":519,"address":901,"textContent":914},"German Center for Neurodegenerative Diseases (DZNE), Bonn, Germany",{"index":880,"baseText":19,"institution":578,"country":579,"address":916,"textContent":917},"Trondheim","Centre for Inflammation Research, Norwegian University of Science and Technology, Trondheim, Norway",{"index":652,"baseText":19,"institution":587,"country":588,"address":919,"textContent":920},"Labège","Vaiomer, Labège, France",{"index":887,"baseText":19,"institution":597,"country":510,"address":922,"textContent":923},"Odense","Department of Gastroenterology and Hepatology, Odense University Hospital, Odense, Denmark",{"index":891,"baseText":19,"institution":609,"country":563,"address":906,"textContent":925},"Institute for Bioengineering of Catalonia, Barcelona, Spain",{"editedBy":927,"editedByContent":930,"reviewedBy":939,"reviewedByContent":942,"approvedBy":949,"approvedByContent":950,"correspondence":951,"equalContribution":952,"presentAddress":19,"other":953},[928],{"textContent":929},"Edited by: Hannelie Korf, KU Leuven, Belgium",[931,933,937],{"#text":932},"\n          ",{"p":934},[935],{"#text":936}," Hannelie Korf, KU Leuven, Belgium",{"#text":938},"\n        ",[940],{"textContent":941},"Reviewed by: Edward Sherwood, Vanderbilt University Medical Center, United States; Gautam Mehta, University College London, United Kingdom",[943,944,948],{"#text":932},{"p":945},[946],{"#text":947}," Edward Sherwood, Vanderbilt University Medical Center, United States; Gautam Mehta, University College London, United Kingdom",{"#text":938},[],[],"*Correspondence: Manimozhiyan Arumugam YXJ1bXVnYW1Ac3VuZC5rdS5kaw==",[],[954,955,959,960,961,965],{"#text":932},{"p":956},[957],{"#text":958},"This article was submitted to Molecular Innate Immunity, a section of the journal Frontiers in Immunology",{"#text":938},{"#text":932},{"p":962},[963],{"#text":964},"†These authors share first authorship",{"#text":938},"2019-02-08","2019-01-11","2018-10-30",69,{"copyrightStatement":971,"copyrightYear":972,"copyrightHolder":973,"licenseUrl":974,"licenseText":975},"Copyright © 2019 Alvarez-Silva, Schierwagen, Pohlmann, Magdaleno, Uschner, Ryan, Vehreschild, Claria, Latz, Lelouvier, Arumugam and Trebicka.",2019,"Alvarez-Silva, Schierwagen, Pohlmann, Magdaleno, Uschner, Ryan, Vehreschild, Claria, Latz, Lelouvier, Arumugam and Trebicka","http://creativecommons.org/licenses/by/4.0/",[976,977,989],{"#text":932},{"p":978},[979,981,987],{"#text":980},"This is an open-access article distributed under the terms of the ",{"ext-link":982,":@":985},[983],{"#text":984},"Creative Commons Attribution License (CC BY)",{"@_ext-link-type":986,"@_xlink:href":974},"uri",{"#text":988},". The use, distribution or reproduction in other forums is permitted, provided the original author(s) and the copyright owner(s) are credited and that the original publication in this journal is cited, in accordance with accepted academic practice. No use, distribution or reproduction is permitted which does not comply with these terms.",{"#text":938},[991,993,995,998,1000,1003,1006],[992],{"#text":500},[994],{"#text":499},[996],{"#text":997},"myeloid cells",[999],{"#text":497},[1001],{"#text":1002},"ascites",[1004],{"#text":1005},"cytokines",[1007],{"#text":1008},"acute-on-chronic liver failure",[],[1011,1012,1021,1022,1031,1032,1041,1042,1051],{"#text":938},{"p":1013},[1014,1015,1019],{"#text":932},{"bold":1016},[1017],{"#text":1018},"Background:",{"#text":1020}," Acquired dysfunctional immunity in cirrhosis predisposes patients to frequent bacterial infections, especially spontaneous bacterial peritonitis (SBP), leading to systemic inflammation that is associated with poor outcome. But systemic inflammation can also be found in the absence of a confirmed infection. Detection of bacterial DNA has been investigated as a marker of SBP and as a predictor of prognosis. Data is, however, contradictory. Here we investigated whether levels of IL-6 and IL-8 putatively produced by myeloid cells in ascites are associated with systemic inflammation and whether inflammation depends on the presence of specific bacterial DNA.",{"#text":938},{"p":1023},[1024,1025,1029],{"#text":932},{"bold":1026},[1027],{"#text":1028},"Methods and Materials:",{"#text":1030}," We enrolled 33 patients with decompensated liver cirrhosis from whom we collected paired samples of blood and ascites. IL-6 and IL-8 were measured in serum samples of all patients using ELISA. In a subset of 10 representative patients, bacterial DNA was extracted from ascites and whole blood, followed by 16S rRNA gene amplicon sequencing.",{"#text":938},{"p":1033},[1034,1035,1039],{"#text":932},{"bold":1036},[1037],{"#text":1038},"Results:",{"#text":1040}," There were significantly higher levels of IL-6 in ascites fluid compared to blood samples in all patients. Interestingly, IL-6 levels in blood correlated tightly with disease severity and surrogates of systemic inflammation, while IL-6 levels in ascites did not. Moreover, patients with higher blood CRP levels showed greater SBP prevalence compared to patients with lower levels, despite similar positive culture results. Bacterial richness was also significantly higher in ascites compared to the corresponding patient blood. We identified differences in microbial composition and diversity between ascites and blood, but no tight relationship with surrogates of systemic inflammation could be observed.",{"#text":938},{"p":1043},[1044,1045,1049],{"#text":932},{"bold":1046},[1047],{"#text":1048},"Discussion:",{"#text":1050}," In decompensated cirrhosis, markers of systemic inflammation and microbiota composition seem to be dysregulated in ascites and blood. While a relationship between systemic inflammation and microbiota composition seems to exist in blood, this is not the case for ascites in our hands. These data may suggest compartmentalization of the immune response and interaction of the latter with the microbiota especially in the blood compartment.",{"#text":1052},"\n      ",[1054,1056,1208,1209,1417,1418,4891,4892,5032,5033,5062],{"#text":1055},"\n    ",{"sec":1057,":@":1205},[1058,1059,1063,1064,1107,1108,1183,1184,1204],{"#text":1052},{"title":1060},[1061],{"#text":1062},"Introduction",{"#text":1052},{"p":1065},[1066,1068,1075,1077,1083,1085,1091,1093,1097,1099,1105],{"#text":1067},"Acquired dysfunctional immunity in cirrhosis predisposes patients to frequent bacterial infections contributing to disease progression and may lead to the development of acute-on-chronic liver failure (ACLF) (",{"xref":1069,":@":1072},[1070],{"#text":1071},"1",{"@_ref-type":1073,"@_rid":1074},"bibr","B1",{"#text":1076},"). Especially, spontaneous bacterial peritonitis (SBP) is one of the most frequent infections in cirrhosis and therefore a trigger for ACLF (",{"xref":1078,":@":1081},[1079],{"#text":1080},"2",{"@_ref-type":1073,"@_rid":1082},"B2",{"#text":1084},"). Interestingly, SBP is defined by the number of granulocytes in ascites and not by cultural detection of bacteria (",{"xref":1086,":@":1089},[1087],{"#text":1088},"3",{"@_ref-type":1073,"@_rid":1090},"B3",{"#text":1092},"). This is because many patients with SBP show negative bacterial cultivation from ascites, while in many other patients, viable bacteria can be cultivated in the absence of peritonitis, so-called bacterascites (",{"xref":1094,":@":1096},[1095],{"#text":1088},{"@_ref-type":1073,"@_rid":1090},{"#text":1098},"). Lack of bacterial cultivation in the presence of SBP can be explained by the concept of dormant microbiota, meaning that bacteria can reside inside circulating and resident immune cells but cannot be cultured and hence detected (",{"xref":1100,":@":1103},[1101],{"#text":1102},"4",{"@_ref-type":1073,"@_rid":1104},"B4",{"#text":1106},").",{"#text":1052},{"p":1109},[1110,1112,1116,1118,1124,1126,1130,1132,1138,1140,1144,1146,1152,1153,1159,1161,1167,1169,1174,1175,1181],{"#text":1111},"The source of infection, especially in the case of SBP, is suspected to be bacterial translocation from the gut (",{"xref":1113,":@":1115},[1114],{"#text":1080},{"@_ref-type":1073,"@_rid":1082},{"#text":1117},"), which is facilitated by impaired intestinal defense and increased intestinal permeability, processes which are correlated with the stage of cirrhosis (",{"xref":1119,":@":1122},[1120],{"#text":1121},"5",{"@_ref-type":1073,"@_rid":1123},"B5",{"#text":1125},"). Not only viable bacteria (",{"xref":1127,":@":1129},[1128],{"#text":1071},{"@_ref-type":1073,"@_rid":1074},{"#text":1131},", ",{"xref":1133,":@":1136},[1134],{"#text":1135},"6",{"@_ref-type":1073,"@_rid":1137},"B6",{"#text":1139},"), but also bacterial components broadly termed pathogen-associated molecular patterns (PAMPs) may induce an immune response and aggravate systemic inflammation (",{"xref":1141,":@":1143},[1142],{"#text":1080},{"@_ref-type":1073,"@_rid":1082},{"#text":1145},"). As a consequence, the presence of circulating bacterial DNA reflects bacterial translocation in cirrhosis. However, the relationship of bacterial DNA with systemic inflammation is still controversially discussed (",{"xref":1147,":@":1150},[1148],{"#text":1149},"7",{"@_ref-type":1073,"@_rid":1151},"B7",{"#text":1131},{"xref":1154,":@":1157},[1155],{"#text":1156},"8",{"@_ref-type":1073,"@_rid":1158},"B8",{"#text":1160},"). PAMP-associated immune response requires recognition by innate immune cells and is reflected by synthesis and secretion of cytokines. Especially levels of the cytokines IL-6 and IL-8 are closely related to ACLF and clinical outcome (",{"xref":1162,":@":1165},[1163],{"#text":1164},"9",{"@_ref-type":1073,"@_rid":1166},"B9",{"#text":1168},"). At the same time, the antibacterial capacity of myeloid cells and myelopoiesis is impaired during decompensation and ACLF (",{"xref":1170,":@":1172},[1171],{"#text":719},{"@_ref-type":1073,"@_rid":1173},"B10",{"#text":1131},{"xref":1176,":@":1179},[1177],{"#text":1178},"11",{"@_ref-type":1073,"@_rid":1180},"B11",{"#text":1182},"). Interestingly, these effects are not only induced by PAMPs (deriving from pathogens), but in general by bacterial-derived molecules, so-called microbe-associated molecular patterns (MAMPs).",{"#text":1052},{"p":1185},[1186,1188,1194,1196,1202],{"#text":1187},"Recent data from our group suggest that specific circulating bacteria or MAMPs in blood are associated with myeloid cell dysregulation and systemic inflammation (",{"xref":1189,":@":1192},[1190],{"#text":1191},"12",{"@_ref-type":1073,"@_rid":1193},"B12",{"#text":1195},"). Therefore, a specific microbial DNA may be more crucial than just detecting any bacterial DNA in circulation. In ascites, the detection of bacterial DNA in ascites does not seem to correlate with SBP or clinical signs of infection (",{"xref":1197,":@":1200},[1198],{"#text":1199},"13",{"@_ref-type":1073,"@_rid":1201},"B13",{"#text":1203},"). Therefore, the question remains, whether specific bacteria in ascites lead to myeloid cell activation with subsequent cytokine release and a systemic inflammatory response. To address this question, we investigated whether the representative cytokine (IL-6, IL-8) levels produced by myeloid cells in ascites reflect systemic inflammation. Moreover, we compared the levels of cytokines in paired ascites and blood samples, together with the general bacterial composition and specific species abundances of the microbiota estimated by 16S ribosomal RNA gene sequencing. Our study focused not only on common pathogens but also on the role of MAMPs in activating myeloid cells of the innate immune response. We hypothesize that DNA from specific bacterial species, but not any bacterial DNA, induces an inflammatory response in cirrhotic patients.",{"#text":1055},{"@_sec-type":1206,"@_id":1207},"intro","s1",{"#text":1055},{"sec":1210,":@":1414},[1211,1212,1216,1217,1238,1239,1280,1281,1294,1295,1322,1323,1413],{"#text":1052},{"title":1213},[1214],{"#text":1215},"Materials and Methods",{"#text":1052},{"sec":1218},[1219,1220,1224,1225,1237],{"#text":938},{"title":1221},[1222],{"#text":1223},"Patient Recruitment and Sample Collection",{"#text":938},{"p":1226},[1227,1229,1235],{"#text":1228},"Ascites and blood were collected in 33 cirrhotic patients scheduled for paracentesis. Paracentesis was performed by international standards (",{"xref":1230,":@":1233},[1231],{"#text":1232},"14",{"@_ref-type":1073,"@_rid":1234},"B14",{"#text":1236},"). The study was performed in accordance with the declaration of Helsinki and approved by the local ethics committee at the University of Bonn (Nr. 121/14). Patients gave their written informed consent.",{"#text":1052},{"#text":1052},{"sec":1240},[1241,1242,1246,1247,1279],{"#text":938},{"title":1243},[1244],{"#text":1245},"Microbiological Analysis",{"#text":938},{"p":1248},[1249,1251,1257,1258,1264,1266,1272,1274,1278],{"#text":1250},"Microbiological culture of blood and ascites was performed at the clinical microbiology department at the University of Bonn in accordance with Microbiology Procedures Quality Standards of the German Society for Hygiene and Microbiology (",{"xref":1252,":@":1255},[1253],{"#text":1254},"15",{"@_ref-type":1073,"@_rid":1256},"B15",{"#text":1131},{"xref":1259,":@":1262},[1260],{"#text":1261},"16",{"@_ref-type":1073,"@_rid":1263},"B16",{"#text":1265},"). Ten milliliters of peripheral whole blood or ascitic fluid were transferred into aerobic, anaerobic and fungal blood culture bottles and incubated for up to 5 days using the Bactex FX blood culture system as described previously (",{"xref":1267,":@":1270},[1268],{"#text":1269},"17",{"@_ref-type":1073,"@_rid":1271},"B17",{"#text":1273},"). SBP was diagnosed based on a leucocyte count in ascites >250/μl (",{"xref":1275,":@":1277},[1276],{"#text":1088},{"@_ref-type":1073,"@_rid":1090},{"#text":1106},{"#text":1052},{"#text":1052},{"sec":1282},[1283,1284,1288,1289,1293],{"#text":938},{"title":1285},[1286],{"#text":1287},"Enzyme-Linked Immunosorbent Assay",{"#text":938},{"p":1290},[1291],{"#text":1292},"Ascites and peripheral blood samples (serum, EDTA-plasma and whole-blood) were collected during paracentesis and stored immediately at −80°C until further use. Enzyme-linked immunosorbent assay for cytokines IL-6 and IL-8 (DY206 and DY208, respectively; R&D Systems Inc., Minneapolis, MN, USA) were performed according to the manufacturer's protocols. All samples were measured in duplicates.",{"#text":1052},{"#text":1052},{"sec":1296},[1297,1298,1302,1303,1321],{"#text":938},{"title":1299},[1300],{"#text":1301},"16S Ribosomal RNA Gene Sequencing",{"#text":938},{"p":1304},[1305,1307,1313,1314,1320],{"#text":1306},"For extraction of total DNA, 100 μl of whole blood or ascitic fluid were used. Samples were mechanically lysed two times for 30 s at 20 Hz in a bead beater (TissueLyser, Qiagen, Hilden, Germany) with 0.1 mm glass beads (MoBio, CA, USA). DNA extraction was performed using the NucleoSpin Blood Kit (Macherey-Nagel, Düren, Germany). Quality and quantity of extracted nucleic acids were controlled by gel electrophoresis. 16S rRNA gene V3-V4 hypervariable regions were amplified and quantified by qPCR, and sequenced using MiSeq technology (Illumina, San Diego, CA, USA) as described previously producing 2 × 300 bp paired-end reads (",{"xref":1308,":@":1311},[1309],{"#text":1310},"18",{"@_ref-type":1073,"@_rid":1312},"B18",{"#text":1131},{"xref":1315,":@":1318},[1316],{"#text":1317},"19",{"@_ref-type":1073,"@_rid":1319},"B19",{"#text":1106},{"#text":1052},{"#text":1052},{"sec":1324},[1325,1326,1330,1331,1365,1366,1396,1397,1412],{"#text":938},{"title":1327},[1328],{"#text":1329},"Bioinformatics and Statistical Analysis",{"#text":938},{"p":1332},[1333,1335,1341,1343,1349,1351,1357,1359,1363],{"#text":1334},"Paired-ends reads were processed in DADA2 version 1.6.0 (",{"xref":1336,":@":1339},[1337],{"#text":1338},"20",{"@_ref-type":1073,"@_rid":1340},"B20",{"#text":1342},") using the following parameters: “trimLeft = 10, truncLen = (260;230), maxN = 0, maxEE = (2,5), minOverlap = 20, maxMismatch = 1, pool = TRUE.” The resulting output was an amplicon sequence variant (ASV) table. The ASVs were mapped against SILVA database (",{"xref":1344,":@":1347},[1345],{"#text":1346},"21",{"@_ref-type":1073,"@_rid":1348},"B21",{"#text":1350},") release 128. Data analysis was performed in R version 3.5, using phyloseq package (",{"xref":1352,":@":1355},[1353],{"#text":1354},"22",{"@_ref-type":1073,"@_rid":1356},"B22",{"#text":1358},") version 1.24.2. Genus level relative abundances were generated by combining ASVs annotated with the same genus using phyloseq package. The alpha-diversity measures were calculated based on rarefied data at 6,000 reads/sample. Significant differences in alpha-diversity between ascites and blood samples as well as between samples with different inflammation status were determined using ",{"italic":1360},[1361],{"#text":1362},"t",{"#text":1364},"-test.",{"#text":938},{"p":1367},[1368,1370,1376,1378,1381,1383,1389,1391,1394],{"#text":1369},"Beta-diversity was calculated using unweighted and weighted UniFrac measures. Effects of different factors on beta-diversity were determined using Adonis Permutational Multivariate Analysis of Variance (PERMANOVA) test from the vegan package (",{"xref":1371,":@":1374},[1372],{"#text":1373},"23",{"@_ref-type":1073,"@_rid":1375},"B23",{"#text":1377},") version 2.5.2. For differential abundance analysis, we chose a ",{"italic":1379},[1380],{"#text":1362},{"#text":1382},"-test based on the evaluation using DAtest package (",{"xref":1384,":@":1387},[1385],{"#text":1386},"24",{"@_ref-type":1073,"@_rid":1388},"B24",{"#text":1390},") version 2.7.11, which showed that, compared with different statistical tests, ",{"italic":1392},[1393],{"#text":1362},{"#text":1395},"-test has the highest area under the curve (AUC = 0.608) while keeping the false discovery rate (FDR) under 0.05.",{"#text":938},{"p":1398},[1399,1401,1405,1407,1410],{"#text":1400},"Statistical analysis of patient characteristics and clinical measures was performed using SPSS version 24 (IBM, Armonk, NY) and Mann–Whitney test for metric variables and Chi-square test for nominal variables. Receiver operator characteristic curve analysis was used to define a cut-off for CRP and divide the cohort into one group with low CRP profile and one group with high CRP profile. ",{"italic":1402},[1403],{"#text":1404},"P",{"#text":1406},"-values were adjusted for multiple testing using Benjamini–Hochberg FDR procedure. An FDR-adjusted ",{"italic":1408},[1409],{"#text":1404},{"#text":1411},"-value below 0.05 was considered statistically significant.",{"#text":1052},{"#text":1055},{"@_sec-type":1415,"@_id":1416},"materials and methods","s2",{"#text":1055},{"sec":1419,":@":4888},[1420,1421,1425,1426,2857,2858,2995,2996,4152,4153,4887],{"#text":1052},{"title":1422},[1423],{"#text":1424},"Results",{"#text":1052},{"sec":1427},[1428,1429,1433,1434,1447,1448,2781,2782,2830,2831,2856],{"#text":938},{"title":1430},[1431],{"#text":1432},"General Description of the Cohort",{"#text":938},{"p":1435},[1436,1438,1445],{"#text":1437},"General characteristics of the patients are summarized in ",{"xref":1439,":@":1442},[1440],{"#text":1441},"Table 1",{"@_ref-type":1443,"@_rid":1444},"table","T1",{"#text":1446},". The cohort consists of patients with decompensated liver cirrhosis as reflected by the model for end-stage liver disease (MELD) and Child-Pugh (CHILD) scores, which assess severity of liver disease, prognosis and mortality. The median MELD score of 15 represents a value at which patients would benefit from liver transplantation. The median CHILD score of 10 is associated with a 1-year survival below 50%. Seventy-two percent of the patients (24/33) showed ACLF at baseline.",{"#text":938},{"table-wrap":1449,":@":2779},[1450,1451,1454,1455,1464,1465,2764,2765,2778],{"#text":932},{"label":1452},[1453],{"#text":1441},{"#text":932},{"caption":1456},[1457,1459,1463],{"#text":1458},"\n            ",{"p":1460},[1461],{"#text":1462},"Patient characteristics.",{"#text":932},{"#text":932},{"table":1466,":@":2761},