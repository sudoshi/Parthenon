    function plumXError(e) {
        $(e).closest('.metric-plum-x').closest('.metrics-bottom').addClass('one');
        $(e).closest('.metric-plum-x').remove();
    }
    $('div.altmetric-embed').on('altmetric:hide', function () {
        $(this).closest('.metric-altmetric').closest('.metrics-bottom').addClass('one');
        $(this).closest('.metric-altmetric').remove();
    });
</script>
        



    
    
    
    
    
    

    
        
        
        
    

