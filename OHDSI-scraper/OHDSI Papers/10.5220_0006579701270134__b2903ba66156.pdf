                    <script type="text/javascript">


                        function loadingCollapseMenu(validationGroup) { //DOM


                            if (Page_ClientValidate(validationGroup)) {
                                var menu = $find("ctl00_MasterPageHeader_RadMenu1");
                                menu.close();
                                document.getElementById('prepage').style.visibility = 'visible';
                            }


                        }

                        function OnClientItemClicking(sender, eventArgs) {
                            var item = eventArgs.get_item();

                            if (item.get_level() == 0) {
                                item.open();
                                console.log(item);
                                eventArgs.set_cancel(true);


                            }
                            else {
                                eventArgs.set_cancel(false);
                            }
                        }


                        function doCustomValidateProceedings(source, args) {
                            args.IsValid = false;

                            if (document.getElementById('ctl00_MasterPageHeader_RadMenu1_i2_ctl00_ProceedingsTitle').value.length > 0) {
                                args.IsValid = true;
                            }
                            if (document.getElementById('ctl00_MasterPageHeader_RadMenu1_i2_ctl00_ProceedingsISBN').value.length > 0) {
                                args.IsValid = true;
                            }
                            if (document.getElementById('ctl00_MasterPageHeader_RadMenu1_i2_ctl00_ProceedingsYear').value.length > 0) {
                                args.IsValid = true;
                            }
                            if (document.getElementById('ctl00_MasterPageHeader_RadMenu1_i2_ctl00_ProceedingsConference').value.length > 0) {
                                args.IsValid = true;
                            }
                            var fields = document.getElementById('ctl00_MasterPageHeader_RadMenu1_i2_ctl00_DropDownListProceedings');

                            var selectedValue = fields.options[fields.selectedIndex].value;

                            if (selectedValue != "Select a Subject") {
                                args.IsValid = true;
                            }


                        }
                        function doCustomValidateAuthors(source, args) {
                            args.IsValid = false;

                            if (document.getElementById('ctl00_MasterPageHeader_RadMenu1_i6_ctl00_AuthorsName').value.length > 0) {
                                args.IsValid = true;
                            }
                            if (document.getElementById('ctl00_MasterPageHeader_RadMenu1_i6_ctl00_AuthorsAffiliation').value.length > 0) {
                                args.IsValid = true;
                            }
                            if (document.getElementById('ctl00_MasterPageHeader_RadMenu1_i6_ctl00_AuthorsConference').value.length > 0) {
                                args.IsValid = true;
                            }


                            var fieldsCountry = document.getElementById('ctl00_MasterPageHeader_RadMenu1_i6_ctl00_DropDownListAuthorsCountries');

                            var selectedValueCountry = fieldsCountry.options[fieldsCountry.selectedIndex].value;

                            if (selectedValueCountry != "Select a Country") {
                                args.IsValid = true;
                            }


                            var fields = document.getElementById('ctl00_MasterPageHeader_RadMenu1_i6_ctl00_DropDownListAuthors');

                            var selectedValue = fields.options[fields.selectedIndex].value;

                            if (selectedValue != "Select a Subject") {
                                args.IsValid = true;
                            }
                        }

                        function doCustomValidateAffiliation(source, args) {

                            args.IsValid = false;

                            if (document.getElementById('ctl00_MasterPageHeader_RadMenu1_i8_ctl00_AffiliationName').value.length > 0) {
                                args.IsValid = true;
                            }

                            var fieldsCountry = document.getElementById('ctl00_MasterPageHeader_RadMenu1_i8_ctl00_DropDownListAffiliationCountry');

                            var selectedValueCountry = fieldsCountry.options[fieldsCountry.selectedIndex].value;

                            if (selectedValueCountry != "Select a Country") {
                                args.IsValid = true;
                            }

                            var fields = document.getElementById('ctl00_MasterPageHeader_RadMenu1_i8_ctl00_DropDownListAffiliation');

                            var selectedValue = fields.options[fields.selectedIndex].value;

                            if (selectedValue != "Select a Subject") {
                                args.IsValid = true;
                            }
                        }
                        function doCustomValidate(source, args) {

                            args.IsValid = false;

                            if (document.getElementById('ctl00_MasterPageHeader_RadMenu1_i3_ctl00_PaperTitle').value.length > 0) {
                                args.IsValid = true;
                            }
                            if (document.getElementById('ctl00_MasterPageHeader_RadMenu1_i3_ctl00_PaperAuthor').value.length > 0) {
                                args.IsValid = true;
                            }
                            if (document.getElementById('ctl00_MasterPageHeader_RadMenu1_i3_ctl00_PaperAffiliation').value.length > 0) {
                                args.IsValid = true;
                            }
                            var fields = document.getElementById('ctl00_MasterPageHeader_RadMenu1_i3_ctl00_DropDownListPaperField');

                            var selectedValue = fields.options[fields.selectedIndex].value;

                            if (selectedValue != "Select a Subject") {
                                args.IsValid = true;
                            }
                        }

                        function hoverTextFunction(description) {
                            var topicName = document.getElementById(description.id).textContent;
                            document.getElementById("menuActionText1").innerHTML = topicName;
                        }
                        function hoverTextFunctionProceeding(description) {
                            var topicName = document.getElementById(description.id).textContent;
                            document.getElementById("menuActionText2").innerHTML = topicName;
                        }
                        function hoverTextFunctionAuthors(description) {
                            var topicName = document.getElementById(description.id).textContent;
                            document.getElementById("menuActionText3").innerHTML = topicName;
                        }
                        function hoverTextFunctionAffiliation(description) {
                            var topicName = document.getElementById(description.id).textContent;
                            document.getElementById("menuActionText4").innerHTML = topicName;
                        }
                   



                    </script>
                </ul>
            </div>
        </div>
    </nav>

