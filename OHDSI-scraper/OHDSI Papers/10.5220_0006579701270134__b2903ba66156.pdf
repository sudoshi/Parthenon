            <p class="PublicationsDetailNormal">

                <span id="ContentPlaceHolder1_LinkPaperPage_LinkPaperContent_LabelTopic" class="LabelSearchRepeater">Related
                    <a id="ContentPlaceHolder1_LinkPaperPage_LinkPaperContent_OntologyTree" href="OntologyTree.aspx" target="_blank">Ontology</a>
                    Subjects/Areas/Topics:</span>
                
                        <span id="ContentPlaceHolder1_LinkPaperPage_LinkPaperContent_RepeaterTopicsFirstRow_Topic_0" title="Biomedical Engineering">Biomedical Engineering</span>
                    ; 
                        <span id="ContentPlaceHolder1_LinkPaperPage_LinkPaperContent_RepeaterTopicsFirstRow_Topic_1" title="Electronic Health Records and Standards">Electronic Health Records and Standards</span>
                    ; 
                        <span id="ContentPlaceHolder1_LinkPaperPage_LinkPaperContent_RepeaterTopicsFirstRow_Topic_2" title="Health Information Systems">Health Information Systems</span>
                    ; 
                        <span id="ContentPlaceHolder1_LinkPaperPage_LinkPaperContent_RepeaterTopicsFirstRow_Topic_3" title="Healthcare Management Systems">Healthcare Management Systems</span>
                    ; 
                        <span id="ContentPlaceHolder1_LinkPaperPage_LinkPaperContent_RepeaterTopicsFirstRow_Topic_4" title="Practice-based Research Methods for Healthcare IT">Practice-based Research Methods for Healthcare IT</span>
                    
