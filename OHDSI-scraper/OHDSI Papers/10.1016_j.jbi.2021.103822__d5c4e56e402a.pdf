<li role="presentation"><a href='?term="J%20Biomed%20Inform"[jour]' class="usa-link" role="menuitem" data-add-to-search="true">Add to search</a></li>
</ul></nav></section><section class="front-matter"><div class="ameta p font-secondary font-xs">
<hgroup><h1>Clinical Comparison Between Trial Participants and Potentially Eligible Patients Using Electronic Health Record Data: A Generalizability Assessment Method</h1></hgroup><div class="cg p">
<a href='https://pubmed.ncbi.nlm.nih.gov/?term="Rogers%20JR"[Author]' class="usa-link" aria-describedby="id1"><span class="name western">James R Rogers</span></a><div hidden="hidden" id="id1">
<h3>
<span class="name western">James R Rogers</span>, <span class="degrees">MS</span>
</h3>
<div class="p">
<sup>1</sup>Department of Biomedical Informatics, Columbia University, New York, NY</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Rogers%20JR"[Author]' class="usa-link"><span class="name western">James R Rogers</span></a>
</div>
</div>
<sup>1</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Hripcsak%20G"[Author]' class="usa-link" aria-describedby="id2"><span class="name western">George Hripcsak</span></a><div hidden="hidden" id="id2">
<h3>
<span class="name western">George Hripcsak</span>, <span class="degrees">MD</span>
</h3>
<div class="p">
<sup>1</sup>Department of Biomedical Informatics, Columbia University, New York, NY</div>
<div class="p">
<sup>2</sup>Medical Informatics Services, New York-Presbyterian Hospital, New York, NY</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Hripcsak%20G"[Author]' class="usa-link"><span class="name western">George Hripcsak</span></a>
</div>
</div>
<sup>1,</sup><sup>2</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Cheung%20YK"[Author]' class="usa-link" aria-describedby="id3"><span class="name western">Ying Kuen Cheung</span></a><div hidden="hidden" id="id3">
<h3>
<span class="name western">Ying Kuen Cheung</span>, <span class="degrees">PhD</span>
</h3>
<div class="p">
<sup>3</sup>Department of Biostatistics, Columbia University, New York, NY</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Cheung%20YK"[Author]' class="usa-link"><span class="name western">Ying Kuen Cheung</span></a>
</div>
</div>
<sup>3</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Weng%20C"[Author]' class="usa-link" aria-describedby="id4"><span class="name western">Chunhua Weng</span></a><div hidden="hidden" id="id4">
<h3>
<span class="name western">Chunhua Weng</span>, <span class="degrees">PhD</span>
</h3>
<div class="p">
<sup>1</sup>Department of Biomedical Informatics, Columbia University, New York, NY</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Weng%20C"[Author]' class="usa-link"><span class="name western">Chunhua Weng</span></a>
</div>
</div>
<sup>1,</sup><sup>#</sup>
</div>
<ul class="d-buttons inline-list">
