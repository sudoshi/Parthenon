<td align="left" valign="bottom" rowspan="1" colspan="1"><strong>Mod: Patient</strong></td>
<td align="left" valign="bottom" rowspan="1" colspan="1"><strong>Mod: Time</strong></td>
<td align="left" valign="bottom" rowspan="1" colspan="1"><strong>Mod: Value</strong></td>
</tr></thead>
<tbody>
<tr>
<td align="left" valign="bottom" rowspan="1" colspan="1">Percentage of Participants With HIV-1 RNA&lt;50<br>Copies/mL at Week 48</td>
<td align="left" valign="bottom" rowspan="1" colspan="1">HIV-1 RNA</td>
<td align="left" valign="bottom" rowspan="1" colspan="1">Percentage/Proportion</td>
<td align="left" valign="bottom" rowspan="1" colspan="1"></td>
<td align="left" valign="bottom" rowspan="1" colspan="1">Week 48</td>
