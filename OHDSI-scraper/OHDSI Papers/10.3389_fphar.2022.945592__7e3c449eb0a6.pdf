iationsIndexes":1066,"isCorresponding":351,"equalContrib":351,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":1068,"onBehalfOf":19},[475,1067],17,"https://loop.frontiersin.org/people/1670559/overview",{"surname":647,"givenNames":646,"suffix":19,"affiliationsIndexes":1070,"isCorresponding":351,"equalContrib":351,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":1071,"onBehalfOf":19},[475],"https://loop.frontiersin.org/people/1535872/overview",{"surname":653,"givenNames":652,"suffix":19,"affiliationsIndexes":1073,"isCorresponding":351,"equalContrib":351,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[1018],{"surname":659,"givenNames":658,"suffix":19,"affiliationsIndexes":1075,"isCorresponding":351,"equalContrib":351,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[1064],{"surname":666,"givenNames":665,"suffix":19,"affiliationsIndexes":1077,"isCorresponding":351,"equalContrib":351,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":1078,"onBehalfOf":19},[475],"https://loop.frontiersin.org/people/1876546/overview",{"surname":673,"givenNames":672,"suffix":19,"affiliationsIndexes":1080,"isCorresponding":351,"equalContrib":351,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":1081,"onBehalfOf":19},[1044],"https://loop.frontiersin.org/people/1706595/overview",{"surname":680,"givenNames":679,"suffix":19,"affiliationsIndexes":1083,"isCorresponding":13,"equalContrib":351,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":1084,"onBehalfOf":19},[1014],"https://loop.frontiersin.org/people/1278499/overview",{"surname":686,"givenNames":685,"suffix":19,"affiliationsIndexes":1086,"isCorresponding":351,"equalContrib":351,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[1067,482,1087],19,[1089,1093,1097,1101,1105,1108,1112,1116,1119,1123,1126,1130,1134,1138,1143,1147,1151,1155,1158],{"index":374,"baseText":19,"institution":1090,"country":499,"address":1091,"textContent":1092},"Department of Biostatistics, Bloomberg School of Public Health, Johns Hopkins University","Baltimore","Department of Biostatistics, Bloomberg School of Public Health, Johns Hopkins University, Baltimore, MD, United States",{"index":1014,"baseText":19,"institution":1094,"country":508,"address":1095,"textContent":1096},"Centre for Statistics in Medicine, Nuffield Department of Orthopaedics, Rheumatology and Musculoskeletal Sciences, Oxford University","Oxford","Centre for Statistics in Medicine, Nuffield Department of Orthopaedics, Rheumatology and Musculoskeletal Sciences, Oxford University, Oxford, United Kingdom",{"index":1018,"baseText":19,"institution":1098,"country":499,"address":1099,"textContent":1100},"Real World Solutions, IQVIA","Cambridge","Real World Solutions, IQVIA, Cambridge, MA, United States",{"index":734,"baseText":19,"institution":1102,"country":499,"address":1103,"textContent":1104},"The OHDSI Center at The Roux Institute, Northeastern University","Portland","The OHDSI Center at The Roux Institute, Northeastern University, Portland, ME, United States",{"index":1021,"baseText":19,"institution":525,"country":526,"address":1106,"textContent":1107},"Barcelona","Fundació Institut Universitari Per a la Recerca a l'Atenció Primària de Salut Jordi Gol i Gurina (IDIAPJGol), Barcelona, Spain",{"index":475,"baseText":19,"institution":1109,"country":499,"address":1110,"textContent":1111},"Observational Health Data Analytics, Janssen Research and Development","Titusville","Observational Health Data Analytics, Janssen Research and Development, Titusville, NJ, United States",{"index":1034,"baseText":19,"institution":1113,"country":499,"address":1114,"textContent":1115},"VA Informatics and Computing Infrastructure, VA Salt Lake City Health Care System","Salt Lake City","VA Informatics and Computing Infrastructure, VA Salt Lake City Health Care System, Salt Lake City, UT, United States",{"index":1035,"baseText":19,"institution":1117,"country":499,"address":1114,"textContent":1118},"Department of Internal Medicine, University of Utah School of Medicine","Department of Internal Medicine, University of Utah School of Medicine, Salt Lake City, UT, United States",{"index":1040,"baseText":19,"institution":1120,"country":499,"address":1121,"textContent":1122},"Tennessee Valley Healthcare System, Veterans Affairs Medical Center","Nashville","Tennessee Valley Healthcare System, Veterans Affairs Medical Center, Nashville, TN, United States",{"index":1041,"baseText":19,"institution":1124,"country":499,"address":1121,"textContent":1125},"Department of Biomedical Informatics, Vanderbilt University Medical Center","Department of Biomedical Informatics, Vanderbilt University Medical Center, Nashville, TN, United States",{"index":1044,"baseText":19,"institution":1127,"country":499,"address":1128,"textContent":1129},"Department of Biomedical Informatics, Columbia University","New York","Department of Biomedical Informatics, Columbia University, New York, NY, United States",{"index":1048,"baseText":19,"institution":1131,"country":508,"address":1132,"textContent":1133},"Division of Population Health and Genomics, University of Dundee","Dundee","Division of Population Health and Genomics, University of Dundee, Dundee, United Kingdom",{"index":735,"baseText":19,"institution":1135,"country":595,"address":1136,"textContent":1137},"Department of Public Health, University of Southern Denmark","Southern Denmark","Department of Public Health, University of Southern Denmark, Southern Denmark, Denmark",{"index":1054,"baseText":19,"institution":1139,"country":1140,"address":1141,"textContent":1142},"Department of Preventive Medicine and Public Health, Yonsei University College of Medicine","South Korea","Seoul","Department of Preventive Medicine and Public Health, Yonsei University College of Medicine, Seoul, South Korea",{"index":1057,"baseText":19,"institution":1144,"country":618,"address":1145,"textContent":1146},"Quality Use of Medicines and Pharmacy Research Centre, Clinical and Health Sciences, University of South Australia","Adelaide","Quality Use of Medicines and Pharmacy Research Centre, Clinical and Health Sciences, University of South Australia, Adelaide, Australia",{"index":1064,"baseText":19,"institution":1148,"country":634,"address":1149,"textContent":1150},"Department of Medical Informatics, Erasmus University Medical Center","Rotterdam","Department of Medical Informatics, Erasmus University Medical Center, Rotterdam, Netherlands",{"index":1067,"baseText":19,"institution":1152,"country":499,"address":1153,"textContent":1154},"Department of Biostatistics, UCLA Fielding School of Public Health, University of California, Los Angeles","Los Angeles","Department of Biostatistics, UCLA Fielding School of Public Health, University of California, Los Angeles, Los Angeles, CA, United States",{"index":482,"baseText":19,"institution":1156,"country":499,"address":1153,"textContent":1157},"Department of Computational Medicine, David Geffen School of Medicine at UCLA, University of California, Los Angeles","Department of Computational Medicine, David Geffen School of Medicine at UCLA, University of California, Los Angeles, Los Angeles, CA, United States",{"index":1087,"baseText":19,"institution":1159,"country":499,"address":1153,"textContent":1160},"Department of Human Genetics, David Geffen School of Medicine at UCLA, University of California, Los Angeles","Department of Human Genetics, David Geffen School of Medicine at UCLA, University of California, Los Angeles, Los Angeles, CA, United States",{"editedBy":1162,"editedByContent":1167,"reviewedBy":1185,"reviewedByContent":1194,"approvedBy":1219,"approvedByContent":1220,"correspondence":1221,"equalContribution":1222,"presentAddress":19,"other":1223},[1163],{"loopId":1164,"fullName":1165,"textContent":1166},"527652","Martin Hennenberg","\r\n            Edited by:\r\n            Martin Hennenberg, LMU Munich, Germany",[1168,1170,1183],{"#text":1169},"\n          ",{"p":1171},[1172,1174,1181],{"#text":1173},"\n            \n            ",{"ext-link":1175,":@":1177},[1176],{"#text":1165},{"@_ext-link-type":1178,"@_xmlns:xlink":1179,"@_xlink:href":1180},"uri","http://www.w3.org/1999/xlink","https://loop.frontiersin.org/people/527652/overview",{"#text":1182},", LMU Munich, Germany",{"#text":1184},"\n        ",[1186,1190],{"loopId":1187,"fullName":1188,"textContent":1189},"1900167","Ruixiao Wang","\r\n            Reviewed by:\r\n            Ruixiao Wang, Lanzhou University, China",{"loopId":1191,"fullName":1192,"textContent":1193},"1856291","Qingfeng Yu","\r\n            Qingfeng Yu, The First Affiliated Hospital of Guangzhou Medical University, China",[1195,1196,1206,1207,1218],{"#text":1169},{"p":1197},[1198,1199,1204],{"#text":1173},{"ext-link":1200,":@":1202},[1201],{"#text":1188},{"@_ext-link-type":1178,"@_xmlns:xlink":1179,"@_xlink:href":1203},"https://loop.frontiersin.org/people/1900167/overview",{"#text":1205},", Lanzhou University, China",{"#text":1169},{"p":1208},[1209,1211,1216],{"#text":1210},"\n            ",{"ext-link":1212,":@":1214},[1213],{"#text":1192},{"@_ext-link-type":1178,"@_xlink:href":1215},"https://loop.frontiersin.org/people/1856291/overview",{"#text":1217},", The First Affiliated Hospital of Guangzhou Medical University, China",{"#text":1184},[],[],"*Correspondence: Daniel Prieto-Alhambra, ZGFuaWVsLnByaWV0b2FsaGFtYnJhQG5kb3Jtcy5veC5hYy51aw==",[],[1224,1225,1229],{"#text":1169},{"p":1226},[1227],{"#text":1228},"This article was submitted to Pharmacoepidemiology, a section of the journal Frontiers in Pharmacology",{"#text":1184},"2022-09-14","2022-07-25","2022-05-16",{"copyrightStatement":1234,"copyrightYear":1235,"copyrightHolder":1236,"licenseUrl":1237,"licenseText":1238},"Copyright © 2022 Nishimura, Xie, Kostka, Duarte-Salles, Fernández Bertolín, Aragón, Blacketer, Shoaibi, DuVall, Lynch, Matheny, Falconer, Morales, Conover, Chan You, Pratt, Weaver, Sena, Schuemie, Reps, Reich, Rijnbeek, Ryan, Hripcsak, Prieto-Alhambra and Suchard.",2022,"Nishimura, Xie, Kostka, Duarte-Salles, Fernández Bertolín, Aragón, Blacketer, Shoaibi, DuVall, Lynch, Matheny, Falconer, Morales, Conover, Chan You, Pratt, Weaver, Sena, Schuemie, Reps, Reich, Rijnbeek, Ryan, Hripcsak, Prieto-Alhambra and Suchard","http://creativecommons.org/licenses/by/4.0/",[1239,1240,1251],{"#text":1169},{"p":1241},[1242,1244,1249],{"#text":1243},"This is an open-access article distributed under the terms of the ",{"ext-link":1245,":@":1248},[1246],{"#text":1247},"Creative Commons Attribution License (CC BY)",{"@_ext-link-type":1178,"@_xlink:href":1237},{"#text":1250},". The use, distribution or reproduction in other forums is permitted, provided the original author(s) and the copyright owner(s) are credited and that the original publication in this journal is cited, in accordance with accepted academic practice. No use, distribution or reproduction is permitted which does not comply with these terms.",{"#text":1184},[1253,1255,1258,1261,1264,1266],[1254],{"#text":484},[1256],{"#text":1257},"observational study",[1259],{"#text":1260},"electronic health records",[1262],{"#text":1263},"federated data model",[1265],{"#text":488},[1267],{"#text":1268},"open science",[],[1271,1272,1281,1282,1291,1292,1301,1302,1311],{"#text":1184},{"p":1273},[1274,1275,1279],{"#text":1169},{"bold":1276},[1277],{"#text":1278},"Purpose:",{"#text":1280}," Alpha-1 blockers, often used to treat benign prostatic hyperplasia (BPH), have been hypothesized to prevent COVID-19 complications by minimising cytokine storm release. The proposed treatment based on this hypothesis currently lacks support from reliable real-world evidence, however. We leverage an international network of large-scale healthcare databases to generate comprehensive evidence in a transparent and reproducible manner.",{"#text":1184},{"p":1283},[1284,1285,1289],{"#text":1169},{"bold":1286},[1287],{"#text":1288},"Methods:",{"#text":1290}," In this international cohort study, we deployed electronic health records from Spain (SIDIAP) and the United States (Department of Veterans Affairs, Columbia University Irving Medical Center, IQVIA OpenClaims, Optum DOD, Optum EHR). We assessed association between alpha-1 blocker use and risks of three COVID-19 outcomes—diagnosis, hospitalization, and hospitalization requiring intensive services—using a prevalent-user active-comparator design. We estimated hazard ratios using state-of-the-art techniques to minimize potential confounding, including large-scale propensity score matching/stratification and negative control calibration. We pooled database-specific estimates through random effects meta-analysis.",{"#text":1184},{"p":1293},[1294,1295,1299],{"#text":1169},{"bold":1296},[1297],{"#text":1298},"Results:",{"#text":1300}," Our study overall included 2.6 and 0.46 million users of alpha-1 blockers and of alternative BPH medications. We observed no significant difference in their risks for any of the COVID-19 outcomes, with our meta-analytic HR estimates being 1.02 (95% CI: 0.92–1.13) for diagnosis, 1.00 (95% CI: 0.89–1.13) for hospitalization, and 1.15 (95% CI: 0.71–1.88) for hospitalization requiring intensive services.",{"#text":1184},{"p":1303},[1304,1305,1309],{"#text":1169},{"bold":1306},[1307],{"#text":1308},"Conclusion:",{"#text":1310}," We found no evidence of the hypothesized reduction in risks of the COVID-19 outcomes from the prevalent-use of alpha-1 blockers—further research is needed to identify effective therapies for this novel disease.",{"#text":1312},"\n      ",[1314,1316,1433,1434,1909,1910,6042,6043,6241,6242,6258],{"#text":1315},"\n    ",{"sec":1317,":@":1431},[1318,1319,1323,1324,1345,1346,1358,1359,1417,1418,1430],{"#text":1312},{"title":1320},[1321],{"#text":1322},"Introduction",{"#text":1312},{"p":1325},[1326,1328,1335,1337,1343],{"#text":1327},"As the number of infections with severe acute respiratory syndrome coronavirus 2 (SARS-CoV-2) continues to increase, so does the search for therapies to prevent its respiratory and multi-organ complications. Treatments under study have been classified into antiviral/repurposed ones, aiming to reduce viral uptake, and concomitant/adjunctive ones, aiming to minimise the risk of or to treat complications (",{"xref":1329,":@":1332},[1330],{"#text":1331},"Sanders et al., 2020",{"@_ref-type":1333,"@_rid":1334},"bibr","B19",{"#text":1336},"). Despite the large number of proposed therapies, most drug trials have been negative: an increasing list of therapies including azithromycin, hydroxychloroquine, lopinavir/ritonavir, and tocilizumab have little or no impact on mortality or patient-relevant outcomes; whilst only corticosteroids and remdesivir have potential effects on mortality, mechanical ventilation, length of hospital stay, or duration of symptoms (",{"xref":1338,":@":1341},[1339],{"#text":1340},"Siemieniuk et al., 2020",{"@_ref-type":1333,"@_rid":1342},"B26",{"#text":1344},"). Given the scarcity of available treatments, the search for medicines with putative effects to treat COVID-19 and minimize its complications is due to continue.",{"#text":1312},{"p":1347},[1348,1350,1356],{"#text":1349},"Activation of inflammatory and related cascades are part of innate immunity and crucial in the immune response against SARS-CoV-2. However, aggressive inflammatory response to SARS-CoV-2, known as cytokine release syndrome (CRS), has been recognized as a driving cause of high morbidity and mortality in COVID-19. In animal studies using mice, a direct disruption of catecholamine synthesis reduced cytokine release and offered protection against lethal complications of CRS (",{"xref":1351,":@":1354},[1352],{"#text":1353},"Staedtke et al., 2018",{"@_ref-type":1333,"@_rid":1355},"B27",{"#text":1357},"). The same study found a similar protection from use of prazosin, an alpha-1 adrenergic receptor antagonist (alpha-1 blocker), to block catecholamines signalling. It has therefore been postulated that CRS may be prevented by targeting the catecholamine-cytokine axis.",{"#text":1312},{"p":1360},[1361,1362,1368,1370,1376,1378,1384,1386,1392,1393,1399,1401,1407,1409,1415],{"#text":1184},{"xref":1363,":@":1366},[1364],{"#text":1365},"Koenecke et al. (2021)",{"@_ref-type":1333,"@_rid":1367},"B11",{"#text":1369}," investigated this hypothesis through a cohort study based primarily on US claims databases, comparing alpha-1 blocker users to non-users among patients hospitalized for acute respiratory distress or pneumonia. A companion paper by ",{"xref":1371,":@":1374},[1372],{"#text":1373},"Rose et al. (2021)",{"@_ref-type":1333,"@_rid":1375},"B17",{"#text":1377}," carried out a similar analysis for hospitalized COVID-19 patients in Veterans Health Administration hospitals. While they found the alpha-1 blocker users to have lower rates of progression to mechanical ventilation and/or mortality, such users vs. non-users comparisons are notoriously prone to systematic biases from residual confounding (",{"xref":1379,":@":1382},[1380],{"#text":1381},"Schneeweiss et al., 2007",{"@_ref-type":1333,"@_rid":1383},"B20",{"#text":1385},"; ",{"xref":1387,":@":1390},[1388],{"#text":1389},"Lund et al., 2015",{"@_ref-type":1333,"@_rid":1391},"B13",{"#text":1385},{"xref":1394,":@":1397},[1395],{"#text":1396},"Schuemie et al., 2019",{"@_ref-type":1333,"@_rid":1398},"B24",{"#text":1400},"). In fact, ",{"xref":1402,":@":1405},[1403],{"#text":1404},"Thomsen et al. (2021)",{"@_ref-type":1333,"@_rid":1406},"B29",{"#text":1408},", another companion paper of theirs based on Danish cohorts hospitalized with pneumonia, found the difference in mortality to become closer to the null and substantially less significant when the comparator cohort is restricted to 5ARI users. Overall, given the complex and dynamic interplay between catecholamines and immune-inflammatory regulation, the net effect of inhibition of catecholamines on COVID-19 thus remains uncertain (",{"xref":1410,":@":1413},[1411],{"#text":1412},"Gubbi et al., 2020",{"@_ref-type":1333,"@_rid":1414},"B7",{"#text":1416},").",{"#text":1312},{"p":1419},[1420,1422,1428],{"#text":1421},"Currently, one randomized controlled trial is ongoing to study the efficacy of prazosin for SARS-CoV-2 infection (",{"xref":1423,":@":1426},[1424],{"#text":1425},"Thorlund et al., 2020",{"@_ref-type":1333,"@_rid":1427},"B30",{"#text":1429},"). Clinical trials are inherently limited in sample size and patient representation, however. There is thus an urgent demand for further reliable and generalizable real-world evidence on the effect of alpha-1 blockers as a prophylaxis or treatment of COVID-19. In this article, we aimed to provide this much needed evidence by studying the association between the use of alpha-1 blockers and the susceptibility to COVID-19 disease (diagnosis), related hospitalization, and requirement of intensive services.",{"#text":1315},{"@_id":1432},"s1",{"#text":1315},{"sec":1435,":@":1906},[1436,1437,1441,1442,1498,1499,1584,1585,1614,1615,1635,1636,1688,1689,1710,1711,1861,1862,1905],{"#text":1312},{"title":1438},[1439],{"#text":1440},"Methods",{"#text":1312},{"sec":1443,":@":1496},[1444,1445,1449,1450,1470,1471,1495],{"#text":1184},{"title":1446},[1447],{"#text":1448},"Study design",{"#text":1184},{"p":1451},[1452,1454,1459,1461,1468],{"#text":1453},"We conducted a prevalent-user active comparator cohort analysis across an internationally distributed network of databases. Our protocol is available at ",{"ext-link":1455,":@":1458},[1456],{"#text":1457},"https://github.com/ohdsi-studies/Covid19SusceptibilityAlphaBlockers",{"@_ext-link-type":1178,"@_xmlns:xlink":1179,"@_xlink:href":1457},{"#text":1460}," and registered in the EU PAS register (EUPAS36231). The study design described in this section is visually summarized in a schematic diagram of ",{"xref":1462,":@":1465},[1463],{"#text":1464},"Figure 1",{"@_ref-type":1466,"@_rid":1467},"fig","F1",{"#text":1469},".",{"#text":1184},{"fig":1472,":@":1493},[1473,1474,1478,1479,1487,1488,1492],{"#text":1169},{"label":1475},[1476],{"#text":1477},"FIGURE 1",{"#text":1169},{"caption":1480},[1481,1482,1486],{"#text":1210},{"p":1483},[1484],{"#text":1485},"Alpha-1 blockers and susceptibility to COVID-19 study design schematic. We highlight eligibility criteria, exposure definitions, adjustment strategies, index date specification (horizontal black arrow) and outcome definitions and time-at-risk. Exposure involves prescriptions to drugs with RxNorm ingredients that map to medications indicated for treatment of BPH.",{"#text":1169},{"#text":1169},{"graphic":1489,":@":1490},[],{"@_xlink:href":1491},"fphar-13-945592-g001.tif",{"#text":1184},{"@_id":1467,"@_position":1494},"float",{"#text":1312},{"@_id":1497},"s2-1",{"#text":1312},{"sec":1500,":@":1582},[1501,1502,1506,1507,1576,1577,1581],{"#text":1184},{"title":1503},[1504],{"#text":1505},"Data sources",{"#text":1184},{"p":1508},[1509,1511,1517,1519],{"#text":1510},"We obtained routinely-collected electronic health records (EHRs) and claims data from Spain and the United States (US). All data sources had been previously mapped to the Observational Medical Outcomes Partnership (OMOP) Common Data Model (CDMv5) (",{"xref":1512,":@":1515},[1513],{"#text":1514},"Hripcsak et al., 2015",{"@_ref-type":1333,"@_rid":1516},"B9",{"#text":1518},"). This enabled distributed network analyses without sharing patient-level data, whilst ensuring data provenance, by applying common analytical programmes across data partner centers. The included data sources are:",{"list":1520,":@":1574},[1521,1527,1540,1546,1552,1564],{"list-item":1522},[1523],{"p":1524},[1525],{"#text":1526},"Information System for Research in Primary Care (SIDIAP) database, covering approximately 80% of the population of Catalonia, Spain, or six million patients in number. SIDIAP contains data since 2006 from general practice EHRs linked to hospital admissions with information on diagnoses, prescriptions, laboratory tests, and lifestyle and sociodemographics and the central database of RT-PCR COVID-19 tests.",{"list-item":1528},[1529],{"p":1530},[1531,1533,1539],{"#text":1532},"US Department of Veterans Affairs (VA) database, covering approximately 12 million patients from 170 medical centers across the US and including administrative, clinical, laboratory, and pharmacy data repositories that are linked using unique patient identifiers (",{"xref":1534,":@":1537},[1535],{"#text":1536},"Lynch et al., 2019",{"@_ref-type":1333,"@_rid":1538},"B14",{"#text":1416},{"list-item":1541},[1542],{"p":1543},[1544],{"#text":1545},"Columbia University Irving Medical Center data warehouse (CUIMC) EHRs covering approximately six million patients from the New York-Presbyterian Hospital/Columbia University Irving Medical Center in the United States. CUIMC includes data on clinical diagnoses, prescriptions, laboratory tests, demographics, and diagnosis and test for COVID-19.",{"list-item":1547},[1548],{"p":1549},[1550],{"#text":1551},"IQVIA Open Claims, covering approximately 160 million patients in the US and providing pre-adjudicated health insurance claims at the anonymized patient-level. The data are collected from inpatient, outpatient, and pharmacy interactions that generates claims for the purpose of reimbursement.",{"list-item":1553},[1554],{"p":1555},[1556,1558,1562],{"#text":1557},"Optum",{"sup":1559},[1560],{"#text":1561},"®",{"#text":1563}," De-Identified Clinformatics Data Mart Database—Date of Death (Optum DOD), covering approximately 86.8 million patients under private health insurance mostly in commercial plans but also in Medicare Advantage. Optum DOD includes data captured from administrative claims processed from inpatient and outpatient medical services and prescriptions as dispensed, as well as results for outpatient lab tests processed by large national lab vendors who participate in data exchange with Optum.",{"list-item":1565},[1566],{"p":1567},[1568,1569,1572],{"#text":1557},{"sup":1570},[1571],{"#text":1561},{"#text":1573}," De-Identified COVID-19 Electronic Health Record (Optum EHR), covering approximately 1.73 million patients from a network of healthcare provider organizations across the US. Optum EHR includes data since 2007 on demographics, medications prescribed and administered, lab results, vital signs and other observable measurements, clinical and inpatient stay administrative data, diagnosis and test for COVID-19.",{"@_list-type":1575},"bullet",{"#text":1184},{"p":1578},[1579],{"#text":1580},"Each site obtained institutional review board approval, or confirmed the study to be exempt or deemed not human subjects research. At the time of this study, SIDIAP and IQVIA were last updated in July, 2020; CUIMC in August, 2020; and VA, Optum DOD, and Optum EHR in September, 2020.",{"#text":1312},{"@_id":1583},"s2-2",{"#text":1312},{"sec":1586,":@":1612},[1587,1588,1592,1593,1611],{"#text":1184},{"title":1589},[1590],{"#text":1591},"Cohort eligibility, study period and follow-up",{"#text":1184},{"p":1594},[1595,1597,1601,1603,1610],{"#text":1596},"Each cohort consisted of adult males aged 18 years or older who received at least one eligible prescription or dispensation for one of the study drugs between 1 November 2019 and 31 January 2020. Index date was set as the date of the last prescription in this time window. We required participants to be observable in their data source for at least 180 days prior to the index date and to have a recorded history of BPH at any time prior to or on the index date (",{"xref":1598,":@":1600},[1599],{"#text":1464},{"@_ref-type":1466,"@_rid":1467},{"#text":1602},"). Participants were then followed up until the earliest of: occurrence of an outcome; end of exposure (i.e., discontinuation of drug use); death; loss or deregistration from the database; or date of last data collection. The distribution of follow-up time and number of at-risk patients within each database is summarized in ",{"xref":1604,":@":1607},[1605],{"#text":1606},"Supplementary Figures 1A,B",{"@_ref-type":1608,"@_rid":1609},"sec","s12",{"#text":1469},{"#text":1312},{"@_id":1613},"s2-3",{"#text":1312},{"sec":1616,":@":1633},[1617,1618,1622,1623,1627,1628,1632],{"#text":1184},{"title":1619},[1620],{"#text":1621},"Exposures",{"#text":1184},{"p":1624},[1625],{"#text":1626},"We compared exposures to alpha-1 blockers (alfuzosin, doxazosin, prazosin, silodosin, tamsulosin, and terazosin) with exposures to other drug classes commonly indicated for treatment of BPH as active comparators. More precisely, the comparator consisted of dutasteride and finasteride (5ARI) and tadalafil (PDE5 inhibitor). The OMOP CDM concept IDs for these drug classes are provided in the supplement.",{"#text":1184},{"p":1629},[1630],{"#text":1631},"We restricted our analysis to subjects under monotherapy at cohort entry, excluding those who were exposed to alternative BPH treatments any time within 180 days prior to and including the index date. With the exception of our analysis on the Optum databases, we defined continuous drug exposures from the start of follow-up by grouping sequential prescriptions that have ≤30-day refill gaps between them. The end of exposure was defined as the end of the last prescription’s drug supply in such a sequence. In the Optum databases, it is difficult to identify periods of continuous drug exposure as prescriptions are not recorded consistently. We therefore used an intent-to-treat (ITT) type analysis, following patients until their record ends regardless of treatment persistence.",{"#text":1312},{"@_id":1634},"s2-4",{"#text":1312},{"sec":1637,":@":1686},[1638,1639,1643,1644,1685],{"#text":1184},{"title":1640},[1641],{"#text":1642},"Outcomes",{"#text":1184},{"p":1645},[1646,1648,1654,1656,1662,1663,1669,1670,1676,1678,1683],{"#text":1647},"We investigated three outcomes: 1) COVID-19 diagnosis; 2) COVID-19 hospitalization (inpatient visit with COVID-19 diagnosis during or up to 3 weeks prior to hospitalization); 3) COVID-19 hospitalization with intensive services (mechanical ventilation, tracheostomy, or extracorporeal membrane oxygenation). For all three outcomes, we required COVID-19 positive status determined through either test results or diagnostic codes. While administrative claims data only record administrations of COVID-19 tests and not their results, ",{"xref":1649,":@":1652},[1650],{"#text":1651},"Kadri et al. (2020)",{"@_ref-type":1333,"@_rid":1653},"B10",{"#text":1655}," has demonstrated the COVID-19 diagnosis code as a reliable proxy for a lab-confirmed case. The definitions of these outcomes are taken from the prior COVID-19 phenotype characterization study using OHDSI’s international database network (",{"xref":1657,":@":1660},[1658],{"#text":1659},"Burn et al., 2020",{"@_ref-type":1333,"@_rid":1661},"B4",{"#text":1385},{"xref":1664,":@":1667},[1665],{"#text":1666},"Morales et al., 2021",{"@_ref-type":1333,"@_rid":1668},"B15",{"#text":1385},{"xref":1671,":@":1674},[1672],{"#text":1673},"Prats-Uribe et al., 2021",{"@_ref-type":1333,"@_rid":1675},"B16",{"#text":1677},"). We provide the full details of our cohort and outcome definitions in the supplement, as well as in the online protocol. We also provide an online data visualization tool (",{"ext-link":1679,":@":1682},[1680],{"#text":1681},"https://data.ohdsi.org/Covid19CharacterizationCharybdisDiagCovid/",{"@_ext-link-type":1178,"@_xlink:href":1681},{"#text":1684},") to demonstrate the consistency and robustness of our outcome definitions across our databases.",{"#text":1312},{"@_id":1687},"s2-5",{"#text":1312},{"sec":1690,":@":1708},[1691,1692,1696,1697,1707],{"#text":1184},{"title":1693},[1694],{"#text":1695},"Study size",{"#text":1184},{"p":1698},[1699,1701,1705],{"#text":1700},"We included all patients meeting the eligibility criteria within each database and hence performed no ",{"italic":1702},[1703],{"#text":1704},"a priori",{"#text":1706}," sample size calculation. Instead, we provided a minimum detectable rate ratio (MDRR) for each target-comparator-outcome triplet across each data source. MDRR is for achieving 5% type-1 error rate and 80% power.",{"#text":1312},{"@_id":1709},"s2-6",{"#text":1312},{"sec":1712,":@":1859},[1713,1714,1718,1719,1759,1760,1772,1773,1838,1839,1858],{"#text":1184},{"title":1715},[1716],{"#text":1717},"Statistical analyses",{"#text":1184},{"p":1720},[1721,1723,1727,1729,1735,1736,1742,1744,1749,1751,1757],{"#text":1722},"To adjust for measured confounding and improve covariate balance between comparison cohorts in a data-driven manner, we built large-scale PS models and fit them ",{"italic":1724},[1725],{"#text":1726},"via",{"#text":1728}," regularized (",{"xref":1730,":@":1733},[1731],{"#text":1732},"ROSENBAUM and RUBIN, 1983",{"@_ref-type":1333,"@_rid":1734},"B18",{"#text":1385},{"xref":1737,":@":1740},[1738],{"#text":1739},"Tian et al., 2018",{"@_ref-type":1333,"@_rid":1741},"B31",{"#text":1743},"). Our large-scale PS models consist of a broad range of pre-defined clinical covariates—including age, gender, race (US data), and other demographics, prior conditions, drug exposures, procedures, and health service utilization behaviors (",{"xref":1745,":@":1748},[1746],{"#text":1747},"Supplementary Table S4",{"@_ref-type":1608,"@_rid":1609},{"#text":1750},")—to allow for the most accurate prediction of treatment and balance cohorts across many characteristics. In particular, including the broad range of covariates gives us an opportunity to control for important confounders, such as baseline blood pressure, that may not have been directly captured by health databases but are associated with other surrogate variables present in the data (",{"xref":1752,":@":1755},[1753],{"#text":1754},"Schuemie et al., 2020",{"@_ref-type":1333,"@_rid":1756},"B25",{"#text":1758},"). For computational efficiency, we excluded all features that occurred in fewer than 0.1% of patients within the target and comparator cohorts prior to PS model fitting.",{"#text":1184},{"p":1761},[1762,1764,1770],{"#text":1763},"In separate analyses, we stratified into 5 PS quintiles or variable-ratio matched patients by PS, and used Cox proportional hazards models to estimate hazard ratios (HRs) between alternative target and comparator treatments for the risk of each outcome in each data source. The regression conditioned on the PS strata/matching-unit with treatment allocation as the sole explanatory variable. We aggregated HR estimates across data sources to produce meta-analytic estimates using a random-effects meta-analysis with inverse-variance weights (",{"xref":1765,":@":1768},[1766],{"#text":1767},"DerSimonian and Laird, 1986",{"@_ref-type":1333,"@_rid":1769},"B5",{"#text":1771},"). To study three outcomes in six data sources (plus one meta-analysis) using two PS-adjustment approaches, we generated 3 x (6 + 1) x 2 = 42 study effects.",{"#text":1184},{"p":1774},[1775,1777,1783,1784,1790,1792,1798,1800,1805,1807,1811,1812,1818,1820,1825,1827,1831,1833,1836],{"#text":1776},"Residual bias often remains in observational studies even after controlling for measured confounding through PS-adjustment (",{"xref":1778,":@":1781},[1779],{"#text":1780},"Schuemie et al., 2014",{"@_ref-type":1333,"@_rid":1782},"B22",{"#text":1385},{"xref":1785,":@":1788},[1786],{"#text":1787},"Schuemie et al., 2016",{"@_ref-type":1333,"@_rid":1789},"B21",{"#text":1791},"). For each study, therefore, we conducted negative control outcome experiments, where the null hypothesis of no effect is believed to be true, using up to 118 controls identified through a data-rich algorithm (",{"xref":1793,":@":1796},[1794],{"#text":1795},"Voss et al., 2017",{"@_ref-type":1333,"@_rid":1797},"B32",{"#text":1799},") and then reviewed by clinicians. We provide the list of these negative control outcomes in ",{"xref":1801,":@":1804},[1802],{"#text":1803},"Supplementary Table S3",{"@_ref-type":1608,"@_rid":1609},{"#text":1806},". The empirical null distributions from these experiments help us detect potential biases and under-conservative uncertainty estimates, thereby allowing us to debias point estimates and adjust confidence intervals (CI) as needed to achieve close to nominal operating characteristics; a more detailed description and demonstration of this calibration process (",{"xref":1808,":@":1810},[1809],{"#text":1780},{"@_ref-type":1333,"@_rid":1782},{"#text":1385},{"xref":1813,":@":1816},[1814],{"#text":1815},"Schuemie et al., 2018",{"@_ref-type":1333,"@_rid":1817},"B23",{"#text":1819},") is provided in the supplement (see ",{"xref":1821,":@":1824},[1822],{"#text":1823},"Supplementary Figure S2",{"@_ref-type":1608,"@_rid":1609},{"#text":1826},", for example). We calibrated each study effect HR estimate, its 95% CI and the ",{"italic":1828},[1829],{"#text":1830},"p",{"#text":1832},"-value to reject the null hypothesis of no differential effect. We declared a HR as significantly different from no effect when the calibrated ",{"italic":1834},[1835],{"#text":1830},{"#text":1837},"-value is less than 0.05, without correcting for multiple testing.",{"#text":1184},{"p":1840},[1841,1843,1849,1851,1857],{"#text":1842},"Blinded to the results, clinicians, and epidemiologists evaluated study diagnostics for these treatment comparisons to assess if they were likely to yield unbiased estimates. The suite of diagnostics included 1) MDRR, 2) distributions of preference score, a transformation of PS that accounts for difference in exposure prevalences, (",{"xref":1844,":@":1847},[1845],{"#text":1846},"Walker et al., 2013",{"@_ref-type":1333,"@_rid":1848},"B33",{"#text":1850},") to evaluate empirical equipoise and population generalizability, 3) extensive patient characteristics to evaluate cohort balance before and after PS-adjustment, and 4) negative control calibration plots to assess residual bias. We defined target and comparator cohorts to stand in empirical equipoise if the majority of patients in both carry preference scores between 0.3 and 0.7 and to achieve sufficient balance if all after-adjustment baseline characteristics return absolute SMD \u003C 0.1 (",{"xref":1852,":@":1855},[1853],{"#text":1854},"Austin, 2009",{"@_ref-type":1333,"@_rid":1856},"B1",{"#text":1416},{"#text":1312},{"@_id":1860},"s2-7",{"#text":1312},{"sec":1863,":@":1903},[1864,1865,1869,1870,1902],{"#text":1184},{"title":1866},[1867],{"#text":1868},"Study execution",{"#text":1184},{"p":1871},[1872,1874,1879,1881,1887,1889,1893,1895,1900],{"#text":1873},"We conducted this study using the open-source OHDSI CohortMethod R package (",{"ext-link":1875,":@":1878},[1876],{"#text":1877},"https://ohdsi.github.io/CohortMethod/",{"@_ext-link-type":1178,"@_xlink:href":1877},{"#text":1880},") with large-scale analytics made possible through the Cyclops R package (",{"xref":1882,":@":1885},[1883],{"#text":1884},"Suchard et al., 2013",{"@_ref-type":1333,"@_rid":1886},"B28",{"#text":1888},"). Start-to-finish open and executable source code is available at: ",{"ext-link":1890,":@":1892},[1891],{"#text":1457},{"@_ext-link-type":1178,"@_xlink:href":1457},{"#text":1894},". To promote transparency and facilitate sharing and exploration of the complete result set, an interactive web application (",{"ext-link":1896,":@":1899},[1897],{"#text":1898},"https://data.ohdsi.org/Covid19SusceptibilityAlphaBlockers/",{"@_ext-link-type":1178,"@_xlink:href":1898},{"#text":1901},") serves up study diagnostics and results for all study effects.",{"#text":1312},{"@_id":1904},"s2-8",{"#text":1315},{"@_sec-type":1907,"@_id":1908},"materials|methods","s2",{"#text":1315},{"sec":1911,":@":6039},[1912,1913,1917,1918,3699,3700,4844,4845,6038],{"#text":1312},{"title":1914},[1915],{"#text":1916},"Results",{"#text":1312},{"sec":1919,":@":3697},[1920,1921,1925,1926,1960,1961,3672,3673,3696],{"#text":1184},{"title":1922},[1923],{"#text":1924},"Baseline characteristics",{"#text":1184},{"p":1927},[1928,1930,1937,1939,1943,1945,1950,1952,1958],{"#text":1929},"We found in total 2,628,170 users of alpha-1 blockers and 464,525 users of alternative BPH therapy—5-alpha reductase inhibitors and phosphodiesterase type 5 inhibitors (5ARI/PDE5)—with diagnosis of BPH, all of whom were included in our propensity score (PS) stratified analyses. For PS matched analysis, 2,426,765 (92.3%) and 463,113 (99.7%) of the subjects could be matched based on their baseline characteristics. ",{"xref":1931,":@":1934},[1932],{"#text":1933},"Table 1",{"@_ref-type":1935,"@_rid":1936},"table","T1",{"#text":1938}," summarizes key socio-demographics, medical history and medicine use for alpha-1 blocker and active comparator users before and after PS stratification and matching. ",{"xref":1940,":@":1942},[1941],{"#text":1933},{"@_ref-type":1935,"@_rid":1936},{"#text":1944}," focuses on OpenClaims and a selected subset of clinical covariates for an illustrative purpose, but ",{"xref":1946,":@":1949},[1947],{"#text":1948},"Supplementary Table S1",{"@_ref-type":1608,"@_rid":1609},{"#text":1951}," provides detailed baseline characteristics for all participants in the six contributing data sources. On average, users of alpha-1 blockers were younger and healthier than users of active comparator medicines. For the most part, PS matching and stratification successfully reduced the differences in baseline characteristics to the negligible level of standardized mean differences (SMD) below 0.1 (",{"xref":1953,":@":1956},[1954],{"#text":1955},"Figure 2",{"@_ref-type":1466,"@_rid":1957},"F2",{"#text":1959},"). Due to the relatively small cohort size, PS matching and stratification were less successful in CUIMC. A few covariates remained imbalanced (SMD > 0.1) after PS stratification in SIDIAP and Optum EHR. Except for these cases, no substantial differences in baseline characteristics remained after PS matching and stratification.",{"#text":1184},{"table-wrap":1962,":@":3671},[1963,1964,1968,1969,1977,1978,3670],{"#text":1169},{"label":1965},[1966],{"#text":1967},"TABLE 1",{"#text":1169},{"caption":1970},[1971,1972,1976],{"#text":1210},{"p":1973},[1974],{"#text":1975},"Baseline patient characteristics for alpha-1 blocker and 5ARI/PDE5 user cohorts in the OpenClaims data source. For each target (T) and comparator (C) cohort, we report the proportion of initiators satisfying selected base-line characteristics and the standardized mean difference (SMD) between the two cohorts before and after stratification. The smaller SMDs after propensity score adjustment demonstrates improved balance between the two cohorts.",{"#text":1169},{"#text":1169},{"table":1979},[1980,1981,2086,2087,3669],{"#text":1210},{"thead":1982,":@":2084},[1983,1985,2000,2001,2022,2023,2042,2043,2083],{"#text":1984},"\n              ",{"tr":1986},[1987,1989,1993,1994,1999],{"#text":1988},"\n                ",{"th":1990,":@":1991},[],{"@_align":1992},"left",{"#text":1988},{"th":1995,":@":1998},[1996],{"#text":1997},"Open claims",{"@_colspan":475,"@_align":1992},{"#text":1984},{"#text":1984},{"tr":2002},[2003,2004,2009,2010,2015,2016,2021],{"#text":1988},{"th":2005,":@":2008},[2006],{"#text":2007},"Characterstics",{"@_align":1992},{"#text":1988},{"th":2011,":@":2014},[2012],{"#text":2013},"Before stratification",{"@_colspan":1018,"@_align":1992},{"#text":1988},{"th":2017,":@":2020},[2018],{"#text":2019},"After stratification",{"@_colspan":1018,"@_align":1992},{"#text":1984},{"#text":1984},{"tr":2024},[2025,2026,2029,2030,2041],{"#text":1988},{"th":2027,":@":2028},[],{"@_align":1992},{"#text":1988},{"th":2031,":@":2040},[2032,2034,2038],{"#text":2033},"\n                  ",{"italic":2035},[2036],{"#text":2037},"N",{"#text":2039}," = 1,995,594 (T) and 366,734 (C)",{"@_colspan":475,"@_align":1992},{"#text":1984},{"#text":1984},{"tr":2044},[2045,2046,2049,2050,2055,2056,2061,2062,2067,2068,2072,2073,2077,2078,2082],{"#text":1988},{"th":2047,":@":2048},[],{"@_align":1992},{"#text":1988},{"th":2051,":@":2054},[2052],{"#text":2053},"T (%)",{"@_align":1992},{"#text":1988},{"th":2057,":@":2060},[2058],{"#text":2059},"C (%)