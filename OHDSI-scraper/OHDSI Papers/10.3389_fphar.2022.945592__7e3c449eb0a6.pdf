{"#text":2443},{"@_align":1992},{"#text":1988},{"td":5473,":@":5476},[5474],{"#text":5475},"5.92",{"@_align":1992},{"#text":1988},{"td":5479,":@":5482},[5480],{"#text":5481},"(0.51–68.2)",{"@_align":1992},{"#text":1988},{"td":5485,":@":5488},[5486],{"#text":5487},"0.16",{"@_align":1992},{"#text":1984},{"#text":1984},{"tr":5492},[5493,5494,5498,5499,5504,5505,5510,5511,5516,5517,5522,5523,5528,5529,5534],{"#text":1988},{"td":5495,":@":5497},[5496],{"#text":4141},{"@_align":1992},{"#text":1988},{"td":5500,":@":5503},[5501],{"#text":5502},"1.08",{"@_valign":2085,"@_align":1992},{"#text":1988},{"td":5506,":@":5509},[5507],{"#text":5508},"(0.91–1.28)",{"@_align":1992},{"#text":1988},{"td":5512,":@":5515},[5513],{"#text":5514},"0.38",{"@_align":1992},{"#text":1988},{"td":5518,":@":5521},[5519],{"#text":5520},"1.05",{"@_align":1992},{"#text":1988},{"td":5524,":@":5527},[5525],{"#text":5526},"(0.90–1.24)",{"@_align":1992},{"#text":1988},{"td":5530,":@":5533},[5531],{"#text":5532},"0.53",{"@_align":1992},{"#text":1984},{"#text":1984},{"tr":5537},[5538,5539,5543,5544,5548,5549,5554,5555,5559,5560,5565,5566,5571,5572,5577],{"#text":1988},{"td":5540,":@":5542},[5541],{"#text":4215},{"@_align":1992},{"#text":1988},{"td":5545,":@":5547},[5546],{"#text":5060},{"@_valign":2085,"@_align":1992},{"#text":1988},{"td":5550,":@":5553},[5551],{"#text":5552},"(0.43–0.94)",{"@_align":1992},{"#text":1988},{"td":5556,":@":5558},[5557],{"#text":2461},{"@_align":1992},{"#text":1988},{"td":5561,":@":5564},[5562],{"#text":5563},"0.77",{"@_align":1992},{"#text":1988},{"td":5567,":@":5570},[5568],{"#text":5569},"(0.49–1.22)",{"@_align":1992},{"#text":1988},{"td":5573,":@":5576},[5574],{"#text":5575},"0.26",{"@_align":1992},{"#text":1984},{"#text":1984},{"tr":5580},[5581,5582,5586,5587,5591,5592,5597,5598,5602,5603,5608,5609,5614,5615,5620],{"#text":1988},{"td":5583,":@":5585},[5584],{"#text":4291},{"@_align":1992},{"#text":1988},{"td":5588,":@":5590},[5589],{"#text":4551},{"@_valign":2085,"@_align"