><!--[--><!--]--><!--[--><span class="References__surname">Veronesi</span><!--]--><!--[--><!--]--><!--[--><span class="References__givenNames">G.</span><!--]--><!--[--><!--]--></span><!--]--><!--[--><!--]--><!--[--><span class="ReferencesList_etal">et al</span><!--]--><!--[--><!--]--></span><!--]--> (<!--[--><!--[--><!--[-->2021<!--]--><!--]--><!--]-->). <!--[--><!--[--><!--[-->The chronic use of multiple photosensitizing drugs is associated with breslow thickness in female melanoma patients: A bicentric retrospective study<!--]--><!--]--><!--]-->. <!--[--><i class="References__source">J. Am. Acad. Dermatol.</i><!--]--><!--[--><!--[--><!--[-->84<!--]--><!--]--><!--]-->, <!--[--><!--[--><!--[-->1762<!--]--><!--]--><!--]-->–<!--[--><!--[--><!--[-->1764<!--]--><!--]--><!--]-->. <!--[--><!--[--><!--[-->10.1016/j.jaad.2020.11.050<!--]--><!--]--><!--]--><!--]--><!--]--><!--]--></p><ul class="References__links"><!----><li class="References__links__item"><a href="https://doi.org/10.1016/j.jaad.2020.11.050" target="_blank" data-event="articleReference-a-crossRef">CrossRef </a></li><li class="References__links__item"><a href="http://scholar.google.com/scholar_lookup?author=E..%2BDika&amp;author=S..%2BMaestroeni&amp;author=M..%2BLambertini&amp;author=F..%2BScarfi&amp;author=A..%2BPatrizi&amp;author=G..%2BVeronesi&amp;publication_year=2021&amp;title=The%2Bchronic%2Buse%2Bof%2Bmultiple%2Bphotosensitizing%2Bdrugs%2Bis%2Bassociated%2Bwith%2Bbreslow%2Bthickness%2Bin%2Bfemale%2Bmelanoma%2Bpatients%3A%2BA%2Bbicentric%2Bretrospective%2Bstudy&amp;journal=J.+Am.+Acad.+Dermatol.&amp;volume=84&amp;pages=1762-1764" target="_blank" data-event="articleReference-a-googleScholar">Google Scholar</a></li></ul></div></li><li class="References__item" id="B3"><div class="References__label"><p>3</p></div><div class="References__content"><p class="notranslate"><!--[--><!--[--><!--[--><!--[--><!--]--><!--[--><span person-group-type="author" class="References__personGroup"><!--[--><!--]--><!--[--><span class="References__name"><!--[--><!--]--><!--[--><span class="References__surname">Doherty</span><!--]--><!--[--><!--]--><!--[--><span class="References__givenNames">V. R.</span><!--]--><!--[--><!--]--></span><!--]--><!--[--><!--]--><!--[--><span class="References__name"><!--[--><!--]--><!--[--><span class="References__surname">Brewster</span><!--]--><!--[--><!--]--><!--[--><span class="References__givenNames">D. H.</span><!--]--><!--[--><!--]--></span><!--]--><!--[--><!--]--><!--[--><span class="References__name"><!--[--><!--]--><!--[--><span class="References__surname">Jensen</span><!--]--><!--[--><!--]--><!--[--><span class="References__givenNames">S.</span><!--]--><!--[--><!--]--></span><!--]--><!--[--><!--]--><!--[--><span class="References__name"><!--[--><!--]--><!--[--><span class="References__surname">Gorman</span><!--]--><!--[--><!--]--><!--[--><span class="References__givenNames">D.</span><!--]--><!--[--><!--]--></span><!--]--><!--[--><!--]--></span><!--]--> (<!--[--><!--[--><!--[-->2010<!--]--><!--]--><!--]-->). <!--[--><!--[--><!--[-->Trends in skin cancer incidence by socioeconomic position in Scotland, 1978-2004<!--]--><!--]--><!--]-->. <!--[--><i class="References__source">Br. J. Cancer</i><!--]--><!--[--><!--[--><!--[-->102<!--]--><!--]--><!--]-->, <!--[--><!--[--><!--[-->1661<!--]--><!--]--><!--]-->–<!--[--><!--[--><!--[-->1664<!--]--><!--]--><!--]-->. <!--[--><!--[--><!--[-->10.1038/sj.bjc.6605678<!--]--><!--]--><!--]--><!--]--><!--]--><!--]--></p><ul class="References__links"><!----><li class="References__links__item"><a href="https://doi.org/10.1038/sj.bjc.6605678" target="_blank" data-event="articleReference-a-crossRef">CrossRef </a></li><li class="References__links__item"><a href="http://scholar.google.com/scholar_lookup?author=V.%2BR..%2BDoherty&amp;author=D.%2BH..%2BBrewster&amp;author=S..%2BJensen&amp;author=D..%2BGorman&amp;publication_year=2010&amp;title=Trends%2Bin%2Bskin%2Bcancer%2Bincidence%2Bby%2Bsocioeconomic%2Bposition%2Bin%2BScotland%2C%2B1978-2004&amp;journal=Br.+J.+Cancer&amp;volume=102&amp;pages=1661-1664" target="_blank" data-event="articleReference-a-googleScholar">Google Scholar</a></li></ul></div></li><li class="References__item" id="B4"><div class="References__label"><p>4</p></div><div class="References__content"><p class="notranslate"><!--[--><!--[--><!--[--><!--[--><!--]--><!--[--><span person-group-type="author" class="References__personGroup"><!--[--><!--]--><!--[--><span class="References__name"><!--[--><!--]--><!--[--><span class="References__surname">Domínguez-Berjón</span><!--]--><!--[--><!--]--><!--[--><span class="References__givenNames">M. F.</span><!--]--><!--[--><!--]--></span><!--]--><!--[--><!--]--><!--[--><span class="References__name"><!--[--><!--]--><!--[--><span class="References__surname">Borrell</span><!--]--><!--[--><!--]--><!--[--><span class="References__givenNames">C.</span><!--]--><!--[--><!--]--></span><!--]--><!--[--><!--]--><!--[--><span class="References__name"><!--[--><!--]--><!--[--><span class="References__surname">Cano-Serral</span><!--]--><!--[--><!--]--><!--[--><span class="References__givenNames">G.</span><!--]--><!--[--><!--]--></span><!--]--><!--[--><!--]--><!--[--><span class="References__name"><!--[--><!--]--><!--[--><span class="References__surname">Esnaola</span><!--]--><!--[--><!--]--><!--[--><span class="References__givenNames">S.</span><!--]--><!--[--><!--]--></span><!--]--><!--[--><!--]--><!--[--><span class="References__name"><!--[--><!--]--><!--[--><span class="References__surname">Nolasco</span><!--]--><!--[--><!--]--><!--[--><span class="References__givenNames">A.</span><!--]--><!--[--><!--]--></span><!--]--><!--[--><!--]--><!--[--><span class="References__name"><!--[--><!--]--><!--[--><span class="References__surname">Pasarin</span><!--]--><!--[--><!--]--><!--[--><span class="References__givenNames">M. I.</span><!--]--><!--[--><!--]--></span><!--]--><!--[--><!--]--><!--[--><span class="ReferencesList_etal">et al</span><!--]--><!--[--