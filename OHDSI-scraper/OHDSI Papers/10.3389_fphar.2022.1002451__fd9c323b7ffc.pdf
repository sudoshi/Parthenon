nNumber":605,"type":616},"1002451/publishers-proof/pdf",{"code":613,"name":613},{"name":618,"fileServerPackageEntryId":619,"fileServerId":611,"fileServerVersionNumber":605,"type":620},"fphar-13-1002451.xml","fphar-13-1002451-r1/fphar-13-1002451.xml",{"code":621,"name":622},"NLM_XML","XML",{"name":624,"fileServerPackageEntryId":19,"fileServerId":625,"fileServerVersionNumber":374,"type":626},"Provisional PDF.pdf","1002451/provisional-pdf",{"code":613,"name":613},"v4",{"title":629,"link":630,"meta":634,"script":768},"Frontiers | Flecainide and risk of skin neoplasms: Results of a large nested case–control study in Spain and Denmark",[631],{"rel":632,"href":633},"canonical","https://www.frontiersin.org/journals/pharmacology/articles/10.3389/fphar.2022.1002451/full",[635,638,641,643,646,650,653,657,660,663,666,668,670,672,674,676,679,682,684,687,690,692,695,698,701,704,707,711,715,718,721,724,726,729,732,735,738,741,743,746,749,752,755,758,760,763,765],{"hid":636,"property":636,"name":636,"content":637},"description","Background: A previous study in Denmark suggested an increased melanoma risk associated with the use of flecainide.Objective: To study the association betwee...",{"hid":639,"property":639,"name":640,"content":629},"og:title","title",{"hid":642,"property":642,"name":636,"content":637},"og:description",{"hid":644,"name":644,"content":645},"keywords","Case control,Flecainide,Skin neoplasm,database,Melanoma",{"hid":647,"property":647,"name":648,"content":649},"og:site_name","site_name","Frontiers",{"hid":651,"property":651,"name":367,"content":652},"og:image","https://images-provider.frontiersin.org/api/ipx/w=1200&f=png/https://www.frontiersin.org/files/Articles/1002451/fphar-13-1002451-HTML-r1/image_m/fphar-13-1002451-t001.jpg",{"hid":654,"property":654,"name":655,"content":656},"og:type","type","article",{"hid":658,"property":658,"name":659,"content":633},"og:url","url",{"hid":661,"name":661,"content":662},"twitter:card","summary_large_image",{"hid":664,"name":664,"content":665},"citation_volume","13",{"hid":667,"name":667,"content":119},"citation_journal_title",{"hid":669,"name":669,"content":649},"citation_publisher",{"hid":671,"name":671,"content":586},"citation_journal_abbrev",{"hid":673,"name":673,"content":587},"citation_issn",{"hid":675,"name":675,"content":465},"citation_doi",{"hid":677,"name":677,"content":678},"citation_firstpage","1002451",{"hid":680,"name":680,"content":681},"citation_language","English",{"hid":683,"name":683,"content":466},"citation_title",{"hid":685,"name":685,"content":686},"citation_keywords","Case control; Flecainide; Skin neoplasm; database; Melanoma",{"hid":688,"name":688,"content":689},"citation_abstract","Background: A previous study in Denmark suggested an increased melanoma risk associated with the use of flecainide.Objective: To study the association between flecainide use and the risk of melanoma and non-melanoma skin cancer in Spain and Denmark.  Methods: We conducted a multi-database case-control study in (database/study period) Spain (SIDIAP/2005-2017 and BIFAP/ 2007-2017) and Denmark (Danish registries/ 2001-2018). We included incident cases of melanoma or non-melanoma skin cancer (NMSC) aged ≥18 with ≥ 2 years of previous data (≥10 years for Denmark) before the skin cancer and matched them to controls (10:1 by age and sex). We excluded persons with immunosuppression or previous cancer. We defined ever use as any prescription fill and high-use as a cumulative dose of at least 200g (reference: never use). We categorised cumulative dose for dose-response assessment. We used conditional logistic regression to compute ORs (95% CI) adjusted for photosensitising, anti-neoplastic, disease-specific drugs, and comorbidities.Results: The total numbers of melanoma/NMSC cases included were: 7,809/64,230 in SIDIAP, 4,661/31,063 in BIFAP and 27,978/152,821 in Denmark. In Denmark, high use of flecainide was associated with increased adjusted ORs of skin cancer compared with never use [melanoma: OR 1.97 (1.38-2.81); NMSC: OR 1.34 (1.15-1.56)]. In Spain, an association between high use of flecainide and NMSC was also observed [BIFAP: OR 1.42 (1.04-1.93); SIDIAP: OR 1.19 (0.95-1.48)]. There was a non-significant dose-response pattern for melanoma in Denmark and no apparent dose-response pattern for NMSC in any of the three databases. We found similar results for ever-use of flecainide.Conclusions: Flecainide use was associated with an increased risk of melanoma (Denmark only) and NMSC (Denmark and Spain) but without substantial evidence of dose-response patterns. Further studies are needed to assess for possible unmeasured confounders.",{"hid":691,"name":691,"content":474},"citation_article_type",{"hid":693,"name":693,"content":694},"citation_pdf_url","https://public-pages-files-2025.frontiersin.org/journals/pharmacology/articles/10.3389/fphar.2022.1002451/pdf",{"hid":696,"name":696,"content":697},"citation_xml_url","https://public-pages-files-2025.frontiersin.org/journals/pharmacology/articles/10.3389/fphar.2022.1002451/xml",{"hid":699,"name":699,"content":700},"citation_fulltext_world_readable","yes",{"hid":702,"name":702,"content":703},"citation_online_date","2022/11/29",{"hid":705,"name":705,"content":706},"citation_publication_date","2022/12/22",{"hid":708,"name":709,"content":710},"citation_author_0","citation_author","Reyes, Carlen ",{"hid":712,"name":713,"content":714},"citation_author_institution_0","citation_author_institution","Fundació Institut Universitari per a la Recerca a L'Atenció Primària de Salut Jordi Gol i Gurina (IDIAPJGol), Spain",{"hid":716,"name":709,"content":717},"citation_author_1","León-Muñoz, Luz M ",{"hid":719,"name":713,"content":720},"citation_author_institution_1","Delegation for the National Plan on Drugs, Spain",{"hid":722,"name":709,"content":723},"citation_author_2","Pistillo, Andrea ",{"hid":725,"name":713,"content":714},"citation_author_institution_2",{"hid":727,"name":709,"content":728},"citation_author_3","Jóhannesdóttir Schmidt, Sigrún Alba ",{"hid":730,"name":713,"content":731},"citation_author_institution_3","Department of Clinical Epidemiology, Denmark",{"hid":733,"name":709,"content":734},"citation_author_4","Kristensen, Kasper Bruun ",{"hid":736,"name":713,"content":737},"citation_author_institution_4","Clinical Pharmacology, Denmark",{"hid":739,"name":709,"content":740},"citation_author_5","Puente, Diana ",{"hid":742,"name":713,"content":714},"citation_author_institution_5",{"hid":744,"name":709,"content":745},"citation_author_6","LLorente-García, Ana ",{"hid":747,"name":713,"content":748},"citation_author_institution_6","Pharmacoepiemiology and Pharmacovigilance Division, Spain",{"hid":750,"name":709,"content":751},"citation_author_7","Huerta-Álvarez, Consuelo ",{"hid":753,"name":713,"content":754},"citation_author_institution_7","Department of Public Health & Maternal and Child Health, Spain",{"hid":756,"name":709,"content":757},"citation_author_8","Pottegård, Anton ",{"hid":759,"name":713,"content":731},"citation_author_institution_8",{"hid":761,"name":709,"content":762},"citation_author_9","Duarte-Salles, Talita ",{"hid":764,"name":713,"content":714},"citation_author_institution_9",{"hid":766,"name":766,"content":767},"dc.identifier","doi:10.3389/fphar.2022.1002451",[769,772,774,776,778],{"src":770,"body":13,"type":771,"async":13},"https://cdnjs.cloudflare.com/polyfill/v3/polyfill.min.js?features=es6","text/javascript",{"src":773,"body":13,"type":771,"async":13},"https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.1/MathJax.js?config=TeX-MML-AM_CHTML",{"src":775,"body":13,"type":771,"async":13},"https://d1bxh8uas1mnw7.cloudfront.net/assets/altmetric_badges-f0bc9b243ff5677d05460c1eb71834ca998946d764eb3bc244ab4b18ba50d21e.js",{"src":777,"body":13,"type":771,"async":13},"https://api.altmetric.com/v1/doi/10.3389/fphar.2022.1002451?callback=_altmetric.embed_callback&domain=www.frontiersin.org&key=3c130976ca2b8f2e88f8377633751ba1&cache_until=14-15",{"src":779,"body":13,"type":771,"async":13},"https://crossmark-cdn.crossref.org/widget/v2.0/widget.js",{"journal":781,"doi":678,"articleType":474,"title":783,"authors":785,"onBehalfOf":19,"affiliations":814,"authorNotes":842,"publicationDate":910,"acceptedDate":911,"receivedDate":912,"correctedDate":19,"retractedDate":19,"volume":597,"elocationId":464,"permissions":913,"keywords":932,"relatedArticles":947,"abstractContent":948,"bodyContent":1001,"appendixContent":7390,"statements":7391,"references":7524,"otherBackSections":11001,"figures":11002,"toc":16098,"correspondingAuthors":16123},{"title":119,"abbreviation":586,"issn":587,"publisherName":782},"Frontiers Media S.A.",[784],{"#text":466},[786,789,791,793,797,800,803,806,809,811],{"surname":487,"givenNames":486,"suffix":19,"affiliationsIndexes":787,"isCorresponding":351,"equalContrib":351,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":788,"onBehalfOf":19},[374],"https://loop.frontiersin.org/people/1789191/overview",{"surname":495,"givenNames":494,"suffix":19,"affiliationsIndexes":790,"isCorresponding":351,"equalContrib":351,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[605],{"surname":502,"givenNames":501,"suffix":19,"affiliationsIndexes":792,"isCorresponding":351,"equalContrib":351,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[374],{"surname":508,"givenNames":507,"suffix":19,"affiliationsIndexes":794,"isCorresponding":351,"equalContrib":351,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[795,796],3,4,{"surname":518,"givenNames":517,"suffix":19,"affiliationsIndexes":798,"isCorresponding":351,"equalContrib":351,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[799],5,{"surname":525,"givenNames":524,"suffix":19,"affiliationsIndexes":801,"isCorresponding":351,"equalContrib":351,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[374,802],6,{"surname":533,"givenNames":532,"suffix":19,"affiliationsIndexes":804,"isCorresponding":351,"equalContrib":351,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[805],7,{"surname":540,"givenNames":539,"suffix":19,"affiliationsIndexes":807,"isCorresponding":351,"equalContrib":351,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[808],8,{"surname":547,"givenNames":546,"suffix":19,"affiliationsIndexes":810,"isCorresponding":351,"equalContrib":351,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[795],{"surname":554,"givenNames":553,"suffix":19,"affiliationsIndexes":812,"isCorresponding":13,"equalContrib":351,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":813,"onBehalfOf":19},[374],"https://loop.frontiersin.org/people/1457612/overview",[815,818,822,826,829,833,836,839],{"index":374,"baseText":19,"institution":491,"country":492,"address":816,"textContent":817},"Barcelona","Fundació Institut Universitari per a la Recerca a L'Atenció Primària de Salut Jordi Gol i Gurina (IDIAPJGol), Barcelona, Spain",{"index":605,"baseText":19,"institution":819,"country":492,"address":820,"textContent":821},"Delegation for the National Plan on Drugs, Ministry of Health","Madrid","Delegation for the National Plan on Drugs, Ministry of Health, Madrid, Spain",{"index":795,"baseText":19,"institution":823,"country":513,"address":824,"textContent":825},"Department of Clinical Epidemiology, Aarhus University Hospital","Aarhus","Department of Clinical Epidemiology, Aarhus University Hospital, Aarhus, Denmark",{"index":796,"baseText":19,"institution":827,"country":513,"address":824,"textContent":828},"Department of Dermatology, Aarhus University Hospital","Department of Dermatology, Aarhus University Hospital, Aarhus, Denmark",{"index":799,"baseText":19,"institution":830,"country":513,"address":831,"textContent":832},"Clinical Pharmacology, Pharmacy, and Environmental Medicine, Institute of Public Health, University of Southern Denmark","Odense","Clinical Pharmacology, Pharmacy, and Environmental Medicine, Institute of Public Health, University of Southern Denmark, Odense, Denmark",{"index":802,"baseText":19,"institution":530,"country":492,"address":834,"textContent":835},"Bellaterra","Universitat Autònoma de Barcelona, Bellaterra, Spain",{"index":805,"baseText":19,"institution":837,"country":492,"address":820,"textContent":838},"Pharmacoepiemiology and Pharmacovigilance Division, Spanish Agency for Medicines and Clinical Devices-AEMPS","Pharmacoepiemiology and Pharmacovigilance Division, Spanish Agency for Medicines and Clinical Devices-AEMPS, Madrid, Spain",{"index":808,"baseText":19,"institution":840,"country":492,"address":820,"textContent":841},"Department of Public Health & Maternal and Child Health, Faculty of Medicine. Complutense University of Madrid-UCM","Department of Public Health & Maternal and Child Health, Faculty of Medicine. Complutense University of Madrid-UCM, Madrid, Spain",{"editedBy":843,"editedByContent":848,"reviewedBy":866,"reviewedByContent":875,"approvedBy":899,"approvedByContent":900,"correspondence":901,"equalContribution":902,"presentAddress":19,"other":903},[844],{"loopId":845,"fullName":846,"textContent":847},"773996","Elisabetta Poluzzi","\r\n            Edited by:\r\n            Elisabetta Poluzzi, University of Bologna, Italy",[849,851,864],{"#text":850},"\n          ",{"p":852},[853,855,862],{"#text":854},"\n            \n            ",{"ext-link":856,":@":858},[857],{"#text":846},{"@_ext-link-type":859,"@_xmlns:xlink":860,"@_xlink:href":861},"uri","http://www.w3.org/1999/xlink","https://loop.frontiersin.org/people/773996/overview",{"#text":863},", University of Bologna, Italy",{"#text":865},"\n        ",[867,871],{"loopId":868,"fullName":869,"textContent":870},"1381439","Emi Dika","\r\n            Reviewed by:\r\n            Emi Dika, University of Bologna, Italy",{"loopId":872,"fullName":873,"textContent":874},"533193","Tanja Mueller","\r\n            Tanja Mueller, University of Strathclyde, United Kingdom",[876,877,886,887,898],{"#text":850},{"p":878},[879,880,885],{"#text":854},{"ext-link":881,":@":883},[882],{"#text":869},{"@_ext-link-type":859,"@_xmlns:xlink":860,"@_xlink:href":884},"https://loop.frontiersin.org/people/1381439/overview",{"#text":863},{"#text":850},{"p":888},[889,891,896],{"#text":890},"\n            ",{"ext-link":892,":@":894},[893],{"#text":873},{"@_ext-link-type":859,"@_xlink:href":895},"https://loop.frontiersin.org/people/533193/overview",{"#text":897},", University of Strathclyde, United Kingdom",{"#text":865},[],[],"*Correspondence: Talita Duarte-Salles, dGR1YXJ0ZUBpZGlhcGpnb2wub3Jn",[],[904,905,909],{"#text":850},{"p":906},[907],{"#text":908},"This article was submitted to Drugs Outcomes Research and Policies, a section of the journal Frontiers in Pharmacology",{"#text":865},"2022-12-22","2022-11-29","2022-07-25",{"copyrightStatement":914,"copyrightYear":915,"copyrightHolder":916,"licenseUrl":917,"licenseText":918},"Copyright © 2022 Reyes, León-Muñoz, Pistillo, Jóhannesdóttir Schmidt, Kristensen, Puente, LLorente-García, Huerta-Álvarez, Pottegård and Duarte-Salles.",2022,"Reyes, León-Muñoz, Pistillo, Jóhannesdóttir Schmidt, Kristensen, Puente, LLorente-García, Huerta-Álvarez, Pottegård and Duarte-Salles","http://creativecommons.org/licenses/by/4.0/",[919,920,931],{"#text":850},{"p":921},[922,924,929],{"#text":923},"This is an open-access article distributed under the terms of the ",{"ext-link":925,":@":928},[926],{"#text":927},"Creative Commons Attribution License (CC BY)",{"@_ext-link-type":859,"@_xlink:href":917},{"#text":930},". The use, distribution or reproduction in other forums is permitted, provided the original author(s) and the copyright owner(s) are credited and that the original publication in this journal is cited, in accordance with accepted academic practice. No use, distribution or reproduction is permitted which does not comply with these terms.",{"#text":865},[933,936,939,942,944],[934],{"#text":935},"case-control studies",[937],{"#text":938},"flecainide",[940],{"#text":941},"skin neoplasm",[943],{"#text":481},[945],{"#text":946},"melanoma",[],[949,950,959,960,969,970,979,980,989,990,999],{"#text":865},{"p":951},[952,953,957],{"#text":850},{"bold":954},[955],{"#text":956},"Background:",{"#text":958}," A previous study in Denmark suggested an increased melanoma risk associated with the use of flecainide.",{"#text":865},{"p":961},[962,963,967],{"#text":850},{"bold":964},[965],{"#text":966},"Objective:",{"#text":968}," To study the association between flecainide use and the risk of melanoma and non-melanoma skin cancer in Spain and Denmark.",{"#text":865},{"p":971},[972,973,977],{"#text":850},{"bold":974},[975],{"#text":976},"Methods:",{"#text":978}," We conducted a multi-database case–control study in (database/study period) Spain (SIDIAP/2005–2017 and BIFAP/2007–2017) and Denmark (Danish registries/2001–2018). We included incident cases of melanoma or non-melanoma skin cancer (NMSC) aged ≥18 with ≥2 years of previous data (≥10 years for Denmark) before the skin cancer and matched them to controls (10:1 by age and sex). We excluded persons with immunosuppression or previous cancer. We defined ever-use as any prescription fill and high-use as a cumulative dose of at least 200 g (reference: never-use). We categorized a cumulative dose for a dose–response assessment. We used conditional logistic regression to compute ORs (95% CI) adjusted for photosensitizing, anti-neoplastic, disease-specific drugs and comorbidities.",{"#text":865},{"p":981},[982,983,987],{"#text":850},{"bold":984},[985],{"#text":986},"Results:",{"#text":988}," The total numbers of melanoma/NMSC cases included were 7,809/64,230 in SIDIAP, 4,661/31,063 in BIFAP, and 27,978/152,821 in Denmark. In Denmark, high-use of flecainide was associated with increased adjusted ORs of skin cancer compared with never-use [melanoma: OR 1.97 (1.38–2.81); NMSC: OR 1.34 (1.15–1.56)]. In Spain, an association between high-use of flecainide and NMSC was also observed [BIFAP: OR 1.42 (1.04–1.93); SIDIAP: OR 1.19 (0.95–1.48)]. There was a non-significant dose–response pattern for melanoma in Denmark and no apparent dose–response pattern for NMSC in any of the three databases. We found similar results for ever-use of flecainide.",{"#text":865},{"p":991},[992,993,997],{"#text":850},{"bold":994},[995],{"#text":996},"Conclusion:",{"#text":998}," Flecainide use was associated with an increased risk of melanoma (Denmark only) and NMSC (Denmark and Spain) but without substantial evidence of dose–response patterns. Further studies are needed to assess for possible unmeasured confounders.",{"#text":1000},"\n      ",[1002,1004,1120,1121,1406,1407,7265,7266,7371,7372,7388],{"#text":1003},"\n    ",{"sec":1005,":@":1118},[1006,1007,1011,1012,1039,1040,1112,1113,1117],{"#text":1000},{"title":1008},[1009],{"#text":1010},"Introduction",{"#text":1000},{"p":1013},[1014,1016,1023,1025,1029,1031,1037],{"#text":1015},"The burden of skin cancer, comprising both melanoma and non-melanoma skin cancer (NMSC), has increased in the past decades (",{"xref":1017,":@":1020},[1018],{"#text":1019},"Saginala et al., 2021",{"@_ref-type":1021,"@_rid":1022},"bibr","B26",{"#text":1024},"). In 2020, estimates from the global statistics (GLOBOCAN) identified 325,000 new cases of melanoma (1.7% of all cancer diagnoses) and positioned melanoma as the most lethal form of skin cancer in the world (",{"xref":1026,":@":1028},[1027],{"#text":1019},{"@_ref-type":1021,"@_rid":1022},{"#text":1030},"). In Europe, the skin cancer incidence is marked by a latitudinal north–south gradient. For example, the annual rate of melanoma decreases from 50 per 100,000 in Denmark to 12 per 100,000 in Spain (",{"xref":1032,":@":1035},[1033],{"#text":1034},"ECIS, 2022",{"@_ref-type":1021,"@_rid":1036},"B7",{"#text":1038},").",{"#text":1000},{"p":1041},[1042,1044,1050,1052,1058,1059,1065,1067,1073,1074,1080,1082,1088,1089,1095,1096,1102,1104,1110],{"#text":1043},"The main risk factor for skin cancer is ultraviolet (UV) light exposure, which may explain the increased skin cancer risk and severity found among users of certain photosensitizing drugs (",{"xref":1045,":@":1048},[1046],{"#text":1047},"Gonçalo et al., 2011",{"@_ref-type":1021,"@_rid":1049},"B12",{"#text":1051},"; ",{"xref":1053,":@":1056},[1054],{"#text":1055},"de Vries et al., 2012",{"@_ref-type":1021,"@_rid":1057},"B1",{"#text":1051},{"xref":1060,":@":1063},[1061],{"#text":1062},"Dika et al., 2021",{"@_ref-type":1021,"@_rid":1064},"B2",{"#text":1066},"). Among these are certain medications used for cardiovascular diseases such as antihypertensives (",{"xref":1068,":@":1071},[1069],{"#text":1070},"Schmidt et al., 2015a",{"@_ref-type":1021,"@_rid":1072},"B29",{"#text":1051},{"xref":1075,":@":1078},[1076],{"#text":1077},"Drucker et al., 2021",{"@_ref-type":1021,"@_rid":1079},"B5",{"#text":1081},") and antiarrhythmics (",{"xref":1083,":@":1086},[1084],{"#text":1085},"Monk, 1995",{"@_ref-type":1021,"@_rid":1087},"B18",{"#text":1051},{"xref":1090,":@":1093},[1091],{"#text":1092},"Hall et al., 2004",{"@_ref-type":1021,"@_rid":1094},"B13",{"#text":1051},{"xref":1097,":@":1100},[1098],{"#text":1099},"Maoz et al., 2009",{"@_ref-type":1021,"@_rid":1101},"B17",{"#text":1103},"). In a hypothesis-generating screening study carried out in Denmark, the use of the classic antiarrhythmic flecainide was associated with a 2-fold increased risk of melanoma (",{"xref":1105,":@":1108},[1106],{"#text":1107},"Pottegård et al., 2016",{"@_ref-type":1021,"@_rid":1109},"B20",{"#text":1111},"), with some evidence of a dose–response pattern.",{"#text":1000},{"p":1114},[1115],{"#text":1116},"Detailed and up-to-date data on the use of flecainide and its relation with skin cancer risk, including both melanoma and NMSC, are not available from Denmark nor from populations in South Europe. Framing skin cancer as a possible adverse effect of flecainide would allow prescribers to reinforce the preventive measures to treated patients. Therefore, the aim of this study was to assess the association between the use of flecainide and the incidence of melanoma and NMSC in adults from Denmark and Spain.",{"#text":1003},{"@_id":1119},"s1",{"#text":1003},{"sec":1122,":@":1403},[1123,1124,1128,1129,1144,1145,1256,1257,1290,1291,1321,1322,1373,1374,1402],{"#text":1000},{"title":1125},[1126],{"#text":1127},"Materials and methods",{"#text":1000},{"sec":1130,":@":1142},[1131,1132,1136,1137,1141],{"#text":865},{"title":1133},[1134],{"#text":1135},"Design",{"#text":865},{"p":1138},[1139],{"#text":1140},"We conducted a nested case–control study, in three databases of two countries, namely the Danish nationwide health registries in Denmark and the SIDIAP and the BIFAP databases in Spain.",{"#text":1000},{"@_id":1143},"s2-1",{"#text":1000},{"sec":1146,":@":1254},[1147,1148,1152,1153,1205,1206,1221,1222,1234,1235,1253],{"#text":865},{"title":1149},[1150],{"#text":1151},"Data sources",{"#text":865},{"p":1154},[1155,1157,1163,1165,1171,1173,1179,1181,1187,1189,1195,1197,1203],{"#text":1156},"In Denmark, we analyzed data gathered from five nationwide registries: the Danish Cancer Registry (",{"xref":1158,":@":1161},[1159],{"#text":1160},"Gjerstorff, 2011",{"@_ref-type":1021,"@_rid":1162},"B11",{"#text":1164},"), the National Prescription Registry (",{"xref":1166,":@":1169},[1167],{"#text":1168},"Pottegård et al., 2017",{"@_ref-type":1021,"@_rid":1170},"B22",{"#text":1172},"), the National Patient Registry (",{"xref":1174,":@":1177},[1175],{"#text":1176},"Schmidt et al., 2015",{"@_ref-type":1021,"@_rid":1178},"B28",{"#text":1180},"), registries on educational level from Statistics Denmark (",{"xref":1182,":@":1185},[1183],{"#text":1184},"Jensen and Rasmussen, 2011",{"@_ref-type":1021,"@_rid":1186},"B15",{"#text":1188},"), and the Civil Registration System (",{"xref":1190,":@":1193},[1191],{"#text":1192},"Schmidt et al., 2014",{"@_ref-type":1021,"@_rid":1194},"B27",{"#text":1196},"). Linkage was achieved using the personal identification number, which is a unique identifier assigned to all Danish residents since 1968 (",{"xref":1198,":@":1201},[1199],{"#text":1200},"Pedersen, 2011",{"@_ref-type":1021,"@_rid":1202},"B19",{"#text":1204},"). Virtually, all medical care in Denmark is supplied by the national health authorities, allowing true population-based register linkage studies covering all legal residents of Denmark.",{"#text":865},{"p":1207},[1208,1210,1214,1216,1220],{"#text":1209},"In Spain, two databases were used: The SIDIAP (",{"italic":1211},[1212],{"#text":1213},"Sistema d’Informació per al Desenvolupament de la Investigació en Atenció Primària",{"#text":1215},") and the BIFAP databases (",{"italic":1217},[1218],{"#text":1219},"Base de Datos para la Investigación Farmacoepidemiológica en Atención Primaria",{"#text":1038},{"#text":865},{"p":1223},[1224,1226,1232],{"#text":1225},"The SIDIAP is a large population-based database that gathers routinely collected anonymized healthcare records from nearly six million people (∼75% of the Catalan population) since 2005 (",{"xref":1227,":@":1230},[1228],{"#text":1229},"Recalde et al., 2022",{"@_ref-type":1021,"@_rid":1231},"B24",{"#text":1233},"). Data include sociodemographic, lifestyle and anthropometric information, clinical diagnosis [International Classification of Diseases 10th revision (ICD-10)], laboratory test results, prescribed and dispensed medications, and hospital referrals, among others.",{"#text":865},{"p":1236},[1237,1239,1244,1246,1252],{"#text":1238},"The BIFAP is a longitudinal population-based database that gathers electronic healthcare anonymized information recorded by general practitioners (GPs) and pediatricians belonging to the National Health System throughout Spain (",{"ext-link":1240,":@":1243},[1241],{"#text":1242},"http://bifap.aemps.es/",{"@_ext-link-type":859,"@_xmlns:xlink":860,"@_xlink:href":1242},{"#text":1245},") since 2001. Nine autonomous regions of Spain currently collaborate in this database providing information on lifestyle factors, clinical events, laboratory test results, specialist referrals, electronic prescriptions, and their dispensations in pharmacies. The BIFAP population is representative of the Spanish population in terms of age and sex. At the time of the study, the database covered a total of 7.8 million patients which represents 49 million person-years of follow-up. The mean follow-up of patients in the database was 6.3 years. The BIFAP database has been extensively described elsewhere (",{"xref":1247,":@":1250},[1248],{"#text":1249},"Maciá-Martínez et al., 2020",{"@_ref-type":1021,"@_rid":1251},"B16",{"#text":1038},{"#text":1000},{"@_id":1255},"s2-2",{"#text":1000},{"sec":1258,":@":1288},[1259,1260,1264,1265,1277,1278,1282,1283,1287],{"#text":865},{"title":1261},[1262],{"#text":1263},"Study population, selection of skin cancer cases, and population control",{"#text":865},{"p":1266},[1267,1269,1275],{"#text":1268},"We included all individuals aged between 18 and 85 years old with an incident diagnosis of melanoma or NMSC between 1 January 2001 and 31 of December 2018, in the Danish Cancer Registry database, between the 1 January 2007 and the 31 December 2017 in the BIFAP database, and between 1 January 2006 and the 31 December 2017 in the SIDIAP database. To ensure sufficient follow-up, we required individuals to be registered for at least two consecutive years in the Spanish databases or to be alive at least 10 years prior to the index data for the Danish registries. Given that immunosuppression may increase the risk of skin cancer (",{"xref":1270,":@":1273},[1271],{"#text":1272},"International Agency for Research on Cancer (IARC), 2012",{"@_ref-type":1021,"@_rid":1274},"B14",{"#text":1276},"), we excluded patients with an HIV diagnosis, an organ transplant (Danish population), and dispensation of azathioprine, cyclosporin, or mycophenolate mofetil. We excluded cases and controls with any previous cancer, except for those with previous NMSC in analyses of melanoma as an outcome (only in Denmark).",{"#text":865},{"p":1279},[1280],{"#text":1281},"In Denmark, we included cases with a histologically verified skin cancer diagnosis in the Danish Cancer Registry using the ICD-10 codes. In SIDIAP, we identified cases through ICD-10-Clinical Modification codes linked to two regional population cancer registries available in Catalonia. In BIFAP, all skin cancer diagnoses were validated using an independent validation process which used a specific algorithm and a natural language processing procedure taking into account comments in the free text to validate the potential cases. All the ATC and ICD codes used to identify the variables are listed in Supplementary Table 1.",{"#text":865},{"p":1284},[1285],{"#text":1286},"We selected controls with risk-set sampling in each database. For each case, we matched to up to 10 controls with the same sex and birth year (± 1 for the Spanish databases). We assigned controls on the same index date as the case to whom they were matched. Subjects were eligible for sampling as controls more than one time before possibly becoming cases. Thereby, the calculated odds ratios (ORs) are direct estimates of the incidence rate ratios (IRRs) that would have emerged from a cohort study in the source population.",{"#text":1000},{"@_id":1289},"s2-3",{"#text":1000},{"sec":1292,":@":1319},[1293,1294,1298,1299,1318],{"#text":865},{"title":1295},[1296],{"#text":1297},"Definition of the exposure to flecainide",{"#text":865},{"p":1300},[1301,1303,1309,1311,1317],{"#text":1302},"We defined ever-use of flecainide as having filled at least one dispensation of flecainide (in BIFAP, we used dispensations unless these were not available in which case prescriptions were selected) before the index date. High-use of flecainide was defined as a cumulative dose of at least 200 g of flecainide (1,000 DDD (",{"xref":1304,":@":1307},[1305],{"#text":1306},"WHO, 2022",{"@_ref-type":1021,"@_rid":1308},"B33",{"#text":1310},")). For the dose–response analyses, we used the following pre-specified categories: ≤19 g, 20–99 g, 100–199 g, 200–399 g, and ≥400 g. In all exposure calculations, we discarded dispensations redeemed during the 2 years before the index date, as recent exposure to flecainide is unlikely to affect skin cancer development and in order to avoid reverse causation (",{"xref":1312,":@":1315},[1313],{"#text":1314},"Pottegård and Hallas, 2017",{"@_ref-type":1021,"@_rid":1316},"B21",{"#text":1038},{"#text":1000},{"@_id":1320},"s2-4",{"#text":1000},{"sec":1323,":@":1371},[1324,1325,1329,1330,1370],{"#text":865},{"title":1326},[1327],{"#text":1328},"Other variables and potential confounders",{"#text":865},{"p":1331},[1332,1334,1340,1341,1345,1346,1352,1354,1360,1362,1368],{"#text":1333},"The list of confounders included comorbid conditions such as diabetes, chronic obstructive pulmonary disease, myocardial infarction (BIFAP and the Danish registries), chronic kidney disease, and alcohol-related disorders (Danish registries), the Charlson Comorbidity Index derived from the prevalence of 14 chronic conditions (SIDIAP and the Danish registries) and related disease-specific drugs, as well as those drugs identified as having photosensitizing properties [retinoids, photosensitizing antibiotics including tetracycline, macrolides, and aminoquinolines, hydrochlorothiazide (Danish registries), amiodarone, and methoxypsoralen/PUVA therapy (",{"xref":1335,":@":1338},[1336],{"#text":1337},"Robinson et al., 2013",{"@_ref-type":1021,"@_rid":1339},"B25",{"#text":1051},{"xref":1342,":@":1344},[1343],{"#text":1070},{"@_ref-type":1021,"@_rid":1072},{"#text":1051},{"xref":1347,":@":1350},[1348],{"#text":1349},"Gallelli et al., 2022",{"@_ref-type":1021,"@_rid":1351},"B10",{"#text":1353},")] or anti-neoplastic effects [aspirin, NSAIDs, oral corticosteroids, and statins (",{"xref":1355,":@":1358},[1356],{"#text":1357},"Friis et al., 2015",{"@_ref-type":1021,"@_rid":1359},"B9",{"#text":1361},")]. We defined drug exposure as at least two prescriptions on separate dates, and the comorbid conditions were selected if registered as primary or secondary discharge or outpatient diagnoses. Other confounders gathered included smoking habits (never, current, and former smokers; only available in SIDIAP and BIFAP) and socioeconomic status defined as the highest education level achieved [basic (10 years), medium (11–13 years), higher (>13 years), or unknown] in the Danish registries or the MEDEA deprivation index in SIDIAP (categorized in quintiles U1 for the least deprived and U5 for the most deprived) (",{"xref":1363,":@":1366},[1364],{"#text":1365},"Domínguez-Berjón et al., 2008",{"@_ref-type":1021,"@_rid":1367},"B4",{"#text":1369},"). For drugs and comorbid conditions, information within 2 years prior to the index date was disregarded.",{"#text":1000},{"@_id":1372},"s2-5",{"#text":1000},{"sec":1375,":@":1400},[1376,1377,1381,1382,1386,1387,1399],{"#text":865},{"title":1378},[1379],{"#text":1380},"Statistical analysis",{"#text":865},{"p":1383},[1384],{"#text":1385},"All analyses followed a conventional matched case–control approach. We computed the frequency and proportion of cases and controls within categories of both flecainide exposure and covariates. We used conditional logistic regression analysis to compute odds ratios (ORs) with 95% confidence intervals (CIs) for the association of NMSC or melanoma with flecainide use adjusted for the predefined potential confounders. In addition to the predefined categories of cumulative use, we carried out a formal dose–response test by restricting to flecainide ever-users and estimating the incremental OR for each 100 g of flecainide using logistic regression while also adjusting for sex, age, and index year. In all analyses, we analyzed NMSC and melanoma separately and never-use of flecainide was the reference group unless stated otherwise. We also calculated adjusted OR according to age (\u003C50, 50–59, 60–74, and 75 +) and sex categories with ever-use as exposure for the Spanish databases and with high-use as exposure for the Danish databases. We performed all the analyses locally and for each database separately. We performed analyses in Stata Release 14.2 (StataCorp, College Station, TX, United States) for the BIFAP database, Stata Release 17.0 (StataCorp, College Station, TX, United States) for the Danish registries, and R version 4.0.3 for SIDIAP.",{"#text":865},{"p":1388},[1389,1391,1397],{"#text":1390},"The study was approved by the Danish Data Protection Agency. According to the Danish law, studies based solely on registered data do not require approval from an ethics review board (",{"xref":1392,":@":1395},[1393],{"#text":1394},"Thygesen et al., 2011",{"@_ref-type":1021,"@_rid":1396},"B31",{"#text":1398},"). We obtained approval for all observational research using SIDIAP data from a local ethics committee (Clinical Research Ethics Committee of the IDIAP Jordi Gol) and for the study in BIFAP from the BIFAP Scientific Committee (Ref #01-2018).",{"#text":1000},{"@_id":1401},"s2-6",{"#text":1003},{"@_sec-type":1404,"@_id":1405},"materials|methods","s2",{"#text":1003},{"sec":1408,":@":7262},[1409,1410,1414,1415,1437,1438,4867,4868,4880,4881,6011,6012,6016,6017,6037,6038,6807,6808,7261],{"#text":1000},{"title":1411},[1412],{"#text":1413},"Results",{"#text":1000},{"p":1416},[1417,1419,1426,1428,1435],{"#text":1418},"The final population included in the study is reported in the ",{"xref":1420,":@":1423},[1421],{"#text":1422},"Supplementary Figures S1 and S2",{"@_ref-type":1424,"@_rid":1425},"sec","s11",{"#text":1427}," (for the Danish and Spanish population, respectively). Baseline characteristics of the cases and controls with and without melanoma and NMSC are reported in ",{"xref":1429,":@":1432},[1430],{"#text":1431},"Table 1",{"@_ref-type":1433,"@_rid":1434},"table","T1",{"#text":1436},". A total of 4,661, 7,809, and 27,978 cases of melanoma and 31,063, 64,230, and 152,821 cases of NMSC and their matched controls were included in the BIFAP, SIDIAP, and Danish registries, respectively. Compared with patients with melanoma, those with NMSC were on average 8–12 years older, were more likely to be men (48% vs. 44%–45%), and had a higher comorbidity burden. The vast majority of patients analyzed had never used flecainide (∼99% of cases); however, among those who did, flecainide was more frequently prescribed among NMSC than melanoma in BIFAP (0.84% vs. 0.60%) and SIDIAP (0.79% vs. 0.50%) and at higher cumulative dosages.",{"#text":1000},{"table-wrap":1439,":@":4865},[1440,1441,1445,1446,1454,1455,4815,4816,4864],{"#text":865},{"label":1442},[1443],{"#text":1444},"TABLE 1",{"#text":865},{"caption":1447},[1448,1449,1453],{"#text":850},{"p":1450},[1451],{"#text":1452},"Characteristics of melanoma and non-melanoma skin cancer cases and matched controls in BIFAP, SIDIAP, and Danish databases.",{"#text":865},{"#text":865},{"table":1456},[1457,1458,1688,1689,4814],{"#text":850},{"thead":1459,":@":1686},[1460,1461,1520,1521,1562,1563,1685],{"#text":890},{"tr":1462},[1463,1465,1469,1470,1476,1477,1481,1482,1487,1488,1492,1493,1507,1508,1519],{"#text":1464},"\n              ",{"th":1466,":@":1467},[],{"@_align":1468},"left",{"#text":1464},{"th":1471,":@":1474},[1472],{"#text":1473},"BIFAP",{"@_colspan":605,"@_align":1475},"center",{"#text":1464},{"th":1478,":@":1480},[1479],{"#text":1473},{"@_colspan":605,"@_align":1475},{"#text":1464},{"th":1483,":@":1486},[1484],{"#text":1485},"SIDIAP",{"@_colspan":605,"@_align":1475},{"#text":1464},{"th":1489,":@":1491},[1490],{"#text":1485},{"@_colspan":605,"@_align":1475},{"#text":1464},{"th":1494,":@":1506},[1495,1497],{"#text":1496},"Danish databases",{"xref":1498,":@":1503},[1499],{"sup":1500},[1501],{"#text":1502},"1",{"@_ref-type":1504,"@_rid":1505},"table-fn","Tfn1",{"@_colspan":605,"@_align":1475},{"#text":1464},{"th":1509,":@":1518},[1510,1512],{"#text":1511},"Danish Databases",{"xref":1513,":@":1517},[1514],{"sup":1515},[1516],{"#text":1502},{"@_ref-type":1504,"@_rid":1505},{"@_colspan":605,"@_align":1475},{"#text":890},{"#text":890},{"tr":1522},[1523,1524,1529,1530,1535,1536,1541,1542,1546,1547,1551,1552,1556,1557,1561],{"#text":1464},{"th":1525,":@":1528},[1526],{"#text":1527},"Subgroup",{"@_rowspan":605,"@_align":1475},{"#text":1464},{"th":1531,":@":1534},[1532],{"#text":1533},"Malignant melanoma",{"@_colspan":605,"@_align":1475},{"#text":1464},{"th":1537,":@":1540},[1538],{"#text":1539},"Non-melanoma skin cancer",{"@_colspan":605,"@_align":1475},{"#text":1464},{"th":1543,":@":1545},[1544],{"#text":1533},{"@_colspan":605,"@_align":1475},{"#text":1464},{"th":1548,":@":1550},[1549],{"#text":1539},{"@_colspan":605,"@_align":1475},{"#text":1464},{"th":1553,":@":1555},[1554],{"#text":1533},{"@_colspan":605,"@_align":1475},{"#text":1464},{"th":1558,":@":1560},[1559],{"#text":1539},{"@_colspan":605,"@_align":1475},{"#text":890},{"#text":890},{"tr":1564},[1565,1566,1577,1578,1588,1589,1598,1599,1608,1609,1618,1619,1628,1629,1638,1639,1648,1649,1654,1655,1664,1665,1674,1675,1684],{"#text":1464},{"th":1567,":@":1576},[1568,1570,1574],{"#text":1569},"Cases, ",{"italic":1571},[1572],{"#text":1573},"N",{"#text":1575},"= 4,661",{"@_align":1475},{"#text":1464},{"th":1579,":@":1587},[1580,1582,1585],{"#text":1581},"Controls, ",{"italic":1583},[1584],{"#text":1573},{"#text":1586},"= 46,610",{"@_align":1475},{"#text":1464},{"th":1590,":@":1597},[1591,1592,1595],{"#text":1569},{"italic":1593},[1594],{"#text":1573},{"#text":1596}," = 31,063",{"@_align":1475},{"#text":1464},{"th":1600,":@":1607},[1601,1602,1605],{"#text":1581},{"italic":1603},[1604],{"#text":1573},{"#text":1606}," = 310,630",{"@_align":1475},{"#text":1464},{"th":1610,":@":1617},[1611,1612,1615],{"#text":1569},{"italic":1613},[1614],{"#text":1573},{"#text":1616}," = 7,809",{"@_align":1475},{"#text":1464},{"th":1620,":@":1627},[1621,1622,1625],{"#text":1581},{"italic":1623},[1624],{"#text":1573},{"#text":1626}," = 75,699",{"@_align":1475},{"#text":1464},{"th":1630,":@":1637},[1631,1632,1635],{"#text":1569},{"italic":1633},[1634],{"#text":1573},{"#text":1636}," = 64,230",{"@_align":1475},{"#text":1464},{"th":1640,":@":1647},[1641,1642,1645],{"#text":1581},{"italic":1643},[1644],{"#text":1573},{"#text":1646}," = 628,767",{"@_align":1475},{"#text":1464},{"th":1650,":@":1653},[1651],{"#text":1652},"Cases, N= 27,978",{"@_align":1475},{"#text":1464},{"th":1656,":@":1663},[1657,1658,1661],{"#text":1581},{"italic":1659},[1660],{"#text":1573},{"#text":1662}," = 279,780",{"@_align":1475},{"#text":1464},{"th":1666,":@":1673},[1667,1668,1671],{"#text":1569},{"italic":1669},[1670],{"#text":1573},{"#text":1672}," = 152,821",{"@_align":1475},{"#text":1464},{"th":1676,":@":1683},[1677,1678,1681],{"#text":1581},{"italic":1679},[1680],{"#text":1573},{"#text":1682}," = 1,528,210",{"@_align":1475},{"#text":890},{"#text":850},{"@_valign":1687},"top",{"#text":850},{"tbody":1690,":@":4813},[1691,1692,1767,1768,1849,1850,1907,1908,1985,1986,2067,2068,2146,2147,2228,2229,2310,2311,2392,2393,2471,2472,2529,2530,2611,2612,2693,2694,2775,2776,2849,2850,2931,2932,2989,2990,3067,3068,3145,3146,3223,3224,3291,3292,3364,3365,3438,3439,3512,3513,3570,3571,3652,3653,3734,3735,3816,3817,3894,3895,3972,3973,4050,4051,4108,4109,4190,4191,4271,4272,4352,4353,4410,4411,4492,4493,4573,4574,4655,4656,4734,4735,4812],{"#text":890},{"tr":1693},[1694,1695,1700,1701,1706,1707,1711,1712,1717,1718,1722,1723,1728,1729,1734,1735,1740,1741,1745,1746,1750,1751,1755,1756,1761,1762,1766],{"#text":1464},{"td":1696,":@":1699},[1697],{"#text":1698},"Age, median (interquartile range)",{"@_align":1475},{"#text":1464},{"td":1702,":@":1705},[1703],{"#text":1704},"61 (48–73)",{"@_align":1475},{"#text":1464},{"td":1708,":@":1710},[1709],{"#text":1704},{"@_align":1475},{"#text":1464},{"td":1713,":@":1716},[1714],{"#text":1715},"73 (63–82)",{"@_align":1475},{"#text":1464},{"td":1719,":@":1721},[1720],{"#text":1715},{"@_align