<tr>
<td align="left" valign="top" rowspan="1" colspan="1">Lowest BMDL pathway</td>
<td align="left" valign="top" rowspan="1" colspan="1">4.3 Xenobiotic Metabolism Signaling</td>
<td align="left" valign="top" rowspan="1" colspan="1">7.7 Aryl Hydrocarbon Signaling</td>
<td align="left" valign="top" rowspan="1" colspan="1">7.9 Xenobiotic Metabolism Signaling</td>
<td align="left" valign="top" rowspan="1" colspan="1">6.9 NRF2-mediated Oxidative Stress Response</td>
<td align="left" valign="top" rowspan="1" colspan="1">18.6 NRF2-mediated Oxidative Stress Response</td>
<td align="left" valign="top" rowspan="1" colspan="1">9 NRF2-mediated Oxidative Stress Response</td>
<td align="left" valign="top" rowspan="1" colspan="1">1 Cell Cycle: G1/S Checkpoint Regulation</td>
<td align="left" valign="top" rowspan="1" colspan="1">3.7 Cell Cycle: G2/M DNA Damage Checkpoint Regulation</td>
<td align="left" valign="top" rowspan="1" colspan="1">7.4 p53 signaling</td>
