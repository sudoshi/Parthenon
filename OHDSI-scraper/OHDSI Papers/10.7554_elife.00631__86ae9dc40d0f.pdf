        data-asset-viewer-width="1435"
        data-asset-viewer-height="1500"
    >
    
      <div class="asset-viewer-inline__header_panel">
          <div class="asset-viewer-inline__header_text">
            <span class="asset-viewer-inline__header_text__prominent">Figure 3</span> with 3 supplements <a href="/articles/00631/figures#fig3" class="asset-viewer-inline__header_link">see all</a>
