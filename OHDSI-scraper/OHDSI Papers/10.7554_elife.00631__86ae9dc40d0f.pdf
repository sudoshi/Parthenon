            </div>
    
      </div>
    
          <figure class="captioned-asset">
          
              <a href="https://iiif.elifesciences.org/lax/00631%2Felife-00631-fig2-v1.tif/full/1500,/0/default.jpg" class="captioned-asset__link" target="_blank" rel="noopener noreferrer">
              <picture class="captioned-asset__picture">
                  <source srcset="https://iiif.elifesciences.org/lax/00631%2Felife-00631-fig2-v1.tif/full/1234,/0/default.webp 2x, https://iiif.elifesciences.org/lax/00631%2Felife-00631-fig2-v1.tif/full/617,/0/default.webp 1x"
                      type="image/webp"
                      >
