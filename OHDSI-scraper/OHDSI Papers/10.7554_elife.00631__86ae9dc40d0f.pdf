        <meta property="og:url" content="https://elifesciences.org/articles/00631">
        <meta property="og:title" content="Stability-mediated epistasis constrains the evolution of an influenza protein">
        <meta name="twitter:site" content="@eLife">

                                                <meta property="og:description" content="Some of the mutations that occur during influenza evolution can only be tolerated in conjunction with other mutations that increase the stability of a viral protein.">
            <meta name="description" content="Some of the mutations that occur during influenza evolution can only be tolerated in conjunction with other mutations that increase the stability of a viral protein.">
        
