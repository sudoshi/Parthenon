        data-asset-viewer-uri="https://iiif.elifesciences.org/lax/00631%2Felife-00631-fig2-v1.tif/full/1500,/0/default.jpg"
        data-asset-viewer-width="1500"
        data-asset-viewer-height="1466"
    >
    
