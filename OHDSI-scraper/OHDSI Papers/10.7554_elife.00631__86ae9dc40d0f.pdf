        <div class="doi__reference-spacing"></div>
      
          <span class="doi">
              <a href="https://doi.org/10.1128/JVI.79.17.11239-11246.2005" class="doi__link">
            https://doi.org/10.1128/JVI.79.17.11239-11246.2005
              </a>
          </span>
      
      
          <ul class="reference__abstracts">
          <li class="reference__abstract">
            <a href="https://scholar.google.com/scholar_lookup?title=Functional+constraints+of+influenza+A+virus+epitopes+limit+escape+from+cytotoxic+T+lymphocytes&amp;author=Berkhoff+EG&amp;author=de+Wit+E&amp;author%5B2%5D=Geelhoed-Mieras+MM&amp;author%5B3%5D=Boon+AC&amp;author%5B4%5D=Symons+J&amp;author%5B5%5D=Fouchier+RA&amp;publication_year=2005&amp;journal=J+Virol&amp;volume=79&amp;pages=pp.+11239%E2%80%9311246" class="reference__abstract_link">Google Scholar</a>
