d align="left">MI (new onset)</td><td align="center">23(5.82)</td><td align="center">6(7.59)</td><td align="center">0.605</td><td align="center">1(1.56)</td><td align="center">0(0.00)</td><td align="center">1.000</td></tr><tr><td align="left">MI (recurrent)</td><td align="center">5(1.27)</td><td align="center">1(1.27)</td><td align="center">1.000</td><td align="center">1(1.56)</td><td align="center">2(3.13)</td><td align="center">1.000</td></tr><tr><td align="left">Stroke</td><td align="center">19(4.81)</td><td align="center">4(5.06)</td><td align="center">1.000</td><td align="center">5(7.81)</td><td align="center">3(4.69)</td><td align="center">0.718</td></tr><tr><td align="left">Stroke, ischemic</td><td align="center">13(3.29)</td><td align="center">3(3.80)</td><td align="center">0.738</td><td align="center">3(4.69)</td><td align="center">3(4.69)</td><td align="center">1.000</td></tr><tr><td align="left">PVD</td><td align="center">1 (0.25)</td><td align="center">1(1.27)</td><td align="center">0.306</td><td align="center">0(0)</td><td align="center">0(0)</td><td align="center">-</td></tr></tbody></table><table-wrap-foot><fn><p>MACCE, major adverse cardiac and cerebrovascular event; MI, myocardial infarction; PVD, peripheral vascular disease</p></fn></table-wrap-foot>
					<br clear='all' />
