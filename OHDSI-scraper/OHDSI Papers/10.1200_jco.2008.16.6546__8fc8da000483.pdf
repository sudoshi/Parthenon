<th colspan="1" rowspan="1" align="center" valign="bottom">10 Years</th>
</tr>
</thead>
<tbody>
<tr>
<td colspan="1" rowspan="1" align="left" valign="top">RT alone</td>
<td colspan="1" rowspan="1" align="center" valign="top">42.8</td>
<td colspan="1" rowspan="1" align="center" valign="top">4</td>
<td colspan="1" rowspan="1" align="center" valign="top">19</td>
<td colspan="1" rowspan="1" align="center" valign="top">34</td>
</tr>
<tr>
<td colspan="1" rowspan="1" align="left" valign="top">Surgery + RT</td>
<td colspan="1" rowspan="1" align="center" valign="top">28.0</td>
<td colspan="1" rowspan="1" align="center" valign="top">3</td>
<td colspan="1" rowspan="1" align="center" valign="top">14</td>
<td colspan="1" rowspan="1" align="center" valign="top">25</td>
</tr>
<tr>
<td colspan="1" rowspan="1" align="left" valign="top">    Any RT</td>
<td colspan="1" rowspan="1" align="center" valign="top">33.6</td>
<td colspan="1" rowspan="1" align="center" valign="top">3</td>
