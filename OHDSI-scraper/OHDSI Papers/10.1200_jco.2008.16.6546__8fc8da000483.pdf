<td colspan="1" rowspan="1" align="center" valign="top">29</td>
</tr>
<tr>
<td colspan="1" rowspan="1" align="left" valign="top">Surgery alone</td>
<td colspan="1" rowspan="1" align="center" valign="top">30.7</td>
<td colspan="1" rowspan="1" align="center" valign="top">3</td>
