            <meta name="citation_title" content="The health care and life sciences community profile for dataset descriptions"><meta name="citation_date" content="2016-08-16"><meta name="citation_doi" content="10.7717/peerj.2331"><meta name="citation_language" content="en"><meta name="citation_pdf_url" content="https://peerj.com/articles/2331.pdf"><meta name="citation_fulltext_html_url" content="https://peerj.com/articles/2331"><meta name="citation_volume" content="4"><meta name="citation_firstpage" content="e2331"><meta name="citation_keywords" content="Data profiling; Dataset descriptions; Metadata; Provenance; FAIR data"><meta name="citation_journal_title" content="PeerJ"><meta name="citation_journal_abbrev" content="PeerJ"><meta name="citation_publisher" content="PeerJ Inc."><meta name="citation_issn" content="2167-8359"><meta name="citation_author" content="Michel Dumontier"><meta name="citation_author_institution" content="Stanford Center for Biomedical Informatics Research, Stanford University, Stanford, CA, United States of America"><meta name="citation_author_email" content="micheldumontier@gmail.com"><meta name="citation_author" content="Alasdair J.G. Gray"><meta name="citation_author_institution" content="Department of Computer Science, Heriot-Watt University, Edinburgh, United Kingdom"><meta name="citation_author_email" content="A.J.G.Gray@hw.ac.uk"><meta name="citation_author" content="M. Scott Marshall"><meta name="citation_author_institution" content="Department of Radiation Oncology (MAASTRO), GROW— School for Oncology and Developmental Biology, MAASTRO Clinic, Maastricht, Netherlands"><meta name="citation_author_email" content="mscottmarshall@gmail.com"><meta name="citation_author" content="Vladimir Alexiev"><meta name="citation_author_institution" content="Ontotext Corporation, Sofia, Bulgaria"><meta name="citation_author" content="Peter Ansell"><meta name="citation_author_institution" content="CSIRO, Australia"><meta name="citation_author" content