<script>
    PeerJ.Com.GoogleTagManager = (function () {
        function enable (){

            var tagManagerAccount = 'GTM-KGDWL2J';

                                    
            (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
                        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
                    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
                    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
            })(window,document,'script','dataLayer',tagManagerAccount);

        }

        function revoke () {
            var cookies = (document.cookie || '').split('; ');
            if (!cookies || cookies.length === 0) return;

            // common domain variants to try
            var domainsToTry = [location.hostname, '.' + location.hostname];
            // optionally add root domain heuristics if you want (see note below)

            var expire = 'Expires=Thu, 01 Jan 1970 00:00:00 GMT; Path=/;';

            cookies.forEach(function(cookie) {
                var eq = cookie.indexOf('=');
                var name = eq > -1 ? cookie.substring(0, eq) : cookie;
                if (name.indexOf('_ga_') === 0) {
                    // try deleting with no domain, with hostname and with .hostname
                    document.cookie = name + '=; ' + expire;
                    domainsToTry.forEach(function(d) {
                        try {
                            document.cookie = name + '=; ' + expire + ' Domain=' + d + '; Path=/;';
                        } catch (e) {
                            // ignore invalid domain formats
                        }
                    });
                }
            });
        }

        function consentToGoogleTagManager ({consent, enableRevoke = false}) {
            if (consent) {
                enable()
            } else if (!consent && enableRevoke) {
                revoke()
            }
        }

        return {
            seekConsent: consentToGoogleTagManager
        }
    })()
</script>


                    
    
    <script>
        // Run through cookieConsent only
        PeerJ.Com.GA = new function() {
            this.disabletracking = function() {
                window['ga-disable-' + 'UA-31208920-1'] = true;

                var cookies = (document.cookie || '').split('; ');
                if (!cookies || cookies.length === 0) return;

                // common domain variants to try
                var domainsToTry = [location.hostname, '.' + location.hostname];
                // optionally add root domain heuristics if you want (see note below)

                var expire = 'Expires=Thu, 01 Jan 1970 00:00:00 GMT; Path=/;';

                cookies.forEach(function(cookie) {
                    var eq = cookie.indexOf('=');
                    var name = eq > -1 ? cookie.substring(0, eq) : cookie;
                    if (name.indexOf('_ga_') === 0 || name.indexof('_gid') || name.indexof('_gat')) {
                        // try deleting with no domain, with hostname and with .hostname
                        document.cookie = name + '=; ' + expire;
                        domainsToTry.forEach(function(d) {
                            try {
                                document.cookie = name + '=; ' + expire + ' Domain=' + d + '; Path=/;';
                            } catch (e) {
                                // ignore invalid domain formats
                            }
                        });
                    }
                });
            };

            this.runGA = function() {
                                (function (i, s, o, g, r, a, m) {
                    i['GoogleAnalyticsObject'] = r;
                    i[r] = i[r] || function () {
                        (i[r].q = i[r].q || []).push(arguments)
                    }, i[r].l = 1 * new Date();
                    a = s.createElement(o),
                        m = s.getElementsByTagName(o)[0];
                    a.async = 1;
                    a.src = g;
                    m.parentNode.insertBefore(a, m)
                })(window, document, 'script', 'https://www.google-analytics.com/analytics.js', 'ga');

                                ga('create', 'UA\u002D31208920\u002D1', 'auto');

                // Removes last octet
                ga('set', 'anonymizeIp', true);

                
                
                                                ga('set', 'dimension4', ';Bioinformatics\u003BTaxonomy\u003BComputational\u0020Science;');
                
                                ga('require', 'displayfeatures');

                                ga('send', 'pageview');

                                                window.setTimeout(function () {
                    ga('send', 'event', 'adjusted bounce rate', 'page visit 15 seconds or more');
                }, 15000);
                
                                
                                            }

            this.seekConsent = function({consent, enableRevoke = false}) {
                if (consent) {
                    this.runGA()
                } else if (enableRevoke && !consent) {
                    this.disabletracking()
                }
            }
        };
    </script>
<script type="text/javascript">
PeerJ.Com.CookieConsent = (function() {
    var debugConsent = false;
    var registeredUser = false;
    var socialAllowCookieName = 'social_allow';
    var analyticsAllowCookieName = 'analytics_allow';
    var socialSettingCookie;
    var analyticsSettingCookie;
    var countryCode = '';
    var sessionReferrer = 'pj-ref';

    var euCountries = {
        'AT': 'Austria',
        'BE': 'Belgium',
        'BG': 'Bulgaria',
        'HR': 'Croatia',
        'CY': 'Cyprus',
        'CZ': 'Czech Republic',
        'DK': 'Denmark',
        'EE': 'Estonia',
        'FI': 'Finland',
        'FR': 'France',
        'DE': 'Germany',
        'GR': 'Greece',
        'HU': 'Hungary',
        'IE': 'Ireland',
        'IT': 'Italy',
        'LV': 'Latvia',
        'LT': 'Lithuania',
        'LU': 'Luxembourg',
        'MT': 'Malta',
        'NL': 'Netherlands',
        'PL': 'Poland',
        'PT': 'Portugal',
        'RO': 'Romania',
        'SK': 'Slovakia',
        'SI': 'Slovenia',
        'ES': 'Spain',
        'SE': 'Sweden',
        'GB': 'United Kingdom'
    };

    var setCountryCookies = function() {
        // Set cookie to do check once every 48 hours
        var expDate = new Date();
        expDate.setHours(expDate.getHours() + 48);

        $.cookie('pj_country_code', 'unknown', { expires: expDate, path: "/"});
        $.cookie('pj_is_eu', 'unknown', { expires: expDate, path: "/"});

        $.ajax({
            type: "GET",
            url: '/x-country/',
            cache: false,
            dataType: "json",
            success: function(data) {
                registeredUser = $.cookie("pj_registered");

                var isEuCode = 'unknown';
                if (data.countryCode) {
                    var dataCountryCode = data.countryCode;

                    if (euCountries.hasOwnProperty(dataCountryCode)) {
                        isEuCode = 'y';
                    } else {
                        isEuCode = 'n';
                    }

                    $.cookie('pj_country_code', dataCountryCode, { expires: expDate, path: "/"});
                    $.cookie('pj_is_eu', isEuCode, { expires: expDate, path: "/"});
                }
            }
        });
    };

    // // Place all analytics within this consent check
    // var runAnalytics = function() {
    //     if (debugConsent) {console.log('running checks');}
    //     var canRunSocial = false;
    //     var canRunAnalytics = false;
    //     var eu = $.cookie("pj_is_eu");
    //
    //     if (eu === 'y') {
    //         // If they are signed up user then they have consented on registration
    //         if (registeredUser) {
    //             canRunSocial = true;
    //             canRunAnalytics = true;
    //         } else {
    //             var social = $.cookie(socialAllowCookieName);
    //             var analytics = $.cookie(analyticsAllowCookieName);
    //
    //             if (social === 'y') {
    //                 canRunSocial = true;
    //             }
    //             if (analytics === 'y') {
    //                 canRunAnalytics = true;
    //             }
    //         }
    //     } else {
    //         canRunSocial = true;
    //         canRunAnalytics = true;
    //     }
    //
    //     if (canRunAnalytics) {
    //         if (debugConsent) {
    //             console.log('loading analytics');
    //         }
    //
    //         if (typeof PeerJ.Com.GA != 'undefined') {
    //             $(PeerJ.Com.GA.runGA());
    //         }
    //
    //         if (typeof PeerJ.Com.GoogleTagManager != 'undefined') {
    //             $(PeerJ.Com.GoogleTagManager.init());
    //         }
    //
    //         // run only if logged out
    //         if (typeof PeerJ.Com.Mixpanel != 'undefined') {
    //             $(PeerJ.Com.Mixpanel.leadView());
    //         }
    //     }
    //
    //     if (canRunSocial) {
    //         if (debugConsent) {
    //             console.log('allowing social cookies');
    //         }
    //
    //         if (typeof PeerJ.Com.Social != 'undefined') {
    //             $(PeerJ.Com.Social.runTwitter());
    //         }
    //     }
    // };

    var init = function() {
        registeredUser = $.cookie("pj_registered");
        if (debugConsent) {console.log(registeredUser);}

        // check if country and eu cookie set
        countryCode = $.cookie("pj_country_code");
        var euCookieSet = $.cookie("pj_is_eu");
        if (!countryCode || !euCookieSet) {
            setCountryCookies();
        }

        if (!$.cookie('pj-ref')) {
            $.cookie('pj-ref', document.referrer, { path: '/' });
        }
    };

    var deleteNonEssentialCookies = function() {
        // 'Privacy first' means whitelisting essential cookies, rather than blacklisting (and potentially missing) third-party cookies
        var essential = [
            "cookieconsent_status",
            "PHPSESSID",
            "meet-new-section-editor",
            "find-your-section-mar2018",
            "pj-dimension",
            "pj-instit",
            "pj-instit-x",
            "pj_country_code",
            "pj_is_eu",
            'pj-ref',
            "pub-offer20102014",
            "peerj_client_id",
            "pj_logout_id",
            "peerj_mp_id",
            "pj_registered",
            "pj_prereg_campaign",
            "pj_prereg_content",
            "pj_prereg_term",
        ];

        // Get document cookies
        var cookies = document.cookie.split(";");
        // Process each cookie
        for (var i = 0; i < cookies.length; i++) {
            var cookie = $.trim(cookies[i]);
            if (debugConsent) {console.log(cookie);}

            // Get the cookie name
            var eqPos = cookie.indexOf("=");
            var name = eqPos > -1 ? cookie.substr(0, eqPos) : cookie;

            // Delete all cookies except those listed in essential
            if (essential === undefined || essential.length === 0 || essential.indexOf(name) === -1) {
                if (debugConsent) {console.log('Deleting cookie: ' + name);}
                document.cookie = name + "=;expires=Thu, 01 Jan 1970 00:00:00 GMT";
            }
        }
    }

    return {
        init: init,
        deleteNonEssentialCookies: deleteNonEssentialCookies,
    }
})()

// $(PeerJ.Com.CookieConsent.init);
</script><script>
    PeerJ.Com.metaPixel = (function () {
        var PIXEL_ID = ''; // keep your templating here

        // Ensure a global manager exists so multiple inclusions won't conflict
        window._fbqManager = window._fbqManager || {
            initializedIds: new Set(),
            consentGranted: false,
            loadingPromise: null
        };

        // Detect whether a fbevents script or a loaded fbq exists
        function isFbeventsPresent() {
            try {
                if (window.fbq && window.fbq.callMethod) return true;
                return !!document.querySelector('script[src*="fbevents.js"]');
            } catch (e) {
                return false;
            }
        }

        // Inject the official-style shim + async load only if needed.
        function injectFbeventsIfNeeded() {
            if (window._fbqManager.loadingPromise) return window._fbqManager.loadingPromise;
            if (isFbeventsPresent()) {
                // Already present or fbq already initialized
                window._fbqManager.loadingPromise = Promise.resolve();
                return window._fbqManager.loadingPromise;
            }

            window._fbqManager.loadingPromise = new Promise(function (resolve, reject) {
                // Minimal safe shim (follows official pattern)
                (function (f, b, e, v, n, t, s) {
                    if (f.fbq) {
                        resolve();
                        return;
                    }
                    n = f.fbq = function () {
                        n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments);
                    };
                    if (!f._fbq) f._fbq = n;
                    n.push = n;
                    n.loaded = true;
                    n.version = '2.0';
                    n.queue = [];
                    t = b.createElement(e);
                    t.async = true;
                    t.src = v;
                    t.id = 'fb-pixel-script';
                    t.addEventListener('load', function () {
                        resolve();
                    });
                    t.addEventListener('error', function (err) {
                        reject(new Error('Failed to load fbevents.js'));
                    });
                    s = b.getElementsByTagName(e)[0];
                    s.parentNode.insertBefore(t, s);
                })(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js');
            });

            return window._fbqManager.loadingPromise;
        }

        // Initialize pixel (only once per ID)
        async function initPixelOnce(pixelId) {
            if (!pixelId) return;
            pixelId = String(pixelId);

            if (window._fbqManager.initializedIds.has(pixelId)) return; // already initialized

            try {
                await injectFbeventsIfNeeded();

                if (window.fbq && window.fbq.callMethod) {
                    // fbq is ready
                    try {
                        fbq('init', pixelId);
                        fbq('track', 'PageView');
                        window._fbqManager.initializedIds.add(pixelId);
                    } catch (e) {
                        console.warn('fbq init/track error', e);
                    }
                } else {
                    // fallback: push to queue on shim
                    window.fbq = window.fbq || function () {
                        window.fbq.callMethod ? window.fbq.callMethod.apply(window.fbq, arguments) : window.fbq.queue.push(arguments);
                    };
                    window.fbq.queue = window.fbq.queue || [];
                    window.fbq('init', pixelId);
                    window.fbq('track', 'PageView');
                    window._fbqManager.initializedIds.add(pixelId);
                }
            } catch (err) {
                console.warn('Failed to load Meta Pixel script:', err);
            }
        }

        // Stop sending events from this manager (we do NOT remove the script)
        function deactivatePixelManager(pixelId) {
            // Remove the id from our initialized list so future calls won't re-init automatically
            if (pixelId) window._fbqManager.initializedIds.delete(String(pixelId));
            // Mark consent false — our wrapper will refuse to send further events.
            window._fbqManager.consentGranted = false;
            location.reload(); // force full page reload to guarantee pixel is deleted
        }

        function consentToMetaPixel({consent, enableRevoke = false}) {
            if (consent && !window._fbqManager.consentGranted) {
                // newly granted
                window._fbqManager.consentGranted = true;

                initPixelOnce(PIXEL_ID);
            } else if (enableRevoke && !consent && window._fbqManager.consentGranted) {
                // revoked
                deactivatePixelManager(PIXEL_ID);
            }
        }

        return {
            seekConsent: consentToMetaPixel,
            initPixelOnce: initPixelOnce,
            deactivatePixelManager: deactivatePixelManager
        }
    })()
</script>


<script type="text/javascript">
    (function () {
        // Main integration with airgap
        window.airgap = window.airgap || {
            ready: function () {
            }
        };

        PeerJ.Com.CookieConsent.init()

        // ↓↓↓↓ PUT YOUR COOKIE ETC. CONSENT IN HERE ↓↓↓↓
        function checkConsent(
                consent = {Advertising: false, Analytics: false, Functional: false},
                enableRevoke = false) {

            /**
             * 1. ensure your service is imported above
             * 2. ensure it provides a `seekConsent` method (see existing services for examples)
             * 3. supply the service name and its consent values in the object below.
             */
            var services = {
                'metaPixel': consent.Advertising && consent.Analytics,
                'GA': consent.Analytics,
                'GoogleTagManager': consent.Analytics,
            }

            var keys = Object.keys(services);
            for (var i = 0; i < keys.length; i++) {
                var key = keys[i];
                var value = services[key];

                try {
                    if (PeerJ.Com.hasOwnProperty(key)) {
                        PeerJ.Com[key].seekConsent({
                            consent: value,
                            enableRevoke: enableRevoke
                        });
                    }
                } catch (e) {
                    console.warn(e);
                }
            }

            if (!consent.Analytics && !consent.Advertising && !consent.Functional) {
                PeerJ.Com.CookieConsent.deleteNonEssentialCookies()
            }
        }

        window.airgap.ready(async function (airgap) {
            try {
                await airgap.sync();
                var consent = await airgap.getConsent();

                checkConsent(consent && consent.purposes)

                try {
                    airgap.addEventListener('consent-change', async function (d) {
                        if (!d || !d.detail || !d.detail.changes) return;

                        // Note: many CMPs send only changed purposes — for robustness, fetch consent again
                        var consent = await airgap.getConsent();

                        checkConsent(consent && consent.purposes, true)

                        // ↓↓↓ MUST GO LAST DO NOT CHECK ANYTHING BELOW THIS SCOPE ↓↓↓
                        if (window._fbqManager) {
                            if (!window._fbqManager.consentGranted) {
                                location.reload()
                            }
                        }
                    });
                } catch (e) {
                    console.warn('airgap addEventListener failed', e);
                }
            } catch (err) {
                console.warn('airgap integration failed', err);
            }
        });
    })();
</script>
    
<script>
    var campaign_keywords = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'];
    var kw = '';
    var lastUtms = {};
    var firstUtms = {};
    var allUtms = {};

    function campaignParams() {
        var index;
        for (index = 0; index < campaign_keywords.length; ++index) {
            kw = getQueryParam(document.URL, campaign_keywords[index]);
            if (kw.length) {
                lastUtms[campaign_keywords[index] + '-last'] = kw;
                firstUtms[campaign_keywords[index] + '-first'] = kw;
                allUtms[campaign_keywords[index] + '-all'] = kw;
            }
        }
    }

    function updatePreregCookie(preregCookie, firstUtmKey) {
        var utmVal = firstUtms[firstUtmKey];
        if (utmVal) {
            var existingPreregCampaign = $.cookie(preregCookie);
            var appendPreregCampaign;
            if (!existingPreregCampaign) {
                appendPreregCampaign = utmVal;
            } else {
                appendPreregCampaign = existingPreregCampaign + ',' + utmVal;

            }
            $.cookie(preregCookie, appendPreregCampaign, {expires: 365, path: "/"});
        }
    }

    function getQueryParam(url, param) {
        // Expects a raw URL
        param = param.replace(/[[]/, "\[").replace(/[]]/, "\]");
        var regexS = "[\?&]" + param + "=([^&#]*)",
                regex = new RegExp( regexS ),
                results = regex.exec(url);
        if (results === null || (results && typeof(results[1]) !== 'string' && results[1].length)) {
            return '';
        } else {
            return decodeURIComponent(results[1]).replace(/\W/gi, ' ');
        }
    }

    function articlePageEvent() {
        var articleContainer = $('.publication-jsondata');
        if (articleContainer.length) {
            var data = articleContainer.data('publication-meta');

            // Must be public
            if (data.publicationSubjects.length) {

                var eventName = 'Viewed-article';
                var preprint = data.preprint;
                if (preprint) {
                    eventName = 'Viewed-preprint';
                }

                data['ip-hash'] = '27c47ff7a4e00f7c856dd99c0ea03899';
                mixpanel.track(eventName, data);
            }
        }
    }

    function sectionListViewEvent() {
            }
</script>










