<th colspan="1" rowspan="1">Male Percentage</th>
<th colspan="1" rowspan="1">Cancer</th>
</tr></thead>
<tbody>
<tr>
<td align="left" colspan="1" rowspan="1">Beyrouti R [<a href="#bib26" class="usa-link" aria-describedby="bib26">26</a>]</td>
<td align="left" colspan="1" rowspan="1">UK</td>
<td align="left" colspan="1" rowspan="1">Europe</td>
<td align="left" colspan="1" rowspan="1">Case Series</td>
<td align="left" colspan="1" rowspan="1">Medical Records</td>
<td align="left" colspan="1" rowspan="1">RT-PCR</td>
<td align="left" colspan="1" rowspan="1">6</td>
<td align="left" colspan="1" rowspan="1">61.0–85.0</td>
<td align="left" colspan="1" rowspan="1">0.83</td>
<td align="left" colspan="1" rowspan="1">2</td>
