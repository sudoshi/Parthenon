<div class="d-panels font-secondary-light">
<div id="aip_a" class="d-panel p" style="display: none">
<div class="p" id="aff1">
<sup><sup>1</sup></sup>Department of Medicine, Stanford University School of Medicine, Stanford, CA</div>
<div id="aff2">
