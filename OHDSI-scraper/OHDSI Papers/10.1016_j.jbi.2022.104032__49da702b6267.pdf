<tr>
<td align="left" valign="top" rowspan="1" colspan="1">&lt;Start&gt;</td>
<td align="left" valign="top" rowspan="1" colspan="1">N/A</td>
<td align="right" valign="top" rowspan="1" colspan="1">23 (100)</td>
