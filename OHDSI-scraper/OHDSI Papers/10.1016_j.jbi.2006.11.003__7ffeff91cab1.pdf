</tr>
<tr>
<td align="right" rowspan="1" colspan="1">0−0.82</td>
<td align="right" rowspan="1" colspan="1">0.18</td>
<td align="right" rowspan="1" colspan="1">182.17</td>
<td align="right" rowspan="1" colspan="1">915.975</td>
<td align="right" rowspan="1" colspan="1">120.557</td>
<td align="right" rowspan="1" colspan="1">0.805</td>
</tr>
<tr>
<td align="right" rowspan="1" colspan="1">0−0.83</td>
<td align="right" rowspan="1" colspan="1">0.17</td>
<td align="right" rowspan="1" colspan="1">162.5</td>
<td align="right" rowspan="1" colspan="1">1006.579</td>
<td align="right" rowspan="1" colspan="1">128.643</td>
<td align="right" rowspan="1" colspan="1">0.803</td>
</tr>
<tr>
<td align="right" rowspan="1" colspan="1">0−0.84</td>
<td align="right" rowspan="1" colspan="1">0.16</td>
<td align="right" rowspan="1" colspan="1">143.94</td>
<td align="right" rowspan="1" colspan="1">1098.479</td>
<td align="right" rowspan="1" colspan="1">136.635</td>
<td align="right" rowspan="1" colspan="1">0.801</td>
</tr>
<tr>
<td align="right" rowspan="1" colspan="1">0−0.85</td>
<td align="right" rowspan="1" colspan="1">0.15</td>
<td align="right" rowspan="1" colspan="1">126.51</td>
<td align="right" rowspan="1" colspan="1">1196.501</td>
<td align="right" rowspan="1" colspan="1">146.363</td>
<td align="right" rowspan="1" colspan="1">0.797</td>
</tr>
<tr>
<td align="right" rowspan="1" colspan="1">0−0.86</td>
<td align="right" rowspan="1" colspan="1">0.14</td>
<td align="right" rowspan="1" colspan="1">110.2</td>
<td align="right" rowspan="1" colspan="1">1303.329</td>
<td align="right" rowspan="1" colspan="1">158.429</td>
<td align="right" rowspan="1" colspan="1">0.793</td>
</tr>
<tr>
<td align="right" rowspan="1" colspan="1">0−0.87</td>
<td align="right" rowspan="1" colspan="1">0.13</td>
<td align="right" rowspan="1" colspan="1">100.3</td>
<td align="right" rowspan="1" colspan="1">1421.675</td>
<td align="right" rowspan="1" colspan="1">173.452</td>
<td align="right" rowspan="1" colspan="1">0.779</td>
</tr>
<tr>
<td align="right" rowspan="1" colspan="1">0−0.88</td>
<td align="right" rowspan="1" colspan="1">0.12</td>
<td align="right" rowspan="1" colspan="1">75.84</td>
<td align="right" rowspan="1" colspan="1">1555.492</td>
<td align="right" rowspan="1" colspan="1">192.473</td>
<td align="right" rowspan="1" colspan="1">0.767</td>
</tr>
<tr>
<td align="right" rowspan="1" colspan="1">0−0.89</td>
<td align="right" rowspan="1" colspan="1">0.11</td>
<td align="right" rowspan="1" colspan="1">68.03</td>
<td align="right" rowspan="1" colspan="1">1708.731</td>
<td align="right" rowspan="1" colspan="1">216.386</td>
<td align="right" rowspan="1" colspan="1">0.748</td>
</tr>
<tr>
<td align="right" rowspan="1" colspan="1">0−0.90</td>
<td align="right" rowspan="1" colspan="1">0.1</td>
<td align="right" rowspan="1" colspan="1">56.22</td>
<td align="right" rowspan="1" colspan="1">1888.114</td>
<td align="right" rowspan="1" colspan="1">247.143</td>
<td align="right" rowspan="1" colspan="1">0.726</td>
</tr>
</tbody>
</table></div>
<div class="p text-right font-secondary"><a href="table/T3/" class="usa-link" target="_blank" rel="noopener noreferrer">Open in a new tab</a></div></section><p id="P62">We then evaluated the disease-finding associations selected respectively by the lower and higher limits of the obtained cutoff range. The results are summarized in <a href="#T4" class="usa-link">Table 4</a>. Among associations selected using the lower limit of the cutoff range, 71.4% were considered to be direct associations, 23.8% to be indirection associations, and 4.8% to be false associations. Among associations selected using the upper limit of the cutoff range, 72.3% were considered to be direct associations, 21.9% to be indirection associations, and 5.8% to be false associations.</p>
<section class="tw xbox font-sm" id="T4"><h4 class="obj_head">Table 4.</h4>
<div class="caption p"><p>Results of the evaluation of the lower and higher limits of the obtained cutoff range</p></div>
<div class="tbl-box p" tabindex="0"><table class="content" frame="box" rules="all">
<thead><tr>
<th align="left" rowspan="1" colspan="1"></th>
<th align="left" rowspan="1" colspan="1">χ<sup>2</sup> cutoff = 110.2</th>
<th align="left" rowspan="1" colspan="1">χ<sup>2</sup> cutoff = 100.3</th>
</tr></thead>
<tbody>
<tr>
<td align="left" rowspan="1" colspan="1">Total</td>
<td align="left" rowspan="1" colspan="1">2,020</td>
<td align="left" rowspan="1" colspan="1">2,193</td>
</tr>
<tr>
<td align="left" rowspan="1" colspan="1">Direct association</td>
<td align="left" rowspan="1" colspan="1">1,442(71.4%)</td>
<td align="left" rowspan="1" colspan="1">1,585 (72.3%)</td>
</tr>
