      $(this)
        .closest('.message')
        .transition('fade');
      setCookie("cookie_consent","essential");
    });

  $('#cookies-essential')
    .on('click', function () {
      $(this)
        .closest('.message')
        .transition('fade');
      setCookie("cookie_consent","essential");
