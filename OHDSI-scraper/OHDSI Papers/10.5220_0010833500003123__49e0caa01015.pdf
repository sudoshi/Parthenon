    <span id="ctl00_MasterPageHeader_SmallMenu_RadButton2" class="RadButton RadButton_Default rbSkinnedButton windowCloseButton LabelAuthorEditor" style="padding: 0px; margin: 0px; float: right;"><input class="rbDecorated" type="submit" name="ctl00$MasterPageHeader$SmallMenu$RadButton2_input" id="ctl00_MasterPageHeader_SmallMenu_RadButton2_input" value="" /><input id="ctl00_MasterPageHeader_SmallMenu_RadButton2_ClientState" name="ctl00_MasterPageHeader_SmallMenu_RadButton2_ClientState" type="hidden" /></span>
    


    
