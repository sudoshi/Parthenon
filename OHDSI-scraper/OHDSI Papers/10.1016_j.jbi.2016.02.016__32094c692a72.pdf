<td align="center" valign="top" rowspan="1" colspan="1">[<a href="#R2" class="usa-link" aria-describedby="R2">2</a>, <a href="#R11" class="usa-link" aria-describedby="R11">11</a>, <a href="#R13" class="usa-link" aria-describedby="R13">13</a>, <a href="#R20" class="usa-link" aria-describedby="R20">20</a>–<a href="#R23" class="usa-link" aria-describedby="R23">23</a>, <a href="#R45" class="usa-link" aria-describedby="R45">45</a>, <a href="#R47" class="usa-link" aria-describedby="R47">47</a>–<a href="#R68" class="usa-link" aria-describedby="R68">68</a>]</td>
<td align="center" valign="top" rowspan="1" colspan="1">[<a href="#R2" class="usa-link" aria-describedby="R2">2</a>, <a href="#R13" class="usa-link" aria-describedby="R13">13</a>, <a href="#R26" class="usa-link" aria-describedby="R26">26</a>, <a href="#R35" class="usa-link" aria-describedby="R35">35</a>, <a href="#R43" class="usa-link" aria-describedby="R43">43</a>, <a href="#R45" class="usa-link" aria-describedby="R45">45</a>, <a href="#R46" class="usa-link" aria-describedby="R46">46</a>, <a href="#R52" class="usa-link" aria-describedby="R52">52</a>, <a href="#R53" class="usa-link" aria-describedby="R53">53</a>, <a href="#R57" class="usa-link" aria-describedby="R57">57</a>, <a href="#R58" class="usa-link" aria-describedby="R58">58</a>, <a href="#R60" class="usa-link" aria-describedby="R60">60</a>, <a href="#R62" class="usa-link" aria-describedby="R62">62</a>–<a href="#R64" class="usa-link" aria-describedby="R64">64</a>, <a href="#R73" class="usa-link" aria-describedby="R73">73</a>–<a href="#R85" class="usa-link" aria-describedby="R85">85</a>]</td>
<td align="center" valign="top" rowspan="1" colspan="1">[<a href="#R9" class="usa-link" aria-describedby="R9">9</a>, <a href="#R89" class="usa-link" aria-describedby="R89">89</a>–<a href="#R93" class="usa-link" aria-describedby="R93">93</a>]</td>
<td align="center" valign="top" rowspan="1" colspan="1">[<a href="#R74" class="usa-link" aria-describedby="R74">74</a>, <a href="#R97" class="usa-link" aria-describedby="R97">97</a>]</td>
