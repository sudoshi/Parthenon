nted code snippet since it's working without it/*shareNavs.forEach(function (shareNav) {shareNav.style.display = 'block';});*/} else {shareNavs.forEach(function (shareNav) {shareNav.style.display = 'hidden';});}let shareNavMob = document.querySelector('#mobile-share-button')if (shareNavMob) {shareNavMob.style.display = 'block';}let hypothesisConfig = document.querySelector('.js-hypothesis-config');if (hypothesisConfig) {if (matchMedia) {var mq = window.matchMedia("(min-width: 1195px)");mq.addListener(WidthChange);WidthChange(mq);}function WidthChange(mq) {// below classes are toggled between mobile and desktopif (mq.matches) {console.log('hypothes.is script has loaded!')var s = document.createElement('script');s.async = true;s.src = 'https://hypothes.is/embed.js';s.id = 'hypothesis-embed-script';document.head.appendChild(s);}}}// let twitterScript = document.createElement('script')twitterScript.id = 'civic-twitter-script'twitterScript.async = 'async'twitterScript.src = 'https://platform.twitter.com/widgets.js'document.body.appendChild(twitterScript);//find all links that start with https://www.youtube.com and extract the parameter v if it exists from the URLlet youtubeLinks = document.querySelectorAll('a[href^="https://www.youtube.com"]');youtubeLinks.forEach(function (link) {let url = new URL(link.href);let videoId = url.searchParams.get("v");if (!videoId) {return false;}//find containing image element with attribute src that contains the videoId if it existslet videoimage = link.querySelector('img[src*="' + videoId + '"]');if (!videoimage) {return false;}//replace the link with the youtube iframe embed linklet iframe = document.createElement("iframe");iframe.width = videoimage.width;iframe.height = videoimage.height;iframe.src = "https://www.youtube.com/embed/" + videoId;iframe.frameborder = "0";iframe.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";iframe.allowFullscreen = true;link.parentNode.replaceChild(iframe, link);});},onRevoke: function () {// remove shareAholiclet shareAholicscript = document.getElementById('civic-shareaholic-script')if (shareAholicscript) {shareAholicscript.remove()}/*let shareNav = document.getElementById('share-nav')if (shareNav) {shareNav.style.display = 'none'} *///if max-width is greater then 843px then run bellow codelet shareNavs = document.querySelectorAll('.share-nav')console.log(window.innerWidth)if(window.innerWidth > 843){shareNavs.forEach(function (shareNav) {shareNav.style.display = 'none';});} else {shareNavs.forEach(function (shareNav) {shareNav.style.display = 'block';});}let shareNavMob = document.querySelector('#mobile-share-button');if (shareNavMob) {shareNavMob.style.display = 'none';}let articleshareNav = document.querySelector('.navbar-nav__item--share')if (articleshareNav) {articleshareNav.style.display = 'none'}//remove hypothesislet hypothesisEmbed = document.querySelector('#hypothesis-embed-script');if (hypothesisEmbed) {hypothesisEmbed.remove();if (document.querySelector('hypothesis-sidebar')) {document.querySelector('hypothesis-sidebar').remove();}}let shareTwitterscript = document.getElementById('civic-twitter-script')if (shareTwitterscript) {shareTwitterscript.remove()}//because removing the script does not remove the twitter timeline, we need to remove it manuallyconst twitterIframe = document.querySelector('.twitter-timeline iframe')if(twitterIframe){twitterIframe.remove();}//find all iframe elements with src starting with "https://www.youtube" and replace them with a corresponding image linklet youtubeIframes = document.querySelectorAll('iframe[src^="https://www.youtube"]');youtubeIframes.forEach(function (iframe) {let videoId = iframe.src.split('/').pop();let img = document.createElement("img");let anchor = document.createElement("a");anchor.href = "https://www.youtube.com/watch?v=" + videoId;img.src = "https://i.ytimg.com/vi/" + videoId + "/hqdefault.jpg";img.width = iframe.width;img.height = iframe.height;iframe.parentNode.replaceChild(anchor, iframe);anchor.appendChild(img);});},thirdPartyCookies: [{name: 'shareAholic',optOutLink: 'https://www.shareaholic.com/privacy/'},{name: 'X',optOutLink: 'https://x.com/settings/account/personalization'},{name: 'YouTube',optOutLink: 'https://support.google.com/youtube/answer/7671399?hl=en'},{name: 'Hypothesis',optOutLink: 'https://web.hypothes.is/privacy/'},{name: 'Google',optOutLink: 'https://policies.google.com/technologies/cookies?hl=en-US'}]}], // Array of objects based on CookieCategory objectposition: 'LEFT',theme: 'DARK'}CookieControl.load(config)</script></body></html>