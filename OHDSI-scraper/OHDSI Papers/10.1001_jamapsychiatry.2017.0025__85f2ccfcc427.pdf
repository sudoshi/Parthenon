<div class="d-panels font-secondary-light">
<div id="aip_a" class="d-panel p" style="display: none">
<div class="p" id="yoi170002aff1">
<sup>1</sup>Department of Psychology, Yale University, New Haven, Connecticut</div>
<div id="yoi170002aff2">
<sup>2</sup>Spring Health, New York City, New York</div>
<div id="yoi170002aff3">
<sup>3</sup>Center for Outcomes Research and Evaluation, Yale–New Haven Hospital, New Haven, Connecticut</div>
