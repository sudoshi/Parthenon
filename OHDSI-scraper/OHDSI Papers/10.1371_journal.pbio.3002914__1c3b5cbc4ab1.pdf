    <form name="searchForm" action="/plosbiology/search" method="get">
      <fieldset>
        <legend>Search</legend>
        <label for="search">Search</label>
        <div class="search-contain">
          <input id="search" type="text" name="q" placeholder="SEARCH" required/>
