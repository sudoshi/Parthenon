liationsIndexes":824,"isCorresponding":331,"equalContrib":331,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":825,"onBehalfOf":19},[821],"http://loop.frontiersin.org/people/941917/overview",{"surname":546,"givenNames":545,"suffix":19,"affiliationsIndexes":827,"isCorresponding":331,"equalContrib":331,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[828],7,{"surname":553,"givenNames":552,"suffix":19,"affiliationsIndexes":830,"isCorresponding":331,"equalContrib":331,"hierarchySymbol":831,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[597],"\r\n            †\r\n          ",[833,836,838,841,843,846,849,852],{"index":356,"baseText":19,"institution":479,"country":480,"address":834,"textContent":835},"Detroit, MI","Department of Ophthalmology, Visual and Anatomical Sciences, School of Medicine, Wayne State University, Detroit, MI, United States",{"index":806,"baseText":19,"institution":500,"country":480,"address":834,"textContent":837},"Department of Biological Sciences, Wayne State University, Detroit, MI, United States",{"index":809,"baseText":19,"institution":507,"country":480,"address":839,"textContent":840},"Ann Arbor, MI","College of Literature, Science, and the Arts, University of Michigan, Ann Arbor, MI, United States",{"index":815,"baseText":19,"institution":521,"country":480,"address":834,"textContent":842},"Class of 2020, School of Medicine, Wayne State University, Detroit, MI, United States",{"index":818,"baseText":19,"institution":528,"country":480,"address":844,"textContent":845},"East Lansing, MI","College of Natural Science, Michigan State University, East Lansing, MI, United States",{"index":821,"baseText":19,"institution":536,"country":480,"address":847,"textContent":848},"Dallas, TX","Retina Foundation of the Southwest, Dallas, TX, United States",{"index":828,"baseText":19,"institution":550,"country":480,"address":850,"textContent":851},"Bethesda, MD","National Eye Institute, National Institutes of Health, Bethesda, MD, United States",{"index":597,"baseText":19,"institution":557,"country":558,"address":853,"textContent":854},"Beijing","Peking Union Medical College, Beijing, China",{"editedBy":856,"editedByContent":859,"reviewedBy":868,"reviewedByContent":871,"approvedBy":878,"approvedByContent":879,"correspondence":880,"equalContribution":881,"presentAddress":19,"other":882},[857],{"textContent":858},"Edited by: Brian Perkins, Cole Eye Institute, United States",[860,862,866],{"#text":861},"\n          ",{"p":863},[864],{"#text":865}," Brian Perkins, Cole Eye Institute, United States",{"#text":867},"\n        ",[869],{"textContent":870},"Reviewed by: Rui Chen, Baylor College of Medicine, United States; Zi-Bing Jin, Capital Medical University, China",[872,873,877],{"#text":861},{"p":874},[875],{"#text":876}," Rui Chen, Baylor College of Medicine, United States; Zi-Bing Jin, Capital Medical University, China",{"#text":867},[],[],"*Correspondence: Shunbin Xu, c3h1QG1lZC53YXluZS5lZHU=",[],[883,884,894,895,896,900],{"#text":861},{"p":885},[886,888,892],{"#text":887},"\n            ",{"sup":889},[890],{"#text":891},"†",{"#text":893},"Present address: Weifeng Li, The Johns Hopkins Predoctoral Training Program in Human Genetics, McKusick-Nathans Institute of Genetic Medicine, School of Medicine, The Johns Hopkins University, Baltimore, MD, United States",{"#text":867},{"#text":861},{"p":897},[898],{"#text":899},"This article was submitted to Signaling, a section of the journal Frontiers in Cell and Developmental Biology",{"#text":867},"2020-12-23","2020-12-07","2020-10-20",{"copyrightStatement":905,"copyrightYear":906,"copyrightHolder":907,"licenseUrl":908,"licenseText":909},"Copyright © 2020 Xu, Coku, Muraleedharan, Harajli, Mishulin, Dahabra, Choi, Garcia, Webb, Birch, Goetz and Li.",2020,"Xu, Coku, Muraleedharan, Harajli, Mishulin, Dahabra, Choi, Garcia, Webb, Birch, Goetz and Li","http://creativecommons.org/licenses/by/4.0/",[910,911,923],{"#text":861},{"p":912},[913,915,921],{"#text":914},"This is an open-access article distributed under the terms of the ",{"ext-link":916,":@":919},[917],{"#text":918},"Creative Commons Attribution License (CC BY)",{"@_ext-link-type":920,"@_xlink:href":908},"uri",{"#text":922},". The use, distribution or reproduction in other forums is permitted, provided the original author(s) and the copyright owner(s) are credited and that the original publication in this journal is cited, in accordance with accepted academic practice. No use, distribution or reproduction is permitted which does not comply with these terms.",{"#text":867},[925,928,931,934,936],[926],{"#text":927},"microRNA",[929],{"#text":930},"miR-183/96/182 cluster",[932],{"#text":933},"inherited retinal dystrophy",[935],{"#text":469},[937],{"#text":470},[],[940,941,945],{"#text":867},{"p":942},[943],{"#text":944},"Inherited retinal dystrophy (IRD) is a heterogenous blinding eye disease and affects more than 200,000 Americans and millions worldwide. By far, 270 protein-coding genes have been identified to cause IRD when defective. However, only one microRNA (miRNA), miR-204, has been reported to be responsible for IRD when a point-mutation occurs in its seed sequence. Previously, we identified that a conserved, polycistronic, paralogous miRNA cluster, the miR-183/96/182 cluster, is highly specifically expressed in all photoreceptors and other sensory organs; inactivation of this cluster in mice resulted in syndromic IRD with multi-sensory defects. We hypothesized that mutations in the miR-183/96/182 cluster in human cause IRD. To test this hypothesis, we perform mutation screening in the pre-miR-183, -96, -182 in >1000 peripheral blood DNA samples of patients with various forms of IRD. We identified six sequence variants, three in pre-miR-182 and three in pre-miR-96. These variants are in the pre-miRNA-182 or -96, but not in the mature miRNAs, and are unlikely to be the cause of the IRD in these patients. In spite of this, the nature and location of these sequence variants in the pre-miRNAs suggest that some may have impact on the biogenesis and maturation of miR-182 or miR-96 and potential roles in the susceptibility to diseases. Although reporting on negative results so far, our study established a system for mutation screening in the miR-183/96/182 cluster in human for a continued effort to unravel and provides deeper insight into the potential roles of miR-183/96/182 cluster in human diseases.",{"#text":946},"\n      ",[948,950,1385,1386,2061,2062,4552,4553,5216,5217,5295,5296,5311,5312,5327,5328,5344],{"#text":949},"\n    ",{"sec":951,":@":1383},[952,953,957,958,1123,1124,1382],{"#text":946},{"title":954},[955],{"#text":956},"Introduction",{"#text":946},{"p":959},[960,962,969,971,977,979,988,990,996,998,1004,1005,1011,1013,1019,1021,1025,1027,1033,1034,1040,1042,1048,1049,1053,1055,1063,1065,1071,1073,1079,1081,1085,1087,1093,1094,1100,1101,1107,1108,1114,1115,1121],{"#text":961},"Inherited retinal dystrophy (IRD) is a heterogeneous blinding eye disease and affects more than 200,000 Americans and millions worldwide (",{"xref":963,":@":966},[964],{"#text":965},"Daiger et al., 2013",{"@_ref-type":967,"@_rid":968},"bibr","B11",{"#text":970},"). Identification of genes that are responsible for IRD when defective is of great importance to the basic understanding as well as development of efficient gene diagnosis and treatment of the disease (",{"xref":972,":@":975},[973],{"#text":974},"Xu, 2015",{"@_ref-type":967,"@_rid":976},"B85",{"#text":978},"). By far, 307 genetic loci are linked to various forms of IRD; among these, 270 protein-coding genes have been identified to cause IRD when defective (RetNet",{"sup":980},[981],{"xref":982,":@":985},[983],{"#text":984},"1",{"@_ref-type":986,"@_rid":987},"fn","footnote1",{"#text":989},". Last updated April 29, 2015). However, the roles of non-coding elements of the genome in IRDs are still not fully investigated, in spite that increasing evidences suggest that non-coding elements are critically important in the regulation of genome structures and expression of protein-coding genes, and that species-specific non-coding elements shape species-specific functions (",{"xref":991,":@":994},[992],{"#text":993},"Lander, 2011",{"@_ref-type":967,"@_rid":995},"B34",{"#text":997},"; ",{"xref":999,":@":1002},[1000],{"#text":1001},"Ulitsky and Bartel, 2013",{"@_ref-type":967,"@_rid":1003},"B73",{"#text":997},{"xref":1006,":@":1009},[1007],{"#text":1008},"Ransohoff et al., 2018",{"@_ref-type":967,"@_rid":1010},"B62",{"#text":1012},"). microRNAs (miRNAs) are endogenous, small, non-coding, regulatory RNAs (",{"xref":1014,":@":1017},[1015],{"#text":1016},"Bartel, 2004",{"@_ref-type":967,"@_rid":1018},"B5",{"#text":1020},"). miRNAs quantitatively regulate gene expression at posttranscriptional levels (",{"xref":1022,":@":1024},[1023],{"#text":1016},{"@_ref-type":967,"@_rid":1018},{"#text":1026},"). Since its discovery in 1993 (",{"xref":1028,":@":1031},[1029],{"#text":1030},"Lee et al., 1993",{"@_ref-type":967,"@_rid":1032},"B36",{"#text":997},{"xref":1035,":@":1038},[1036],{"#text":1037},"Wightman et al., 1993",{"@_ref-type":967,"@_rid":1039},"B81",{"#text":1041},"), miRNAs have been proven to play important roles in normal functions, as well as in diseases when defective (",{"xref":1043,":@":1046},[1044],{"#text":1045},"Ambros, 2004",{"@_ref-type":967,"@_rid":1047},"B2",{"#text":997},{"xref":1050,":@":1052},[1051],{"#text":1016},{"@_ref-type":967,"@_rid":1018},{"#text":1054},"). Based on miRBase Release 22.1 (October, 2018)",{"sup":1056},[1057],{"xref":1058,":@":1061},[1059],{"#text":1060},"2",{"@_ref-type":986,"@_rid":1062},"footnote2",{"#text":1064},", at least 2654 mature miRNAs (1917 precursors) have been identified in humans. In spite of their importance in gene-expression regulation, by far, only one miRNA, miR-204, been identified to cause syndromic IRD with ocular coloboma when a dominant point mutation nt37 C > T in the seed sequence of miR-204 occurred in a large 5-generation family (",{"xref":1066,":@":1069},[1067],{"#text":1068},"Conte et al., 2015",{"@_ref-type":967,"@_rid":1070},"B10",{"#text":1072},"). The seed sequence of a miRNA is one of the most important determinants of the downstream target genes and, therefore, functions of the miRNA (",{"xref":1074,":@":1077},[1075],{"#text":1076},"Lewis et al., 2003",{"@_ref-type":967,"@_rid":1078},"B38",{"#text":1080},"). The nt37 C > T mutation results in both gain-of-function and loss-of-function effects, because this mutation in the seed sequence creates abnormal target genes that wild type miR-204 does not regulate, meanwhile loses control of many downstream target genes that miR-204 normally targets (",{"xref":1082,":@":1084},[1083],{"#text":1068},{"@_ref-type":967,"@_rid":1070},{"#text":1086},"). However, no mutations in other miRNAs have been identified to cause IRD in human, although increasing evidences suggest that miRNAs are required for the normal development and functions of photoreceptors and the retina as a whole (",{"xref":1088,":@":1091},[1089],{"#text":1090},"Sanuki et al., 2011",{"@_ref-type":967,"@_rid":1092},"B67",{"#text":997},{"xref":1095,":@":1098},[1096],{"#text":1097},"Lumayag et al., 2013",{"@_ref-type":967,"@_rid":1099},"B44",{"#text":997},{"xref":1102,":@":1105},[1103],{"#text":1104},"Busskamp et al., 2014",{"@_ref-type":967,"@_rid":1106},"B7",{"#text":997},{"xref":1109,":@":1112},[1110],{"#text":1111},"Sundermeier et al., 2014",{"@_ref-type":967,"@_rid":1113},"B70",{"#text":997},{"xref":1116,":@":1119},[1117],{"#text":1118},"Aldunate et al., 2019",{"@_ref-type":967,"@_rid":1120},"B1",{"#text":1122},").",{"#text":946},{"p":1125},[1126,1128,1134,1135,1141,1142,1148,1149,1155,1156,1162,1163,1167,1169,1173,1175,1181,1183,1189,1191,1195,1196,1200,1201,1207,1208,1214,1216,1220,1221,1225,1227,1231,1233,1237,1238,1242,1244,1248,1249,1255,1256,1262,1264,1270,1272,1276,1278,1284,1286,1292,1294,1298,1300,1304,1306,1310,1312,1316,1318,1322,1323,1329,1330,1336,1338,1344,1346,1350,1351,1357,1358,1364,1366,1370,1372,1380],{"#text":1127},"Previously, we and others identified a conserved, paralogous, polycistronic miRNA cluster, the miR-183/96/182 cluster (hereafter referred to as miR-183/96/182), which is contained within 4 kilo bases (kb) on mouse chromosome 6qA3 with conservation of synteny to human chromosome 7q32.2 and is highly specifically expressed in all sensory organs (",{"xref":1129,":@":1132},[1130],{"#text":1131},"Lagos-Quintana et al., 2003",{"@_ref-type":967,"@_rid":1133},"B33",{"#text":997},{"xref":1136,":@":1139},[1137],{"#text":1138},"Wienholds et al., 2005",{"@_ref-type":967,"@_rid":1140},"B80",{"#text":997},{"xref":1143,":@":1146},[1144],{"#text":1145},"Kloosterman et al., 2006",{"@_ref-type":967,"@_rid":1147},"B28",{"#text":997},{"xref":1150,":@":1153},[1151],{"#text":1152},"Weston et al., 2006",{"@_ref-type":967,"@_rid":1154},"B79",{"#text":997},{"xref":1157,":@":1160},[1158],{"#text":1159},"Xu et al., 2007",{"@_ref-type":967,"@_rid":1161},"B86",{"#text":997},{"xref":1164,":@":1166},[1165],{"#text":1097},{"@_ref-type":967,"@_rid":1099},{"#text":1168},"). Member of miR-183/96/182 share high sequence homology and overlapping downstream genes and, therefore, functions (",{"xref":1170,":@":1172},[1171],{"#text":1159},{"@_ref-type":967,"@_rid":1161},{"#text":1174},"). Consistent with their high-level specific expression in sensory organs, point mutations of miR-96 result in progressive, non-syndromic hearing loss in both human (",{"xref":1176,":@":1179},[1177],{"#text":1178},"Mencia et al., 2009",{"@_ref-type":967,"@_rid":1180},"B48",{"#text":1182},") and mouse (",{"xref":1184,":@":1187},[1185],{"#text":1186},"Lewis et al., 2009",{"@_ref-type":967,"@_rid":1188},"B39",{"#text":1190},"), with no apparent retinal phenotype, suggesting that miR-96 plays a predominant role in the inner ear, but not in retina (",{"xref":1192,":@":1194},[1193],{"#text":1186},{"@_ref-type":967,"@_rid":1188},{"#text":997},{"xref":1197,":@":1199},[1198],{"#text":1178},{"@_ref-type":967,"@_rid":1180},{"#text":997},{"xref":1202,":@":1205},[1203],{"#text":1204},"Li et al., 2010",{"@_ref-type":967,"@_rid":1206},"B40",{"#text":997},{"xref":1209,":@":1212},[1210],{"#text":1211},"Kuhn et al., 2011",{"@_ref-type":967,"@_rid":1213},"B32",{"#text":1215},") and that members of miR-183/96/182 have distinct roles in different tissues/organs. In adult mouse retina, miR-183/96/182 is mainly expressed in all photoreceptors and a subgroup of ganglion cells. Members of miR-183/96/182 are among the highest expressed miRNAs in the retina (",{"xref":1217,":@":1219},[1218],{"#text":1159},{"@_ref-type":967,"@_rid":1161},{"#text":997},{"xref":1222,":@":1224},[1223],{"#text":1097},{"@_ref-type":967,"@_rid":1099},{"#text":1226},"). miR-182 accounts for ∼64%, miR-183 another ∼4% of all miRNAs in cone photoreceptors (",{"xref":1228,":@":1230},[1229],{"#text":1104},{"@_ref-type":967,"@_rid":1106},{"#text":1232},"). Developmentally, miR-183/96/182 is minimally expressed in embryonic retina; but significantly upregulated soon after birth, suggesting that miR-183/96/182 play important roles in the postnatal functional differentiation of photoreceptors (",{"xref":1234,":@":1236},[1235],{"#text":1159},{"@_ref-type":967,"@_rid":1161},{"#text":997},{"xref":1239,":@":1241},[1240],{"#text":1097},{"@_ref-type":967,"@_rid":1099},{"#text":1243},"). Expression of miR-183/96/182 in the retina follows a diurnal rhythmic pattern – lowest around noon, highest in the early evening, suggesting a role in circadian function in the retina (",{"xref":1245,":@":1247},[1246],{"#text":1159},{"@_ref-type":967,"@_rid":1161},{"#text":997},{"xref":1250,":@":1253},[1251],{"#text":1252},"Xu, 2009",{"@_ref-type":967,"@_rid":1254},"B84",{"#text":997},{"xref":1257,":@":1260},[1258],{"#text":1259},"Ko, 2020",{"@_ref-type":967,"@_rid":1261},"B29",{"#text":1263},"). In addition, miR-183/96/182 is responsive to light (",{"xref":1265,":@":1268},[1266],{"#text":1267},"Krol et al., 2010",{"@_ref-type":967,"@_rid":1269},"B31",{"#text":1271},") – induced by light, and downregulated by darkness with 30 minutes (",{"xref":1273,":@":1275},[1274],{"#text":1267},{"@_ref-type":967,"@_rid":1269},{"#text":1277},"). Targeted deletion of miR-182 alone in mouse did not result in a discernible phenotype, suggesting functional compensation by miR-183 and miR-96 (",{"xref":1279,":@":1282},[1280],{"#text":1281},"Jin et al., 2009",{"@_ref-type":967,"@_rid":1283},"B25",{"#text":1285},"). However, knockdown of miR-183/96/182 in postmitotic rod photoreceptors in a miRNA-sponge transgenic mouse model resulted in increased susceptibility to light damage in the retina (",{"xref":1287,":@":1290},[1288],{"#text":1289},"Zhu et al., 2011",{"@_ref-type":967,"@_rid":1291},"B90",{"#text":1293},"), with no discernible histological or functional defects in the retina under normal lighting conditions (",{"xref":1295,":@":1297},[1296],{"#text":1289},{"@_ref-type":967,"@_rid":1291},{"#text":1299},"), suggesting that miR-183/96/182 plays an important role in protecting the retina from light damage. We demonstrated that complete inactivation of miR-183/96/182 in mice results in syndromic IRD with multi-sensory defect (",{"xref":1301,":@":1303},[1302],{"#text":1097},{"@_ref-type":967,"@_rid":1099},{"#text":1305},"), suggesting that miR-183/96/182 is required for the normal development and physiological functions of the retina and other sensory organs (",{"xref":1307,":@":1309},[1308],{"#text":1097},{"@_ref-type":967,"@_rid":1099},{"#text":1311},"), providing one of the first evidences that mutation of an individual miRNA gene results in retinal dysfunction and degeneration in mammals. Our report (",{"xref":1313,":@":1315},[1314],{"#text":1097},{"@_ref-type":967,"@_rid":1099},{"#text":1317},") has been further validated by several other groups (",{"xref":1319,":@":1321},[1320],{"#text":1104},{"@_ref-type":967,"@_rid":1106},{"#text":997},{"xref":1324,":@":1327},[1325],{"#text":1326},"Fan et al., 2017",{"@_ref-type":967,"@_rid":1328},"B14",{"#text":997},{"xref":1331,":@":1334},[1332],{"#text":1333},"Xiang et al., 2017",{"@_ref-type":967,"@_rid":1335},"B83",{"#text":1337},") and our follow-up studies (",{"xref":1339,":@":1342},[1340],{"#text":1341},"Geng et al., 2018",{"@_ref-type":967,"@_rid":1343},"B16",{"#text":1345},"). Recent reports further substantiated critical roles of miR-183/96/182, especially miR-182/miR-183, in functional differentiation and maturation of photoreceptors (",{"xref":1347,":@":1349},[1348],{"#text":1104},{"@_ref-type":967,"@_rid":1106},{"#text":997},{"xref":1352,":@":1355},[1353],{"#text":1354},"Mahmoudian-Sani et al., 2019",{"@_ref-type":967,"@_rid":1356},"B45",{"#text":997},{"xref":1359,":@":1362},[1360],{"#text":1361},"Peskova et al., 2020",{"@_ref-type":967,"@_rid":1363},"B59",{"#text":1365},"). Based on these evidences, we hypothesize that mutations in miR-183/96/182 in human also cause IRD, possibly syndromic IRD. To test this hypothesis, we established a collaboration with the National Ophthalmic Genotyping and Phenotyping Network (eyeGENE",{"sup":1367},[1368],{"#text":1369},"®",{"#text":1371},")",{"sup":1373},[1374],{"xref":1375,":@":1378},[1376],{"#text":1377},"3",{"@_ref-type":986,"@_rid":1379},"footnote3",{"#text":1381},", which was created by the National Eye Institute (NEI), National Institutes of Health (NIH) to enhance the study of inherited eye diseases. We obtained >1000 IRD patient DNA samples. Here we report our results in the mutation screening in these patients by far.",{"#text":949},{"@_id":1384},"S1",{"#text":949},{"sec":1387,":@":2058},[1388,1389,1393,1394,1723,1724,1877,1878,1914,1915,1936,1937,1952,1953,1968,1969,2024,2025,2057],{"#text":946},{"title":1390},[1391],{"#text":1392},"Materials and Methods",{"#text":946},{"sec":1395,":@":1721},[1396,1397,1401,1402,1411,1412,1515,1516,1720],{"#text":867},{"title":1398},[1399],{"#text":1400},"Human Genomic DNA Samples",{"#text":867},{"p":1403},[1404,1406,1409],{"#text":1405},"This study was performed in accordance with the tenets of Declaration of Helsinki, and informed consent was obtained from all participants. The research was approved by the Institutional Review Board (IRB) of Wayne State University, National Institutes of Health, and Committee for Protection of Human Subjects, University of Texas Southwestern Medical Center. The eyeGENE",{"sup":1407},[1408],{"#text":1369},{"#text":1410}," Network constructed a framework to collect DNA samples from patients with various forms of IRD and linked them with clinical information and genetic testing data. To discover potential disease-causing mutations in miR-183/96/182 responsible for IRDs, we obtained DNA samples of IRD patients, in which no disease-causing mutations have been found in any protein-coding genes that have been screened by eyeGENE. Most testing on protein-coding genes at the eyeGENE was performed by standard commercial, fee for service panel testing, but did not go through CNV detection and evaluation of deep intronic variants.",{"#text":867},{"p":1413},[1414,1416,1420,1422,1426,1428,1432,1434,1440,1442,1448,1450,1456,1457,1463,1464,1468,1470,1474,1476,1479,1481,1484,1486,1489,1491,1494,1496,1499,1501,1504,1506,1513],{"#text":1415},"Although the phenotypes in the miR-183/96/182 knockout mice do not completely match any human IRD, they resemble various aspects of several human IRD. The following rationales in reference to the phenotypes of the miR-183/96/182 knockout (ko) mice (",{"xref":1417,":@":1419},[1418],{"#text":1097},{"@_ref-type":967,"@_rid":1099},{"#text":1421},") were considered for sample selection: (1) since miR-183/96/182 is located at human chromosome 7q32.2, cases with X-linked IRD are excluded; (2) the most prominent ERG abnormalities in miR-183/96/182 ko mice is a decreased ",{"italic":1423},[1424],{"#text":1425},"b",{"#text":1427},"-wave amplitude in both scotopic and photopic ERG (",{"xref":1429,":@":1431},[1430],{"#text":1097},{"@_ref-type":967,"@_rid":1099},{"#text":1433},"). This phenotype resembles those observed in human incomplete Schubert-Bornschein type of stationary congenital night blindness (iSCNB) (",{"xref":1435,":@":1438},[1436],{"#text":1437},"Miyake et al., 1986",{"@_ref-type":967,"@_rid":1439},"B52",{"#text":1441},"); (3) the sensory syndromic feature are clinically reminiscent of Usher syndrome (",{"xref":1443,":@":1446},[1444],{"#text":1445},"Yan and Liu, 2010",{"@_ref-type":967,"@_rid":1447},"B87",{"#text":1449},"); (4) the cone photoreceptor system is more affected than rod photoreceptors in the ko mice; (5) it has been shown that different mutations in genes associated with IRD can cause different forms of IRD; same mutations in the orthologous genes in mouse can cause different phenotypes compared to patients (",{"xref":1451,":@":1454},[1452],{"#text":1453},"Riazuddin et al., 2010",{"@_ref-type":967,"@_rid":1455},"B63",{"#text":997},{"xref":1458,":@":1461},[1459],{"#text":1460},"Naeem et al., 2012",{"@_ref-type":967,"@_rid":1462},"B56",{"#text":997},{"xref":1465,":@":1467},[1466],{"#text":965},{"@_ref-type":967,"@_rid":968},{"#text":1469},"). Based on these considerations, we hypothesized that mutations in human miR-183/96/182 may cause one or more forms of IRD, with increased likelihood to cause SCNB, Usher syndrome and cone-rod dystrophy (CRD), and other type of cone diseases. Therefore, we first collected DNA samples of patients with SCNB (",{"italic":1471},[1472],{"#text":1473},"n",{"#text":1475}," = 16), Usher syndrome (",{"italic":1477},[1478],{"#text":1473},{"#text":1480}," = 74), CRD (",{"italic":1482},[1483],{"#text":1473},{"#text":1485}," = 248), Stargardt disease (",{"italic":1487},[1488],{"#text":1473},{"#text":1490}," = 249), Achromatopsia/Blue Cone Monochromacy (A/BCM) (",{"italic":1492},[1493],{"#text":1473},{"#text":1495}," = 4), Occult Macular Dystrophy (OMD. ",{"italic":1497},[1498],{"#text":1473},{"#text":1500}," = 6), Pattern Dystrophy and Adult Onset Foveomacular Dystrophy (PD and AOFD. ",{"italic":1502},[1503],{"#text":1473},{"#text":1505}," = 105) (",{"xref":1507,":@":1510},[1508],{"#text":1509},"Table 1",{"@_ref-type":1511,"@_rid":1512},"table","T1",{"#text":1514},"). In addition, 509 samples with Retinitis Pigmentosa (RP) were also collected considering that miR-183/96/182 plays important roles in both rod and cones; rod system is also affected in the miR-183/96/182 ko mice. As we could not predict the inheritance pattern of a potential IRD caused by mutations in miR-183/96/182, samples with both autosomal dominant and recessive inheritance were included. DNA samples of 80 unaffected individuals were included as controls.",{"#text":867},{"table-wrap":1517,":@":1718},[1518,1519,1523,1524,1532,1533,1704,1705,1717],{"#text":861},{"label":1520},[1521],{"#text":1522},"TABLE 1",{"#text":861},{"caption":1525},[1526,1527,1531],{"#text":887},{"p":1528},[1529],{"#text":1530},"DNA samples of various inherited retinal dystrophy and unaffected controls.",{"#text":861},{"#text":861},{"table":1534,":@":1701},[1535,1536,1620,1621,1700],{"#text":887},{"thead":1537},[1538,1540,1619],{"#text":1539},"\n              ",{"tr":1541},[1542,1544,1551,1552,1558,1559,1564,1565,1570,1571,1576,1577,1582,1583,1588,1589,1594,1595,1600,1601,1606,1607,1612,1613,1618],{"#text":1543},"\n                ",{"td":1545,":@":1548},[1546],{"#text":1547},"Disease",{"@_valign":1549,"@_align":1550},"top","left",{"#text":1543},{"td":1553,":@":1556},[1554],{"#text":1555},"SCNB",{"@_valign":1549,"@_align":1557},"center",{"#text":1543},{"td":1560,":@":1563},[1561],{"#text":1562},"Usher Syn.",{"@_valign":1549,"@_align":1557},{"#text":1543},{"td":1566,":@":1569},[1567],{"#text":1568},"Cone-rod dys.",{"@_valign":1549,"@_align":1557},{"#text":1543},{"td":1572,":@":1575},[1573],{"#text":1574},"Stargardt Disease",{"@_valign":1549,"@_align":1557},{"#text":1543},{"td":1578,":@":1581},[1579],{"#text":1580},"A/BCM",{"@_valign":1549,"@_align":1557},{"#text":1543},{"td":1584,":@":1587},[1585],{"#text":1586},"OMD",{"@_valign":1549,"@_align":1557},{"#text":1543},{"td":1590,":@":1593},[1591],{"#text":1592},"PD and AOFD",{"@_valign":1549,"@_align":1557},{"#text":1543},{"td":1596,":@":1599},[1597],{"#text":1598},"RP",{"@_valign":1549,"@_align":1557},{"#text":1543},{"td":1602,":@":1605},[1603],{"#text":1604},"Subtotal",{"@_valign":1549,"@_align":1557},{"#text":1543},{"td":1608,":@":1611},[1609],{"#text":1610},"Unaffected",{"@_valign":1549,"@_align":1557},{"#text":1543},{"td":1614,":@":1617},[1615],{"#text":1616},"Total",{"@_valign":1549,"@_align":1557},{"#text":1539},{"#text":887},{"#text":887},{"tbody":1622},[1623,1624,1699],{"#text":1539},{"tr":1625},[1626,1627,1632,1633,1638,1639,1644,1645,1650,1651,1656,1657,1662,1663,1668,1669,1674,1675,1680,1681,1686,1687,1692,1693,1698],{"#text":1543},{"td":1628,":@":1631},[1629],{"#text":1630},"Number of samples",{"@_valign":1549,"@_align":1550},{"#text":1543},{"td":1634,":@":1637},[1635],{"#text":1636},"16",{"@_valign":1549,"@_align":1557},{"#text":1543},{"td":1640,":@":1643},[1641],{"#text":1642},"74",{"@_valign":1549,"@_align":1557},{"#text":1543},{"td":1646,":@":1649},[1647],{"#text":1648},"239",{"@_valign":1549,"@_align":1557},{"#text":1543},{"td":1652,":@":1655},[1653],{"#text":1654},"242",{"@_valign":1549,"@_align":1557},{"#text":1543},{"td":1658,":@":1661},[1659],{"#text":1660},"4",{"@_valign":1549,"@_align":1557},{"#text":1543},{"td":1664,":@":1667},[1665],{"#text":1666},"6",{"@_valign":1549,"@_align":1557},{"#text":1543},{"td":1670,":@":1673},[1671],{"#text":1672},"105",{"@_valign":1549,"@_align":1557},{"#text":1543},{"td":1676,":@":1679},[1677],{"#text":1678},"509",{"@_valign":1549,"@_align":1557},{"#text":1543},{"td":1682,":@":1685},[1683],{"#text":1684},"1179",{"@_valign":1549,"@_align":1557},{"#text":1543},{"td":1688,":@":1691},[1689],{"#text":1690},"80",{"@_valign":1549,"@_align":1557},{"#text":1543},{"td":1694,":@":1697},[1695],{"#text":1696},"1259",{"@_valign":1549,"@_align":1557},{"#text":1539},{"#text":887},{"#text":861},{"@_cellspacing":818,"@_cellpadding":818,"@_frame":1702,"@_rules":1703},"hsides","groups",{"#text":861},{"table-wrap-foot":1706},[1707,1708,1716],{"#text":887},{"attrib":1709},[1710,1711,1715],{"#text":1539},{"italic":1712},[1713],{"#text":1714},"SCNB, stationary congenital night blindness; Usher syn., Usher syndrome, Cone-rod dys., cone-rod dystrophy; A/BCM, Achromatopsia/Blue Cone Monochromacy; OMD, Occult Macular Dystrophy; PD and AOFD, Pattern Dystrophy and Adult Onset Foveomacular Dystrophy; RP, retinitis pigmentosa.",{"#text":887},{"#text":861},{"#text":867},{"@_position":1719,"@_id":1512},"float",{"#text":946},{"@_id":1722},"S2.SS1",{"#text":946},{"sec":1725,":@":1875},[1726,1727,1731,1732,1763,1764,1800,1801,1805,1806,1810,1811,1834,1835,1846,1847,1860,1861,1874],{"#text":867},{"title":1728},[1729],{"#text":1730},"Amplification of Pre-miR-183/96/182 and Sanger Sequencing",{"#text":867},{"p":1733},[1734,1736,1740,1742,1749,1751,1755,1757,1761],{"#text":1735},"The miR-183/96/182 is located on human chromosome 7q32.2 and clustered with 5 kb (",{"xref":1737,":@":1739},[1738],{"#text":1159},{"@_ref-type":967,"@_rid":1161},{"#text":1741},"). Since pre-miR-183 and pre-miR-96 are only 135 nucleotides (nt) apart, while pre-miR-182 is ∼4.2 kb 3′ of pre-miR-96 (",{"xref":1743,":@":1746},[1744],{"#text":1745},"Figure 1A",{"@_ref-type":1747,"@_rid":1748},"fig","F1",{"#text":1750},"), to screen miR-183/96/182, we amplified pre-miR-183, pre-miR-96 and pre-miR-182 in two amplicons (",{"xref":1752,":@":1754},[1753],{"#text":1745},{"@_ref-type":1747,"@_rid":1748},{"#text":1756},"). pre-miR-183 and pre-miR-96 were amplified together using primers: 183/96-F1 (forward primer) and 183/96-R1 (reverse primer) (",{"xref":1758,":@":1760},[1759],{"#text":1745},{"@_ref-type":1747,"@_rid":1748},{"#text":1762},"), which will produce a 754-bp amplification product. Pre-miR-182 was amplified separately using primers, 182-F0/182-R3 with a 681-bp amplicon.",{"#text":867},{"fig":1765,":@":1799},[1766,1767,1771,1772,1792,1793,1798],{"#text":861},{"label":1768},[1769],{"#text":1770},"FIGURE 1",{"#text":861},{"caption":1773},[1774,1775,1791],{"#text":887},{"p":1776},[1777,1779,1783,1785,1789],{"#text":1778},"PCR-sequencing strategy for mutation screening in the miR-183/96/182 cluster. ",{"bold":1780},[1781],{"#text":1782},"(A)",{"#text":1784}," Schematic illustration of the miR-183/96/182 cluster in relation to the PCR and sequencing primers. Pre-miR-183/96 is amplified by 183/96-F1/R1 and sequenced by primers of 183/96-F2 and 183/96-R2. pre-miR-182 was amplified with primers 182-F0/R3, and sequenced by 182-F1 and 182-R2. The numbers above the double arrows indicate the sizes of the marked fragments in base pairs (bp). ",{"bold":1786},[1787],{"#text":1788},"(B)",{"#text":1790}," Examples of amplification products.",{"#text":861},{"#text":861},{"graphic":1794,":@":1795},[],{"@_xmlns:xlink":1796,"@_xlink:href":1797},"http://www.w3.org/1999/xlink","fcell-08-619641-g001.tif",{"#text":867},{"@_id":1748,"@_position":1719},{"#text":867},{"p":1802},[1803],{"#text":1804},"The PCR reaction was carried out with 100 ng genomic DNA, 3 μM forward and reverse primers, 1xPCR buffer and 5 units of Taq polymerase (MIDSCI) on a S1000 thermal cycler (Bio-Rad) with the following program: 95°C, 5 min; then 95°C, 30 s; 62°C, 1 min; 72°C, 2 min for 30 cycles, followed 72°C, 10 min.",{"#text":867},{"p":1807},[1808],{"#text":1809},"The sequences of the PCR primers are as the following:",{"#text":867},{"disp-quote":1812},[1813,1814,1818,1819,1823,1824,1828,1829,1833],{"#text":861},{"p":1815},[1816],{"#text":1817},"183/96-F1: 5′-GAAGGTCATCTTGGGCTGAT-3′;",{"#text":861},{"p":1820},[1821],{"#text":1822},"183/96-R1: 5′- CCTACAGATGGTTTCAGACTC-3′.",{"#text":861},{"p":1825},[1826],{"#text":1827},"182-F0: 5′-TCTGGCCTGGCTTGTGCTG-3′;",{"#text":861},{"p":1830},[1831],{"#text":1832},"182-R3: 5′-GGCTTCCCAGCTGACTTGAG-3′.",{"#text":867},{"#text":867},{"p":1836},[1837,1839,1844],{"#text":1838},"The amplification product was run on a 1.5% agarose gel to ensure the specificity (",{"xref":1840,":@":1843},[1841],{"#text":1842},"Figure 1B",{"@_ref-type":1747,"@_rid":1748},{"#text":1845},"), before purified using the gel/PCR DNA fragment extraction kit (IBI Scientific). 50 ng of purified PCR product was sent for Sanger sequencing by the Genome Sciences Core, Wayne State University or Genewiz with the following nested sequencing primers:",{"#text":867},{"disp-quote":1848},[1849,1850,1854,1855,1859],{"#text":861},{"p":1851},[1852],{"#text":1853},"For pre-miR-183/96 amplicon: 183/96-F2: 5′-GTGGATC TTGTGAAGAGGTG-3′; 183/96-R2: 5′- AGGCAGTGT AAGGCGATCTG -3′.",{"#text":861},{"p":1856},[1857],{"#text":1858},"For pre-miR-182 amplicon: 182-F1: 5′-ACAGGAACT GCAGGTTACAGA -3′; 182-R2: 5′- CTTGAGGACCTGT GACCTCA-3′.",{"#text":867},{"#text":867},{"p":1862},[1863,1865,1872],{"#text":1864},"Sequences obtained from sequencing using the forward primers (183/96-F2 or 182-F1) were aligned with the reference sequence downloaded from the UCSC Genome Browser [Human Dec. 2013 (GRCh38/hg38) Assembly] (",{"xref":1866,":@":1869},[1867],{"#text":1868},"Supplementary Material",{"@_ref-type":1870,"@_rid":1871},"supplementary-material","SM1",{"#text":1873},") using Vector NTI 11.0 (Invitrogen). All sequence variants identified by the sequence alignment were confirmed by the sequencing using the reverse primers (183/96-R2 or 182-R2).",{"#text":946},{"@_id":1876},"S2.SS2",{"#text":946},{"sec":1879,":@":1912},[1880,1881,1885,1886,1911],{"#text":867},{"title":1882},[1883],{"#text":1884},"Copy Number Assay",{"#text":867},{"p":1887},[1888,1890,1893,1895,1898,1900,1904,1906,1909],{"#text":1889},"Patient genomic DNA was extracted from blood using the IBI gMAX mini genomic kit. DNA was diluted to 5 ng/μL with nuclease–free water. 4 μl of diluted DNA was added per well in a 96 well plate. Custom designed TaqMan",{"sup":1891},[1892],{"#text":1369},{"#text":1894}," Copy Number Assay (4400294. Assay ID: MIR182_CDYMJXM) for pre-miR-182 was added along with TaqMan",{"sup":1896},[1897],{"#text":1369},{"#text":1899}," Copy Number Reference Assay ",{"italic":1901},[1902],{"#text":1903},"RNase P",{"#text":1905},". The reactions were run on an Applied Biosystems 7500 Fast Real-Time PCR System using the following cycle parameters: 95°C, 10 min; then 95°C, 15 s; 60°C, 60 s for 40 cycles. Data generated was analyzed using Applied Biosystems CopyCaller",{"sup":1907},[1908],{"#text":1369},{"#text":1910}," Software v2.0.",{"#text":946},{"@_id":1913},"S2.SS3",{"#text":946},{"sec":1916,":@":1934},[1917,1918,1922,1923,1933],{"#text":867},{"title":1919},[1920],{"#text":1921},"Isolation of Mononuclear Cells From Peripheral Blood",{"#text":867},{"p":1924},[1925,1927,1931],{"#text":1926},"Peripheral blood mononuclear cells (PBMNC) were isolated from human peripheral blood (with EDTA or heparin as anti-coagulant) using the Histopaque-1077 (Sigma-Aldrich. Cat No. 10771). Manufacturer’s instruction was followed. Briefly, 3 ml of peripheral blood was carefully layered on 3 ml Histopaque-1077 in a 15-ml conical tube and centrifuged at 400 × ",{"italic":1928},[1929],{"#text":1930},"g",{"#text":1932}," for 30 min at room temperature. After centrifugation, the upper plasma layer was aspirated off. Then the PBMNC layer was carefully removed and washed in cold PBS. The cells are divided into two tubes for total RNA isolation using the RNeasy RNA isolation kit (Qiagen) and miRNA isolation using the miRVana miRNA isolation kit (Ambion). RNA concentration and quality were analyzed using a NanoDrop 2000 (Thermo Fisher Scientific).",{"#text":946},{"@_id":1935},"S2.SS4",{"#text":946},{"sec":1938,":@":1950},[1939,1940,1944,1945,1949],{"#text":867},{"title":1941},[1942],{"#text":1943},"Genomic DNA Preparation",{"#text":867},{"p":1946},[1947],{"#text":1948},"Two milliliters of peripheral blood was used for genomic DNA preparation using the gMAX DNA mini kit (IBI Scientific) following manufacturer’s instruction. Subsequently, DNA concentration and quality were assayed on the NanoDrop 2000 (Thermo Fisher Scientific).",{"#text":946},{"@_id":1951},"S2.SS5",{"#text":946},{"sec":1954,":@":1966},[1955,1956,1960,1961,1965],{"#text":867},{"title":1957},[1958],{"#text":1959},"Quantitative (q)RT-PCR of miR-182",{"#text":867},{"p":1962},[1963],{"#text":1964},"qRT-PCR was performed using TaqMan miRNA primers and RT-PCR kit (Life Technologies) on a CFX Connect Real-time System (Bio-Rad, Hercules, CA, United States) with snRNA U6 as an endogenous control as described before.",{"#text":946},{"@_id":1967},"S2.SS6",{"#text":946},{"sec":1970,":@":2022},[1971,1972,1976,1977,2021],{"#text":867},{"title":1973},[1974],{"#text":1975},"Secondary Structure Prediction of Hsa-pre-miR-182 and Hsa-pre-miR-96",{"#text":867},{"p":1978},[1979,1981,1988,1990,1998,2000,2006,2007,2013,2014,2020],{"#text":1980},"The sequences of hsa-pre-miR-182 and hsa-pre-miR-96 were downloaded from miRBase",{"sup":1982},[1983],{"xref":1984,":@":1986},[1985],{"#text":1660},{"@_ref-type":986,"@_rid":1987},"footnote4",{"#text":1989},". The residues of sequence variants identified in this study were modified to obtain the sequences of the mutant forms of hsa-pre-miR-182 and hsa-pre-miR-96. Then these sequences were uploaded to the RNAfold web server",{"sup":1991},[1992],{"xref":1993,":@":1996},[1994],{"#text":1995},"5",{"@_ref-type":986,"@_rid":1997},"footnote5",{"#text":1999}," to obtain predicted secondary structures with minimum free energy (MFE) and partition function (",{"xref":2001,":@":2004},[2002],{"#text":2003},"Mathews et al., 2004",{"@_ref-type":967,"@_rid":2005},"B46",{"#text":997},{"xref":2008,":@":2011},[2009],{"#text":2010},"Gruber et al., 2008",{"@_ref-type":967,"@_rid":2012},"B18",{"#text":997},{"xref":2015,":@":2018},[2016],{"#text":2017},"Lorenz et al., 2011",{"@_ref-type":967,"@_rid":2019},"B43",{"#text":1122},{"#text":946},{"@_id":2023},"S2.SS7",{"#text":946},{"sec":2026,":@":2055},[2027,2028,2032,2033,2054],{"#text":867},{"title":2029},[2030],{"#text":2031},"Statistical Analysis",{"#text":867},{"p":2034},[2035,2037,2041,2043,2047,2049,2052],{"#text":2036},"When the comparison was made among more than two conditions, One-way ANOVA with Bonferroni’s multiple comparison test was employed (GraphPad Prism); adjusted ",{"italic":2038},[2039],{"#text":2040},"p",{"#text":2042}," \u003C 0.05 was considered significant. Otherwise, a two-tailed Student’s ",{"italic":2044},[2045],{"#text":2046},"t",{"#text":2048}," test was used to determine the significance; ",{"italic":2050},[2051],{"#text":2040},{"#text":2053}," \u003C 0.05 was considered significant. The significance of the association of sequence variants to various disease categories in this cohort was compared to general population by Fisher’s exact test, or Chi square test for the tri-allelic SNP rs80041074 (pre-miR-182 nt94 G > A).",{"#text":946},{"@_id":2056},"S2.SS8",{"#text":949},{"@_id":2059,"@_sec-type":2060},"S2","materials|methods",{"#text":949},{"sec":2063,":@":4550},[2064,2065,2069,2070,2095,2096,2161,2162,2215,2216,4090,4091,4549],{"#text":946},{"title":2066},[2067],{"#text":2068},"Results",{"#text":946},{"p":2071},[2072,2074,2078,2080,2086,2088,2094],{"#text":2073},"Among the 1179 IRD patient samples (",{"xref":2075,":@":2077},[2076],{"#text":1509},{"@_ref-type":1511,"@_rid":1512},{"#text":2079},"), we identified three sequence variants in the pre-miR-182: nt106 G > A, nt105 C > T and nt94 G > A (",{"xref":2081,":@":2084},[2082],{"#text":2083},"Figure 2",{"@_ref-type":1747,"@_rid":2085},"F2",{"#text":2087},"), and three sequence variants in pre-miR-94: nt36 T > C, nt39 C > T and nt42 C > T (",{"xref":2089,":@":2092},[2090],{"#text":2091},"Figure 3",{"@_ref-type":1747,"@_rid":2093},"F3",{"#text":1122},{"#text":946},{"fig":2097,":@":2160},[2098,2099,2103,2104,2154,2155,2159],{"#text":867},{"label":2100},[2101],{"#text":2102},"FIGURE 2",{"#text":867},{"caption":2105},[2106,2107,2153],{"#text":861},{"p":2108},[2109,2111,2115,2117,2120,2122,2125,2127,2131,2133,2137,2139,2143,2145,2151],{"#text":2110},"Sequence variants identified in pre-miR-182. ",{"bold":2112},[2113],{"#text":2114},"(A–D)",{"#text":2116}," Example of Sanger sequencing chromatography of patient DNA samples which are heterozygous for pre-miR-182 nt106 G/A alleles ",{"bold":2118},[2119],{"#text":1782},{"#text":2121}," and homozygous for pre-miR-182 nt106 A/A allele ",{"bold":2123},[2124],{"#text":1788},{"#text":2126},", heterozygous for pre-miR-182 nt105 C > T ",{"bold":2128},[2129],{"#text":2130},"(C)",{"#text":2132}," and nt94 G > A variants ",{"bold":2134},[2135],{"#text":2136},"(D)",{"#text":2138},". ",{"bold":2140},[2141],{"#text":2142},"(E)",{"#text":2144}," Summary of the sequence variants of pre-miR-182 in the context of the hairpin structures of hsa-miR-182. Reference: ",{"ext-link":2146,":@":2149},[2147],{"#text":2148},"miRbase.org",{"@_ext-link-type":920,"@_xlink:href":2150},"http://miRbase.org",{"#text":2152},".",{"#text":867},{"#text":867},{"graphic":2156,":@":2157},[],{"@_xlink:href":2158},"fcell-08-619641-g002.tif",{"#text":946},{"@_id":2085,"@_position":1719},{"#text":946},{"fig":2163,":@":2214},[2164,2165,2169,2170,2208,2209,2213],{"#text":867},{"label":2166},[2167],{"#text":2168},"FIGURE 3",{"#text":867},{"caption":2171},[2172,2173,2207],{"#text":861},{"p":2174},[2175,2177,2181,2183,2186,2188,2191,2193,2196,2197,2200,2202,2206],{"#text":2176},"Sequence variants identified in pre-miR-96. ",{"bold":2178},[2179],{"#text":2180},"(A–C)",{"#text":2182}," Example of Sanger sequencing chromatography of patient DNA samples which are heterozygous for pre-miR-96 nt36 T > C ",{"bold":2184},[2185],{"#text":1782},{"#text":2187},", nt39 C > T ",{"bold":2189},[2190],{"#text":1788},{"#text":2192},", and nt42 C > T variants ",{"bold":2194},[2195],{"#text":2130},{"#text":2138},{"bold":2198},[2199],{"#text":2136},{"#text":2201}," Summary of the sequence variants of pre-miR-96 in the context of the hairpin structures of pre-miR-96. Reference: ",{"ext-link":2203,":@":2205},[2204],{"#text":2148},{"@_ext-link-type":920,"@_xlink:href":2150},{"#text":2152},{"#text":867},{"#text":867},{"graphic":2210,":@":2211},[],{"@_xlink:href":2212},"fcell-08-619641-g003.tif",{"#text":946},{"@_id":2093,"@_position":1719},{"#text":946},{"sec":2217,":@":4088},[2218,2219,2223,2224,3970,3971,4026,4027,4087],{"#text":867},{"title":2220},[2221],{"#text":2222},"Sequence Variants in Hsa-pre-miR-182",{"#text":867},{"sec":2225,":@":3968},[2226,2227,2231,2232,2263,2264,3445,3446,3455,3456,3513,3514,3561,3562,3967],{"#text":861},{"title":2228},[2229],{"#text":2230},"Pre-miR-182 nt106 G > A",{"#text":861},{"p":2233},[2234,2236,2242,2244,2249,2251,2255,2257,2261],{"#text":2235},"This variant was found in 32 IRD patients, including two in CSNB patients, nine CRD, one Usher syndrome, four PD and AOFD, three Stargardt disease patients, and 13 patients with RP (",{"xref":2237,":@":2240},[2238],{"#text":2239},"Table 2",{"@_ref-type":1511,"@_rid":2241},"T2",{"#text":2243}," and ",{"xref":2245,":@":2248},[2246],{"#text":2247},"Figures 2A,B",{"@_ref-type":1747,"@_rid":2085},{"#text":2250},"). Among these, we found homozygosity for the less common A allele in five patients including one CRD, two Stargardt, and two RP patients (",{"xref":2252,":@":2254},[2253],{"#text":2239},{"@_ref-type":1511,"@_rid":2241},{"#text":2256},"). Copy-number assay confirmed that these cases are true homozygosity for this variant instead of a micro-deletion in one allele. In 80 unaffected individuals, we identified one individual heterozygous for pre-miR-182 nt106 G/A. The A allele frequency in our samples is as the following: overall frequency in IRD patients: 1.569%; in CSNB patients: 6.250%; Usher syndrome: 0.676%; CRD: 2.092%; Stargardt dis.: 1.033%; PD and AOFD: 1.905%; other RP: 1.473% (",{"xref":2258,":@":2260},[2259],{"#text":2239},{"@_ref-type":1511,"@_rid":2241},{"#text":2262},"). In unaffected individual: 0.625%.",{"#text":861},{"table-wrap":2265,":@":3444},[2266,2267,2271,2272,2280,2281,3425,3426,3443],{"#text":887},{"label":2268},[2269],{"#text":2270},"TABLE 2",{"#text":887},{"caption":2273},[2274,2275,2279],{"#text":1539},{"p":2276},[2277],{"#text":2278},"Allele frequency of the sequence variants among the samples.",{"#text":887},{"#text":887},{"table":2282,":@":3424},[2283,2284,2677,2678,3423],{"#text":1539},{"thead":2285},[2286,2287,2352,2353,2394,2395,2455,2456,2532,2533,2596,2597,2676],{"#text":1543},{"tr":2288},[2289,2291,2295,2296,2303,2304,2311,2312,2319,2320,2327,2328,2335,2336,2343,2344,2351],{"#text":2290},"\n                  ",{"td":2292,":@":2294},[2293],{"#text":1547},{"@_valign":1549,"@_align":1550},{"#text":2290},{"td":2297,":@":2302},[2298,2300],{"#text":2299},"Variant",{"hr":2301},[],{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":2305,":@":2310},[2306,2308],{"#text":2307},"nt106 G > A",{"hr":2309},[],{"@_valign":1549,"@_align":1557,"@_colspan":809},{"#text":2290},{"td":2313,":@":2318},[2314,2316],{"#text":2315},"nt105 C > T",{"hr":2317},[],{"@_valign":1549,"@_align":1557,"@_colspan":806},{"#text":2290},{"td":2321,":@":2326},[2322,2324],{"#text":2323},"nt94 G > A",{"hr":2325},[],{"@_valign":1549,"@_align":1557,"@_colspan":806},{"#text":2290},{"td":2329,":@":2334},[2330,2332],{"#text":2331},"nt36 T > C",{"hr":2333},[],{"@_valign":1549,"@_align":1557,"@_colspan":806},{"#text":2290},{"td":2337,":@":2342},[2338,2340],{"#text":2339},"nt39 C > T",{"hr":2341},[],{"@_valign":1549,"@_align":1557,"@_colspan":806},{"#text":2290},{"td":2345,":@":2350},[2346,2348],{"#text":2347},"nt42 C > T",{"hr":2349},[],{"@_valign":1549,"@_align":1557,"@_colspan":806},{"#text":1543},{"#text":1543},{"tr":2354},[2355,2356,2358,2359,2361,2362,2367,2368,2372,2373,2377,2378,2383,2384,2388,2389,2393],{"#text":2290},{"td":2357},[],{"#text":2290},{"td":2360},[],{"#text":2290},{"td":2363,":@":2366},[2364],{"#text":2365},"pre-miR-182",{"@_valign":1549,"@_align":1557,"@_colspan":809},{"#text":2290},{"td":2369,":@":2371},[2370],{"#text":2365},{"@_valign":1549,"@_align":1557,"@_colspan":806},{"#text":2290},{"td":2374,":@":2376},[2375],{"#text":2365},{"@_valign":1549,"@_align":1557,"@_colspan":806},{"#text":2290},{"td":2379,":@":2382},[2380],{"#text":2381},"pre-miR-96",{"@_valign":1549,"@_align":1557,"@_colspan":806},{"#text":2290},{"td":2385,":@":2387},[2386],{"#text":2381},{"@_valign":1549,"@_align":1557,"@_colspan":806},{"#text":2290},{"td":2390,":@":2392},[2391],{"#text":2381},{"@_valign":1549,"@_align":1557,"@_colspan":806},{"#text":1543},{"#text":1543},{"tr":2396},[2397,2398,2400,2401,2407,2408,2415,2416,2423,2424,2431,2432,2439,2440,2447,2448,2454],{"#text":2290},{"td":2399},[],{"#text":2290},{"td":2402},[2403,2405],{"#text":2404}," ",{"hr":2406},[],{"#text":2290},{"td":2409,":@":2414},[2410,2412],{"#text":2411},"(rs76481776)",{"hr":2413},[],{"@_valign":1549,"@_align":1557,"@_colspan":809},{"#text":2290},{"td":2417,":@":2422},[2418,2420],{"#text":2419},"(rs77586312)",{"hr":2421},[],{"@_valign":1549,"@_align":1557,"@_colspan":806},{"#text":2290},{"td":2425,":@":2430},[2426,2428],{"#text":2427},"(rs80041074)",{"hr":2429},[],{"@_valign":1549,"@_align":1557,"@_colspan":806},{"#text":2290},{"td":2433,":@":2438},[2434,2436],{"#text":2435},"(rs41274239)",{"hr":2437},[],{"@_valign":1549,"@_align":1557,"@_colspan":806},{"#text":2290},{"td":2441,":@":2446},[2442,2444],{"#text":2443},"(rs73159662)",{"hr":2445},[],{"@_valign":1549,"@_align":1557,"@_colspan":806},{"#text":2290},{"td":2449,":@":2453},[2450,2451],{"#text":2443},{"hr":2452},[],{"@_valign":1549,"@_align":1557,"@_colspan":806},{"#text":1543},{"#text":1543},{"tr":2457},[2458,2459,2461,2462,2467,2468,2477,2478,2487,2488,2501,2502,2511,2512,2521,2522,2531],{"#text":2290},{"td":2460},[],{"#text":2290},{"td":2463,":@":2466},[2464],{"#text":2465},"Freq in dbSNP",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":2469,":@":2