,"@_align":1557},{"#text":1543},{"#text":1543},{"tr":3276},[3277,3278,3283,3284,3288,3289,3293,3294,3296,3297,3302,3303,3305,3306,3308,3309,3313,3314,3318,3319,3321,3322,3324,3325,3327,3328,3330,3331,3333,3334,3336],{"#text":2290},{"td":3279,":@":3282},[3280],{"#text":3281},"Un-affected",{"@_valign":1549,"@_align":1550},{"#text":2290},{"td":3285,":@":3287},[3286],{"#text":1690},{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3290,":@":3292},[3291],{"#text":984},{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3295},[],{"#text":2290},{"td":3298,":@":3301},[3299],{"#text":3300},"0.625",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3304},[],{"#text":2290},{"td":3307},[],{"#text":2290},{"td":3310,":@":3312},[3311],{"#text":984},{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3315,":@":3317},[3316],{"#text":3300},{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3320},[],{"#text":2290},{"td":3323},[],{"#text":2290},{"td":3326},[],{"#text":2290},{"td":3329},[],{"#text":2290},{"td":3332},[],{"#text":2290},{"td":3335},[],{"#text":1543},{"#text":1543},{"tr":3339},[3340,3341,3345,3346,3351,3352,3357,3358,3360,3361,3366,3367,3371,3372,3377,3378,3383,3384,3389,3390,3394,3395,3400,3401,3405,3406,3411,3412,3416,3417,3421],{"#text":2290},{"td":3342,":@":3344},[3343],{"#text":1616},{"@_valign":1549,"@_align":1550},{"#text":2290},{"td":3347,":@":3350},[3348],{"#text":3349},"1261",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3353,":@":3356},[3354],{"#text":3355},"65",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3359},[],{"#text":2290},{"td":3362,":@":3365},[3363],{"#text":3364},"1.507",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3368,":@":3370},[3369],{"#text":1660},{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3373,":@":3376},[3374],{"#text":3375},"0.079",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3379,":@":3382},[3380],{"#text":3381},"15",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3385,":@":3388},[3386],{"#text":3387},"0.317",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3391,":@":3393},[3392],{"#text":1666},{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3396,":@":3399},[3397],{"#text":3398},"0.119",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3402,":@":3404},[3403],{"#text":1060},{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3407,":@":3410},[3408],{"#text":3409},"0.04",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3413,":@":3415},[3414],{"#text":1660},{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3418,":@":3420},[3419],{"#text":3375},{"@_valign":1549,"@_align":1557},{"#text":1543},{"#text":1539},{"#text":887},{"@_cellspacing":818,"@_cellpadding":818,"@_frame":1702,"@_rules":1703},{"#text":887},{"table-wrap-foot":3427},[3428,3429,3442],{"#text":1539},{"attrib":3430},[3431,3432,3441],{"#text":1543},{"italic":3433},[3434,3436,3439],{"#text":3435},"Freq, frequency; No, number; homo, homozygote; SCNB, stationary congenital night blindness; Usher syn., Usher syndrome; Cone-rod dys., cone-rod dystrophy; A/BCM, Achromatopsia/Blue Cone Monochromacy; OMD, Occult Macular Dystrophy; PD and AOFD, Pattern Dystrophy and Adult Onset Foveomacular Dystrophy; RP, retinitis pigmentosa. *, **, ***: ",{"italic":3437},[3438],{"#text":2040},{"#text":3440}," \u003C 0.05, 0.01, and 0.001 when compared to general population data compiled by dbSNP by Fisher’s exact test.",{"#text":1539},{"#text":887},{"#text":861},{"@_position":1719,"@_id":2241},{"#text":861},{"p":3447},[3448,3450,3454],{"#text":3449},"The pre-miR-182 nt106 G > A variant is a known single nucleotide polymorphism (SNP) documented in the dbSNP as rs76481776 with the allele frequencies of 5.952% (7211/121160) for the A allele, while 94.048% (113949/121160) for the G allele based on data from UCSC genome browser (dbSNP build 151). Statistical analysis suggest that the pre-miR-182 A allele appears to be significantly lower in all groups of patients and overall IRD population in this cohort, except in CSNB patients (",{"xref":3451,":@":3453},[3452],{"#text":2239},{"@_ref-type":1511,"@_rid":2241},{"#text":1122},{"#text":861},{"p":3457},[3458,3460,3465,3467,3473,3475,3479,3480,3484,3485,3489,3490,3497,3499,3505,3506,3512],{"#text":3459},"The pre-miR-182 nt106 G > A is located at the 5th nucleotide from the 3′ end of the hairpin structure of the human pre-miR-182 (",{"xref":3461,":@":3464},[3462],{"#text":3463},"Figure 2E",{"@_ref-type":1747,"@_rid":2085},{"#text":3466},"). It is predicted that nt106 G > A change results in a transition of G•U wobble base-pairing to a classical Watson-Crick base pair A•U, suggesting potential functional significance (",{"xref":3468,":@":3471},[3469],{"#text":3470},"Varani and McClain, 2000",{"@_ref-type":967,"@_rid":3472},"B74",{"#text":3474},"). However, a secondary structure prediction using the RNAfold algorithm (",{"xref":3476,":@":3478},[3477],{"#text":2003},{"@_ref-type":967,"@_rid":2005},{"#text":997},{"xref":3481,":@":3483},[3482],{"#text":2010},{"@_ref-type":967,"@_rid":2012},{"#text":997},{"xref":3486,":@":3488},[3487],{"#text":2017},{"@_ref-type":967,"@_rid":2019},{"#text":1371},{"sup":3491},[3492],{"xref":3493,":@":3495},[3494],{"#text":1666},{"@_ref-type":986,"@_rid":3496},"footnote6",{"#text":3498}," showed little changes in the secondary structure and the minimum free energy of the hair-pin structure of pre-miR-182 (",{"xref":3500,":@":3503},[3501],{"#text":3502},"Figure 4A",{"@_ref-type":1747,"@_rid":3504},"F4",{"#text":2243},{"xref":3507,":@":3510},[3508],{"#text":3509},"Table 3",{"@_ref-type":1511,"@_rid":3511},"T3",{"#text":1122},{"#text":861},{"fig":3515,":@":3560},[3516,3517,3521,3522,3554,3555,3559],{"#text":887},{"label":3518},[3519],{"#text":3520},"FIGURE 4",{"#text":887},{"caption":3523},[3524,3525,3553],{"#text":1539},{"p":3526},[3527,3529,3532,3534,3537,3539,3543,3545,3551],{"#text":3528},"Minimum free energy secondary structure prediction with base-pair probability on wild type (WT) hsa-pre-miR-182 ",{"bold":3530},[3531],{"#text":1782},{"#text":3533}," and hsa-pre-miR-96 ",{"bold":3535},[3536],{"#text":1788},{"#text":3538}," and their mutant forms with sequence variants. Data was compiled using publicly available software ",{"italic":3540},[3541],{"#text":3542},"RNAfold",{"#text":3544}," (",{"ext-link":3546,":@":3549},[3547],{"#text":3548},"http://rna.tbi. univie.ac.at//cgi-bin/RNAWebSuite/RNAfold.cgi",{"@_ext-link-type":920,"@_xlink:href":3550},"http://rna.tbi.univie.ac.at//cgi-bin/RNAWebSuite/RNAfold.cgi",{"#text":3552},"). Arrows indicate the sequence variant nucleotide. The brackets mark the areas with predicted changes of the secondary structure because of the sequence variants.",{"#text":887},{"#text":887},{"graphic":3556,":@":3557},[],{"@_xlink:href":3558},"fcell-08-619641-g004.tif",{"#text":861},{"@_id":3504,"@_position":1719},{"#text":861},{"table-wrap":3563,":@":3966},[3564,3565,3569,3570,3578,3579,3965],{"#text":887},{"label":3566},[3567],{"#text":3568},"TABLE 3",{"#text":887},{"caption":3571},[3572,3573,3577],{"#text":1539},{"p":3574},[3575],{"#text":3576},"Changes in the predicted secondary structures and their free energy caused by the variants of pre-miR-182 (A) and pre-miR-96 (B).",{"#text":887},{"#text":887},{"table":3580,":@":3964},[3581,3582,3616,3617,3963],{"#text":1539},{"thead":3583},[3584,3585,3615],{"#text":1543},{"tr":3586},[3587,3588,3593,3594,3599,3600,3604,3605,3609,3610,3614],{"#text":2290},{"td":3589,":@":3592},[3590],{"#text":3591},"Pre-miR-182",{"@_valign":1549,"@_align":1550},{"#text":2290},{"td":3595,":@":3598},[3596],{"#text":3597},"WT",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3601,":@":3603},[3602],{"#text":2307},{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3606,":@":3608},[3607],{"#text":2323},{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3611,":@":3613},[3612],{"#text":2315},{"@_valign":1549,"@_align":1557},{"#text":1543},{"#text":1539},{"#text":1539},{"tbody":3618},[3619,3620,3653,3654,3687,3688,3721,3722,3755,3756,3767,3768,3817,3818,3829,3830,3862,3863,3895,3896,3929,3930,3962],{"#text":1543},{"tr":3621},[3622,3623,3628,3629,3634,3635,3640,3641,3646,3647,3652],{"#text":2290},{"td":3624,":@":3627},[3625],{"#text":3626},"Minimum free energy (MFE)",{"@_valign":1549,"@_align":1550},{"#text":2290},{"td":3630,":@":3633},[3631],{"#text":3632},"–47.10",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3636,":@":3639},[3637],{"#text":3638},"–47.80",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3642,":@":3645},[3643],{"#text":3644},"–43.80",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3648,":@":3651},[3649],{"#text":3650},"–48.60",{"@_valign":1549,"@_align":1557},{"#text":1543},{"#text":1543},{"tr":3655},[3656,3657,3662,3663,3668,3669,3674,3675,3680,3681,3686],{"#text":2290},{"td":3658,":@":3661},[3659],{"#text":3660},"Free energy of the thermodynamic ensemble",{"@_valign":1549,"@_align":1550},{"#text":2290},{"td":3664,":@":3667},[3665],{"#text":3666},"–48.41",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3670,":@":3673},[3671],{"#text":3672},"–49.03",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3676,":@":3679},[3677],{"#text":3678},"–45.26",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3682,":@":3685},[3683],{"#text":3684},"–49.19",{"@_valign":1549,"@_align":1557},{"#text":1543},{"#text":1543},{"tr":3689},[3690,3691,3696,3697,3702,3703,3708,3709,3714,3715,3720],{"#text":2290},{"td":3692,":@":3695},[3693],{"#text":3694},"Frequency of the MFE structure (%)",{"@_valign":1549,"@_align":1550},{"#text":2290},{"td":3698,":@":3701},[3699],{"#text":3700},"  11.89",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3704,":@":3707},[3705],{"#text":3706},"  13.55",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3710,":@":3713},[3711],{"#text":3712},"    9.41",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3716,":@":3719},[3717],{"#text":3718},"  38.11",{"@_valign":1549,"@_align":1557},{"#text":1543},{"#text":1543},{"tr":3723},[3724,3725,3730,3731,3736,3737,3742,3743,3748,3749,3754],{"#text":2290},{"td":3726,":@":3729},[3727],{"#text":3728},"Ensemble diversity",{"@_valign":1549,"@_align":1550},{"#text":2290},{"td":3732,":@":3735},[3733],{"#text":3734},"    7.40",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3738,":@":3741},[3739],{"#text":3740},"    6.27",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3744,":@":3747},[3745],{"#text":3746},"    9.30",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3750,":@":3753},[3751],{"#text":3752},"    4.64",{"@_valign":1549,"@_align":1557},{"#text":1543},{"#text":1543},{"tr":3757},[3758,3759,3766],{"#text":2290},{"td":3760,":@":3765},[3761,3762,3764],{"#text":2542},{"hr":3763},[],{"#text":2290},{"@_valign":1549,"@_align":1550,"@_colspan":818},{"#text":1543},{"#text":1543},{"tr":3769},[3770,3771,3780,3781,3789,3790,3798,3799,3807,3808,3816],{"#text":2290},{"td":3772,":@":3779},[3773,3774,3778],{"#text":2542},{"bold":3775},[3776],{"#text":3777},"Pre-miR-96",{"#text":2290},{"@_valign":1549,"@_align":1550},{"#text":2290},{"td":3782,":@":3788},[3783,3784,3787],{"#text":2542},{"bold":3785},[3786],{"#text":3597},{"#text":2290},{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3791,":@":3797},[3792,3793,3796],{"#text":2542},{"bold":3794},[3795],{"#text":2331},{"#text":2290},{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3800,":@":3806},[3801,3802,3805],{"#text":2542},{"bold":3803},[3804],{"#text":2339},{"#text":2290},{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3809,":@":3815},[3810,3811,3814],{"#text":2542},{"bold":3812},[3813],{"#text":2347},{"#text":2290},{"@_valign":1549,"@_align":1557},{"#text":1543},{"#text":1543},{"tr":3819},[3820,3821,3828],{"#text":2290},{"td":3822,":@":3827},[3823,3824,3826],{"#text":2542},{"hr":3825},[],{"#text":2290},{"@_valign":1549,"@_align":1550,"@_colspan":818},{"#text":1543},{"#text":1543},{"tr":3831},[3832,3833,3837,3838,3843,3844,3849,3850,3855,3856,3861],{"#text":2290},{"td":3834,":@":3836},[3835],{"#text":3626},{"@_valign":1549,"@_align":1550},{"#text":2290},{"td":3839,":@":3842},[3840],{"#text":3841},"–34.80",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3845,":@":3848},[3846],{"#text":3847},"–35.60",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3851,":@":3854},[3852],{"#text":3853},"34.80",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3857,":@":3860},[3858],{"#text":3859},"–33.60",{"@_valign":1549,"@_align":1557},{"#text":1543},{"#text":1543},{"tr":3864},[3865,3866,3870,3871,3876,3877,3882,3883,3888,3889,3894],{"#text":2290},{"td":3867,":@":3869},[3868],{"#text":3660},{"@_valign":1549,"@_align":1550},{"#text":2290},{"td":3872,":@":3875},[3873],{"#text":3874},"–35.26",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3878,":@":3881},[3879],{"#text":3880},"–36.19",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3884,":@":3887},[3885],{"#text":3886},"35.26",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3890,":@":3893},[3891],{"#text":3892},"–34.37",{"@_valign":1549,"@_align":1557},{"#text":1543},{"#text":1543},{"tr":3897},[3898,3899,3904,3905,3910,3911,3916,3917,3922,3923,3928],{"#text":2290},{"td":3900,":@":3903},[3901],{"#text":3902},"Frequency of the MFE structure",{"@_valign":1549,"@_align":1550},{"#text":2290},{"td":3906,":@":3909},[3907],{"#text":3908},"  47.49",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3912,":@":3915},[3913],{"#text":3914},"  38.16",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3918,":@":3921},[3919],{"#text":3920},"47.51",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3924,":@":3927},[3925],{"#text":3926},"  28.84",{"@_valign":1549,"@_align":1557},{"#text":1543},{"#text":1543},{"tr":3931},[3932,3933,3937,3938,3943,3944,3949,3950,3955,3956,3961],{"#text":2290},{"td":3934,":@":3936},[3935],{"#text":3728},{"@_valign":1549,"@_align":1550},{"#text":2290},{"td":3939,":@":3942},[3940],{"#text":3941},"    2.90",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3945,":@":3948},[3946],{"#text":3947},"    2.42",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3951,":@":3954},[3952],{"#text":3953},"   2.90",{"@_valign":1549,"@_align":1557},{"#text":2290},{"td":3957,":@":3960},[3958],{"#text":3959},"    2.97",{"@_valign":1549,"@_align":1557},{"#text":1543},{"#text":1539},{"#text":887},{"@_cellspacing":818,"@_cellpadding":818,"@_frame":1702,"@_rules":1703},{"#text":861},{"@_position":1719,"@_id":3511},{"#text":867},{"@_id":3969},"S3.SS1.SSS1",{"#text":867},{"sec":3972,":@":4024},[3973,3974,3978,3979,4001,4002,4023],{"#text":861},{"title":3975},[3976],{"#text":3977},"Pre-miR-182 nt105 C > T",{"#text":861},{"p":3980},[3981,3983,3987,3988,3993,3995,3999],{"#text":3982},"Pre-miR-182 nt105 C > T was identified in one CSNB and one CRD patient (",{"xref":3984,":@":3986},[3985],{"#text":2239},{"@_ref-type":1511,"@_rid":2241},{"#text":2243},{"xref":3989,":@":3992},[3990],{"#text":3991},"Figure 2C",{"@_ref-type":1747,"@_rid":2085},{"#text":3994},"), which are heterozygous for this allele. The overall frequency of the T allele in our IRD cohort: 0.085%. In SCNB: 3.125%; in CRD: 0.209% (",{"xref":3996,":@":3998},[3997],{"#text":2239},{"@_ref-type":1511,"@_rid":2241},{"#text":4000},"). This variant was not identified in any unaffected individuals. This variant is documented in dbSNP as a rare SNP rs77586312: with frequencies of the T allele 0.152% (184/121378), while the C allele 99.848% (121194/121378). Comparing to the general population data compiled at dbSNP, the rare pre-miR-183 nt105 T appears to be significantly enriched in CSNB patients in this cohort.",{"#text":861},{"p":4003},[4004,4006,4010,4012,4016,4018,4022],{"#text":4005},"This variant is also near the 3′ end of the hsa-pre-miR-182, located at the 6th nucleotide from the 3′ end (",{"xref":4007,":@":4009},[4008],{"#text":3463},{"@_ref-type":1747,"@_rid":2085},{"#text":4011},"). It results in a change of the classical Watson-Crick base pair G•C to a G•U wobble base pair. Secondary structure prediction by RNAfold suggest that nt105 C > T variant may induce changes in the basal segment of the stem of pre-miR-182 (the bracketed area in ",{"xref":4013,":@":4015},[4014],{"#text":3502},{"@_ref-type":1747,"@_rid":3504},{"#text":4017},"), although it did not cause drastic changes of the minimum free energy (",{"xref":4019,":@":4021},[4020],{"#text":3509},{"@_ref-type":1511,"@_rid":3511},{"#text":1122},{"#text":867},{"@_id":4025},"S3.SS1.SSS2",{"#text":867},{"sec":4028,":@":4085},[4029,4030,4034,4035,4056,4057,4061,4062,4084],{"#text":861},{"title":4031},[4032],{"#text":4033},"Pre-miR-182 nt94 G > A",{"#text":861},{"p":4036},[4037,4039,4043,4044,4049,4051,4055],{"#text":4038},"Pre-miR-182 nt94 G > A was identified in one Usher syndrome, two unrelated Stargardt disease, one PD and AOFD and three unrelated other RP patients, as well as in one unaffected individual (",{"xref":4040,":@":4042},[4041],{"#text":2239},{"@_ref-type":1511,"@_rid":2241},{"#text":2243},{"xref":4045,":@":4048},[4046],{"#text":4047},"Figure 2D",{"@_ref-type":1747,"@_rid":2085},{"#text":4050},"). All are heterozygous for this allele. The overall frequency of this variant in all IRD patients in this cohort was 0.297%. It has a frequency of 0.676% in Usher syndrome; 0.413% in Stargardt disease; 0.476% in PD and AOFD; 0.295% in other RP patients. In unaffected individuals: 0.625% (",{"xref":4052,":@":4054},[4053],{"#text":2239},{"@_ref-type":1511,"@_rid":2241},{"#text":1122},{"#text":861},{"p":4058},[4059],{"#text":4060},"Pre-miR-182 t94 G > A is documented as a rare tri-allelic SNP rs80041074 with minor allele frequency as A 0.389% (475/121998), T allele 0.001% (1/121998), while the common allele G has a frequency of 99.61% (121522/121998) in the dbSNP (dbSNP build 151).",{"#text":861},{"p":4063},[4064,4066,4070,4072,4076,4078,4082],{"#text":4065},"This SNP is located at the 17th nucleotide from the 3′ end of the hsa-pre-miR-182. It disrupts a C•G in the predicted hair-pin structure (",{"xref":4067,":@":4069},[4068],{"#text":3463},{"@_ref-type":1747,"@_rid":2085},{"#text":4071},"). Secondary structure prediction by RNAfold showed that nt94 G > A change may induce changes in the size of the bulge (bracketed area in ",{"xref":4073,":@":4075},[4074],{"#text":3502},{"@_ref-type":1747,"@_rid":3504},{"#text":4077},") of the secondary structure of pre-miR-182, resulting in an increase of the minimum free energy level (",{"xref":4079,":@":4081},[4080],{"#text":3509},{"@_ref-type":1511,"@_rid":3511},{"#text":4083},". from −47.10 to −43.80) at its thermodynamic ground state. However, whether these changes impose any impact on miR-182 maturation need to be test experimentally.",{"#text":867},{"@_id":4086},"S3.SS1.SSS3",{"#text":946},{"@_id":4089},"S3.SS1",{"#text":946},{"sec":4092,":@":4547},[4093,4094,4098,4099,4108,4109,4164,4165,4219,4220,4283,4284,4546],{"#text":867},{"title":4095},[4096],{"#text":4097},"Sequence Variants in Hsa-pre-miR-96",{"#text":867},{"p":4100},[4101,4103,4107],{"#text":4102},"We identified three sequence variants in pre-miR-94: nt36 T > C, nt39 C > T and nt42 C > T (",{"xref":4104,":@":4106},[4105],{"#text":2091},{"@_ref-type":1747,"@_rid":2093},{"#text":1122},{"#text":867},{"sec":4110,":@":4162},[4111,4112,4116,4117,4139,4140,4144,4145,4161],{"#text":861},{"title":4113},[4114],{"#text":4115},"Pre-miR-96 nt36 T > C",{"#text":861},{"p":4118},[4119,4121,4125,4126,4131,4133,4138],{"#text":4120},"The pre-miR-96 nt36 T > C was identified in three unrelated RP patients heterozygous for this allele, but not in any other IRD patients and unaffected controls (",{"xref":4122,":@":4124},[4123],{"#text":2239},{"@_ref-type":1511,"@_rid":2241},{"#text":2243},{"xref":4127,":@":4130},[4128],{"#text":4129},"Figure 3A",{"@_ref-type":1747,"@_rid":2093},{"#text":4132},"). The minor C allele has a frequency of 0.295% in RP patients, 0.127% in all IRD patients. This variant is located in the loop region of hsa-pre-miR-96 (",{"xref":4134,":@":4137},[4135],{"#text":4136},"Figure 3D",{"@_ref-type":1747,"@_rid":2093},{"#text":1122},{"#text":861},{"p":4141},[4142],{"#text":4143},"The pre-miR-96 nt36 T > C variant is known as a rare SNP rs41274239 with allele frequencies of 0.249% (65/26162) for the minor C allele; 99.752% (26097/26162) for the common T allele based on data from UCSC genome browser (dbSNP build 151).",{"#text":861},{"p":4146},[4147,4149,4154,4156,4160],{"#text":4148},"Secondary structure prediction using RNAfold showed that pre-miR-96 nt36 T > C may change the landscape of the terminal loop of pre-miR-96 (the bracketed area in ",{"xref":4150,":@":4153},[4151],{"#text":4152},"Figure 4B",{"@_ref-type":1747,"@_rid":3504},{"#text":4155},") at its thermodynamic ground state, although this change did not induce drastic changes in the free energy of the secondary structure of pre-miR-96 (",{"xref":4157,":@":4159},[4158],{"#text":3509},{"@_ref-type":1511,"@_rid":3511},{"#text":1122},{"#text":867},{"@_id":4163},"S3.SS2.SSS1",{"#text":867},{"sec":4166,":@":4217},[4167,4168,4172,4173,4195,4196,4216],{"#text":861},{"title":4169},[4170],{"#text":4171},"Pre-miR-96 nt39 C > T",{"#text":861},{"p":4174},[4175,4177,4181,4182,4187,4189,4193],{"#text":4176},"The pre-miR-96 nt39 C > T variant was identified in one Stargardt disease patient who is heterozygous for this allele (",{"xref":4178,":@":4180},[4179],{"#text":2239},{"@_ref-type":1511,"@_rid":2241},{"#text":2243},{"xref":4183,":@":4186},[4184],{"#text":4185},"Figure 3B",{"@_ref-type":1747,"@_rid":2093},{"#text":4188},"). In the study cohort, the minor T allele has a frequency of 0.207% in Stargardt disease patients, and 0.042% in all IRD patients. None was detected in the unaffected samples (",{"xref":4190,":@":4192},[4191],{"#text":2239},{"@_ref-type":1511,"@_rid":2241},{"#text":4194},"). This variant is documented as rare SNP rs73159662: C: 99.990% (10181/10182); T: 0.010% (1/10182) in dbSNP (build 151).",{"#text":861},{"p":4197},[4198,4200,4204,4206,4210,4211,4215],{"#text":4199},"This variant is also located in the stem loop region of the hsa-miR-96 (",{"xref":4201,":@":4203},[4202],{"#text":4136},{"@_ref-type":1747,"@_rid":2093},{"#text":4205},"). Secondary structure prediction by RNAfold program did not expect significant changes in the thermodynamic status of the secondary structure of pre-miR-96 (",{"xref":4207,":@":4209},[4208],{"#text":4152},{"@_ref-type":1747,"@_rid":3504},{"#text":2243},{"xref":4212,":@":4214},[4213],{"#text":3509},{"@_ref-type":1511,"@_rid":3511},{"#text":1122},{"#text":867},{"@_id":4218},"S3.SS2.SSS2",{"#text":867},{"sec":4221,":@":4281},[4222,4223,4227,4228,4237,4238,4242,4243,4280],{"#text":861},{"title":4224},[4225],{"#text":4226},"Pre-miR-96 nt42 C > T",{"#text":861},{"p":4229},[4230,4232,4236],{"#text":4231},"This variant was identified in two unrelated Stargardt disease patients heterozygous for this allele. In the study cohort, the minor T allele in Stargardt disease patient is 0.413%, while the overall frequency in all IRD is 0.085% (",{"xref":4233,":@":4235},[4234],{"#text":2239},{"@_ref-type":1511,"@_rid":2241},{"#text":1122},{"#text":861},{"p":4239},[4240],{"#text":4241},"Pre-miR-96 nt42 C > T variant is documented as a rare SNP rs73159662 with the minor allele T frequency as: 0.287% (75/26094), the common C allele 99.713% (26019/26095) in the dbSNP (build 151).",{"#text":861},{"p":4244},[4245,4247,4251,4253,4257,4259,4263,4265,4271,4272,4278],{"#text":4246},"This variant is predicted to disrupt the classical Watson-Crick base pair G•C at the first residue after the terminal loop of the predicted hsa-pre-miR-96 structure (miRbase) (",{"xref":4248,":@":4250},[4249],{"#text":4136},{"@_ref-type":1747,"@_rid":2093},{"#text":4252},"), suggesting potential impact on the structures around the terminal loop. Secondary structure prediction by RNAfold algorithm suggested that nt42 C > T may induce similar changes in the terminal loop of pre-miR-96 at its thermodynamic ground state, as did the pre-miR-96 nt36 T > C variant (the bracketed area in ",{"xref":4254,":@":4256},[4255],{"#text":4152},{"@_ref-type":1747,"@_rid":3504},{"#text":4258},"), although it did not induce drastic changes in the free energy of the secondary structure of pre-miR-96 (",{"xref":4260,":@":4262},[4261],{"#text":3509},{"@_ref-type":1511,"@_rid":3511},{"#text":4264},"). Since the terminal loops of pre-miRNAs can play important roles in miRNA biogenesis (",{"xref":4266,":@":4269},[4267],{"#text":4268},"Castilla-Llorente et al., 2013",{"@_ref-type":967,"@_rid":4270},"B8",{"#text":997},{"xref":4273,":@":4276},[4274],{"#text":4275},"Treiber et al., 2019",{"@_ref-type":967,"@_rid":4277},"B72",{"#text":4279},"), whether these variants impose significant impact on miR-96 maturation should be further studied.",{"#text":867},{"@_id":4282},"S3.SS2.SSS3",{"#text":867},{"sec":4285,":@":4544},[4286,4287,4291,4292,4434,4435,4447,4448,4492,4493,4509,4510,4543],{"#text":861},{"title":4288},[4289],{"#text":4290},"Segregation Study in a Family, Family 4100, of a Proband Homozygous for Pre-miR-182 nt106 G > A Variant",{"#text":861},{"p":4293},[4294,4296,4302,4304,4308,4310,4314,4316,4320,4322,4328,4330,4334,4336,4342,4344,4348,4349,4353,4354,4358,4359,4363,4364,4368,4370,4376,4377,4383,4384,4390,4391,4397,4398,4404,4406,4412,4413,4419,4420,4426,4427,4433],{"#text":4295},"In spite that the pre-miR-182 nt106 G > A is common variant with a frequency of 5.952% in general population (dbSNP), it was reported that minor A allele is associated with higher risk of late insomnia in major depression patients (",{"xref":4297,":@":4300},[4298],{"#text":4299},"Saus et al., 2010",{"@_ref-type":967,"@_rid":4301},"B68",{"#text":4303},"). ",{"italic":4305},[4306],{"#text":4307},"In vitro",{"#text":4309}," expression studies showed that the A allele resulted in an increased production of mature miR-182 and enhanced inhibition of its target genes (",{"xref":4311,":@":4313},[4312],{"#text":4299},{"@_ref-type":967,"@_rid":4301},{"#text":4315},"). In addition, pre-miR-182 nt106 G > A is also reported to be associated with high tension glaucoma (HTG), but not normal tension glaucoma (NTG); the A allele gives 30% higher expression of mature miR-182 ",{"italic":4317},[4318],{"#text":4319},"in vitro",{"#text":4321}," transfection/expression experiment (",{"xref":4323,":@":4326},[4324],{"#text":4325},"Liu et al., 2016",{"@_ref-type":967,"@_rid":4327},"B42",{"#text":4329},"). Furthermore, this variant is also shown to be associated with genetic susceptibility to Behcet’s disease and Vogt-Koyanagi-Harada (VKH) syndrome, both of which have autoimmune uveitis; mature miR-182 showed an increased expression level in activated CD4",{"sup":4331},[4332],{"#text":4333},"+",{"#text":4335}," T cells of the patients with nt106 A allele than normal controls (",{"xref":4337,":@":4340},[4338],{"#text":4339},"Yu et al., 2014",{"@_ref-type":967,"@_rid":4341},"B88",{"#text":4343},"). These reports suggest that pre-miR-182 nt106 G > A variant may have significant impact on the maturation of miR-182, which play important roles in the differentiation of photoreceptors and the function of the retina and other sensory systems (",{"xref":4345,":@":4347},[4346],{"#text":1097},{"@_ref-type":967,"@_rid":1099},{"#text":997},{"xref":4350,":@":4352},[4351],{"#text":1104},{"@_ref-type":967,"@_rid":1106},{"#text":997},{"xref":4355,":@":4357},[4356],{"#text":1326},{"@_ref-type":967,"@_rid":1328},{"#text":997},{"xref":4360,":@":4362},[4361],{"#text":1354},{"@_ref-type":967,"@_rid":1356},{"#text":997},{"xref":4365,":@":4367},[4366],{"#text":1361},{"@_ref-type":967,"@_rid":1363},{"#text":4369},"). Consistent with this report, recent reports from us and others have shown that miR-183/96/182, including miR-182, is also expressed and plays important roles in the immune systems and autoimmune diseases (",{"xref":4371,":@":4374},[4372],{"#text":4373},"Stittrich et al., 2010",{"@_ref-type":967,"@_rid":4375},"B69",{"#text":997},{"xref":4378,":@":4381},[4379],{"#text":4380},"Donatelli et al., 2014",{"@_ref-type":967,"@_rid":4382},"B13",{"#text":997},{"xref":4385,":@":4388},[4386],{"#text":4387},"Ichiyama et al., 2016",{"@_ref-type":967,"@_rid":4389},"B23",{"#text":997},{"xref":4392,":@":4395},[4393],{"#text":4394},"Li et al., 2016",{"@_ref-type":967,"@_rid":4396},"B41",{"#text":997},{"xref":4399,":@":4402},[4400],{"#text":4401},"Muraleedharan et al., 2016",{"@_ref-type":967,"@_rid":4403},"B54",{"#text":4405},", ",{"xref":4407,":@":4410},[4408],{"#text":4409},"2019",{"@_ref-type":967,"@_rid":4411},"B55",{"#text":997},{"xref":4414,":@":4417},[4415],{"#text":4416},"Wan et al., 2016",{"@_ref-type":967,"@_rid":4418},"B76",{"#text":997},{"xref":4421,":@":4424},[4422],{"#text":4423},"Wurm et al., 2017",{"@_ref-type":967,"@_rid":4425},"B82",{"#text":997},{"xref":4428,":@":4431},[4429],{"#text":4430},"Wang et al., 2019",{"@_ref-type":967,"@_rid":4432},"B77",{"#text":1122},{"#text":861},{"p":4436},[4437,4439,4445],{"#text":4438},"If the A allele does affect the miR-182 maturation and contribute to various diseases, we hypothesized that homozygosity of pre-miR-182 nt106 G > A may have significant functional impact on mature miR-182 expression and contribute to syndromic IRD. To test this hypothesis, we collected DNA samples from several members of a family – Family 4100, in which multiple members have Stargardt disease and the proband, II-2, is homozygous for the less common, pre-miR-182 nt106 A allele (A/A) (",{"xref":4440,":@":4443},[4441],{"#text":4442},"Figure 5A",{"@_ref-type":1747,"@_rid":4444},"F5",{"#text":4446},"). To test whether the Stargardt disease is associated with syndromic immune defects, we expanded our clinical observation to include both retinal and immune/inflammatory symptoms. The proband was diagnosed to have Stargardt disease at age of 65 in 2019 with clear vitreous, normal optic nerve, normal retinal vessels, pigmentary changes throughout macula, GA OU (both eyes), mfERG results in 2013 were abnormal surrounding the fovea, visual fields showed central scotoma and general reduction of sensitivity. However, his vision acuity has stayed remarkably good (20/20 and 20/50 in 2019). Patient reports unknown autoimmune ear disease leading to a sudden and permanent hearing loss in the left ear in 2004, and thought to be attributed to psoriatic arthritis. Patient also reports mild flares of arthritis in thumbs and knee. One sister of the proband, II-3, was diagnosed with Stargardt disease in 2016 with pigmentary changes throughout macula (flecks). She has no reported auto-immune disease diagnosed. Another sister of the proband, II-5, is also diagnosed with Stargardt disease and was reported to have Lupus-like symptoms, although they have not been accurately diagnosed.",{"#text":861},{"fig":4449,":@":4491},[4450,4451,4455,4456,4485,4486,4490],{"#text":887},{"label":4452},[4453],{"#text":4454},"FIGURE 5",{"#text":887},{"caption":4457},[4458,4459,4484],{"#text":1539},{"p":4460},[4461,4463,4466,4468,4472,4474,4477,4479,4482],{"#text":4462},"Inheritance patterns of the pre-miR-182 nt106 G/A allele and the expression levels of mature miR-182 in peripheral blood mononuclear cells (PBMNC) in a family with multiple cases of Stargardt disease -Family 4100. ",{"bold":4464},[4465],{"#text":1782},{"#text":4467}," the family pedigree. Proband II-2 and his brother II-4 are homozygous for the less common pre-miR-182 nt106 A allele (A/A); while II-5, III-1, 2, 3 are heterozygous (G/A) for this allele. Red: with Stargardt disease. Blue: with Complaint of autoimmune disease(s). ",{"bold":4469},[4470],{"#text":4471},"(B,C)",{"#text":4473}," qRT-PCR on pre-miR-182 in the PBMNC of selected family members. *",{"italic":4475},[4476],{"#text":2040},{"#text":4478}," \u003C 0.05; ***",{"italic":4480},[4481],{"#text":2040},{"#text":4483}," \u003C 0.001.",{"#text":887},{"#text":887},{"graphic":4487,":@":4488},[],{"@_xlink:href":4489},"fcell-08-619641-g005.tif",{"#text":861},{"@_id":4444,"@_position":1719},{"#text":861},{"p":4494},[4495,4497,4501,4503,4507],{"#text":4496},"To test whether the Stargardt disease and/or the autoimmune symptoms segregate with the A/A homozygosity, blood samples were collected from individual II2, 4, 5 and III-1,2,3. Unfortunately, genotyping on the pre-miR-182 showed that neither the Stargardt disease nor the autoimmune symptoms segregated with pre-miR-182 nt106 A/A homozygosity (",{"xref":4498,":@":4500},[4499],{"#text":4442},{"@_ref-type":1747,"@_rid":4444},{"#text":4502},"). II-4, homozygous to A/A, is phenotypically normal; while II-5 and III-3, who are heterozygous (G/A) for the pre-miR-182 nt106 allele, are affected with Stargardt disease, as well as autoimmune symptom (for II-5) (",{"xref":4504,":@":4506},[4505],{"#text":4442},{"@_ref-type":1747,"@_rid":4444},{"#text":4508},"). Therefore, homozygosity of pre-miR-182 nt106 A/A is unlikely to be the cause of the Stargardt disease and autoimmune symptoms in this family.",{"#text":861},{"p":4511},[4512,4514,4519,4521,4525,4526,4530,4531,4535,4537,4541],{"#text":4513},"To test whether the pre-miR-182 nt106 G > A variant has any impact on the expression levels of mature miR-182, we isolated RNA from PBMNC in these family members. qRT-PCR result showed no clear correlation between the expression levels of mature miR-182 and the genotype of pre-miR-182 nt106 alleles (A/A or G/A) (",{"xref":4515,":@":4518},[4516],{"#text":4517},"Figures 5B,C",{"@_ref-type":1747,"@_rid":4444},{"#text":4520},"). Homozygosity for the pre-miR-182 nt106 A allele (A/A) did not show increased expression of mature miR-182, as described by previous reports (",{"xref":4522,":@":4524},[4523],{"#text":4299},{"@_ref-type":967,"@_rid":4301},{"#text":997},{"xref":4527,":@":4529},[4528],{"#text":4339},{"@_ref-type":967,"@_rid":4341},{"#text":997},{"xref":4532,":@":4534},[4533],{"#text":4325},{"@_ref-type":967,"@_rid":4327},{"#text":4536},"). On the contrary, mature miR-182 in PBMNC from individuals with G/A allele had an increasing trend than the ones with A/A allele (",{"xref":4538,":@":4540},[4539],{"#text":4517},{"@_ref-type":1747,"@_rid":4444},{"#text":4542},"), although the difference did not pass statistical significance threshold, because of limited number of samples.",{"#text":867},{"@_id":4545},"S3.SS2.SSS4",{"#text":946},{"@_id":4548},"S3.SS2",{"#text":949},{"@_id":4551},"S3",{"#text":949},{"sec":4554,":@":5214},[4555,4556,4560,4561,4680,4681,4690,4691,4872,4873,4912,4913,5024,5025,5080,5081,5195,5196,5200,5201,5213],{"#text":946},{"title":4557},[4558],{"#text":4559},"Discussion",{"#text":946},{"p":4562},[4563,4565,4569,4571,4577,4579,4585,4587,4591,4593,4597,4599,4603,4604,4608,4609,4613,4614,4618,4620,4626,4628,4634,4635,4641,4642,4648,4650,4656,4658,4664,4665,4671,4672,4678],{"#text":4564},"By far, only three miRNAs, miR-96, miR-184 and miR-204, have been identified to cause inherited diseases in human when mutated. Point mutations in the seed region of the mature miR-96 (nt13 G > A and nt14 C > A) cause autosomal dominant non-syndromic hearing loss (",{"xref":4566,":@":4568},[4567],{"#text":1178},{"@_ref-type":967,"@_rid":1180},{"#text":4570},"). A point mutation in the seed sequence of miR-184 (nt57 C > U) is reported to cause autosomal dominant, familial keratoconus with early onset anterior polar cataract (",{"xref":4572,":@":4575},[4573],{"#text":4574},"Hughes et al., 2011",{"@_ref-type":967,"@_rid":4576},"B21",{"#text":4578},") and an autosomal dominant syndromic anterior segment dysgenesis – the endothelial dystrophy, iris hypoplasia, congenital cataract, and stromal thinning (EDICT) syndrome (",{"xref":4580,":@":4583},[4581],{"#text":4582},"Iliff et al., 2012",{"@_ref-type":967,"@_rid":4584},"B24",{"#text":4586},"). A dominant mutation in miR-204, nt37 C > T, causes an autosomal dominant IRD associated with bilateral ocular coloboma (",{"xref":4588,":@":4590},[4589],{"#text":1068},{"@_ref-type":967,"@_rid":1070},{"#text":4592},") – the first and only report that a point mutation in an individual miRNA results in significant functional consequence and causes IRD in human. In these three cases, the disease-causing mutations are all in the seed sequences of mature miRNAs. The seed sequence of a miRNA is one of the most important determinants of its downstream target genes and hence functions (",{"xref":4594,":@":4596},[4595],{"#text":1076},{"@_ref-type":967,"@_rid":1078},{"#text":4598},"). These mutations in the seed sequences of miR-96, miR-184, and miR-204 resulted in both loss and gain of function effects – loss of control of normal target genes while creating new, abnormal target genes, leading to global dysregulation of gene expression and dominant inherited diseases (",{"xref":4600,":@":4602},[4601],{"#text":1178},{"@_ref-type":967,"@_rid":1180},{"#text":997},{"xref":4605,":@":4607},[4606],{"#text":4574},{"@_ref-type":967,"@_rid":4576},{"#text":997},{"xref":4610,":@":4612},[4611],{"#text":4582},{"@_ref-type":967,"@_rid":4584},{"#text":997},{"xref":4615,":@":4617},[4616],{"#text":1068},{"@_ref-type":967,"@_rid":1070},{"#text":4619},"). Here we identified three sequence variants in pre-miR-182; three sequence variants in pre-miR-96 among 1179 patients with various forms of IRD. All of these sequence variants are located in the pre-miR-182 or pre-miR-96, but not in the mature miR-182 or miR-96. Therefore, they won’t have any impact on the spectrum of downstream targets of miR-182 or miR-96. In addition, these variants are all known SNPs which have been identified in the general population and reported in the dbSNP. Therefore, the sequence variants that we identified so far are less likely to be the disease-causing mutations responsible for the IRD symptoms in these patients. In the CSNB group, the rare pre-miR-182 nt105 T appears to be significantly enriched in CSNB patients when compared to the general population data compiled at dbSNP; however, we only have a small number of CSNB patients in this cohort; whether this “enrichment” is of biological significance or a random bias because of the small number of samples needs to be further investigated in future studies with more CSNB patient samples. In our cohort of a total of 1179 patients, five probands (0.42%) were found homozygous for the pre-miR-182 nt106 G > A (rs76481776). Although there is no data on the homozygosity of this variant in the general population, it is reasonable to predict a ∼0.35% frequency in the general population based on its 5.952% allele frequency, which is similar to the frequency in our cohort (0.42%). In Family 4100, in which multiple members are diagnosed with Stargardt disease and the proband is homozygous for the minor pre-miR-182 nt106 A allele, homozygosity of the A allele did not segregate with either the Stargardt disease or autoimmune symptoms in members of this family, suggesting that it is unlikely to be the cause for these diseases. While we were investigating on mutations in miR-183/96/182, eyeGENE continued on the screening in protein-coding genes and identified that the proband of Family 4100 was heterozygous for ABCA4 c.5461-10T > C VUS (variant of uncertain significance). This variant is located in intron 38 of the ABCA4 gene. It was first discovered in 1999 in Stargardt disease patients (",{"xref":4621,":@":4624},[4622],{"#text":4623},"Maugeri et al., 1999",{"@_ref-type":967,"@_rid":4625},"B47",{"#text":4627},"), and has been described as the third most frequent gene variant associated with Stargardt disease in individuals with European or African descent (",{"xref":4629,":@":4632},[4630],{"#text":4631},"Zernant et al., 2011",{"@_ref-type":967,"@_rid":4633},"B89",{"#text":997},{"xref":4636,":@":4639},[4637],{"#text":4638},"Roberts et al., 2012",{"@_ref-type":967,"@_rid":4640},"B65",{"#text":997},{"xref":4643,":@":4646},[4644],{"#text":4645},"Miraldi Utz et al., 2014",{"@_ref-type":967,"@_rid":4647},"B51",{"#text":4649},"). Although it was initially identified as a sequence variant without significant functional consequence (",{"xref":4651,":@":4654},[4652],{"#text":4653},"Rivera et al., 2000",{"@_ref-type":967,"@_rid":4655},"B64",{"#text":4657},"), recent reports suggest that this mutation results in a decreased expression level of wild type ABCA4 and splicing defects with exons 39/40 skipped, leading to frameshift and premature stop, playing a causative and a pathological role in Stargardt disease (",{"xref":4659,":@":4662},[4660],{"#text":4661},"Sangermano et al., 2016",{"@_ref-type":967,"@_rid":4663},"B66",{"#text":997},{"xref":4666,":@":4669},[4667],{"#text":4668},"Aukrust et al., 2017",{"@_ref-type":967,"@_rid":4670},"B3",{"#text":997},{"xref":4673,":@":4676},[4674],{"#text":4675},"Jonsson et al., 2018",{"@_ref-type":967,"@_rid":4677},"B26",{"#text":4679},"). We predict that the intronic mutation, c.5461-10T > C in ABCA4, contributes to the Stargardt disease in Family 4100. Further investigation is required to determine whether the disease in this family is solely caused by the ABCA4 c.5461-10T > C variant or whether mutations in other genes are involved.",{"#text":946},{"p":4682},[4683,4685,4688],{"#text":4684},"Therefore, we haven’t yet identified disease-causing mutations in the miR-183/96/182 cluster in human. However, this is the first stage of a long-term study. The negative results so far cannot exclude miR-183/96/182 as a disease-causing gene in these IRD patients yet. In current study, the mutation screening is purely focused on the sequences of pre-miR-183/-96/-182. In the next stage of our study, we plan to sequence the entire genomic region of the miR-183/96/182 gene to test whether there are mutations in the promoter/enhancer and other regions of the miR-183/96/182 cluster gene which may affect the transcription and post-transcriptional regulation of the miR-183/96/182 cluster and contribute to or cause IRD in these patients. We are aware of the challenges to the identification of disease-causing mutations in this cohort. First, most IRD patients are sporadic cases without family history, inheritance pattern and DNA samples from other members of the family. Second, no RNA and other tissue samples from the same patients are available to test the expression levels of miR-183/96/182 in the retina or other tissues. To meet these challenges, as we showed in Family 4100, we extended our collaboration with dedicated physician scientists and candidate family members to obtain additional family history and samples to make conclusive studies, once clues are identified in the initial screening. In addition, future studies including Crispr-Cas9-mediated mutagenesis in iPS cells in combination of ",{"italic":4686},[4687],{"#text":4319},{"#text":4689}," organogenesis will further help meet these challenges.",{"#text":946},{"p":4692},[4693,4695,4701,4702,4708,4709,4715,4716,4722,4724,4730,4731,4737,4739,4745,4747,4753,4754,4760,4761,4767,4769,4775,4776,4780,4781,4787,4789,4793,4794,4798,4799,4803,4804,4808,4810,4814,4815,4819,4820,4824,4825,4829,4830,4834,4836,4840,4842,4846,4847,4853,4854,4858,4859,4863,4865,4870],{"#text":4694},"In spite that we have not yet identified disease-causing mutations, studies on the rare sequence variants have stimulated greater insights into the potential of mutations of miR-183/96/182 in human diseases. Although these sequence variants are not expected to change the spectrum of downstream target genes of miR-182 or miR-96, we do not exclude the possibility that they have significant impact on miRNA biogenesis and maturation of the miR-182 or miR-96. miRNA biogenesis involves two RNase III-type enzymes, DROSHA in the nucleus (",{"xref":4696,":@":4699},[4697],{"#text":4698},"Lee et al., 2003",{"@_ref-type":967,"@_rid":4700},"B37",{"#text":997},{"xref":4703,":@":4706},[4704],{"#text":4705},"Denli et al., 2004",{"@_ref-type":967,"@_rid":4707},"B12",{"#text":997},{"xref":4710,":@":4713},[4711],{"#text":4712},"Han et al., 2004",{"@_ref-type":967,"@_rid":4714},"B20",{"#text":997},{"xref":4717,":@":4720},[4718],{"#text":4719},"Landthaler et al., 2004",{"@_ref-type":967,"@_rid":4721},"B35",{"#text":4723},") and DICER in the cytosol (",{"xref":4725,":@":4728},[4726],{"#text":4727},"Grishok et al., 2001",{"@_ref-type":967,"@_rid":4729},"B17",{"#text":997},{"xref":4732,":@":4735},[4733],{"#text":4734},"Hutvagner et al., 2001",{"@_ref-type":967,"@_rid":4736},"B22",{"#text":4738},"). Drosha and a dimer of its cofactor DGCR8 form the core of a heterotrimeric Microprocessor (",{"xref":4740,":@":4743},[4741],{"#text":4742},"Nguyen et al., 2015",{"@_ref-type":967,"@_rid":4744},"B58",{"#text":4746},"), which essentially determines the mature miRNA sequence, as Drosha generates the termini of pre-miRNA, from which ∼22 nt are measured by DICER (",{"xref":4748,":@":4751},[4749],{"#text":4750},"Auyeung et al., 2013",{"@_ref-type":967,"@_rid":4752},"B4",{"#text":997},{"xref":4755,":@":4758},[4756],{"#text":4757},"Fang and Bartel, 2015",{"@_ref-type":967,"@_rid":4759},"B15",{"#text":997},{"xref":4762,":@":4765},[4763],{"#text":4764},"Kim et al., 2017",{"@_ref-type":967,"@_rid":4766},"B27",{"#text":4768},"). The mammalian Microprocessor prefers a stem of 35 ± 1 bp, a terminal unstructured loop and single-stranded regions flanking the base of hairpin (",{"xref":4770,":@":4773},[4771],{"#text":4772},"Figure 6",{"@_ref-type":1747,"@_rid":4774},"F6",{"#text":997},{"xref":4777,":@":4779},[4778],{"#text":4757},{"@_ref-type":967,"@_rid":4759},{"#text":997},{"xref":4782,":@":4785},[4783],{"#text":4784},"Bartel, 2018",{"@_ref-type":967,"@_rid":4786},"B6",{"#text":4788},"). Throughout the stem, pairing is preferred, although a few mismatches or small bulges are tolerated. Several features of the hairpin structure of a pre-miRNA enhances the processing and help specify the sites of cleavage by Drosha (",{"xref":4790,":@":4792},[4791],{"#text":4772},{"@_ref-type":1747,"@_rid":4774},{"#text":997},{"xref":4795,":@":4797},[4796],{"#text":4750},{"@_ref-type":967,"@_rid":4752},{"#text":997},{"xref":4800,":@":4802},[4801],{"#text":4757},{"@_ref-type":967,"@_rid":4759},{"#text":997},{"xref":4805,":@":4807},[4806],{"#text":4784},{"@_ref-type":967,"@_rid":4786},{"#text":4809},"). Drosha recognizes the base of the hairpin, including the basal UG motif and the mismatched GHG motif (H = A, C or U), while DGCR8 dimer recognizes the apical region, including the apical UGU motif. Drosha and DGCR8 dimer act as a molecular caliper to measure the length of the stem (",{"xref":4811,":@":4813},[4812],{"#text":4750},{"@_ref-type":967,"@_rid":4752},{"#text":997},{"xref":4816,":@":4818},[4817],{"#text":4757},{"@_ref-type":967,"@_rid":4759},{"#text":997},{"xref":4821,":@":4823},[4822],{"#text":4742},{"@_ref-type":967,"@_rid":4744},{"#text":997},{"xref":4826,":@":4828},[4827],{"#text":4784},{"@_ref-type":967,"@_rid":4786},{"#text":997},{"xref":4831,":@":4833},[4832],{"#text":4772},{"@_ref-type":1747,"@_rid":4774},{"#text":4835},"). A 3′ flanking CNNC motif, ∼17–18 nt downstream of the Drosha cleavage site (",{"xref":4837,":@":4839},[4838],{"#text":4750},{"@_ref-type":967,"@_rid":4752},{"#text":4841},"), is recognized by auxiliary factors, e.g., SRp20 or p72, to enhance the processing (",{"xref":4843,":@":4845},[4844],{"#text":4750},{"@_ref-type":967,"@_rid":4752},{"#text":997},{"xref":4848,":@":4851},[4849],{"#text":4850},"Mori et al., 2014",{"@_ref-type":967,"@_rid":4852},"B53",{"#text":997},{"xref":4855,":@":4857},[4856],{"#text":4784},{"@_ref-type":967,"@_rid":4786},{"#text":997},{"xref":4860,":@":4862},[4861],{"#text":4772},{"@_ref-type":1747,"@_rid":4774},{"#text":4864},"). The pre-miR-182 nt94 G > A variant is located in the vicinity of the GHG motif; while pre-miR-182 nt106 G > A and nt105 C > T are located in the CNNC motif of the pri-miR-182 hairpin structure. These sequence variants may modulate the processing by the Microprocessor and result in changes in the production of mature miR-182. Our preliminary study on the expression of mature miR-182 in PBMNCs of the family with Stargardt disease (",{"xref":4866,":@":4869},[4867],{"#text":4868},"Figure 5C",{"@_ref-type":1747,"@_rid":4444},{"#text":4871},") showed a trend consistent with this hypothesis. The average expression levels of mature miR-182 in the individuals with homozygous nt106 A/A allele showed a decreased trend when compared to the ones heterozygous for this allele (nt106 G/A). However, we only obtained two samples with homozygous nt106 A/A allele because of its rarity, therefore, cannot make statistically significant conclusion yet. Further larger-scale study is needed to validate this result and prove our hypothesis. In addition, we’d clarify that the current study serves as the discovery stage of a long-term project. We will perform downstream experiments to evaluate the functional consequences and potential roles in diseases of all other variants in the future.",{"#text":946},{"fig":4874,":@":4911},[4875,4876,4880,4881,4905,4906,4910],{"#text":867},{"label":4877},[4878],{"#text":4879},"FIGURE 6",{"#text":867},{"caption":4882},[4883,4884,4904],{"#text":861},{"p":4885},[4886,4888,4892,4893,4897,4898,4902],{"#text":4887},"Structural and primary sequence features of pri-miRNA stem of canonical miRNA hairpin (modified from ",{"xref":4889,":@":4891},[4890],{"#text":4757},{"@_ref-type":967,"@_rid":4759},{"#text":997},{"xref":4894,":@":4896},[4895],{"#text":4742},{"@_ref-type":967,"@_rid":4744},{"#text":997},{"xref":4899,":@":4901},[4900],{"#text":4784},{"@_ref-type":967,"@_rid":4786},{"#text":4903},"). A canonical miRNA hairpin includes a 35 +/− 1 bp stem, an unstructured terminal loop and singled stranded flanking regions. A basal UG motif, a mismatched GHG motif (H = A, C or U), an apical UGU motif, and flanking CNNC (N = any of the four nucleotides) motif enhance the processing and the precision of Drosha cleavage (red arrowheads). Purple arrowheads mark the sites for DICER cleavage.",{"#text":867},{"#text":867},{"graphic":4907,":@":4908},[],{"@_xlink:href":4909},"fcell-08-619641-g006.tif",{"#text":946},{"@_id":4774,"@_position":1719},{"#text":946},{"p":4914},[4915,4917,4923,4924,4930,4932,4938,4939,4945,4946,4952,4954,4960,4961,4967,4969,4973,4974,4978,4980,4984,4986,4990,4991,4997,4998,5002,5003,5007,5008,5012,5013,5017,5018,5022],{"#text":4916},"Intriguingly, all three sequence variants identified in pre-miR-96 are in the terminal loop of pri-miR-96 hairpin structure. Recent reports demonstrate that increasing number of RNA binding proteins (RBPs) recognize the terminal loops of selective pri-miRNA hairpin structures, e.g., Lin28a (",{"xref":4918,":@":4921},[4919],{"#text":4920},"Viswanathan et al., 2008",{"@_ref-type":967,"@_rid":4922},"B75",{"#text":997},{"xref":4925,":@":4928},[4926],{"#text":4927},"Nam et al., 2011",{"@_ref-type":967,"@_rid":4929},"B57",{"#text":4931},"), hnRNPA1 (",{"xref":4933,":@":4936},[4934],{"#text":4935},"Guil and Caceres, 2007",{"@_ref-type":967,"@_rid":4937},"B19",{"#text":997},{"xref":4940,":@":4943},[4941],{"#text":4942},"Michlewski et al., 2008",{"@_ref-type":967,"@_rid":4944},"B50",{"#text":997},{"xref":4947,":@":4950},[4948],{"#text":4949},"Kooshapur et al., 2018",{"@_ref-type":967,"@_rid":4951},"B30",{"#text":4953},"), KSRP (",{"xref":4955,":@":4958},[4956],{"#text":4957},"Trabucchi et al., 2009",{"@_ref-type":967,"@_rid":4959},"B71",{"#text":997},{"xref":4962,":@":4965},[4963],{"#text":4964},"Michlewski and Caceres, 2010",{"@_ref-type":967,"@_rid":4966},"B49",{"#text":4968},"), to modulate the processing of pri-miRNAs by the Microprocessor and/or pre-miRNA by Dicer (",{"xref":4970,":@":4972},[4971],{"#text":4268},{"@_ref-type":967,"@_rid":4270},{"#text":997},{"xref":4975,":@":4977},[4976],{"#text":4275},{"@_ref-type":967,"@_rid":4277},{"#text":4979},"). The temporal and tissue specificity of the expression of these RBPs may play a role in defining the expression pattern and function of selective miRNAs at a given time and in a given cell type (",{"xref":4981,":@":4983},[4982],{"#text":4268},{"@_ref-type":967,"@_rid":4270},{"#text":4985},"). It is reasonable to speculate that the sequence variants in pre-miR-96 may have consequential impact on the maturation and expression levels of mature miR-96. Since miR-182 and miR-96 are among the highest expressed miRNAs and play important roles in the functional differentiation of photoreceptors, hair cells and other sensory neurons (",{"xref":4987,":@":4989},[4988],{"#text":1152},{"@_ref-type":967,"@_rid":1154},{"#text":4405},{"xref":4992,":@":4995},[4993],{"#text":4994},"2011",{"@_ref-type":967,"@_rid":4996},"B78",{"#text":997},{"xref":4999,":@":5001},[5000],{"#text":1159},{"@_ref-type":967,"@_rid":1161},{"#text":997},{"xref":5004,":@":5006},[5005],{"#text":1097},{"@_ref-type":967,"@_rid":1099},{"#text":997},{"xref":5009,":@":5011},[5010],{"#text":1104},{"@_ref-type":967,"@_rid":1106},{"#text":997},{"xref":5014,":@":5016},[5015],{"#text":1326},{"@_ref-type":967,"@_rid":1328},{"#text":997},{"xref":5019,":@":5021},[5020],{"#text":1341},{"@_ref-type":967,"@_rid":1343},{"#text":5023},"), if these sequence variants have significant influence on the production of mature miR-182 or miR-96, we further hypothesize that these changes could impose quantitative modulation on the functions of photoreceptors and other sensory neurons and confer susceptibility to various types of IRDs and syndromic diseases in other sensory organs.",{"#text":946},{"p":5026},[5027,5029,5033,5034,5038,5040,5044,5046,5050,5051,5055,5057,5061,5063,5067,5069,5073,5075,5079],{"#text":5028},"As we mentioned earlier, recent discoveries from us and other groups have greatly expanded our knowledge on the miR-183/96/182 cluster. In addition to the sensory organs, miR-183/96/182 cluster plays important roles in both innate and adaptive immune systems. In innate immune system, we demonstrated that miR-183/96/182 cluster is expressed in macrophages and neutrophils and modulates their phagocytosis and intracellular bacterial killing capacity and their inflammatory response to bacterial infection through targeting Nox2 and DAP12 (",{"xref":5030,":@":5032},[5031],{"#text":4401},{"@_ref-type":967,"@_rid":4403},{"#text":4405},{"xref":5035,":@":5037},[5036],{"#text":4409},{"@_ref-type":967,"@_rid":4411},{"#text":5039},"). Inactivation of miR-183/96/182 cluster in mice resulted in increased phagocytosis and bactericidal capacity and decreased production of pro-inflammatory cytokines in response to ",{"italic":5041},[5042],{"#text":5043},"Pseudomonas aeruginosa",{"#text":5045}," (PA) infection and decreased overall severity of PA keratitis (",{"xref":5047,":@":5049},[5048],{"#text":4401},{"@_ref-type":967,"@_rid":4403},{"#text":4405},{"xref":5052,":@":5054},[5053],{"#text":4409},{"@_ref-type":967,"@_rid":4411},{"#text":5056},"). Wurm et al. further discovered that miR-182 modulates granulocytic differentiation through a negative regulatory loop with targeting transcription factor C/EBPα (",{"xref":5058,":@":5060},[5059],{"#text":4423},{"@_ref-type":967,"@_rid":4425},{"#text":5062},"). C/EBPα is a master regulator of myelopoiesis. It blocks miR-182 expression by direct promoter binding during myeloid differentiation; while miR-182 targets C/EBPα and impairs myelopoiesis and granulocytic differentiation (",{"xref":5064,":@":5066},[5065],{"#text":4423},{"@_ref-type":967,"@_rid":4425},{"#text":5068},"). miR-182 expression is highly elevated in acute myeloid leukemia (AML) patients with C/EBPα mutations disrupting its C-terminal DNA binding domain and is recommended as a prognostic marker in cytogenetically high-risk AML patients (",{"xref":5070,":@":5072},[5071],{"#text":4423},{"@_ref-type":967,"@_rid":4425},{"#text":5074},"). In natural killer (NK) cells, miR-183/96/182 cluster is induced by TGFβ and mediate TGFβ-induced inhibition of NK cell functions, e.g., tumor cytolysis, through targeting DAP12 (",{"xref":5076,":@":5078},[5077],{"#text":4380},{"@_ref-type":967,"@_rid":4382},{"#text":1122},{"#text":946},{"p":5082},[5083,5085,5089,5091,5095,5097,5101,5103,5107,5109,5113,5115,5118,5120,5123,5125,5128,5130,5134,5136,5140,5142,5148,5149,5154,5155,5159,5161,5165,5166,5170,5171,5175,5177,5181,5183,5188,5190,5194],{"#text":5084},"In adaptive immune system, we showed that miR-183/96/182 is involved in invariant NKT cell development, maturation and effector functions (",{"xref":5086,":@":5088},[5087],{"#text":4430},{"@_ref-type":967,"@_rid":4432},{"#text":5090},"). miR-182 and miR-183, but not miR-96, are shown to be drastically induced in activated helper T (Th) cells through the IL-2/CD25/STAT5 pathway (",{"xref":5092,":@":5094},[5093],{"#text":4373},{"@_ref-type":967,"@_rid":4375},{"#text":5096},"). miR-182 promotes clonal expansion of activated Th cells through targeting Foxo1 (",{"xref":5098,":@":5100},[5099],{"#text":4373},{"@_ref-type":967,"@_rid":4375},{"#text":5102},"). Furthermore, we and our collaborators further showed that in Th17 cells, induced by IL-6-STAT3 signaling, the miR-183/96/182 cluster promotes Th17 pathogenicity by targeting Foxo1-IL1r1 pathway (",{"xref":5104,":@":5106},[5105],{"#text":4387},{"@_ref-type":967,"@_rid":4389},{"#text":5108},"). Inactivation of miR-183/96/182 cluster in mice results in decreased production of pathogenic cytokines and decreased severity of experimental autoimmune encephalomyelitis (EAE) (",{"xref":5110,":@":5112},[5111],{"#text":4387},{"@_ref-type":967,"@_rid":4389},{"#text":5114},"). Another study suggested that miR-182 inhibits CD4",{"sup":5116},[5117],{"#text":4333},{"#text":5119},"CD25",{"sup":5121},[5122],{"#text":4333},{"#text":5124},"FoxP3",{"sup":5126},[5127],{"#text":4333},{"#text":5129}," regulatory T (Treg) cell differentiation (",{"xref":5131,":@":5133},[5132],{"#text":4416},{"@_ref-type":967,"@_rid":4418},{"#text":5135},"); knockdown of miR-182 results in increased Tregs in peripheral lymph nodes and spleen, contributing to decreased severity of EAE in mice (",{"xref":5137,":@":5139},[5138],{"#text":4416},{"@_ref-type":967,"@_rid":4418},{"#text":5141},"). In addition, miR-183/96/182 cluster is highly induced during B cell activation as well (",{"xref":5143,":@":5146},[5144],{"#text":5145},"Pucella et al., 2015",{"@_ref-type":967,"@_rid":5147},"B61",{"#text":4405},{"xref":5150,":@":5152},[5151],{"#text":4409},{"@_ref-type":967,"@_rid":5153},"B60",{"#text":997},{"xref":5156,":@":5158},[5157],{"#text":4394},{"@_ref-type":967,"@_rid":4396},{"#text":5160},"). In spite of its highly responsiveness to B cell activation, miR-183/96/182 ko or miR-182 ko mice have intact B-cell and T-cell development and follicular helper (Tfh) cell and germinal center (GC) B-cell population (",{"xref":5162,":@":5164},[5163],{"#text":5145},{"@_ref-type":967,"@_rid":5147},{"#text":4405},{"xref":5167,":@":5169},[5168],{"#text":4409},{"@_ref-type":967,"@_rid":5153},{"#text":997},{"xref":5172,":@":5174},[5173],{"#text":4394},{"@_ref-type":967,"@_rid":4396},{"#text":5176},"). However, miR-182 ko mice showed a delayed generation of antigen-specific antibody production at an early stage in the immunization regimen when challenged with a T-cell-dependent antigen and a complete impairment of antigen response in a T-cell-independent type II antigen challenge, suggesting that miR-182 is required for the extrafollicular antigen response (",{"xref":5178,":@":5180},[5179],{"#text":4394},{"@_ref-type":967,"@_rid":4396},{"#text":5182},"). Consistent with the functions of miR-183/96/182 cluster in immune systems, in an association study, ",{"xref":5184,":@":5187},[5185],{"#text":5186},"Yu et al. (2014)",{"@_ref-type":967,"@_rid":4341},{"#text":5189}," reported that the pre-miR-182 nt106 A allele is associated with genetic susceptibility to Behcet’s disease and Vogt-Koyanagi-Harada (VKH) syndrome, both of which are characterized with autoimmune uveitis (",{"xref":5191,":@":5193},[5192],{"#text":4339},{"@_ref-type":967,"@_rid":4341},{"#text":1122},{"#text":946},{"p":5197},[5198],{"#text":5199},"Collectively, these reports suggest that miR-183/96/182 cluster plays important roles in different aspects of the functions of various types of innate and adaptive immune cells and tumorigenesis, in addition to its essential roles in photoreceptors and other sensory neurons. Therefore, we predict that mutations in the miR-183/96/182 cluster and dysregulation of its expression may result in defects or phenotypic changes in different aspects of the immune system and the inflammatory/immune responses to antigen invasion and other external and internal pathological insults. Diseases caused by defects in the miR-183/96/182 are most possibly syndromic in nature with constellations of symptoms beyond either sensory or immune systems.",{"#text":946},{"p":5202},[5203,5205,5211],{"#text":5204},"Considering that miRNAs are quantitative regulators of gene expression and that immune/inflammation processes play important roles in normal aging and many multi-factorial retinal diseases, e.g., autoimmune uveitis, age-related macular degeneration, diabetic retinopathy, and glaucoma (",{"xref":5206,":@":5209},[5207],{"#text":5208},"Chen et al., 2019",{"@_ref-type":967,"@_rid":5210},"B9",{"#text":5212},"), we predict that sequence variants and other mutations in the miR-183/96/182 cluster may contribute to pathogenesis and enhance the susceptibility to these diseases. Studies on the functional consequence of the sequence variants or other mutations of miR-183/96/182 must be conducted in a broader context including both sensory and immune system as well as neuroimmune interactions.",{"#text":949},{"@_id":5215},"S4",{"#text":949},{"sec":5218,":@":5293},[5219,5220,5224,5225,5292],{"#text":946},{"title":5221},[5222],{"#text":5223},"Data Availability Statement",{"#text":946},{"p":5226},[5227,5229,5234,5235,5241,5245,5246,5251,5255,5256,5261,5265,5266,5271,5275,5277,5282,5286,5287,5291],{"#text":5228},"The datasets presented in this study can be found in online repositories. The names of the repository/repositories and accession number(s) can be found below: ",{"ext-link":5230,":@":5233},[5231],{"#text":5232},"https://www.ncbi.nlm.nih.gov/snp/",{"@_ext-link-type":920,"@_xlink:href":5232},{"#text":4405},{"ext-link":5236,":@":5239},[5237],{"#text":5238},"rs76481776",{"@_ext-link-type":5240,"@_xlink:href":5238},"DDBJ/EMBL/GenBank",{"ext-link":5242,":@":5244},[5243],{"#text":5232},{"@_ext-link-type":920,"@_xlink:href":5232},{"#text":4405},{"ext-link":5247,":@":5250},[5248],{"#text":5249},"rs77586312",{"@_ext-link-type":5240,"@_xlink:href":5249},{"ext-link":5252,":@":5254},[5253],{"#text":5232},{"@_ext-link-type":920,"@_xlink:href":5232},{"#text":4405},{"ext-link":5257,":@":5260},[5258],{"#text":5259},"rs80041074",{"@_ext-link-type":5240,"@_xlink:href":5259},{"ext-link":5262,":@":5264},[5263],{"#text":5232},{"@_ext-link-type":920,"@_xlink:href":5232},{"#text":4405},{"ext-link":5267,":@":5270},[5268],{"#text":5269},"rs41274239",{"@_ext-link-type":5240,"@_xlink:href":5269},{"ext-link":5272,":@":5274},[5273],{"#text":5232},{"@_ext-link-type":920,"@_xlink:href":5232},{"#text":5276},", and ",{"ext-link":5278,":@":5281},[5279],{"#text":5280},"rs73159662",{"@_ext-link-type":5240,"@_xlink:href":5280},{"ext-link":5283,":@":5285},[5284],{"#text":5232},{"@_ext-link-type":920,"@_xlink:href":5232},{"#text":4405},{"ext-link":5288,":@":5290},[5289],{"#text":5280},{"@_ext-link-type":5240,"@_xlink:href":5280},{"#text":2152},{"#text":949},{"@_id":5294},"S5",{"#text":949},{"sec":5297,":@":5309},[5298,5299,5303,5304,5308],{"#text":946},{"title":5300},[5301],{"#text":5302},"Ethics Statement",{"#text":946},{"p":5305},[5306],{"#text":5307},"The studies involving human participants were reviewed and approved by the IRB of Wayne State University, National Institutes of Health, and Committee for Protection of Human Subjects, University of Texas Southwestern Medical Center. The patients/participants provided their written informed consent to participate in this study.",{"#text":949},{"@_id":5310},"S6",{"#text":949},{"sec":5313,":@":5325},[5314,5315,5319,5320,5324],{"#text":946},{"title":5316},[5317],{"#text":5318},"Author Contributions",{"#text":946},{"p":5321},[5322],{"#text":5323},"SX: project conception, experimental design, data analysis, and manuscript preparation. AC, CM, AH, EM, CD, WL, JC, and WG: conducting the experiments and data analysis. KW and DB: sample collection and clinical data of members of Family 4100. KG: sample collection from eyeGENE. All authors contributed to the article and approved the submitted version.",{"#text":949},{"@_id":5326},"S7",{"#text":949},{"sec":5329,":@":5341},[5330,5331,5335,5336,5340],{"#text":946},{"title":5332},[5333],{"#text":5334},"Conflict of Interest",{"#text":946},{"p":5337},[5338],{"#text":5339},"The authors declare that the research was conducted in the absence of any commercial or financial relationships that could be construed as a potential conflict of interest.",{"#text":949},{"@_sec-type":5342,"@_id":5343},"COI-statement","conf1",{"#text":5345},"\n  ",[],[5348,5415,5427,5439,5453,5462,5474,5499],{"title":5349,"order":356,"content":5350},"Data availability statement",[5351,5352,5355,5356,5414],{"#text":946},{"title":5353},[5354],{"#text":5223},{"#text":946},{"p":5357},[5358,5359,5363,5364,5368,5372,5373,5377,5381,5382,5386,5390,5391,5395,5399,5400,5404,5408,5409,5413],{"#text":5228},{"ext-link":5360,":@":5362},[5361],{"#text":5232},{"@_ext-link-type":920,"@_xmlns:xlink":1796,"@_xlink:href":5232},{"#text":4405},{"ext-link":5365,":@":5367},[5366],{"#text":5238},{"@_ext-link-type":5240,"@_xlink:href":5238},{"ext-link":5369,":@":5371},[5370],{"#text":5232},{"@_ext-link-type":920,"@_xlink:href":5232},{"#text":4405},{"ext-link":5374,":@":5376},[5375],{"#text":5249},{"@_ext-link-type":5240,"@_xlink:href":5249},{"ext-link":5378,":@":5380},[5379],{"#text":5232},{"@_ext-link-type":920,"@_xlink:href":5232},{"#text":4405},{"ext-link":5383,":@":5385},[5384],{"#text":5259},{"@_ext-link-type":5240,"@_xlink:href":5259},{"ext-link":5387,":@":5389},[5388],{"#text":5232},{"@_ext-link-type":920,"@_xlink:href":5232},{"#text":4405},{"ext-link":5392,":@":5394},[5393],{"#text":5269},{"@_ext-link-type":5240,"@_xlink:href":5269},{"ext-link":5396,":@":5398},[5397],{"#text":5232},{"@_ext-link-type":920,"@_xlink:href":5232},{"#text":5276},{"ext-link":5401,":@":5403},[5402],{"#text":5280},{"@_ext-link-type":5240,"@_xlink:href":5280},{"ext-link":5405,":@":5407},[5406],{"#text":5232},{"@_ext-link-type":920,"@_xlink:href":5232},{"#text":4405},{"ext-link":5410,":@":5412},[5411],{"#text":5280},{"@_ext-link-type":5240,"@_xlink:href":5280},{"#text":2152},{"#text":949},{"title":5416,"order":806,"content":5417},"Ethics statement",[5418,5419,5422,5423,5426],{"#text":946},{"title":5420},[5421],{"#text":5302},{"#text":946},{"p":5424},[5425],{"#text":5307},{"#text":949},{"title":5428,"order":809,"content":5429},"Author contributions",[5430,5431,5434,5435,5438],{"#text":946},{"title":5432},[5433],{"#text":5318},{"#text":946},{"p":5436},[5437],{"#text":5323},{"#text":949},{"title":5440,"order":818,"content":5441},"Funding",[5442,5443,5452],{"#text":867},{"p":5444},[5445,5446,5450],{"#text":861},{"bold":5447},[5448],{"#text":5449},"Funding.",{"#text":5451}," This work was supported by grants R01 EY026059 (SX) from the National Eye Institute, National Institutes of Health and by an unrestricted RPB (Research to Prevent Blindness) grant to the Department of Ophthalmology, Visual and Anatomical Sciences, Kresge Eye Institute.",{"#text":946},{"title":5454,"order":821,"content":5455},"Acknowledgments",[5456,5457,5461],{"#text":946},{"p":5458},[5459],{"#text":5460},"We thank all physician scientists who participated and provided patient samples to eyeGENE. We also thank the staff members at eyeGENE for their effort to collect and maintain the DNA samples and associated clinical data. Utmost, we thank all patients and their family members who have donated their blood samples for the cause of fighting blindness.",{"#text":949},{"title":5463,"order":597,"content":5464},"Conflict of interest",[5465,5466,5469,5470,5473],{"#text":946},{"title":5467},[5468],{"#text":5334},{"#text":946},{"p":5471},[5472],{"#text":5339},{"#text":949},{"title":5475,"order":5476,"content":5477},"Supplementary material",14,[5478,5479,5482,5483,5492,5493,5498],{"#text":946},{"title":5480},[5481],{"#text":1868},{"#text":946},{"p":5484},[5485,5487],{"#text":5486},"The Supplementary Material for this article can be found online at: ",{"ext-link":5488,":@":5491},[5489],{"#text":5490},"https://www.frontiersin.org/articles/10.3389/fcell.2020.619641/full#supplementary-material",{"@_ext-link-type":920,"@_xmlns:xlink":1796,"@_xlink:href":5490},{"#text":946},{"supplementary-material":5494,":@":5495},[],{"@_xlink:href":5496,"@_id":1871,"@_mimetype":5497,"@_xmlns:xlink":1796},"Data_Sheet_1.PDF","application/pdf",{"#text":949},{"title":5500,"order":5501,"content":5502},"Footnotes",19,[5503,5504,5523,5524,5543,5544,5562,5563,5581,5582,5600,5601,5618],{"#text":946},{"fn":5505,":@":5522},[5506,5507,5510,5511,5521],{"#text":867},{"label":5508},[5509],{"#text":984},{"#text":867},{"p":5512},[5513,5514,5520],{"#text":861},{"ext-link":5515,":@":5518},[5516],{"#text":5517},"sph.uth.edu/Retnet",{"@_ext-link-type":920,"@_xmlns:xlink":1796,"@_xlink:href":5519},"https://sph.uth.edu/Retnet",{"#text":867},{"#text":946},{"@_id":987},{"#text":946},{"fn":5525,":@":5542},[5526,5527,5530,5531,5541],{"#text":867},{"label":5528},[5529],{"#text":1060},{"#text":867},{"p":5532},[5533,5534,5540],{"#text":861},{"ext-link":5535,":@":5538},[5536],{"#text":5537},"www.mirbase.org",{"@_ext-link-type":920,"@_xlink:href":5539},"http://www.mirbase.org",{"#text":867},{"#text":946},{"@_id":1062},{"#text":946},{"fn":5545,":@":5561},[5546,5547,5550,5551,5560],{"#text":867},{"label":5548},[5549],{"#text":1377},{"#text":867},{"p":5552},[5553,5554,5559],{"#text":861},{"ext-link":5555,":@":5558},[5556],{"#text":5557},"https://eyegene.nih.gov/",{"@_ext-link-type":920,"@_xlink:href":5557},{"#text":867},{"#text":946},{"@_id":1379},{"#text":946},{"fn":5564,":@":5580},[5565,5566,5569,5570,5579],{"#text":867},{"label":5567},[5568],{"#text":1660},{"#text":867},{"p":5571},[5572,5573,5578],{"#text":861},{"ext-link":5574,":@":5577},[5575],{"#text":5576},"http://www.mirbase.org/",{"@_ext-link-type":920,"@_xlink:href":5576},{"#text":867},{"#text":946},{"@_id":1987},{"#text":946},{"fn":5583,":@":5599},[5584,5585,5588,5589,5598],{"#text":867},{"label":5586},[5587],{"#text":1995},{"#text":867},{"p":5590},[5591,5592,5597],{"#text":861},{"ext-link":5593,":@":5596},[5594],{"#text":5595},"http://rna.tbi.univie.ac.at/cgi-bin/RNAWebSuite/RNAfold.cgi",{"@_ext-link-type":920,"@_xlink:href":5595},{"#text":867},{"#text":946},{"@_id":1997},{"#text":946},{"fn":5602,":@":5617},[5603,5604,5607,5608,5616],{"#text":867},{"label":5605},[5606],{"#text":1666},{"#text":867},{"p":5609},[5610,5611,5615],{"#text":861},{"ext-link":5612,":@":5614},[5613],{"#text":3550},{"@_ext-link-type":920,"@_xlink:href":3550},{"#text":867},{"#text":946},{"@_id":3496},{"#text":949},[5620,5765,5823,5976,6088,6142,6207,6351,6446,6568,6710,6807,6923,7066,7205,7285,7420,7560,7686,7758,7885,8026,8153,8292,8390,8519,8666,8759,8881,8948,9083,9220,9358,9469,9535,9623,9714,9838,9952,10090,10183,10318,10457,10575,10706,10809,10947,11089,11216,11294,11398,11540,11653,11792,11935,12078,12215,12338,12478,12609,12732,12868,12963,13099,13238,13335,13482,13620,13758,13899,14038,14176,14265,14341,14425,14509,14647,14780,14921,15028,15154,15241,15374,15511,15573,15636,15746,15826,15947,16086],{"content":5621,"id":1120,"index":19,"authors":5758,"title":5726,"source":5732,"volume":2824,"year":4409,"fpage":19,"lpage":19,"doi":5746,"pmid":5752},[5622,5623,5757],{"#text":867},{"citation":5624,":@":5755},[5625,5626,5718,5719,5722,5723,5727,5733,5736,5738,5742,5743,5749],{"#text":861},{"person-group":5627,":@":5716},[5628,5629