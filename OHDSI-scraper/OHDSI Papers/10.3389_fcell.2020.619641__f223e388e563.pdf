":542},941917,"David","Birch","David ",[543],{"organizationName":536,"countryName":480,"cityName":19,"stateName":19,"zipCode":19},{"id":353,"firstName":545,"middleName":19,"lastName":546,"givenNames":547,"isCorresponding":331,"isProfilePublic":331,"userId":353,"email":-1,"affiliations":548},"Kerry","Goetz","Kerry ",[549],{"organizationName":550,"countryName":480,"cityName":19,"stateName":19,"zipCode":19},"National Eye Institute, National Institutes of Health",{"id":353,"firstName":552,"middleName":19,"lastName":553,"givenNames":554,"isCorresponding":331,"isProfilePublic":331,"userId":353,"email":-1,"affiliations":555},"Weifeng","Li","Weifeng ",[556],{"organizationName":557,"countryName":558,"cityName":19,"stateName":19,"zipCode":19},"Peking Union Medical College","China",[560],{"id":561,"firstName":562,"middleName":19,"lastName":563,"givenNames":564,"isCorresponding":331,"isProfilePublic":13,"userId":561,"email":-1,"affiliations":565},837012,"Brian","Perkins","Brian ",[566],{"organizationName":567,"countryName":480,"cityName":19,"stateName":19,"zipCode":19},"Cole Eye Institute, Cleveland Clinic",[569,577],{"id":570,"firstName":571,"middleName":19,"lastName":572,"givenNames":573,"isCorresponding":331,"isProfilePublic":13,"userId":570,"email":-1,"affiliations":574},37583,"Rui","Chen","Rui ",[575],{"organizationName":576,"countryName":480,"cityName":19,"stateName":19,"zipCode":19},"Baylor College of Medicine",{"id":578,"firstName":579,"middleName":19,"lastName":580,"givenNames":581,"isCorresponding":331,"isProfilePublic":13,"userId":578,"email":-1,"affiliations":582},117293,"Zi-Bing","Jin","Zi-Bing ",[583],{"organizationName":584,"countryName":558,"cityName":19,"stateName":19,"zipCode":19},"Beijing Insitute of Ophthalmology, Beijing Tongren Hospital, Capital Medical University",{"id":118,"slug":120,"name":119,"shortName":586,"electronicISSN":587,"field":588,"specialtyId":28,"journalSectionPaths":590},"Front. Cell Dev. Biol.","2296-634X",{"id":589,"domainId":356},10,[59