lign":2068,"@_align":2080},{"#text":1359},{"td":4068,":@":4071},[4069],{"#text":4070},"−1.74 (−2.69; −0.36)",{"@_valign":2068,"@_align":2080},{"#text":1355},{"#text":1355},{"tr":4075},[4076,4077,4081,4082,4087,4088,4093],{"#text":1359},{"td":4078,":@":4080},[4079],{"#text":2365},{"@_valign":2068,"@_align":2069},{"#text":1359},{"td":4083,":@":4086},[4084],{"#text":4085},"−1.72 (−2.67; −0.30)",{"@_valign":2068,"@_align":2080},{"#text":1359},{"td":4089,":@":4092},[4090],{"#text":4091},"−1.76 (−2.73; −0.38)",{"@_valign":2068,"@_align":2080},{"#text":1355},{"#text":1355},{"tr":4096},[4097,4098,4102,4103,4108,4109,4114],{"#text":1359},{"td":4099,":@":4101},[4100],{"#text":2393},{"@_valign":2068,"@_align":2069},{"#text":1359},{"td":4104,":@":4107},[4105],{"#text":4106},"−1.70 (−2.74; −0.25)",{"@_valign":2068,"@_align":2080},{"#text":1359},{"td":4110,":@":4113},[4111],{"#text":4112},"−1.75 (−2.75; −0.35)",{"@_valign":2068,"@_align":2080},{"#text":1355},{"#text":1355},{"tr":4117},[4118,4119,4123,4124,4129,4130,4150],{"#text":1359},{"td":4120,":@":4122},[4121],{"#text":2421},{"@_valign":2068,"@_align":2069},{"#text":1359},{"td":4125,":@":4128},[4126],{"#text":4127},"−1.61 (−2.78; −0.10)",{"@_valign":2068,"@_align":2080},{"#text":1359},{"td":4131,":@":4149},[4132,4134,4140,4142,4148],{"#text":4133},"−1.65",{"xref":4135,":@":4139},[4136],{"sup":4137},[4138],{"#text":3004},{"@_ref-type":2810,"@_rid":3964},{"#text":4141}," (−2.69; −0.23",{"xref":4143,":@":4147},[4144],{"sup":4145},[4146],{"#text":3004},{"@_ref-type":2810,"@_rid":3964},{"#text":1755},{"@_valign":2068,"@_align":2080},{"#text":1355},{"#text":1355},{"tr":4153},[4154,4155,4159,4160,4165,4166,4171],{"#text":1359},{"td":4156,":@":4158},[4157],{"#text":2449},{"@_valign":2068,"@_align":2069},{"#text":1359},{"td":4161,":@":4164},[4162],{"#text":4163},"−1.50 (−2.75; 0.02)",{"@_valign":2068,"@_align":2080},{"#text":1359},{"td":4167,":@":4170},[4168],{"#text":4169},"−1.49 (−2.58; −0.04)",{"@_valign":2068,"@_align":2080},{"#text":1355},{"#text":1355},{"tr":4174},[4175,4176,4180,4181,4186,4187,4200],{"#text":1359},{"td":4177,":@":4179},[4178],{"#text":2477},{"@_valign":2068,"@_align":2069},{"#text":1359},{"td":4182,":@":4185},[4183],{"#text":4184},"−1.33 (−2.64; 0.19)",{"@_valign":2068,"@_align":2080},{"#text":1359},{"td":4188,":@":4199},[4189,4191,4197],{"#text":4190},"−1.25",{"xref":4192,":@":4196},[4193],{"sup":4194},[4195],{"#text":3004},{"@_ref-type":2810,"@_rid":3964},{"#text":4198}," (−2.44; 0.28)",{"@_valign":2068,"@_align":2080},{"#text":1355},{"#text":1355},{"tr":4203},[4204,4205,4209,4210,4215,4216,4237],{"#text":1359},{"td":4206,":@":4208},[4207],{"#text":2505},{"@_valign":2068,"@_align":2069},{"#text":1359},{"td":4211,":@":4214},[4212],{"#text":4213},"−1.12 (−2.52; 0.43)",{"@_valign":2068,"@_align":2080},{"#text":1359},{"td":4217,":@":4236},[4218,4220,4227,4229,4235],{"#text":4219},"−1.00",{"xref":4221,":@":4225},[4222],{"sup":4223},[4224],{"#text":2965},{"@_ref-type":2810,"@_rid":4226},"TN8",{"#text":4228}," (−2.32; 0.64",{"xref":4230,":@":4234},[4231],{"sup":4232},[4233],{"#text":2965},{"@_ref-type":2810,"@_rid":4226},{"#text":1755},{"@_valign":2068,"@_align":2080},{"#text":1355},{"#text":1355},{"tr":4240},[4241,4242,4246,4247,4252,4253,4265],{"#text":1359},{"td":4243,":@":4245},[4244],{"#text":2533},{"@_valign":2068,"@_align":2069},{"#text":1359},{"td":4248,":@":4251},[4249],{"#text":4250},"−0.92 (−2.43; 0.72)",{"@_valign":2068,"@_align":2080},{"#text":1359},{"td":4254,":@":4264},[4255,4257,4263],{"#text":4256},"−0.78 (−2.23; 0.96",{"xref":4258,":@":4262},[4259],{"sup":4260},[4261],{"#text":3004},{"@_ref-type":2810,"@_rid":3964},{"#text":1755},{"@_valign":2068,"@_align":2080},{"#text":1355},{"#text":1355},{"tr":4268},[4269,4270,4274,4275,4280,4281,4286],{"#text":1359},{"td":4271,":@":4273},[4272],{"#text":2561},{"@_valign":2068,"@_align":2069},{"#text":1359},{"td":4276,":@":4279},[4277],{"#text":4278},"−0.69 (−2.36; 1.08)",{"@_valign":2068,"@_align":2080},{"#text":1359},{"td":4282,":@":4285},[4283],{"#text":4284},"−0.58 (−2.17; 1.27)",{"@_valign":2068,"@_align":2080},{"#text":1355},{"#text":886},{"#text":892},{"@_frame":2640,"@_rules":2641},{"#text":892},{"table-wrap-foot":4292},[4293,4294,4310,4311,4328,4329,4337],{"#text":886},{"fn":4295,":@":4309},[4296,4297,4300,4301,4308],{"#text":1355},{"label":4298},[4299],{"#text":3004},{"#text":1355},{"p":4302},[4303,4304,4307],{"#text":1359},{"italic":4305},[4306],{"#text":3197},{"#text":1355},{"#text":886},{"@_id":3964},{"#text":886},{"fn":4312,":@":4327},[4313,4314,4317,4318,4326],{"#text":1355},{"label":4315},[4316],{"#text":2965},{"#text":1355},{"p":4319},[4320,4321,4325],{"#text":1359},{"italic":4322},[4323],{"#text":4324},"P-value \u003C0.01",{"#text":3235},{"#text":886},{"@_id":4226},{"#text":886},{"p":4330},[4331,4332,4336],{"#text":1355},{"italic":4333},[4334],{"#text":4335},"QTVI, QT variability index",{"#text":3235},{"#text":892},{"#text":1000},{"@_position":2644,"@_id":1998},{"#text":1000},{"fig":4342,":@":4364},[4343,4344,4348,4349,4357,4358,4363],{"#text":892},{"label":4345},[4346],{"#text":4347},"Figure 1",{"#text":892},{"caption":4350},[4351,4352,4356],{"#text":886},{"p":4353},[4354],{"#text":4355},"Median, 2nd, and 98th percentiles of SDqt for all ages in men and women.",{"#text":892},{"#text":892},{"graphic":4359,":@":4360},[],{"@_xmlns:xlink":4361,"@_xlink:href":4362},"http://www.w3.org/1999/xlink","fphys-10-01272-g0001.tif",{"#text":1000},{"@_id":2024,"@_position":2644},{"#text":1000},{"fig":4367,":@":4388},[4368,4369,4373,4374,4382,4383,4387],{"#text":892},{"label":4370},[4371],{"#text":4372},"Figure 2",{"#text":892},{"caption":4375},[4376,4377,4381],{"#text":886},{"p":4378},[4379],{"#text":4380},"Median, 2nd, and 98th percentiles of STVqt for all ages in men and women.",{"#text":892},{"#text":892},{"graphic":4384,":@":4385},[],{"@_xlink:href":4386},"fphys-10-01272-g0002.tif",{"#text":1000},{"@_id":4389,"@_position":2644},"F2",{"#text":1000},{"fig":4392,":@":4413},[4393,4394,4398,4399,4407,4408,4412],{"#text":892},{"label":4395},[4396],{"#text":4397},"Figure 3",{"#text":892},{"caption":4400},[4401,4402,4406],{"#text":886},{"p":4403},[4404],{"#text":4405},"Median, 2nd, and 98th percentiles of QTVI for all ages in men and women.",{"#text":892},{"#text":892},{"graphic":4409,":@":4410},[],{"@_xlink:href":4411},"fphys-10-01272-g0003.tif",{"#text":1000},{"@_id":2030,"@_position":2644},{"#text":1000},{"p":4416},[4417],{"#text":4418},"The median and LLN of SDqt and STVqt remain relatively constant over age. The ULN of both markers slightly decreases until the age of 45, after which it strongly increases. The normal values of QTVI show a decrease until about 20 years, after which they start to rise again. Overall, sex differences are limited for STVqt and SDqt, with the exception of the ULN after the age of 45 where the female curve follows a steeper course than its male counterpart. Although statistically significant differences between men and women can be found for the median values above age 20, all differences are \u003C0.4 ms and do not appear practically relevant. For QTVI, sex differences are minimal.",{"#text":1003},{"@_sec-type":4421,"@_id":4422},"results","s3",{"#text":1003},{"sec":4425,":@":4576},[4426,4427,4431,4432,4436,4437,4505,4506,4510,4511,4521,4522,4550,4551,4570,4571,4575],{"#text":1000},{"title":4428},[4429],{"#text":4430},"Discussion",{"#text":1000},{"p":4433},[4434],{"#text":4435},"This is the first paper to report comprehensive normal values of QT variability based on 10-s, standard 12-lead ECGs. We report the median, LLN, and ULN of SDqt, STVqt, and QTVI across all ages and stratified on sex.",{"#text":1000},{"p":4438},[4439,4441,4445,4447,4451,4453,4457,4459,4463,4465,4469,4470,4474,4475,4479,4481,4485,4486,4490,4491,4495,4497,4503],{"#text":4440},"A paper by Baumert et al. presents a meta-analysis of normal values from 45 studies involving 1,954 adults with QTVI measurements and from 23 studies involving 1,190 adults with SDqt measurements (Baumert et al., ",{"xref":4442,":@":4444},[4443],{"#text":1028},{"@_ref-type":1021,"@_rid":1030},{"#text":4446},"). Without taking age or ECG-recording duration into account, this meta-analysis found for men a mean QTVI of −1.6 and a mean SDqt of 3.3 milliseconds. The underlying studies of this meta-analysis differ widely in methodology. None of these studies is based on the standard 10-s ECG, typically ECG recordings of 256 s or more were used (Baumert et al., ",{"xref":4448,":@":4450},[4449],{"#text":1028},{"@_ref-type":1021,"@_rid":1030},{"#text":4452},"). In children, there is a study by Kusuki et al. that reports normal values of 173 children without organic heart disease aged 0–7 years, using only lead CM5 on ECG recordings containing 120 beats (Kusuki et al., ",{"xref":4454,":@":4456},[4455],{"#text":1141},{"@_ref-type":1021,"@_rid":1143},{"#text":4458},"). Their paper concludes that QTVI decreases from birth to age 7, which is in accordance with our findings. Unfortunately this study does not give the results in percentiles but in means and standard deviations. A study by Yeragani et al. using 10-min recordings found no significant difference in QTVI between 15 children aged 6–14 years and 34 normal adults aged 20–55 years (Yeragani et al., ",{"xref":4460,":@":4462},[4461],{"#text":1118},{"@_ref-type":1021,"@_rid":1120},{"#text":4464},"). Assuming that these 10-min recordings have the same age-dependent pattern as our 10-s recordings, this may be explained by the children being on the descending limb of the QTVI curve, while the adults are at the same height on the ascending limb. There are three studies that track normal values for QTVI derived from 10- to 30-min recordings over a longer age range, between 20 and 90 years (Piccirillo et al., ",{"xref":4466,":@":4468},[4467],{"#text":1126},{"@_ref-type":1021,"@_rid":1128},{"#text":1130},{"xref":4471,":@":4473},[4472],{"#text":1052},{"@_ref-type":1021,"@_rid":1135},{"#text":1086},{"xref":4476,":@":4478},[4477],{"#text":1148},{"@_ref-type":1021,"@_rid":1150},{"#text":4480},"). These studies, with 40, 131, and 143 healthy participants, show that QTVI increases with age, which concurs with our findings (Piccirillo et al., ",{"xref":4482,":@":4484},[4483],{"#text":1126},{"@_ref-type":1021,"@_rid":1128},{"#text":1130},{"xref":4487,":@":4489},[4488],{"#text":1052},{"@_ref-type":1021,"@_rid":1135},{"#text":1086},{"xref":4492,":@":4494},[4493],{"#text":1148},{"@_ref-type":1021,"@_rid":1150},{"#text":4496},"). Further, SDqt was analyzed by Kraus et al., showing that SDqt is higher in women and that SDqt increases with age (Krauss et al., ",{"xref":4498,":@":4501},[4499],{"#text":4500},"2009",{"@_ref-type":1021,"@_rid":4502},"B15",{"#text":4504},"); both findings are consistent with the results of this study. Kraus et al. used 24 h Holter recordings, and calculated hourly mean values for SDqt.",{"#text":1000},{"p":4507},[4508],{"#text":4509},"As no other study reports median, LLN and ULN values stratified on sex, full-scale comparisons of our results with those of other studies are without being. To the extent that comparisons are possible, our findings are in general agreement with those of previous studies that used longer recordings. The age- and sex-dependent normal values of QT variability reported here may serve to establish cut-off values for various clinical and pharmacological applications. For example, a drug associated with risk of ventricular arrhythmias might be withheld if the QT variability is above a certain limit.",{"#text":1000},{"p":4512},[4513,4515,4519],{"#text":4514},"In a previous review on the literature of QT variability, we surmised that QT-variability markers carry information about the risk of ventricular arrhythmias, SCD, and total mortality: the higher the QT variability, the higher the risk, perhaps indicating repolarization instability (Niemeijer et al., ",{"xref":4516,":@":4518},[4517],{"#text":1076},{"@_ref-type":1021,"@_rid":1078},{"#text":4520},"). In this light, the large increase of the ULN of SDqt and STVqt in older age compared to the relatively stable median and LLN might point to a subset of the population at risk for arrhythmias or worse, notably so in women, where this increase is more pronounced.",{"#text":1000},{"p":4523},[4524,4526,4530,4532,4536,4538,4543,4545,4549],{"#text":4525},"Our study has a number of strengths. With 13,828 ECGs it is by far the largest study reporting normal values for QT variability. We include both men and women, and have a wide age coverage, from 11 days to 90 years. All ECGs were analyzed consistently and automatically with the well-validated MEANS program and FSA technique (Ritsema van Eck, ",{"xref":4527,":@":4529},[4528],{"#text":1319},{"@_ref-type":1021,"@_rid":1321},{"#text":4531},"; Rijnbeek et al., ",{"xref":4533,":@":4535},[4534],{"#text":1327},{"@_ref-type":1021,"@_rid":1329},{"#text":4537},"). This approach eliminates intra-observer bias and uses all 12 ECG leads, which limits dependency of QT variability on lead-dependent T-wave amplitudes. Moreover, while concerns have been raised about the reproducibility of QT variability when measured beat-by-beat (Feeny et al., ",{"xref":4539,":@":4541},[4540],{"#text":1076},{"@_ref-type":1021,"@_rid":4542},"B9",{"#text":4544},"), FSA exploits the correlation between individual beats and has been shown to produce highly reproducible results (Rijnbeek et al., ",{"xref":4546,":@":4548},[4547],{"#text":1327},{"@_ref-type":1021,"@_rid":1329},{"#text":1950},{"#text":1000},{"p":4552},[4553,4555,4561,4563,4568],{"#text":4554},"Our study also has limitations. First, we had a relatively low number of ECGs in the extremes of the age distribution. For this reason, we did not give normal limits for ages higher than 90 years, and the normal limits of participants younger than 6 months should be used with caution. Second, the use of 10-s recordings prohibits measurement of QT variability over longer time intervals, as required for the detection of, e.g., respiratory modulation and diurnal changes. However, respiratory modulation was studied by Emori and Ohe, who conclude that it does not affect QT variability in healthy participants (Emori and Ohe, ",{"xref":4556,":@":4559},[4557],{"#text":4558},"1999",{"@_ref-type":1021,"@_rid":4560},"B8",{"#text":4562},"). As for diurnal changes, a study by Yeragani et al. has shown that QT variability differs between the waking and sleeping hours, but also that it is fairly constant within either period (Yeragani et al., ",{"xref":4564,":@":4566},[4565],{"#text":1242},{"@_ref-type":1021,"@_rid":4567},"B28",{"#text":4569},"). Therefore, if all ECGs are recorded in awake persons this should not materially affect the results. Third, 10-s ECGs may sometimes contain only a few QT intervals, rendering the QT-variability estimates less reliable than in longer recordings. Finally, race is not a category that is officially recognized in The Netherlands and thus our records did not contain this information. However, the populations from which we have recruited our participants may deemed to be white in the large majority. Further studies are needed to determine the possible effect of race on the normal limits of QT variability.",{"#text":1000},{"p":4572},[4573],{"#text":4574},"In conclusion, normal limits have been established for SDqt, STVqt, and QTVI derived from 10-s ECGs, using a consistent and automatic methodology for all ages and both sexes. We found strong age effects for all markers. These normal values should help both researchers and clinicians to decide upon cut-off values of abnormal QT variability in 10-s ECGs, improving the practical applicability of QT variability.",{"#text":1003},{"@_sec-type":4577,"@_id":4578},"discussion","s4",{"#text":1003},{"sec":4581,":@":4593},[4582,4583,4587,4588,4592],{"#text":1000},{"title":4584},[4585],{"#text":4586},"Data Availability Statement",{"#text":1000},{"p":4589},[4590],{"#text":4591},"The datasets generated for this study are available on request to the corresponding author.",{"#text":1003},{"@_sec-type":4594,"@_id":4595},"data-availability-statement","s5",{"#text":1003},{"sec":4598,":@":4610},[4599,4600,4604,4605,4609],{"#text":1000},{"title":4601},[4602],{"#text":4603},"Ethics Statement",{"#text":1000},{"p":4606},[4607],{"#text":4608},"This study was approved by the Medical Ethics Committee of the Erasmus University Medical Center. Since all data were anonymized and retrospectively collected, individual informed consent from the study participants was not required according to Dutch legislation.",{"#text":1003},{"@_id":4611},"s6",{"#text":1003},{"sec":4614,":@":4640},[4615,4616,4620,4621,4625,4626,4639],{"#text":1000},{"title":4617},[4618],{"#text":4619},"Author Contributions",{"#text":1000},{"p":4622},[4623],{"#text":4624},"MEB, JK, and PR: conception and design of the work. MEB, GH, MLB, HH, CS, and BS: data collection and cleaning. JK and PR: data processing. MEB, JK, GH, and PR: statistical analysis and interpretation. MEB: drafting of the manuscript. All authors: critical review of the manuscript.",{"#text":1000},{"sec":4627},[4628,4629,4633,4634,4638],{"#text":892},{"title":4630},[4631],{"#text":4632},"Conflict of Interest",{"#text":892},{"p":4635},[4636],{"#text":4637},"The authors declare that the research was conducted in the absence of any commercial or financial relationships that could be construed as a potential conflict of interest.",{"#text":1000},{"#text":1003},{"@_id":4641},"s7",{"#text":4643},"\n  ",[],[4646,4658,4670,4694,4708,4736,4749],{"title":4647,"order":446,"content":4648},"Data availability statement",[4649,4650,4653,4654,4657],{"#text":1000},{"title":4651},[4652],{"#text":4586},{"#text":1000},{"p":4655},[4656],{"#text":4591},{"#text":1003},{"title":4659,"order":847,"content":4660},"Ethics statement",[4661,4662,4665,4666,4669],{"#text":1000},{"title":4663},[4664],{"#text":4603},{"#text":1000},{"p":4667},[4668],{"#text":4608},{"#text":1003},{"title":4671,"order":850,"content":4672},"Author contributions",[4673,4674,4677,4678,4681,4682,4693],{"#text":1000},{"title":4675},[4676],{"#text":4619},{"#text":1000},{"p":4679},[4680],{"#text":4624},{"#text":1000},{"sec":4683},[4684,4685,4688,4689,4692],{"#text":892},{"title":4686},[4687],{"#text":4632},{"#text":892},{"p":4690},[4691],{"#text":4637},{"#text":1000},{"#text":1003},{"title":4695,"order":856,"content":4696},"Funding",[4697,4698,4707],{"#text":892},{"p":4699},[4700,4701,4705],{"#text":886},{"bold":4702},[4703],{"#text":4704},"Funding.",{"#text":4706}," This work was supported by grants from the Netherlands Organization for Health Research and Development (ZonMw) (Priority Medicines Elderly 113102005 to MEB and PR; and HTA 80-82500-98-10208 to BS). The Utrecht Health Project received grants from the Ministry of Health, Welfare, and Sports, the University of Utrecht, the Province of Utrecht, the Dutch Organisation of Care Research (ZON), the University Medical Center of Utrecht, and the Dutch College of Healthcare Insurance Companies (CVZ). The Rotterdam Study was supported by the Erasmus MC and Erasmus University Rotterdam, the Netherlands Organization for Scientific Research (NWO), ZonMw, the Research Institute for Diseases in the Elderly (RIDE), the Netherlands Genomics Initiative (NGI), the Ministry of Education, Culture and Science, the Ministry of Health Welfare and Sports, the European Commission (DG XII), and the Municipality of Rotterdam.",{"#text":1000},{"title":4709,"order":857,"content":4710},"Acknowledgments",[4711,4712,4735],{"#text":1000},{"p":4713},[4714,4716,4720,4722,4727,4729,4734],{"#text":4715},"This paper includes content from the doctoral thesis of MEB, ",{"italic":4717},[4718],{"#text":4719},"QT variability and other electrocardiographic predictors of sudden cardiac death",{"#text":4721},", available at the website of the Erasmus University Rotterdam, ",{"ext-link":4723,":@":4726},[4724],{"#text":4725},"https://repub.eur.nl/pub/101801",{"@_ext-link-type":935,"@_xmlns:xlink":4361,"@_xlink:href":4725},{"#text":4728}," (van den Berg, ",{"xref":4730,":@":4732},[4731],{"#text":1327},{"@_ref-type":1021,"@_rid":4733},"B26",{"#text":1950},{"#text":1003},{"title":4737,"order":4738,"content":4739},"Conflict of interest",8,[4740,4741,4744,4745,4748],{"#text":892},{"title":4742},[4743],{"#text":4632},{"#text":892},{"p":4746},[4747],{"#text":4637},{"#text":1000},{"title":4750,"order":4751,"content":4752},"Supplementary material",14,[4753,4754,4758,4759,4768,4769,4774,4775,4780,4781,4785],{"#text":1000},{"title":4755},[4756],{"#text":4757},"Supplementary Material",{"#text":1000},{"p":4760},[4761,4763],{"#text":4762},"The Supplementary Material for this article can be found online at: ",{"ext-link":4764,":@":4767},[4765],{"#text":4766},"https://www.frontiersin.org/articles/10.3389/fphys.2019.01272/full#supplementary-material",{"@_ext-link-type":935,"@_xmlns:xlink":4361,"@_xlink:href":4766},{"#text":1000},{"supplementary-material":4770,":@":4771},[],{"@_xlink:href":4772,"@_id":2007,"@_mimetype":4773,"@_xmlns:xlink":4361},"Table_1.pdf","application/pdf",{"#text":1000},{"supplementary-material":4776,":@":4777},[],{"@_xlink:href":4778,"@_id":4779,"@_mimetype":4773,"@_xmlns:xlink":4361},"Table_2.pdf","SM2",{"#text":1000},{"supplementary-material":4782,":@":4783},[],{"@_xlink:href":4784,"@_id":2015,"@_mimetype":4773,"@_xmlns:xlink":4361},"Table_3.pdf",{"#text":1003},[4787,4906,5017,5158,5299,5440,5522,5630,5710,5805,5946,6083,6223,6330,6412,6541,6679,6817,6956,7086,7202,7320,7389,7532,7669,7762,7813,7953,8057],{"content":4788,"id":1062,"index":19,"authors":4901,"title":4864,"source":4869,"volume":4873,"year":1060,"fpage":4879,"lpage":4884,"doi":4889,"pmid":4895},[4789,4790,4900],{"#text":892},{"citation":4791,":@":4898},[4792,4793,4854,4856,4859,4861,4865,4866,4870,4874,4876,4880,4881,4885,4886,4892],{"#text":886},{"person-group":4794,":@":4852},[4795,4796,4809,4810,4823,4824,4837,4838,4851],{"#text":1355},{"name":4797},[4798,4799,4803,4804,4808],{"#text":1359},{"surname":4800},[4801],{"#text":4802},"Albert",{"#text":1359},{"given-names":4805},[4806],{"#text":4807},"C. M.",{"#text":1355},{"#text":1355},{"name":4811},[4812,4813,4817,4818,4822],{"#text":1359},{"surname":4814},[4815],{"#text":4816},"McGovern",{"#text":1359},{"given-names":4819},[4820],{"#text":4821},"B. A.",{"#text":1355},{"#text":1355},{"name":4825},[4826,4827,4831,4832,4836],{"#text":1359},{"surname":4828},[4829],{"#text":4830},"Newell",{"#text":1359},{"given-names":4833},[4834],{"#text":4835},"J. B.",{"#text":1355},{"#text":1355},{"name":4839},[4840,4841,4845,4846,4850],{"#text":1359},{"surname":4842},[4843],{"#text":4844},"Ruskin",{"#text":1359},{"given-names":4847},[4848],{"#text":4849},"J. N.",{"#text":1355},{"#text":886},{"@_person-group-type":4853},"author",{"#text":4855}," (",{"year":4857},[4858],{"#text":1060},{"#text":4860},"). ",{"article-title":4862},[4863],{"#text":4864},"Sex differences in cardiac arrest survivors",{"#text":2017},{"source":4867},[4868],{"#text":4869},"Circulation",{"volume":4871},[4872],{"#text":4873},"93",{"#text":4875},", ",{"fpage":4877},[4878],{"#text":4879},"1170",{"#text":2009},{"lpage":4882},[4883],{"#text":4884},"1176",{"#text":2017},{"pub-id":4887,":@":4890},[4888],{"#text":4889},"10.1161/01.CIR.93.6.1170",{"@_pub-id-type":4891},"doi",{"pub-id":4893,":@":4896},[4894],{"#text":4895},"8653838",{"@_pub-id-type":4897},"pmid",{"@_citation-type":4899},"journal",{"#text":1000},[4902,4903,4904,4905],{"surname":4802,"givenNames":4807},{"surname":4816,"givenNames":4821},{"surname":4830,"givenNames":4835},{"surname":4844,"givenNames":4849},{"content":4907,"id":1150,"index":19,"authors":5012,"title":4979,"source":4984,"volume":4988,"year":1148,"fpage":4993,"lpage":4998,"doi":5003,"pmid":5008},[4908,4909,5011],{"#text":892},{"citation":4910,":@":5010},[4911,4912,4971,4972,4975,4976,4980,4981,4985,4989,4990,4994,4995,4999,5000,5005],{"#text":886},{"person-group":4913,":@":4970},[4914,4915,4928,4929,4942,4943,4956,4957,4969],{"#text":1355},{"name":4916},[4917,4918,4922,4923,4927],{"#text":1359},{"surname":4919},[4920],{"#text":4921},"Baumert",{"#text":1359},{"given-names":4924},[4925],{"#text":4926},"M.",{"#text":1355},{"#text":1355},{"name":4930},[4931,4932,4936,4937,4941],{"#text":1359},{"surname":4933},[4934],{"#text":4935},"Czippelova",{"#text":1359},{"given-names":4938},[4939],{"#text":4940},"B.",{"#text":1355},{"#text":1355},{"name":4944},[4945,4946,4950,4951,4955],{"#text":1359},{"surname":4947},[4948],{"#text":4949},"Porta",{"#text":1359},{"given-names":4952},[4953],{"#text":4954},"A.",{"#text":1355},{"#text":1355},{"name":4958},[4959,4960,4964,4965,4968],{"#text":1359},{"surname":4961},[4962],{"#text":4963},"Javorka",{"#text":1359},{"given-names":4966},[4967],{"#text":4926},{"#text":1355},{"#text":886},{"@_person-group-type":4853},{"#text":4855},{"year":4973},[4974],{"#text":1148},{"#text":4860},{"article-title":4977},[4978],{"#text":4979},"Decoupling of QT interval variability from heart rate variability with ageing",{"#text":2017},{"source":4982},[4983],{"#text":4984},"Physiol. Meas.",{"volume":4986},[4987],{"#text":4988},"34",{"#text":4875},{"fpage":4991},[4992],{"#text":4993},"1435",{"#text":2009},{"lpage":4996},[4997],{"#text":4998},"1448",{"#text":2017},{"pub-id":5001,":@":5004},[5002],{"#text":5003},"10.1088/0967-3334/34/11/1435",{"@_pub-id-type":4891},{"pub-id":5006,":@":5009},[5007],{"#text":5008},"24104598",{"@_pub-id-type":4897},{"@_citation-type":4899},{"#text":1000},[5013,5014,5015,5016],{"surname":4921,"givenNames":4926},{"surname":4935,"givenNames":4940},{"surname":4949,"givenNames":4954},{"surname":4963,"givenNames":4926},{"content":5018,"id":1030,"index":19,"authors":5151,"title":5118,"source":5123,"volume":5127,"year":1028,"fpage":5132,"lpage":5137,"doi":5142,"pmid":5147},[5019,5020,5150],{"#text":892},{"citation":5021,":@":5149},[5022,5023,5109,5111,5114,5115,5119,5120,5124,5128,5129,5133,51