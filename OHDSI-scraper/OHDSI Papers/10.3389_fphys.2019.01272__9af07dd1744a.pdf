bel":313},{"text":360,"url":361,"target":80,"ariaLabel":362},"Emails and alerts ","https://subscription-management.frontiersin.org/emails/preferences#block0","Subscribe to Frontiers emails",{"text":364,"url":114,"target":27,"ariaLabel":365},"Contact us ","Subscribe to newsletter",{"text":367,"url":368,"target":27,"ariaLabel":28},"Submit","https://www.frontiersin.org/submission/submit",{"text":109,"url":110,"target":80,"ariaLabel":28},[371,379,384,389],{"link":372,"type":375,"color":376,"icon":377,"size":378,"hiddenText":13},{"text":373,"url":374,"target":80,"ariaLabel":373},"Frontiers Facebook","https://www.facebook.com/Frontiersin","Link","Grey","Facebook","Medium",{"link":380,"type":375,"color":376,"icon":383,"size":378,"hiddenText":13},{"text":381,"url":382,"target":80,"ariaLabel":28},"Frontiers Twitter","https://twitter.com/frontiersin","Twitter",{"link":385,"type":375,"color":376,"icon":388,"size":378,"hiddenText":13},{"text":386,"url":387,"target":80,"ariaLabel":28},"Frontiers LinkedIn","https://www.linkedin.com/company/frontiers","LinkedIn",{"link":390,"type":375,"color":376,"icon":393,"size":378,"hiddenText":13},{"text":391,"url":392,"target":80,"ariaLabel":28},"Frontiers Instagram","https://www.instagram.com/frontiersin_","Instagram","Frontiers Media SA. All rights reserved.","https://www.frontiersin.org/legal/terms-and-conditions","https://www.frontiersin.org/legal/privacy-policy","https://www.frontiersin.org/about/accessibility-statement",{},false,{"__typename":401,"identifier":118,"name":119,"slug":120,"banner":402,"description":480,"mission":481,"palette":482,"impactFactor":483,"citeScore":484,"citations":485,"showTagline":28,"twitter":486},"Journal",[403],{"id":404,"src":405,"name":406,"tags":407,"type":439,"width":440,"height":441,"idHash":442,"archive":443,"brandId":444,"limited":443,"fileSize":445,"isPublic":446,"original":447,"copyright":19,"extension":448,"thumbnails":450,"dateCreated":458,"description":459,"orientation":460,"userCreated":461,"watermarked":443,"dateModified":458,"datePublished":462,"ecsArchiveFiles":463,"propertyOptions":464,"property_Channel":469,"property_Sub-Type":471,"property_Asset_Type":473,"activeOriginalFocusPoint":475,"property_Office_Department":478},"8661D86F-DC44-47C3-8EDF5AC7C3010522","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/8661D86F-DC44-47C3-8EDF5AC7C3010522/webimage-175D1AF6-D0D7-457F-9F3319DF25C432BF.png","FPHYS_Main Visual_Red_Website",[408,409,410,411,412,413,414,415,416,417,418,419,420,421,422,423,424,425,426,427,428,429,430,431,432,433,434,435,436,437,438],"medical","anatomical","healthy","athlete","muscular","chest","organs","education","health","system","anatomy","bones","person","shape","biology","male","shoulders","muscle","nature","face","science","torso","fitness","skeleton","man","illustration","skin","medicine","body","3d","human","image",5000,3750,"1748dd1e17cf8710",0,"22C10171-81B3-4DA6-99342F272A32E8BB",7157365,1,"https://brand.frontiersin.org/m/1748dd1e17cf8710/original/FPHYS_Main-Visual_Red_Website.jpg",[449],"jpg",{"mini":451,"thul":452,"webimage":405,"Guidelines":453,"WebsiteJpg_XL":454,"WebsiteWebP_L":455,"WebsiteWebP_M":456,"WebsiteWebP_XL":457},"https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/8661D86F-DC44-47C3-8EDF5AC7C3010522/mini-C3B0E16A-BAEB-48B5-91EB5B674F1EF10C.png","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/8661D86F-DC44-47C3-8EDF5AC7C3010522/thul-E9E052B8-3DB0-4F07-93D30E218A898731.png","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/8661D86F-DC44-47C3-8EDF5AC7C3010522/CADBD0FC-2672-4E45-A7D1A3BAE338337E/Guidelines-FPHYS_Main Visual_Red_Website.png","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/8661D86F-DC44-47C3-8EDF5AC7C3010522/CADBD0FC-2672-4E45-A7D1A3BAE338337E/WebsiteJpg_XL-FPHYS_Main Visual_Red_Website.jpg","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/8661D86F-DC44-47C3-8EDF5AC7C3010522/CADBD0FC-2672-4E45-A7D1A3BAE338337E/WebsiteWebP_L-FPHYS_Main Visual_Red_Website.webp","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/8661D86F-DC44-47C3-8EDF5AC7C3010522/CADBD0FC-2672-4E45-A7D1A3BAE338337E/WebsiteWebP_M-FPHYS_Main Visual_Red_Website.webp","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/8661D86F-DC44-47C3-8EDF5AC7C3010522/CADBD0FC-2672-4E45-A7D1A3BAE338337E/WebsiteWebP_XL-FPHYS_Main Visual_Red_Website.webp","2022-06-27T10:00:47Z","Human anatomy showing face, head, shoulders and back muscular system, bone structure and vascular system.; Shutterstock ID 342678791; purchase_order: Main Visual; job: ; client: ; other:","landscape","Caroline Sutter","2022-06-27T09:27:09Z",[],[465,466,467,468],"414FB2D4-2283-43FD-BE14E534ECA67928","6C18119B-14BD-4951-B437696F4357BD33","7C692885-DB25-4858-B1FB4FF47B241E9B","D88C0047-EC30-4506-A7DF28A4D765E1CF",[470],"frontiersin_org",[472],"Main_Visual",[474],"Photography",{"x":476,"y":477},2500,1875,[479],"Publishing","Explore open access research in physiology, revealing how organisms function from cells to systems in health, adaptation and disease.","\u003Cp>Frontiers in Physiology explores the physiology of living systems across all levels, from the molecular and subcellular to the intact organism and its interaction with the environment.\u003C/p>\n\n\u003Cp>Led by Field Chief Editor Prof John D Imig (University of Arkansas for Medical Sciences, USA) and indexed in Scopus, Web of Science (SCIE), PubMed Central (PMC), and DOAJ, the journal welcomes human and animal studies across all areas of physiology, including technologies for investigating physiological function. Topics of interest include, but are not limited to:\u003C/p>\n\u003Cul>\n  \u003Cli>avian, aquatic, and invertebrate physiology\u003C/li>\n  \u003Cli>biophysics, medical physics and imaging\u003C/li>\n  \u003Cli>cancer-related physiology and pathophysiology\u003C/li>\n  \u003Cli>cardiac electrophysiology\u003C/li>\n  \u003Cli>cell, membrane, metabolic, mitochondrial and redox physiology\u003C/li>\n  \u003Cli>chronobiology\u003C/li>\n  \u003Cli>computational physiology and medicine\u003C/li>\n  \u003Cli>craniofacial, tooth, skin, skeletal, and striated muscle physiology\u003C/li>\n  \u003Cli>developmental physiology\u003C/li>\n  \u003Cli>environmental, aviation, and space physiology\u003C/li>\n  \u003Cli>exercise physiology\u003C/li>\n  \u003Cli>gastrointestinal and physiology\u003C/li>\n  \u003Cli>integrative, clinical, and translational physiology\u003C/li>\n  \u003Cli>neurophysiology and autonomic neuroscience\u003C/li>\n  \u003Cli>physio-logging\u003C/li>\n  \u003Cli>reproductive and mating physiology\u003C/li>\n  \u003Cli>respiratory, vascular, renal and red blood cell physiology.\u003C/li>\n\u003C/ul>\n\n\u003Cp>Frontiers in Physiology particularly welcomes studies that support and advance the UN’s Sustainable Development Goals (SDGs), notably SDG 3: good health and well-being.\u003C/p>\n\n\u003Cp>Manuscripts that focus solely on clinical or medical research, including cancer studies, traditional medicine, and patient prognosis, are not suitable for publication in this journal. Additionally, research that is purely statistical or computational, such as regression analysis or network analysis, without a clear physiological context or application, is not within the scope of this journal.\u003C/p>\n\n\u003Cp>Frontiers in Physiology welcomes cancer-related research which focuses on the physiology and pathophysiology of the disease from cellular mechanisms to altered organ physiology. Should a manuscript purely focus on cancer etiology, cancer bioinformatics identifying novel biomarkers, cancer treatments, and cancer disease progression, it will not be considered in scope for the journal. Similarly, manuscripts on disease etiology, purely pathological processes, identification of novel biomarkers, and the progression, treatment, or management of disease – including clinical trials, and pilot studies – or purely bibliometric studies are not suitable for publication in this journal, and will be redirected to Frontiers in Medicine or Frontiers in Oncology as appropriate. Case reports will be considered in specified sections for publication in this journal. Please check section scope descriptions.\u003C/p>\n\n\u003Cp>Frontiers’ journals require that manuscripts primarily comprising computational studies of public data, must include appropriate validation. Please refer to the \u003Ca href=\"https://www.frontiersin.org/guidelines/policies-and-publication-ethics#standards-for-research-methodology:~:text=complaints%20and%20allegations.-,Standards%20for%20research%20methodology,-Experiments\">Frontiers Standards for research methodology policy\u003C/a>, for more information. Manuscripts not adhering to these standards will not be considered.\u003Cp>\n\n\u003Cp>Frontiers in Physiology is committed to understanding how body components work together to maintain a healthy state by communicating scientific knowledge to researchers and the public alike, to enable the scientific breakthroughs of the future.\u003C/p>","red","4 .0","6.1","478949","@FrontPhysiol",{"id":118,"name":119,"slug":120,"abbreviation":488,"isOnline":13,"isOpenForSubmissions":13,"citeScore":489,"impactFactor":490},"fphys",7.3,3.4,{"displayTitlePillLabels":13,"displayRelatedArticlesBox":13,"showEditors":13,"showReviewers":13,"showLoopImpactLink":13,"enableFigshare":399},{"isPublic":399,"allowCompanyUsers":399,"whiteListEmails":493,"enableAllJournals":399,"whiteListJournals":494},[],[],{"spaceId":446,"name":446,"availableJournalPages":496,"announcement":500,"useJournalPalettes":399},[306,311,308,497,498,499],"volumes","about","community-reviewers",{"__typename":501,"sys":502,"preHeader":504,"title":505,"description":506,"image":507,"link":529},"Announcement",{"id":503},"2IPv1l2IAkUt7RUrh3yJzz","Frontiers' quality","How do we build trust in science?","Behind each Frontiers journal is an editorial board committed to upholding research integrity and scientific quality",[508],{"id":509,"src":510,"name":511,"tags":512,"type":439,"width":513,"height":514,"archive":443,"brandId":444,"limited":443,"fileSize":515,"isPublic":443,"original":28,"copyright":28,"extension":516,"thumbnails":518,"dateCreated":525,"description":28,"orientation":460,"watermarked":443,"dateModified":525,"selectedFile":28,"datePublished":526,"videoPreviewURLs":527,"textMetaproperties":528},"1C167ADA-64D7-41F6-B87288EAF1BEC484","https://brand.frontiersin.org/m/47cd35867c2ab214/webimage-Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.png","Horizontal-Scientist looking at 3D rendered graphic scans from Magnetic Resonance Imaging (MRI) scanner, close up",[],1920,1080,2419221,[517],"png",{"mini":519,"thul":520,"webimage":510,"Guidelines":521,"WebsiteJpg_XL":522,"WebsiteWebP_L":523,"WebsiteWebP_M":524},"https://brand.frontiersin.org/m/47cd35867c2ab214/mini-Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.png","https://brand.frontiersin.org/m/47cd35867c2ab214/thul-Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.png","https://brand.frontiersin.org/asset/1c167ada-64d7-41f6-b872-88eaf1bec484/Guidelines/Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.png","https://brand.frontiersin.org/asset/1c167ada-64d7-41f6-b872-88eaf1bec484/WebsiteJpg_XL/Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.jpg","https://brand.frontiersin.org/asset/1c167ada-64d7-41f6-b872-88eaf1bec484/WebsiteWebP_L/Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.webp","https://brand.frontiersin.org/asset/1c167ada-64d7-41f6-b872-88eaf1bec484/WebsiteWebP_M/Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.webp","2026-03-06T11:24:30Z","2026-03-06T11:24:07Z",[],[],{"text":530,"url":531,"target":27,"ariaLabel":28},"Learn more","https://www.frontiersin.org/about/quality",{"loggedUserInfo":-1},{"currentArticle":534,"isPreviewPage":399,"hasSupplementalData":399,"showCrossmarkWidget":13,"articleTemplate":688,"currentArticlePageMetaInfo":689,"xmlParsedArticleContent":830,"xmlParsingError":-1},{"id":535,"doi":536,"title":537,"acceptanceDate":538,"receptionDate":539,"publicationDate":540,"lastModifiedDate":541,"isPublished":13,"abstract":542,"researchTopic":28,"articleType":543,"stage":546,"keywords":548,"authors":555,"editors":617,"reviewers":626,"journal":646,"section":653,"impactMetrics":655,"volume":659,"articleVolume":660,"relatedArticles":661,"isPublishedV2":399,"contents":662,"files":663},476968,"10.3389/fphys.2019.01272","Normal Values of QT Variability in 10-s Electrocardiograms for all Ages",["Date","2019-09-19T08:27:50.000Z"],["Date","2019-06-06T08:54:07.000Z"],["Date","2019-10-04T00:00:00.000Z"],["Date","2026-04-06T05:22:34.716Z"],"Aims \nQT variability is a promising electrocardiographic marker. It has been studied as a screening tool for coronary artery disease and left ventricular hypertrophy, and increased QT variability is a known risk factor for sudden cardiac death. Considering that comprehensive normal values for QT variability were lacking, we set out to establish these in standard 10-second electrocardiograms (ECGs) covering both sexes and all ages.\n\nMethods \nTen-second, 12-lead ECGs were provided by five Dutch population studies (Pediatric Normal ECG Study, Leiden University Einthoven Science Project, Prevention of Renal and Vascular End-stage Disease Study, Utrecht Health Project, Rotterdam Study). ECGs were recorded digitally and processed by well-validated analysis software. We selected cardiologically healthy participants, 46% being women. Ages ranged from 11 days to 91 years. After quality control, 13,828 ECGs were available. We assessed three markers: standard deviation of QT intervals (SDqt), short-term QT variability (STVqt), and QT variability index (QTVI).\n\nResults \nFor SDqt and STVqt, the median and the lower limit of normal remained stable with age. The upper limit of normal declined until around age 45, and increased strongly in the elderly, notably so in women. This implies that a subset of the population, small enough not to have appreciable effect on the median, shows a high degree of QT variability with a possible risk of arrhythmias or worse, especially in women. Otherwise, sex differences were negligible in all three measurements. For QTVI, median and normal limits decreased until age 20, and steadily went up afterwards except for the lower limit of normal, which flattens off after age 65.\n\nConclusion \nWe report the first set of normal values for QT variability based on 10-second ECGs, for all ages and both sexes.",{"id":544,"name":545},24,"Original Research",{"id":547,"name":19},18,[549,550,551,552,553,554],"electrocardiography (ECG)","Normal limits","QT variability","heart-rate variability (HRV)","Children","Elderly",[556,565,572,578,585,592,599,610],{"id":557,"firstName":558,"middleName":19,"lastName":559,"givenNames":560,"isCorresponding":399,"isProfilePublic":13,"userId":557,"email":-1,"affiliations":561},459773,"Marten E.","van den Berg","Marten E. ",[562],{"organizationName":563,"countryName":564,"cityName":19,"stateName":19,"zipCode":19},"Department of Medical Informatics, Erasmus MC – University Medical Center Rotterdam","Netherlands",{"id":566,"firstName":567,"middleName":19,"lastName":568,"givenNames":569,"isCorresponding":399,"isProfilePublic":13,"userId":566,"email":-1,"affiliations":570},409133,"Jan A.","Kors","Jan A. ",[571],{"organizationName":563,"countryName":564,"cityName":19,"stateName":19,"zipCode":19},{"id":443,"firstName":573,"middleName":19,"lastName":574,"givenNames":575,"isCorresponding":399,"isProfilePublic":399,"userId":443,"email":-1,"affiliations":576},"Gerard","van Herpen","Gerard ",[577],{"organizationName":563,"countryName":564,"cityName":19,"stateName":19,"zipCode":19},{"id":443,"firstName":579,"middleName":19,"lastName":580,"givenNames":581,"isCorresponding":399,"isProfilePublic":399,"userId":443,"email":-1,"affiliations":582},"Michiel L.","Bots","Michiel L. ",[583],{"organizationName":584,"countryName":564,"cityName":19,"stateName":19,"zipCode":19},"Julius Center for Health Sciences and Primary Care, University Medical Center Utrecht, Utrecht University",{"id":443,"firstName":586,"middleName":19,"lastName":587,"givenNames":588,"isCorresponding":399,"isProfilePublic":399,"userId":443,"email":-1,"affiliations":589},"Hans","Hillege","Hans ",[590],{"organizationName":591,"countryName":564,"cityName":19,"stateName":19,"zipCode":19},"Department of Cardiology, University Medical Center Groningen",{"id":443,"firstName":593,"middleName":19,"lastName":594,"givenNames":595,"isCorresponding":399,"isProfilePublic":399,"userId":443,"email":-1,"affiliations":596},"Cees A.","Swenne","Cees A. ",[597],{"organizationName":598,"countryName":564,"cityName":19,"stateName":19,"zipCode":19},"Department of Cardiology, Leiden University Medical Center",{"id":443,"firstName":600,"middleName":19,"lastName":601,"givenNames":602,"isCorresponding":399,"isProfilePublic":399,"userId":443,"email":-1,"affiliations":603},"Bruno H.","Stricker","Bruno H. ",[604,606,608],{"organizationName":605,"countryName":564,"cityName":19,"stateName":19,"zipCode":19},"Department of Epidemiology, Erasmus MC – University Medical Center Rotterdam",{"organizationName":607,"countryName":564,"cityName":19,"stateName":19,"zipCode":19},"Department of Internal Medicine, Erasmus MC – University Medical Center Rotterdam",{"organizationName":609,"countryName":564,"cityName":19,"stateName":19,"zipCode":19},"Inspectorate of Health Care",{"id":611,"firstName":612,"middleName":19,"lastName":613,"givenNames":614,"isCorresponding":399,"isProfilePublic":13,"userId":611,"email":-1,"affiliations":615},453426,"Peter R.","Rijnbeek","Peter R. ",[616],{"organizationName":563,"countryName":564,"cityName":19,"stateName":19,"zipCode":19},[618],{"id":619,"firstName":620,"middleName":19,"lastName":621,"givenNames":622,"isCorresponding":399,"isProfilePublic":13,"userId":619,"email":-1,"affiliations":623},9338,"Tobias","Opthof","Tobias ",[624],{"organizationName":625,"countryName":564,"cityName":19,"stateName":19,"zipCode":19},"Academic Medical Center",[627,637],{"id":628,"firstName":629,"middleName":630,"lastName":631,"givenNames":632,"isCorresponding":399,"isProfilePublic":13,"userId":628,"email":-1,"affiliations":633},95886,"Larisa","G","Tereshchenko","Larisa  G",[634],{"organizationName":635,"countryName":636,"cityName":19,"stateName":19,"zipCode":19},"Oregon Health and Science University","United States",{"id":638,"firstName":639,"middleName":19,"lastName":640,"givenNames":641,"isCorresponding":399,"isProfilePublic":13,"userId":638,"email":-1,"affiliations":642},236128,"Juhani","Junttila","Juhani ",[643],{"organizationName":644,"countryName":645,"cityName":19,"stateName":19,"zipCode":19},"University of Oulu","Finland",{"id":118,"slug":120,"name":119,"shortName":647,"electronicISSN":648,"field":649,"specialtyId":28,"journalSectionPaths":651},"Front. Physiol.","1664-042X",{"id":650,"domainId":446},65,[652],{"section":653},{"id":139,"name":140,"slug":141,"specialtyId":654},132,{"views":656,"downloads":657,"citations":658},4993,1532,7,10,"Volume 10 - 2019",[],{"titleHtml":19,"fullTextHtml":19,"menuHtml":19},[664,669,675,678,684],{"name":665,"fileServerPackageEntryId":19,"fileServerId":666,"fileServerVersionNumber":446,"type":667},"EPUB.epub","476968/epub",{"code":668,"name":668},"EPUB",{"name":670,"fileServerPackageEntryId":671,"fileServerId":672,"fileServerVersionNumber":446,"type":673},"fphys-10-01272.pdf","fphys-10-01272/fphys-10-01272.pdf","476968/pubmed-zip",{"code":674,"name":674},"PDF",{"name":670,"fileServerPackageEntryId":19,"fileServerId":676,"fileServerVersionNumber":446,"type":677},"476968/publishers-proof/pdf",{"code":674,"name":674},{"name":679,"fileServerPackageEntryId":680,"fileServerId":672,"fileServerVersionNumber":446,"type":681},"fphys-10-01272.xml","fphys-10-01272/fphys-10-01272.xml",{"code":682,"name":683},"NLM_XML","XML",{"name":685,"fileServerPackageEntryId":19,"fileServerId":686,"fileServerVersionNumber":446,"type":687},"Provisional PDF.pdf","476968/provisional-pdf",{"code":674,"name":674},"v4",{"title":690,"link":691,"meta":695,"script":818},"Frontiers | Normal Values of QT Variability in 10-s Electrocardiograms for all Ages",[692],{"rel":693,"href":694},"canonical","https://www.frontiersin.org/journals/physiology/articles/10.3389/fphys.2019.01272/full",[696,699,702,704,707,711,714,718,721,724,727,729,731,733,735,737,740,743,745,748,751,753,756,759,762,765,768,772,776,779,781,784,786,789,792,795,798,801,804,807,810,813,815],{"hid":697,"property":697,"name":697,"content":698},"description","Aims QT variability is a promising electrocardiographic marker. It has been studied as a screening tool for coronary artery disease and left ventricular hype...",{"hid":700,"property":700,"name":701,"content":690},"og:title","title",{"hid":703,"property":703,"name":697,"content":698},"og:description",{"hid":705,"name":705,"content":706},"keywords","electrocardiography (ECG),Normal limits,QT variability,heart-rate variability (HRV),Children,Elderly",{"hid":708,"property":708,"name":709,"content":710},"og:site_name","site_name","Frontiers",{"hid":712,"property":712,"name":439,"content":713},"og:image","https://images-provider.frontiersin.org/api/ipx/w=1200&f=png/https://www.frontiersin.org/files/Articles/476968/fphys-10-01272-HTML/image_m/fphys-10-01272-g001.jpg",{"hid":715,"property":715,"name":716,"content":717},"og:type","type","article",{"hid":719,"property":719,"name":720,"content":694},"og:url","url",{"hid":722,"name":722,"content":723},"twitter:card","summary_large_image",{"hid":725,"name":725,"content":726},"citation_volume","10",{"hid":728,"name":728,"content":119},"citation_journal_title",{"hid":730,"name":730,"content":710},"citation_publisher",{"hid":732,"name":732,"content":647},"citation_journal_abbrev",{"hid":734,"name":734,"content":648},"citation_issn",{"hid":736,"name":736,"content":536},"citation_doi",{"hid":738,"name":738,"content":739},"citation_firstpage","476968",{"hid":741,"name":741,"content":742},"citation_language","English",{"hid":744,"name":744,"content":537},"citation_title",{"hid":746,"name":746,"content":747},"citation_keywords","electrocardiography (ECG); Normal limits; QT variability; heart-rate variability (HRV); Children; Elderly",{"hid":749,"name":749,"content":750},"citation_abstract","Aims QT variability is a promising electrocardiographic marker. It has been studied as a screening tool for coronary artery disease and left ventricular hypertrophy, and increased QT variability is a known risk factor for sudden cardiac death. Considering that comprehensive normal values for QT variability were lacking, we set out to establish these in standard 10-second electrocardiograms (ECGs) covering both sexes and all ages.Methods Ten-second, 12-lead ECGs were provided by five Dutch population studies (Pediatric Normal ECG Study, Leiden University Einthoven Science Project, Prevention of Renal and Vascular End-stage Disease Study, Utrecht Health Project, Rotterdam Study). ECGs were recorded digitally and processed by well-validated analysis software. We selected cardiologically healthy participants, 46% being women. Ages ranged from 11 days to 91 years. After quality control, 13,828 ECGs were available. We assessed three markers: standard deviation of QT intervals (SDqt), short-term QT variability (STVqt), and QT variability index (QTVI).Results For SDqt and STVqt, the median and the lower limit of normal remained stable with age. The upper limit of normal declined until around age 45, and increased strongly in the elderly, notably so in women. This implies that a subset of the population, small enough not to have appreciable effect on the median, shows a high degree of QT variability with a possible risk of arrhythmias or worse, especially in women. Otherwise, sex differences were negligible in all three measurements. For QTVI, median and normal limits decreased until age 20, and steadily went up afterwards except for the lower limit of normal, which flattens off after age 65.Conclusion We report the first set of normal values for QT variability based on 10-second ECGs, for all ages and both sexes.",{"hid":752,"name":752,"content":545},"citation_article_type",{"hid":754,"name":754,"content":755},"citation_pdf_url","https://public-pages-files-2025.frontiersin.org/journals/physiology/articles/10.3389/fphys.2019.01272/pdf",{"hid":757,"name":757,"content":758},"citation_xml_url","https://public-pages-files-2025.frontiersin.org/journals/physiology/articles/10.3389/fphys.2019.01272/xml",{"hid":760,"name":760,"content":761},"citation_fulltext_world_readable","yes",{"hid":763,"name":763,"content":764},"citation_online_date","2019/09/19",{"hid":766,"name":766,"content":767},"citation_publication_date","2019/10/04",{"hid":769,"name":770,"content":771},"citation_author_0","citation_author","van den Berg, Marten E. ",{"hid":773,"name":774,"content":775},"citation_author_institution_0","citation_author_institution","Department of Medical Informatics, Erasmus MC – University Medical Center Rotterdam, Netherlands",{"hid":777,"name":770,"content":778},"citation_author_1","Kors, Jan A. ",{"hid":780,"name":774,"content":775},"citation_author_institution_1",{"hid":782,"name":770,"content":783},"citation_author_2","van Herpen, Gerard ",{"hid":785,"name":774,"content":775},"citation_author_institution_2",{"hid":787,"name":770,"content":788},"citation_author_3","Bots, Michiel L. ",{"hid":790,"name":774,"content":791},"citation_author_institution_3","Julius Center for Health Sciences and Primary Care, University Medical Center Utrecht, Utrecht University, Netherlands",{"hid":793,"name":770,"content":794},"citation_author_4","Hillege, Hans ",{"hid":796,"name":774,"content":797},"citation_author_institution_4","Department of Cardiology, University Medical Center Groningen, Netherlands",{"hid":799,"name":770,"content":800},"citation_author_5","Swenne, Cees A. ",{"hid":802,"name":774,"content":803},"citation_author_institution_5","Department of Cardiology, Leiden University Medical Center, Netherlands",{"hid":805,"name":770,"content":806},"citation_author_6","Stricker, Bruno H. ",{"hid":808,"name":774,"content":809},"citation_author_institution_6","Department of Epidemiology, Erasmus MC – University Medical Center Rotterdam, Netherlands",{"hid":811,"name":770,"content":812},"citation_author_7","Rijnbeek, Peter R. ",{"hid":814,"name":774,"content":775},"citation_author_institution_7",{"hid":816,"name":816,"content":817},"dc.identifier","doi:10.3389/fphys.2019.01272",[819,822,824,826,828],{"src":820,"body":13,"type":821,"async":13},"https://cdnjs.cloudflare.com/polyfill/v3/polyfill.min.js?features=es6","text/javascript",{"src":823,"body":13,"type":821,"async":13},"https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.1/MathJax.js?config=TeX-MML-AM_CHTML",{"src":825,"body":13,"type":821,"async":13},"https://d1bxh8uas1mnw7.cloudfront.net/assets/altmetric_badges-f0bc9b243ff5677d05460c1eb71834ca998946d764eb3bc244ab4b18ba50d21e.js",{"src":827,"body":13,"type":821,"async":13},"https://api.altmetric.com/v1/doi/10.3389/fphys.2019.01272?callback=_altmetric.embed_callback&domain=www.frontiersin.org&key=3c130976ca2b8f2e88f8377633751ba1&cache_until=14-15",{"src":829,"body":13,"type":821,"async":13},"https://crossmark-cdn.crossref.org/widget/v2.0/widget.js",{"journal":831,"doi":536,"articleType":545,"title":833,"authors":835,"onBehalfOf":19,"affiliations":861,"authorNotes":880,"publicationDate":915,"acceptedDate":916,"receivedDate":917,"correctedDate":19,"retractedDate":19,"volume":659,"elocationId":918,"permissions":919,"keywords":939,"relatedArticles":957,"abstractContent":958,"bodyContent":1001,"appendixContent":4644,"statements":4645,"references":4786,"otherBackSections":8176,"figures":8177,"toc":10233,"correspondingAuthors":10258},{"title":119,"abbreviation":647,"issn":648,"publisherName":832},"Frontiers Media S.A.",[834],{"#text":537},[836,840,843,845,848,851,854,858],{"surname":559,"givenNames":558,"suffix":19,"affiliationsIndexes":837,"isCorresponding":399,"equalContrib":399,"hierarchySymbol":838,"footnoteSymbol":19,"loopUrl":839,"onBehalfOf":19},[446],"\r\n            †\r\n          ","http://loop.frontiersin.org/people/459773/overview",{"surname":568,"givenNames":567,"suffix":19,"affiliationsIndexes":841,"isCorresponding":399,"equalContrib":399,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":842,"onBehalfOf":19},[446],"http://loop.frontiersin.org/people/409133/overview",{"surname":574,"givenNames":573,"suffix":19,"affiliationsIndexes":844,"isCorresponding":399,"equalContrib":399,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[446],{"surname":580,"givenNames":579,"suffix":19,"affiliationsIndexes":846,"isCorresponding":399,"equalContrib":399,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[847],2,{"surname":587,"givenNames":586,"suffix":19,"affiliationsIndexes":849,"isCorresponding":399,"equalContrib":399,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[850],3,{"surname":594,"givenNames":593,"suffix":19,"affiliationsIndexes":852,"isCorresponding":399,"equalContrib":399,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[853],4,{"surname":601,"givenNames":600,"suffix":19,"affiliationsIndexes":855,"isCorresponding":399,"equalContrib":399,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[856,857,658],5,6,{"surname":613,"givenNames":612,"suffix":19,"affiliationsIndexes":859,"isCorresponding":13,"equalContrib":399,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":860,"onBehalfOf":19},[446],"http://loop.frontiersin.org/people/453426/overview",[862,865,868,871,874,876,878],{"index":446,"baseText":19,"institution":563,"country":564,"address":863,"textContent":864},"Rotterdam","Department of Medical Informatics, Erasmus MC – University Medical Center Rotterdam, Rotterdam, Netherlands",{"index":847,"baseText":19,"institution":584,"country":564,"address":866,"textContent":867},"Utrecht","Julius Center for Health Sciences and Primary Care, University Medical Center Utrecht, Utrecht University, Utrecht, Netherlands",{"index":850,"baseText":19,"institution":591,"country":564,"address":869,"textContent":870},"Groningen","Department of Cardiology, University Medical Center Groningen, Groningen, Netherlands",{"index":853,"baseText":19,"institution":598,"country":564,"address":872,"textContent":873},"Leiden","Department of Cardiology, Leiden University Medical Center, Leiden, Netherlands",{"index":856,"baseText":19,"institution":605,"country":564,"address":863,"textContent":875},"Department of Epidemiology, Erasmus MC – University Medical Center Rotterdam, Rotterdam, Netherlands",{"index":857,"baseText":19,"institution":607,"country":564,"address":863,"textContent":877},"Department of Internal Medicine, Erasmus MC – University Medical Center Rotterdam, Rotterdam, Netherlands",{"index":658,"baseText":19,"institution":609,"country":564,"address":866,"textContent":879},"Inspectorate of Health Care, Utrecht, Netherlands",{"editedBy":881,"editedByContent":884,"reviewedBy":893,"reviewedByContent":896,"approvedBy":903,"approvedByContent":904,"correspondence":905,"equalContribution":906,"presentAddress":907,"other":908},[882],{"textContent":883},"Edited by: Tobias Opthof, Academic Medical Center (AMC), Netherlands",[885,887,891],{"#text":886},"\n          ",{"p":888},[889],{"#text":890}," Tobias Opthof, Academic Medical Center (AMC), Netherlands",{"#text":892},"\n        ",[894],{"textContent":895},"Reviewed by: Larisa G. Tereshchenko, Oregon Health & Science University, United States; Juhani Junttila, University of Oulu, Finland",[897,898,902],{"#text":886},{"p":899},[900],{"#text":901}," Larisa G. Tereshchenko, Oregon Health & Science University, United States; Juhani Junttila, University of Oulu, Finland",{"#text":892},[],[],"*Correspondence: Peter R. Rijnbeek cC5yaWpuYmVla0BlcmFzbXVzbWMubmw=",[],"\r\n          †Present address: Marten E. van den Berg, Department of Epidemiology, Erasmus MC – University Medical Center Rotterdam, Rotterdam, Netherlands\r\n        ",[909,910,914],{"#text":886},{"p":911},[912],{"#text":913},"This article was submitted to Cardiac Electrophysiology, a section of the journal Frontiers in Physiology",{"#text":892},"2019-10-04","2019-09-19","2019-06-06",1272,{"copyrightStatement":920,"copyrightYear":921,"copyrightHolder":922,"licenseUrl":923,"licenseText":924},"Copyright © 2019 van den Berg, Kors, van Herpen, Bots, Hillege, Swenne, Stricker and Rijnbeek.",2019,"van den Berg, Kors, van Herpen, Bots, Hillege, Swenne, Stricker and Rijnbeek","http://creativecommons.org/licenses/by/4.0/",[925,926,938],{"#text":886},{"p":927},[928,930,936],{"#text":929},"This is an open-access article distributed under the terms of the ",{"ext-link":931,":@":934},[932],{"#text":933},"Creative Commons Attribution License (CC BY)",{"@_ext-link-type":935,"@_xlink:href":923},"uri",{"#text":937},". The use, distribution or reproduction in other forums is permitted, provided the original author(s) and the copyright owner(s) are credited and that the original publication in this journal is cited, in accordance with accepted academic practice. No use, distribution or reproduction is permitted which does not comply with these terms.",{"#text":892},[940,943,946,948,951,954],[941],{"#text":942},"electrocardiography",[944],{"#text":945},"normal limits",[947],{"#text":551},[949],{"#text":950},"heart-rate variability",[952],{"#text":953},"children",[955],{"#text":956},"elderly",[],[959,960,969,970,979,980,989,990,999],{"#text":892},{"p":961},[962,963,967],{"#text":886},{"bold":964},[965],{"#text":966},"Aims:",{"#text":968}," QT variability is a promising electrocardiographic marker. It has been studied as a screening tool for coronary artery disease and left ventricular hypertrophy, and increased QT variability is a known risk factor for sudden cardiac death. Considering that comprehensive normal values for QT variability were lacking, we set out to establish these in standard 10-s electrocardiograms (ECGs) covering both sexes and all ages.",{"#text":892},{"p":971},[972,973,977],{"#text":886},{"bold":974},[975],{"#text":976},"Methods:",{"#text":978}," Ten-second, 12-lead ECGs were provided by five Dutch population studies (Pediatric Normal ECG Study, Leiden University Einthoven Science Project, Prevention of Renal and Vascular End-stage Disease Study, Utrecht Health Project, Rotterdam Study). ECGs were recorded digitally and processed by well-validated analysis software. We selected cardiologically healthy participants, 46% being women. Ages ranged from 11 days to 91 years. After quality control, 13,828 ECGs were available. We assessed three markers: standard deviation of QT intervals (SDqt), short-term QT variability (STVqt), and QT variability index (QTVI).",{"#text":892},{"p":981},[982,983,987],{"#text":886},{"bold":984},[985],{"#text":986},"Results:",{"#text":988}," For SDqt and STVqt, the median and the lower limit of normal remained stable with age. The upper limit of normal declined until around age 45, and increased strongly in the elderly, notably so in women. This implies that a subset of the population, small enough not to have appreciable effect on the median, shows a high degree of QT variability with a possible risk of arrhythmias or worse, especially in women. Otherwise, sex differences were negligible in all three measurements. For QTVI, median, and normal limits decreased until age 20, and steadily went up afterwards except for the lower limit of normal, which flattens off after age 65.",{"#text":892},{"p":991},[992,993,997],{"#text":886},{"bold":994},[995],{"#text":996},"Conclusion:",{"#text":998}," We report the first set of normal values for QT variability based on 10-s ECGs, for all ages and both sexes.",{"#text":1000},"\n      ",[1002,1004,1162,1163,1956,1957,4423,4424,4579,4580,4596,4597,4612,4613,4642],{"#text":1003},"\n    ",{"sec":1005,":@":1159},[1006,1007,1011,1012,1093,1094,1153,1154,1158],{"#text":1000},{"title":1008},[1009],{"#text":1010},"Introduction",{"#text":1000},{"p":1013},[1014,1016,1023,1025,1031,1033,1039,1041,1047,1049,1055,1057,1063,1065,1071,1073,1079,1081,1085,1087,1091],{"#text":1015},"QT variability is a measure of the spontaneous fluctuations in the duration of the QT interval on the electrocardiogram (ECG). These fluctuations are thought to be the result of local variations in cardiac repolarization (Berger et al., ",{"xref":1017,":@":1020},[1018],{"#text":1019},"1997",{"@_ref-type":1021,"@_rid":1022},"bibr","B4",{"#text":1024},"), and to reflect cardiac electrical instability (Baumert et al., ",{"xref":1026,":@":1029},[1027],{"#text":1028},"2016",{"@_ref-type":1021,"@_rid":1030},"B3",{"#text":1032},"). For this reason, QT variability has been studied in relation to ventricular arrhythmias (Haigney et al., ",{"xref":1034,":@":1037},[1035],{"#text":1036},"2004",{"@_ref-type":1021,"@_rid":1038},"B11",{"#text":1040},") and sudden cardiac death (SCD) (Piccirillo et al., ",{"xref":1042,":@":1045},[1043],{"#text":1044},"2007",{"@_ref-type":1021,"@_rid":1046},"B19",{"#text":1048},"). Moreover, increased QT variability was found to be a useful screening tool for coronary artery disease and left ventricular hypertrophy (Schlegel et al., ",{"xref":1050,":@":1053},[1051],{"#text":1052},"2010",{"@_ref-type":1021,"@_rid":1054},"B24",{"#text":1056},"), which are important underlying causes of SCD (Albert et al., ",{"xref":1058,":@":1061},[1059],{"#text":1060},"1996",{"@_ref-type":1021,"@_rid":1062},"B1",{"#text":1064},"; Haukilahti et al., ",{"xref":1066,":@":1069},[1067],{"#text":1068},"2019",{"@_ref-type":1021,"@_rid":1070},"B12",{"#text":1072},"). The effects of cardiac drugs on QT variability have also been studied: β-blockers decrease QT variability (except sotalol), while digoxin and β-sympathicomimetic drugs increase QT variability (Niemeijer et al., ",{"xref":1074,":@":1077},[1075],{"#text":1076},"2014",{"@_ref-type":1021,"@_rid":1078},"B17",{"#text":1080},"). The most commonly used QT-variability markers are the standard deviation of QT intervals (SDqt), short-term QT variability (STVqt), and the QT variability index (QTVI) (Niemeijer et al., ",{"xref":1082,":@":1084},[1083],{"#text":1076},{"@_ref-type":1021,"@_rid":1078},{"#text":1086},"; Baumert et al., ",{"xref":1088,":@":1090},[1089],{"#text":1028},{"@_ref-type":1021,"@_rid":1030},{"#text":1092},"). Definitions of these markers are given in the paragraph on QT variability measurement below.",{"#text":1000},{"p":1095},[1096,1098,1102,1103,1107,1109,1113,1115,1121,1123,1129,1131,1136,1138,1144,1145,1151],{"#text":1097},"QT variability has been measured on ECG recordings down to 10 s, and up to 24 h (Niemeijer et al., ",{"xref":1099,":@":1101},[1100],{"#text":1076},{"@_ref-type":1021,"@_rid":1078},{"#text":1086},{"xref":1104,":@":1106},[1105],{"#text":1028},{"@_ref-type":1021,"@_rid":1030},{"#text":1108},"). Because the standard 10-s ECG is cheap, non-burdening, and in ubiquitous use, it would pay off to have normal values for QT variability based on 10-s ECGs. A position paper by Baumert et al. presented a meta-analysis of previous QT-variability studies including healthy participants (Baumert et al., ",{"xref":1110,":@":1112},[1111],{"#text":1028},{"@_ref-type":1021,"@_rid":1030},{"#text":1114},"). This meta-analysis only showed study-specific average values for SDqt and QTVI, but did not stratify on sex or age (other than distinguishing between adults, children, and infants). Some of the studies that were reviewed reported age-specific normal limits (Yeragani et al., ",{"xref":1116,":@":1119},[1117],{"#text":1118},"2000",{"@_ref-type":1021,"@_rid":1120},"B29",{"#text":1122},"; Piccirillo et al., ",{"xref":1124,":@":1127},[1125],{"#text":1126},"2006",{"@_ref-type":1021,"@_rid":1128},"B18",{"#text":1130},"; Boettger et al., ",{"xref":1132,":@":1134},[1133],{"#text":1052},{"@_ref-type":1021,"@_rid":1135},"B5",{"#text":1137},"; Kusuki et al., ",{"xref":1139,":@":1142},[1140],{"#text":1141},"2011",{"@_ref-type":1021,"@_rid":1143},"B16",{"#text":1086},{"xref":1146,":@":1149},[1147],{"#text":1148},"2013",{"@_ref-type":1021,"@_rid":1150},"B2",{"#text":1152},"), but all these studies were done on small sample sizes and none used 10-s ECGs.",{"#text":1000},{"p":1155},[1156],{"#text":1157},"In the present study we provide normal values for the commonly used QT-variability markers SDqt, STVqt, and QTVI, based on a large set of standard 12-lead, 10-s ECGs of cardiologically healthy persons, covering both sexes and all ages.",{"#text":1003},{"@_sec-type":1160,"@_id":1161},"intro","s1",{"#text":1003},{"sec":1164,":@":1953},[1165,1166,1170,1171,1274,1275,1288,1289,1879,1880,1952],{"#text":1000},{"title":1167},[1168],{"#text":1169},"Methods",{"#text":1000},{"sec":1172},[1173,1174,1178,1179,1263,1264,1268,1269,1273],{"#text":892},{"title":1175},[1176],{"#text":1177},"Study Population",{"#text":892},{"p":1180},[1181,1183],{"#text":1182},"We combined data from five population studies conducted in the Netherlands. The 10-s, 12-lead ECGs from these studies were digitally recorded and stored at sampling rates of at least 500 Hz, up to 1,200 Hz in the pediatric group. All data were anonymized. The following studies were included:\n",{"list":1184,":@":1261},[1185,1205,1219,1233,1247],{"list-item":1186},[1187],{"p":1188},[1189,1191,1197,1199,1203],{"#text":1190},"Pediatric Normal ECG Study (Rijnbeek et al., ",{"xref":1192,":@":1195},[1193],{"#text":1194},"2001",{"@_ref-type":1021,"@_rid":1196},"B21",{"#text":1198},"): The population of this study consists of 1,912 children, their ages ranging from 11 days to 16 years. The children were recruited in the year 2000 at three children's health centers, three primary schools, and one secondary school in the city of Rotterdam. The childrens' height and weight, measured before ECG recording, corresponded well with the Dutch growth standard (Rijnbeek et al., ",{"xref":1200,":@":1202},[1201],{"#text":1194},{"@_ref-type":1021,"@_rid":1196},{"#text":1204},"). ECGs were recorded with a portable PC-based acquisition system (Cardio Control, Delft, The Netherlands).",{"list-item":1206},[1207],{"p":1208},[1209,1211,1217],{"#text":1210},"Leiden University Einthoven Science Project (Scherptong et al., ",{"xref":1212,":@":1215},[1213],{"#text":1214},"2008",{"@_ref-type":1021,"@_rid":1216},"B23",{"#text":1218},"): The population of this study contains 787 medical students of Leiden University. The ages of the participants ranged between 17 and 29 years, and all attested to be in good health. The ECGs were recorded from 2005 until 2007 with Megacart electrocardiographs (Siemens, Erlangen, Germany).",{"list-item":1220},[1221],{"p":1222},[1223,1225,1231],{"#text":1224},"Prevention of Renal and Vascular End-stage Disease (PREVEND) Study (de Jong et al., ",{"xref":1226,":@":1229},[1227],{"#text":1228},"2003",{"@_ref-type":1021,"@_rid":1230},"B7",{"#text":1232},"): This study, which started in 1997, aims to investigate the natural course of microalbuminuria and its relation to renal and cardiovascular disease in the general population. The PREVEND population consists of 8,592 participants aged 28–75 years, from the city of Groningen. Medical records, including medication use, were available for all participants. ECGs were recorded with CardioPerfect equipment (Welch Allyn, USA).",{"list-item":1234},[1235],{"p":1236},[1237,1239,1245],{"#text":1238},"Utrecht Health Project (Grobbee et al., ",{"xref":1240,":@":1243},[1241],{"#text":1242},"2005",{"@_ref-type":1021,"@_rid":1244},"B10",{"#text":1246},"): This ongoing study started in 2000 in Leidsche Rijn, a newly developed residential area of Utrecht. All new inhabitants were invited by their general practitioner to participate. The population of this study consists of 6,542 participants with ages ranging from 17 to 85 years. Written informed consent was obtained and an individual health profile was made by dedicated research nurses. Baseline assessment included physical examination, ECG, blood tests, and interview-assisted questionnaires. Pharmacy records were used to obtain information about medication. ECGs were recorded with CardioPerfect equipment (Welch Allyn, USA).",{"list-item":1248},[1249],{"p":1250},[1251,1253,1259],{"#text":1252},"Rotterdam Study (Hofman et al., ",{"xref":1254,":@":1257},[1255],{"#text":1256},"1991",{"@_ref-type":1021,"@_rid":1258},"B13",{"#text":1260},"): This study, which started in 1990, investigates determinants of a number of age-related disorders in an elderly population, prominently among them cardiovascular disease. The first two cohorts of the Rotterdam Study population consist of 10,994 inhabitants of Ommoord, a suburb of Rotterdam, aged 55 years or older. Participants were visited at home for an interview and were subsequently examined at the research center. Detailed information was collected on health status, medical history, and medication use. ECGs were recorded with an ACTA electrocardiograph (Esaote, Florence, Italy).",{"@_list-type":1262},"order",{"#text":892},{"p":1265},[1266],{"#text":1267},"From these five populations, totaling 28,827 participants, we excluded individuals with proof or suspicion of cardiac disease. Reasons for exclusion were, therefore, a history of myocardial infarction, heart failure, coronary bypass surgery, coronary angioplasty, or pacemaker implantation. Further exclusion criteria were hypertension and diabetes mellitus. Hypertension was defined as a systolic blood pressure ≥160 mmHg or a diastolic blood pressure ≥100 mmHg or use of antihypertensive medication, including beta-blockers. Diabetes mellitus was defined as a non-fasting serum glucose ≥11 mmol/l or use of glucose-lowering drugs. After applying these criteria, 15,248 individuals remained available.",{"#text":892},{"p":1270},[1271],{"#text":1272},"This study was approved by the Medical Ethics Committee of the Erasmus University Medical Center. Since all data were anonymized and retrospectively collected, individual informed consent from the participants in our study was not required according to Dutch legislation.",{"#text":1000},{"#text":1000},{"sec":1276},[1277,1278,1282,1283,1287],{"#text":892},{"title":1279},[1280],{"#text":1281},"ECG Quality Control",{"#text":892},{"p":1284},[1285],{"#text":1286},"All ECGs were manually checked. We removed ECGs with disturbances that could potentially affect accurate measurement of the QT interval, such as excessive noise, excessive baseline wander, and sudden baseline jumps or spikes. We also removed ECGs with premature ventricular beats, premature supraventricular beats, and second or third degree atrioventricular block. This resulted in a final 13,828 ECGs for analysis.",{"#text":1000},{"#text":1000},{"sec":1290},[1291,1292,1296,1297,1332,1333,1343,1344,1536,1537,1546,1547,1595,1596,1873,1874,1878],{"#text":892},{"title":1293},[1294],{"#text":1295},"QT-Variability Measurement",{"#text":892},{"p":1298},[1299,1301,1307,1309,1314,1316,1322,1324,1330],{"#text":1300},"The ECGs were processed by our Modular ECG Analysis System (MEANS), an ECG computer program that has been evaluated extensively (van Bemmel et al., ",{"xref":1302,":@":1305},[1303],{"#text":1304},"1990",{"@_ref-type":1021,"@_rid":1306},"B25",{"#text":1308},"; Willems et al., ",{"xref":1310,":@":1312},[1311],{"#text":1256},{"@_ref-type":1021,"@_rid":1313},"B27",{"#text":1315},"). MEANS signals excessive noise and baseline wander, recognizes ectopic beats and the various forms of AV block. It computes one representative averaged beat over all beats of each of the 12 leads and identifies within these averaged beats the P, QRS, and T waves with their points of onset and offset for the 12 leads simultaneously. For the special case of QT-interval measurement fiducial segment averaging (FSA) was applied, a technique that exploits the correlation between signal segments from individual beats (Ritsema van Eck, ",{"xref":1317,":@":1320},[1318],{"#text":1319},"2002",{"@_ref-type":1021,"@_rid":1321},"B22",{"#text":1323},"). An FSA implementation in combination with MEANS has been described and evaluated extensively before (Rijnbeek et al., ",{"xref":1325,":@":1328},[1326],{"#text":1327},"2017",{"@_ref-type":1021,"@_rid":1329},"B20",{"#text":1331},"). Briefly, MEANS first determines the locations of the individual QRS complexes and provisional fiducial points (i.e., the onsets of the QRS complexes and the ends of the T waves). Baseline wander is corrected using restricted splines, and a detection function consisting of the root-mean-square ECG signal is computed. Second, the fiducial point in each individual beat is shifted in an iterative procedure until maximum correlation is achieved between a small signal segment of the detection function around this fiducial point and the average of the segments around the fiducial points of the remaining complexes. The amount of shifting is retained and constitutes the individual beat variation. Finally, the QT interval for each beat is calculated from the shifts of the initial QRS onset and T end.",{"#text":892},{"p":1334},[1335,1337,1341],{"#text":1336},"We calculated the QT-variability markers SDqt, STVqt, and QTVI (Niemeijer et al., ",{"xref":1338,":@":1340},[1339],{"#text":1076},{"@_ref-type":1021,"@_rid":1078},{"#text":1342},"). SDqt is defined as the standard deviation of the QT intervals. STVqt is defined as the average of the absolute differences between the QT intervals of subsequent beats:",{"#text":892},{"disp-formula":1345,":@":1534},[1346,1347,1351,1352,1533],{"#text":886},{"label":1348},[1349],{"#text":1350},"(1)",{"#text":886},{"mml:math":1353,":@":1530},[1354,1356,1529],{"#text":1355},"\n            ",{"mml:mtable":1357,":@":1526},[1358,1360,1525],{"#text":1359},"\n              ",{"mml:mtr":1361},[1362,1364,1524],{"#text":1363},"\n                ",{"mml:mtd":1365},[1366,1368,1372,1373,1377,1378,1419,1420,1523],{"#text":1367},"\n                  ",{"mml:mtext":1369},[1370],{"#text":1371},"STVqt",{"#text":1367},{"mml:mo":1374},[1375],{"#text":1376},"=",{"#text":1367},{"mml:msubsup":1379},[1380,1382,1391,1392,1409,1410,1418],{"#text":1381},"\n                    ",{"mml:mrow":1383},[1384,1386,1390],{"#text":1385},"\n                      ",{"mml:mo":1387},[1388],{"#text":1389},"∑",{"#text":1381},{"#text":1381},{"mml:mrow":1393},[1394,1395,1399,1400,1403,1404,1408],{"#text":1385},{"mml:mi":1396},[1397],{"#text":1398},"i",{"#text":1385},{"mml:mo":1401},[1402],{"#text":1376},{"#text":1385},{"mml:mn":1405},[1406],{"#text":1407},"1",{"#text":1381},{"#text":1381},{"mml:mrow":1411},[1412,1413,1417],{"#text":1385},{"mml:mi":1414},[1415],{"#text":1416},"n",{"#text":1381},{"#text":1367},{"#text":1367},{"mml:mfrac":1421},[1422,1423,1501,1502,1522],{"#text":1381},{"mml:mrow":1424},[1425,1426,1430,1431,1435,1436,1467,1468,1472,1473,1476,1477,1496,1497,1500],{"#text":1385},{"mml:mo":1427},[1428],{"#text":1429},"|",{"#text":1385},{"mml:mi":1432},[1433],{"#text":1434},"Q",{"#text":1385},{"mml:msub":1437},[1438,1440,1449,1450,1466],{"#text":1439},"\n                        ",{"mml:mrow":1441},[1442,1444,1448],{"#text":1443},"\n                          ",{"mml:mi":1445},[1446],{"#text":1447},"T",{"#text":1439},{"#text":1439},{"mml:mrow":1451},[1452,1453,1456,1457,1461,1462,1465],{"#text":1443},{"mml:mi":1454},[1455],{"#text":1398},{"#text":1443},{"mml:mo":1458},[1459],{"#text":1460},"+",{"#text":1443},{"mml:mn":1463},[1464],{"#text":1407},{"#text":1439},{"#text":1385},{"#text":1385},{"mml:mo":1469},[1470],{"#text":1471},"-",{"#text":1385},{"mml:mi":1474},[1475],{"#text":1434},{"#text":1385},{"mml:msub":1478},[1479,1480,1487,1488,1495],{"#text":1439},{"mml:mrow":1481},[1482,1483,1486],{"#text":1443},{"mml:mi":1484},[1485],{"#text":1447},{"#text":1439},{"#text":1439},{"mml:mrow":1489},[1490,1491,1494],{"#text":1443},{"mml:mi":1492},[1493],{"#text":1398},{"#text":1439},{"#text":1385},{"#text":1385},{"mml:mo":1498},[1499],{"#text":1429},{"#text":1381},{"#text":1381},{"mml:mrow":1503},[1504,1505,1508,1509,1521],{"#text":1385},{"mml:mi":1506},[1507],{"#text":1416},{"#text":1385},{"mml:msqrt":1510},[1511,1512,1520],{"#text":1439},{"mml:mrow":1513},[1514,1515,1519],{"#text":1443},{"mml:mn":1516},[1517],{"#text":1518},"2",{"#text":1439},{"#text":1385},{"#text":1381},{"#text":1367},{"#text":1363},{"#text":1359},{"#text":1355},{"@_class":1527,"@_columnalign":1528},"eqnarray","right center left",{"#text":886},{"@_id":1531,"@_xmlns:mml":1532},"M1","http://www.w3.org/1998/Math/MathML",{"#text":892},{"@_id":1535},"E1",{"#text":892},{"p":1538},[1539,1541,1544],{"#text":1540},"where ",{"italic":1542},[1543],{"#text":1416},{"#text":1545}," is the number of differences.",{"#text":892},{"p":1548},[1549,1551,1555,1561,1563,1566,1572,1574,1578,1583,1585,1588,1593],{"#text":1550},"QTVI normalizes the variance of the QT intervals (",{"italic":1552},[1553],{"#text":1554},"QT",{"sub":1556},[1557],{"italic":1558},[1559],{"#text":1560},"v",{"#text":1562},") for mean QT (",{"italic":1564},[1565],{"#text":1554},{"sub":1567},[1568],{"italic":1569},[1570],{"#text":1571},"m",{"#text":1573},") squared, and the variance of the heart rate (",{"italic":1575},[1576],{"#text":1577},"HR",{"sub":1579},[1580],{"italic":1581},[1582],{"#text":1560},{"#text":1584},") for mean heart rate (",{"italic":1586},[1587],{"#text":1577},{"sub":1589},[1590],{"italic":1591},[1592],{"#text":1571},{"#text":1594},") squared, and is defined as:",{"#text":892},{"disp-formula":1597,":@":1871},[1598,1599,1603,1604,1870],{"#text":886},{"label":1600},[1601],{"#text":1602},"(2)",{"#text":886},{"mml:math":1605,":@":1868},[1606,1607,1867],{"#text":1355},{"mml:mtable":1608,":@":1866},[1609,1610,1865],{"#text":1359},{"mml:mtr":1611},[1612,1613,1864],{"#text":1363},{"mml:mtd":1614},[1615,1616,1620,1621,1624,1625,1629,1630,1634,1635,1655,1656,1863],{"#text":1367},{"mml:mtext":1617},[1618],{"#text":1619},"QTVI",{"#text":1367},{"mml:mo":1622},[1623],{"#text":1376},{"#text":1367},{"mml:mi":1626},[1627],{"#text":1628},"l",{"#text":1367},{"mml:mi":1631},[1632],{"#text":1633},"o",{"#text":1367},{"mml:msub":1636},[1637,1638,1646,1647,1654],{"#text":1381},{"mml:mrow":1639},[1640,1641,1645],{"#text":1385},{"mml:mi":1642},[1643],{"#text":1644},"g",{"#text":1381},{"#text":1381},{"mml:mrow":1648},[1649,1650,1653],{"#text":1385},{"mml:mn":1651},[1652],{"#text":726},{"#text":1381},{"#text":1367},{"#text":1367},{"mml:mrow":1657},[1658,1659,1663,1664,1857,1858,1862],{"#text":1381},{"mml:mo":1660},[1661],{"#text":1662},"[",{"#text":1381},{"mml:mrow":1665},[1666,1667,1758,1759,1763,1764,1851,1852,1856],{"#text":1385},{"mml:mrow":1668},[1669,1670,1675,1676,1751,1752,1757],{"#text":1439},{"mml:mo":1671,":@":1674},[1672],{"#text":1673},"(",{"@_stretchy":13},{"#text":1439},{"mml:mrow":1677},[1678,1679,1750],{"#text":1443},{"mml:mfrac":1680},[1681,1683,1713,1714,1749],{"#text":1682},"\n                            ",{"mml:mrow":1684},[1685,1687,1690,1691,1712],{"#text":1686},"\n                              ",{"mml:mi":1688},[1689],{"#text":1434},{"#text":1686},{"mml:msub":1692},[1693,1695,1703,1704,1711],{"#text":1694},"\n                                ",{"mml:mrow":1696},[1697,1699,1702],{"#text":1698},"\n                                  ",{"mml:mi":1700},[1701],{"#text":1447},{"#text":1694},{"#text":1694},{"mml:mrow":1705},[1706,1707,1710],{"#text":1698},{"mml:mi":1708},[1709],{"#text":1560},{"#text":1694},{"#text":1686},{"#text":1682},{"#text":1682},{"mml:mrow":1715},[1716,1717,1720,1721,1748],{"#text":1686},{"mml:mi":1718},[1719],{"#text":1434},{"#text":1686},{"mml:msubsup":1722},[1723,1724,1731,1732,1739,1740,1747],{"#text":1694},{"mml:mrow":1725},[1726,1727,1730],{"#text":1698},{"mml:mi":1728},[1729],{"#text":1447},{"#text":1694},{"#text":1694},{"mml:mrow":1733},[1734,1735,1738],{"#text":1698},{"mml:mi":1736},[1737],{"#text":1571},{"#text":1694},{"#text":1694},{"mml:mrow":1741},[1742,1743,1746],{"#text":1698},{"mml:mn":1744},[1745],{"#text":1518},{"#text":1694},{"#text":1686},{"#text":1682},{"#text":1443},{"#text":1439},{"#text":1439},{"mml:mo":1753,":@":1756},[1754],{"#text":1755},")",{"@_stretchy":13},{"#text":1385},{"#text":1385},{"mml:mo":1760},[1761],{"#text":1762},"/",{"#text":1385},{"mml:mrow":1765},[1766,1767,1771,1772,1845,1846,1850],{"#text":1439},{"mml:mo":1768,":@":1770},[1769],{"#text":1673},{"@_stretchy":13},{"#text":1439},{"mml:mrow":1773},[1774,1775,1844],{"#text":1443},{"mml:mfrac":1776},[1777,1778,1807,1808,1843],{"#text":1682},{"mml:mrow":1779},[1780,1781,1785,1786,1806],{"#text":1686},{"mml:mi":1782},[1783],{"#text":1784},"H",{"#text":1686},{"mml:msub":1787},[1788,1789,1797,1798,1805],{"#text":1694},{"mml:mrow":1790},[1791,1792,1796],{"#text":1698},{"mml:mi":1793},[1794],{"#text":1795},"R",{"#text":1694},{"#text":1694},{"mml:mrow":1799},[1800,1801,1804],{"#text":1698},{"mml:mi":1802},[1803],{"#text":1560},{"#text":1694},{"#text":1686},{"#text":1682},{"#text":1682},{"mml:mrow":1809},[1810,1811,1814,1815,1842],{"#text":1686},{"mml:mi":1812},[1813],{"#text":1784},{"#text":1686},{"mml:msubsup":1816},[1817,1818,1825,1826,1833,1834,1841],{"#text":1694},{"mml:mrow":1819},[1820,1821,1824],{"#text":1698},{"mml:mi":1822},[1823],{"#text":1795},{"#text":1694},{"#text":1694},{"mml:mrow":1827},[1828,1829,1832],{"#text":1698},{"mml:mi":1830},[1831],{"#text":1571},{"#text":1694},{"#text":1694},{"mml:mrow":1835},[1836,1837,1840],{"#text":1698},{"mml:mn":1838},[1839],{"#text":1518},{"#text":1694},{"#text":1686},{"#text":1682},{"#text":1443},{"#text":1439},{"#text":1439},{"mml:mo":1847,":@":1849},[1848],{"#text":1755},{"@_stretchy":13},{"#text":1385},{"#text":1385},{"mml:mtext":1853},[1854],{"#text":1855}," ",{"#text":1381},{"#text":1381},{"mml:mo":1859},[1860],{"#text":1861},"]",{"#text":1367},{"#text":1363},{"#text":1359},{"#text":1355},{"@_class":1527,"@_columnalign":1528},{"#text":886},{"@_id":1869},"M2",{"#text":892},{"@_id":1872},"E2",{"#text":892},{"p":1875},[1876],{"#text":1877},"In 11 ECGs all QT intervals were measured as identical, producing SDqt and STVqt values of zero. However, if the variance of QT is zero, QTVI cannot be computed because the logarithm of zero is undefined. These cases are addressed by setting the QTVI to −3.60, the lowest QTVI value that occurred in our data.",{"#text":1000},{"#text":1000},{"sec":1881},[1882,1883,1887,1888,1939,1940,1951],{"#text":892},{"title":1884},[1885],{"#text":1886},"Estimation of Normal Values",{"#text":892},{"p":1889},[1890,1892,1896,1898,1904,1906,1909,1911,1914,1916,1920,1922,1926,1928,1932,1934,1937],{"#text":1891},"We used the Box-Cox ",{"italic":1893},[1894],{"#text":1895},"t",{"#text":1897}," distribution in a semi-parametric model for location, scale, and shape to estimate centile curves (Cole and Green, ",{"xref":1899,":@":1902},[1900],{"#text":1901},"1992",{"@_ref-type":1021,"@_rid":1903},"B6",{"#text":1905},"). The Box-Cox ",{"italic":1907},[1908],{"#text":1895},{"#text":1910}," distribution allows for modeling of the distribution of the median, skewness, and kurtosis as functions of age. The lower limit of normal (LLN) was defined as the 2nd percentile and the upper limit of normal (ULN) as the 98th percentile. The Box-Cox ",{"italic":1912},[1913],{"#text":1895},{"#text":1915}," distribution was implemented with the ",{"italic":1917},[1918],{"#text":1919},"lms",{"#text":1921}," function of the R-package ",{"italic":1923},[1924],{"#text":1925},"gamlss",{"#text":1927},", and the normal values for all age categories were estimated using the ",{"italic":1929},[1930],{"#text":1931},"predict.gamlss",{"#text":1933}," function of the ",{"italic":1935},[1936],{"#text":1925},{"#text":1938}," package. The normal values of a given age category were estimated for the central age in that category. For example, normal values for the category of 30–39 years are based on the estimated values for participants aged 35 years.",{"#text":892},{"p":1941},[1942,1944,1949],{"#text":1943},"Differences in LLN, median, and ULN between men and women were tested per age group, using non-parametric estimates and a bootstrap approach with 5,000 bootstrap samples (Johnson and Romer, ",{"xref":1945,":@":1947},[1946],{"#text":1028},{"@_ref-type":1021,"@_rid":1948},"B14",{"#text":1950},").",{"#text":1000},{"#text":1003},{"@_sec-type":1954,"@_id":1955},"methods","s2",{"#text":1003},{"sec":1958,":@":4420},[1959,1960,1964,1965,2033,2034,2645,2646,3250,3251,3805,3806,4340,4341,4365,4366,4390,4391,4414,4415,4419],{"#text":1000},{"title":1961},[1962],{"#text":1963},"Results",{"#text":1000},{"p":1966},[1967,1968,1975,1977,1983,1985,1991,1993,1999,2001,2008,2010,2016,2018,2025,2026,2031],{"#text":892},{"xref":1969,":@":1972},[1970],{"#text":1971},"Table 1",{"@_ref-type":1973,"@_rid":1974},"table","T1",{"#text":1976}," shows the number of available ECGs grouped by sex and age category. Most age groups had more than 100 ECGs, only the age groups below 6 months or above 90 years contained fewer ECGs. ",{"xref":1978,":@":1981},[1979],{"#text":1980},"Table 2",{"@_ref-type":1973,"@_rid":1982},"T2",{"#text":1984}," gives the age-dependent median, ULN, and LLN of SDqt, stratified by sex. ",{"xref":1986,":@":1989},[1987],{"#text":1988},"Table 3",{"@_ref-type":1973,"@_rid":1990},"T3",{"#text":1992}," shows these statistics for STVqt and ",{"xref":1994,":@":1997},[1995],{"#text":1996},"Table 4",{"@_ref-type":1973,"@_rid":1998},"T4",{"#text":2000}," for QTVI. Additional percentile values for the three markers are given in ",{"xref":2002,":@":2005},[2003],{"#text":2004},"Supplementary Tables 1",{"@_ref-type":2006,"@_rid":2007},"supplementary-material","SM1",{"#text":2009},"–",{"xref":2011,":@":2014},[2012],{"#text":2013},"3",{"@_ref-type":2006,"@_rid":2015},"SM3",{"#text":2017},". ",{"xref":2019,":@":2022},[2020],{"#text":2021},"Figures 1",{"@_ref-type":2023,"@_rid":2024},"fig","F1",{"#text":2009},{"xref":2027,":@":2029},[2028],{"#text":2013},{"@_ref-type":2023,"@_rid":2030},"F3",{"#text":2032}," show continuous age-dependent curves of the median and the normal limits of SDqt, STVqt, and QTVI, respectively.",{"#text":1000},{"table-wrap":2035,":@":2643},[2036,2037,2040,2041,2049,2050,2642],{"#text":892},{"label":2038},[2039],{"#text":1971},{"#text":892},{"caption":2042},[2043,2044,2048],{"#text":886},{"p":2045},[2046],{"#text":2047},"The study population stratified on sex and age groups.",{"#text":892},{"#text":892},{"table":2051,":@":2639},[2052,2053,2103,2104,2638],{"#text":886},{"thead":2054},[2055,2056,2102],{"#text":1355},{"tr":2057},[2058,2059,2070,2071,2081,2082,2091,2092,2101],{"#text":1359},{"th":2060,":@":2067},[2061,2062,2066],{"#text":1363},{"bold":2063},[2064],{"#text":2065},"Age group",{"#text":1359},{"@_valign":2068,"@_align":2069},"top","left",{"#text":1359},{"th":2072,":@":2079},[2073,2074,2078],{"#text":1363},{"bold":2075},[2076],{"#text":2077},"No. of boys/men",{"#text":1359},{"@_valign":2068,"@_align":2080},"center",{"#text":1359},{"th":2083,":@":2090},[2084,2085,2089],{"#text":1363},{"bold":2086},[2087],{"#text":2088},"No. of girls/women",{"#text":1359},{"@_valign":2068,"@_align":2080},{"#text":1359},{"th":2093,":@":2100},[2094,2095,2099],{"#text":1363},{"bold":2096},[2097],{"#text":2098},"Total",{"#text":1359},{"@_valign":2068,"@_align":2080},{"#text":1355},{"#text":886},{"#text":886}