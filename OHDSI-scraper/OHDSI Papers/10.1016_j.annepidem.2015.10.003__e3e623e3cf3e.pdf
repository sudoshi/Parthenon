<div class="fn p" id="FN2"><p id="P33">Disclosures: The authors have no financial or other conflicts to disclose</p></div>
<div class="fn p" id="FN3">
<sup>1</sup><p class="display-inline" id="P34">* using the arithmetic equation <span xmlns:mml="http://www.w3.org/1998/Math/MathML"><math id="M1" overflow="linebreak"><mi>P</mi><mi>S</mi><mi>A</mi><mi>V</mi><mo>=</mo><mo stretchy="false">(</mo><mn>1</mn><mo>/</mo><mo stretchy="false">(</mo><mi>n</mi><mo>−</mo><mn>1</mn><mo stretchy="false">)</mo><mo stretchy="false">)</mo><mo>*</mo><mo stretchy="false">(</mo><msubsup><mi>Σ</mi><mrow><mi>i</mi><mo>=</mo><mn>1</mn></mrow><mi>n</mi></msubsup><mo stretchy="false">(</mo><msub><mi>p</mi><mi>i</mi></msub><mo>−</mo><msub><mi>P</mi><mrow><mi>i</mi><mo>−</mo><mn>1</mn></mrow></msub><mo stretchy="false">)</mo><mo>/</mo><mo stretchy="false">(</mo><msub><mi>t</mi><mi>i</mi></msub><mo>−</mo><msub><mi>t</mi><mrow><mi>i</mi><mo>−</mo><mn>1</mn></mrow></msub><mo stretchy="false">)</mo><mo stretchy="false">)</mo></math></span>, where n = total number of PSA tests, p = PSA value, t = time at PSA test.</p>
</div>
</div></section><section id="ref-list1" class="ref-list"><h2 class="pmc_sec_title">References</h2>
