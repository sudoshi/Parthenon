<td valign="top" align="center" rowspan="1" colspan="1">83.8 ± 38.5 (93.3 ± 2.4)</td>
</tr>
<tr>
<td valign="top" align="right" rowspan="1" colspan="1">Patient Care After Patient</td>
<td valign="top" align="center" rowspan="1" colspan="1">54.4 ± 30.6</td>
<td valign="top" align="center" rowspan="1" colspan="1">6.3 ± 3.8 (11.8 ± 3.8)</td>
