<sup>3,</sup><sup>4</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Shang%20N"[Author]' class="usa-link" aria-describedby="id4"><span class="name western">Ning Shang</span></a><div hidden="hidden" id="id4">
<h3><span class="name western">Ning Shang</span></h3>
<div class="p">
<sup>1</sup>Columbia University Medical Center, New York, NY</div>
<div class="p">
<sup>4</sup>Observational Health Data Sciences and Informatics (OHDSI), New York, NY, USA</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Shang%20N"[Author]' class="usa-link"><span class="name western">Ning Shang</span></a>
</div>
</div>
<sup>1,</sup><sup>4</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Hripcsak%20G"[Author]' class="usa-link" aria-describedby="id5"><span class="name western">George Hripcsak</span></a><div hidden="hidden" id="id5">
<h3><span class="name western">George Hripcsak</span></h3>
<div class="p">
<sup>1</sup>Columbia University Medical Center, New York, NY</div>
<div class="p">
<sup>4</sup>Observational Health Data Sciences and Informatics (OHDSI), New York, NY, USA</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Hripcsak%20G"[Author]' class="usa-link"><span class="name western">George Hripcsak</span></a>
</div>
</div>
<sup>1,</sup><sup>4,</sup><sup>*</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Weng%20C"[Author]' class="usa-link" aria-describedby="id6"><span class="name western">Chunhua Weng</span></a><div hidden="hidden" id="id6">
<h3><span class="name western">Chunhua Weng</span></h3>
<div class="p">
<sup>1</sup>Columbia University Medical Center, New York, NY</div>
<div class="p">
<sup>4</sup>Observational Health Data Sciences and Informatics (OHDSI), New York, NY, USA</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Weng%20C"[Author]' class="usa-link"><span class="name western">Chunhua Weng</span></a>
</div>
</div>
<sup>1,</sup><sup>4,</sup><sup>*</sup>
</div>
<ul class="d-buttons inline-list">
<li><button class="d-button" aria-controls="aip_a" aria-expanded="false">Author information</button></li>
<li><button class="d-button" aria-controls="anp_a" aria-expanded="false">Article notes</button></li>
