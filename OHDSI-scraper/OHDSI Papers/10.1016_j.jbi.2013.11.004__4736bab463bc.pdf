<td align="center" valign="top" rowspan="1" colspan="1">344,287,179</td>
</tr>
<tr>
<td align="left" valign="top" rowspan="1" colspan="1">
<em>Total Events</em>
</td>
<td align="right" valign="top" rowspan="1" colspan="1">134,663,064</td>
<td align="center" valign="top" rowspan="1" colspan="1">930,414,718</td>
</tr>
<tr>
<td align="left" valign="top" rowspan="1" colspan="1">    Observation_General</td>
<td align="right" valign="top" rowspan="1" colspan="1">217,996,211</td>
<td align="center" valign="top" rowspan="1" colspan="1">1,836,001,442</td>
</tr>
