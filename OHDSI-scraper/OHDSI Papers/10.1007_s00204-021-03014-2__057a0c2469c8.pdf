<sup>6</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Yauk%20CL"[Author]' class="usa-link" aria-describedby="id8"><span class="name western">Carole L Yauk</span></a><div hidden="hidden" id="id8">
<h3><span class="name western">Carole L Yauk</span></h3>
<div class="p">
<sup>1</sup>Environmental Health Science and Research Bureau, Health Canada, Ottawa, ON, Canada</div>
<div class="p">
<sup>7</sup>Department of Biology, University of Ottawa, Ottawa, ON, Canada</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Yauk%20CL"[Author]' class="usa-link"><span class="name western">Carole L Yauk</span></a>
</div>
</div>
<sup>1,</sup><sup>7,</sup><sup>*</sup>
</div>
<ul class="d-buttons inline-list">
<li><button class="d-button" aria-controls="aip_a" aria-expanded="false">Author information</button></li>
<li><button class="d-button" aria-controls="anp_a" aria-expanded="false">Article notes</button></li>
