<dd><p id="P52">DNA damage-inducing</p></dd>
<dt>HAT</dt>
<dd><p id="P53">Histone acetyltransferase</p></dd>
<dt>HDACi</dt>
<dd><p id="P54">Histone deacetylase inhibitor</p></dd>
<dt>KE</dt>
<dd><p id="P55">Key event</p></dd>
<dt>MIE</dt>
<dd><p id="P56">Molecular initiating event</p></dd>
<dt>MOA</dt>
<dd><p id="P57">Mode of action</p></dd>
<dt>NSC</dt>
<dd><p id="P58">Nearest shrunken centroid</p></dd>
