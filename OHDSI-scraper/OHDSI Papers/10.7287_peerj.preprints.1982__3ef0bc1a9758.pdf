    <meta name="citation_title" content="The health care and life sciences community profile for dataset descriptions"><meta name="citation_date" content="2017-01-09"><meta name="citation_doi" content="10.7287/peerj.preprints.1982v2"><meta name="citation_language" content="en"><meta name="citation_pdf_url" content="https://peerj.com/preprints/1982.pdf"><meta name="citation_fulltext_html_url" content="https://peerj.com/preprints/1982"><meta name="citation_technical_report_number" content="e1982v2"><meta name="citation_keywords" content="data profiling; dataset descriptions; metadata; provenance; FAIR data"><meta name="citation_technical_report_institution" content="PeerJ Preprints"><meta name="citation_publisher" content="PeerJ Inc."><meta name="citation_issn" content="2167-9843"><meta name="citation_author" content="Michel Dumontier"><meta name="citation_author_institution" content="Stanford Center for Biomedical Informatics Research, Stanford University, Stanford, California, United States"><meta name="citation_author" content="Alasdair J G Gray"><meta name="citation_author_institution" content="Computer Science, Heriot-Watt University, Edinburgh, United Kingdom"><meta name="citation_author_email" content="A.J.G.Gray@hw.ac.uk"><meta name="citation_author" content="M. Scott Marshall"><meta name="citation_author_institution" content="Department of Radiation Oncology (MAASTRO), GROW - School for Oncology and Developmental Biology, MAASTRO Clinic, Maastricht, The Netherlands"><meta name="citation_author" content="Vladimir Alexiev"><meta name="citation_author_institution" content="Ontotext Corporation, Sofia, Bulgaria"><meta name="citation_author" content="Peter Ansell"><meta name="citation_author_institution" content="CSIRO, Canberra, Australia"><meta name="citation_author" content="Gary D Bader"><meta name="citation_author_institution" content="The Donnelly Centre, University of Toronto, Toronto, Canada"><meta name="citation_author" content="Joachim Baran"><meta name=