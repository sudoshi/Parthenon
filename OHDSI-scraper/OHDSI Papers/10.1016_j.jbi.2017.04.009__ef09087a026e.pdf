<td valign="top" align="center" rowspan="1" colspan="1">0.519 (0.452 ~ 0.585)</td>
</tr>
<tr>
<td valign="top" align="left" rowspan="1" colspan="1"><strong>L1 + ICD9</strong></td>
<td valign="top" align="left" rowspan="1" colspan="1">921/1170 (0.79)</td>
<td valign="top" align="left" rowspan="1" colspan="1">923/1320 (0.70)</td>
<td valign="top" align="center" rowspan="1" colspan="1">0.79 (0.73 ~ 0.84)</td>
</tr>
<tr>
<td valign="top" align="left" rowspan="1" colspan="1"><strong>L2 + ICD9</strong></td>
<td valign="top" align="left" rowspan="1" colspan="1">920/1170 (0.79)</td>
<td valign="top" align="left" rowspan="1" colspan="1">896/1320 (0.68)</td>
