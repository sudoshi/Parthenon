</tr></thead>
<tbody>
<tr>
<td valign="top" align="left" rowspan="1" colspan="1"><strong>Level 1 (L1)</strong></td>
<td valign="top" align="left" rowspan="1" colspan="1">1029/1170 (0.88)</td>
<td valign="top" align="left" rowspan="1" colspan="1">212/1320 (0.16)</td>
<td valign="top" align="center" rowspan="1" colspan="1">0.59 (0.51 ~ 0.66)</td>
</tr>
<tr>
<td valign="top" align="left" rowspan="1" colspan="1"><strong>Level 2 (L2)</strong></td>
<td valign="top" align="left" rowspan="1" colspan="1">812/1170 (0.69)</td>
<td valign="top" align="left" rowspan="1" colspan="1">456/1320 (0.35)</td>
<td valign="top" align="center" rowspan="1" colspan="1">0.52 (0.45 ~ 0.60)</td>
</tr>
<tr>
<td valign="top" align="left" rowspan="1" colspan="1"><strong>L1 + ICD9</strong></td>
<td valign="top" align="left" rowspan="1" colspan="1">1158/1170 (0.99)</td>
<td valign="top" align="left" rowspan="1" colspan="1">771/1320 (0.58)</td>
<td valign="top" align="center" rowspan="1" colspan="1">0.85 (0.80 ~ 0.89)</td>
</tr>
<tr>
<td valign="top" align="left" rowspan="1" colspan="1"><strong>L2 + ICD9</strong></td>
<td valign="top" align="left" rowspan="1" colspan="1">910/1170 (0.78)</td>
<td valign="top" align="left" rowspan="1" colspan="1">836/1320 (0.63)</td>
<td valign="top" align="center" rowspan="1" colspan="1">0.74 (0.67 ~ 0.82)</td>
</tr>
<tr>
<td valign="top" align="left" style="background-color:#BFFFFA" rowspan="1" colspan="1"><strong>Big Logistic</strong></td>
<td valign="top" align="left" style="background-color:#BFFFFA" rowspan="1" colspan="1">768/1170 (0.66)</td>
<td valign="top" align="left" style="background-color:#BFFFFA" rowspan="1" colspan="1">866/1320 (0.66)</td>
<td valign="top" align="center" style="background-color:#BFFFFA" rowspan="1" colspan="1">0.65 (0.59 ~ 0.72)</td>
</tr>
<tr>
<td valign="top" align="left" style="background-color:#FFF9B0" rowspan="1" colspan="1"><strong>Big SVM</strong></td>
<td valign="top" align="left" style="background-color:#FFF9B0" rowspan="1" colspan="1">784/1170 (0.67)</td>
<td valign="top" align="left" style="background-color:#FFF9B0" rowspan="1" colspan="1">862/1320 (0.65)</td>
