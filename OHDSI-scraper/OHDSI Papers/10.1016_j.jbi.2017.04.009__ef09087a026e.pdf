<td valign="top" align="left" style="background-color:#BFFFFA" rowspan="1" colspan="1">39/39 (1.00)</td>
<td valign="top" align="left" style="background-color:#BFFFFA" rowspan="1" colspan="1">0/15 (0.00)</td>
<td valign="top" align="left" style="background-color:#BFFFFA" rowspan="1" colspan="1">29/29 (1.00)</td>
<td valign="top" align="left" style="background-color:#BFFFFA" rowspan="1" colspan="1">n/a</td>
