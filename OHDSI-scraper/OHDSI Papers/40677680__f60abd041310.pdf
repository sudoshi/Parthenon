<sup>2,</sup><sup>*</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Hripcsak%20G"[Author]' class="usa-link" aria-describedby="id3"><span class="name western">George Hripcsak</span></a><div hidden="hidden" id="id3">
<h3><span class="name western">George Hripcsak</span></h3>
<div class="p">
<sup>3</sup>Department of Biomedical Informatics, Columbia University, New York, NY 10027, USA</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Hripcsak%20G"[Author]' class="usa-link"><span class="name western">George Hripcsak</span></a>
</div>
</div>
<sup>3</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Ning%20Y"[Author]' class="usa-link" aria-describedby="id4"><span class="name western">Yang Ning</span></a><div hidden="hidden" id="id4">
<h3><span class="name western">Yang Ning</span></h3>
<div class="p">
