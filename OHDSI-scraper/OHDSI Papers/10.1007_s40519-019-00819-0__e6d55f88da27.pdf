<thead>
<tr>
<th align="left" valign="top" rowspan="1" colspan="1">Variable</th>
<th align="center" valign="top" rowspan="1" colspan="1">1</th>
<th align="center" valign="top" rowspan="1" colspan="1">2</th>
<th align="center" valign="top" rowspan="1" colspan="1">3</th>
