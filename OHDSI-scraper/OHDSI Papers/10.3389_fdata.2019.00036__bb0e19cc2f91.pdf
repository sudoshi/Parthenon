res":11214,"toc":14878,"correspondingAuthors":14896},{"title":119,"abbreviation":529,"issn":530,"publisherName":723},"Frontiers Media S.A.",[725],{"#text":404},[727,730,732,735,737,739,742,746,748,750],{"surname":431,"givenNames":430,"suffix":19,"affiliationsIndexes":728,"isCorresponding":13,"equalContrib":315,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":729,"onBehalfOf":19},[330],"http://loop.frontiersin.org/people/155511/overview",{"surname":439,"givenNames":438,"suffix":19,"affiliationsIndexes":731,"isCorresponding":315,"equalContrib":315,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[541],{"surname":447,"givenNames":446,"suffix":19,"affiliationsIndexes":733,"isCorresponding":315,"equalContrib":315,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[330,734],3,{"surname":455,"givenNames":454,"suffix":19,"affiliationsIndexes":736,"isCorresponding":315,"equalContrib":315,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[330],{"surname":461,"givenNames":460,"suffix":19,"affiliationsIndexes":738,"isCorresponding":315,"equalContrib":315,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[541],{"surname":467,"givenNames":466,"suffix":19,"affiliationsIndexes":740,"isCorresponding":315,"equalContrib":315,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[741],4,{"surname":476,"givenNames":475,"suffix":19,"affiliationsIndexes":743,"isCorresponding":315,"equalContrib":315,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":745,"onBehalfOf":19},[744],5,"http://loop.frontiersin.org/people/41592/overview",{"surname":483,"givenNames":482,"suffix":19,"affiliationsIndexes":747,"isCorresponding":315,"equalContrib":315,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[413],{"surname":490,"givenNames":489,"suffix":19,"affiliationsIndexes":749,"isCorresponding":315,"equalContrib":315,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[330],{"surname":497,"givenNames":496,"suffix":751,"affiliationsIndexes":752,"isCorresponding":315,"equalContrib":315,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":753,"onBehalfOf":19},"Jr.",[330],"http://loop.frontiersin.org/people/26036/overview",[755,758,761,764,767,770],{"index":330,"baseText":19,"institution":435,"country":436,"address":756,"textContent":757},"Washington, DC","Department of Oncology, Department of Biochemistry and Molecular & Cellular Biology, Georgetown University Medical Center, Washington, DC, United States",{"index":541,"baseText":19,"institution":443,"country":444,"address":759,"textContent":760},"Ottawa, ON","Environmental Health Science and Research Bureau, Health Canada, Ottawa, ON, Canada",{"index":734,"baseText":19,"institution":452,"country":436,"address":762,"textContent":763},"Rockville, MD","Amelia Technologies LLC, Rockville, MD, United States",{"index":741,"baseText":19,"institution":471,"country":472,"address":765,"textContent":766},"Bonn","Federal Institute for Drugs and Medical Devices, Bonn, Germany",{"index":744,"baseText":19,"institution":480,"country":472,"address":768,"textContent":769},"Leverkusen","Investigational Toxicology, Bayer AG, Pharmaceuticals, Leverkusen, Germany",{"index":413,"baseText":19,"institution":487,"country":436,"address":756,"textContent":771},"Health and Environmental Sciences Institute, Washington, DC, United States",{"editedBy":773,"editedByContent":776,"reviewedBy":785,"reviewedByContent":788,"approvedBy":795,"approvedByContent":796,"correspondence":797,"equalContribution":798,"presentAddress":19,"other":799},[774],{"textContent":775},"Edited by: Yvonne Will, Pfizer, United States",[777,779,783],{"#text":778},"\n          ",{"p":780},[781],{"#text":782}," Yvonne Will, Pfizer, United States",{"#text":784},"\n        ",[786],{"textContent":787},"Reviewed by: Julia Rager, University of North Carolina at Chapel Hill, United States; Matthew Thomas Martin, Pfizer, United States",[789,790,794],{"#text":778},{"p":791},[792],{"#text":793}," Julia Rager, University of North Carolina at Chapel Hill, United States; Matthew Thomas Martin, Pfizer, United States",{"#text":784},[],[],"*Correspondence: Heng-Hong Li SEwyMzRAZ2VvcmdldG93bi5lZHU=",[],[800,801,805],{"#text":778},{"p":802},[803],{"#text":804},"This article was submitted to Medicine and Public Health, a section of the journal Frontiers in Big Data",{"#text":784},"2019-10-08","2019-09-17","2019-04-26",36,{"copyrightStatement":811,"copyrightYear":812,"copyrightHolder":813,"licenseUrl":814,"licenseText":815},"Copyright © 2019 Li, Yauk, Chen, Hyduke, Williams, Frötschl, Ellinger-Ziegelbauer, Pettit, Aubrecht and Fornace.",2019,"Li, Yauk, Chen, Hyduke, Williams, Frötschl, Ellinger-Ziegelbauer, Pettit, Aubrecht and Fornace","http://creativecommons.org/licenses/by/4.0/",[816,817,829],{"#text":778},{"p":818},[819,821,827],{"#text":820},"This is an open-access article distributed under the terms of the ",{"ext-link":822,":@":825},[823],{"#text":824},"Creative Commons Attribution License (CC BY)",{"@_ext-link-type":826,"@_xlink:href":814},"uri",{"#text":828},". The use, distribution or reproduction in other forums is permitted, provided the original author(s) and the copyright owner(s) are credited and that the original publication in this journal is cited, in accordance with accepted academic practice. No use, distribution or reproduction is permitted which does not comply with these terms.",{"#text":784},[831,833,835,838,840],[832],{"#text":422},[834],{"#text":423},[836],{"#text":837},"genotoxicity",[839],{"#text":425},[841],{"#text":842},"high-throughput (HT) approaches",[],[845,846,877],{"#text":784},{"p":847},[848,850,854,856,859,861,864,866,869,871,875],{"#text":849},"Genotoxicity testing is an essential component of the safety assessment paradigm required by regulatory agencies world-wide for analysis of drug candidates, and environmental and industrial chemicals. Current genotoxicity testing batteries feature a high incidence of irrelevant positive findings—particularly for ",{"italic":851},[852],{"#text":853},"in vitro",{"#text":855}," chromosomal damage (CD) assays. The risk management of compounds with positive ",{"italic":857},[858],{"#text":853},{"#text":860}," findings is a major challenge and requires complex, time consuming, and costly follow-up strategies including animal testing. Thus, regulators are urgently in need of new testing approaches to meet legislated mandates. Using machine learning, we identified a set of transcripts that responds predictably to DNA-damage in human cells that we refer to as the TGx-DDI biomarker, which was originally referred to as TGx-28.65. We proposed to use this biomarker in conjunction with current genotoxicity testing batteries to differentiate compounds with irrelevant “false” positive findings in the ",{"italic":862},[863],{"#text":853},{"#text":865}," CD assays from true DNA damaging agents (i.e., for de-risking agents that are clastogenic ",{"italic":867},[868],{"#text":853},{"#text":870}," but not ",{"italic":872},[873],{"#text":874},"in vivo",{"#text":876},"). We validated the performance of the TGx-DDI biomarker to identify true DNA damaging agents, assessed intra- and inter- laboratory reproducibility, and cross-platform performance. Recently, to augment the application of this biomarker, we developed a high-throughput cell-based genotoxicity testing system using the NanoString nCounter® technology. Here, we review the status of TGx-DDI development, its integration in the genotoxicity testing paradigm, and progress to date in its qualification at the US Food and Drug Administration (FDA) as a drug development tool. If successfully validated and implemented, the TGx-DDI biomarker assay is expected to significantly augment the current strategy for the assessment of genotoxic hazards for drugs and chemicals.",{"#text":878},"\n      ",[880,882,1159,1160,5754,5755,5872,5873,6107,6108,6154,6155,6184],{"#text":881},"\n    ",{"sec":883,":@":1156},[884,885,889,890,913,914,975,976,1069,1070,1132,1133,1155],{"#text":878},{"title":886},[887],{"#text":888},"Introduction",{"#text":878},{"p":891},[892,894,897,899,902,904,911],{"#text":893},"Genetic alterations are an important hallmark of cancer, and DNA damage (genotoxic stress) is a central driver of carcinogenesis. Therefore, the assessment of a chemical's potential to induce gene mutations and/or chromosomal damage has been formalized in various genotoxicity testing batteries that are widely accepted and provide insight into the carcinogenic potential of drug candidates, cosmetics, food additives, environmental, and industrial chemicals. In general, genotoxicity testing batteries consist of standardized ",{"italic":895},[896],{"#text":853},{"#text":898}," and ",{"italic":900},[901],{"#text":874},{"#text":903}," assays, and have been successful in protecting human health through identification of genotoxic and carcinogenic exposures (Snyder and Green, ",{"xref":905,":@":908},[906],{"#text":907},"2001",{"@_ref-type":909,"@_rid":910},"bibr","B35",{"#text":912},").",{"#text":878},{"p":915},[916,918,921,923,926,928,932,934,938,940,943,945,951,953,956,958,961,963,966,968,974],{"#text":917},"Although the mechanistic association between genetic damage and cancer is well-understood, the correlation between genotoxicity, the potential of chemicals to induce primary DNA damage, and carcinogenic potential in animals or humans is complicated by alternative non-genotoxic mechanisms of carcinogenesis and the experimental limitations of ",{"italic":919},[920],{"#text":853},{"#text":922}," genotoxicity assays. In fact, many compounds testing positive in genetic toxicology batteries, particularly with ",{"italic":924},[925],{"#text":853},{"#text":927}," chromosomal damage (CD) assays, do not represent an appreciable carcinogenic risk to humans (Snyder and Green, ",{"xref":929,":@":931},[930],{"#text":907},{"@_ref-type":909,"@_rid":910},{"#text":933},"). ",{"italic":935},[936],{"#text":937},"In vitro",{"#text":939}," CD assays are designed to detect structural chromosomal abnormalities induced by the test compounds. The widely used CD assays include the chromosomal aberration assay, and micronucleus assay. All mammalian cell genotoxicity tests have low specificity of below 45%, which become more severe when two or three tests are combined. For example, it was reported that 75–95% of non-carcinogens gave positive (i.e., false positive) results in at least one standard ",{"italic":941},[942],{"#text":853},{"#text":944}," genotoxicity test (Kirkland et al., ",{"xref":946,":@":949},[947],{"#text":948},"2005",{"@_ref-type":909,"@_rid":950},"B22",{"#text":952},"). In drug development, a larger percent of new lead molecules are expected to yield potentially irrelevant positive ",{"italic":954},[955],{"#text":853},{"#text":957}," genotoxicity findings. Since assessing carcinogenicity in animal studies during the early stages of drug development is often not feasible, potentially safe drug candidates may be excluded from the development pipeline. Therefore, the differentiation of true positives from irrelevant positives in the ",{"italic":959},[960],{"#text":853},{"#text":962}," tests, such as the ",{"italic":964},[965],{"#text":853},{"#text":967}," CD assays, is crucial for the initial assessment of human risk. This concept is also reflected in the current Food and Drug Administration (FDA) guidance for industry (",{"ext-link":969,":@":972},[970],{"#text":971},"https://www.fda.gov/downloads/Drugs/GuidanceComplianceRegulatoryInformation/Guidances/UCM079257.pdf",{"@_ext-link-type":826,"@_xmlns:xlink":973,"@_xlink:href":971},"http://www.w3.org/1999/xlink",{"#text":912},{"#text":878},{"p":977},[978,980,983,985,988,989,992,994,1000,1002,1008,1010,1015,1017,1020,1022,1025,1027,1032,1034,1037,1039,1042,1044,1047,1049,1052,1054,1057,1059,1062,1064,1067],{"#text":979},"Currently, there are two approaches used to address the risk and relevance of positive ",{"italic":981},[982],{"#text":853},{"#text":984}," CD assays. The first approach relies on characterizing the risk and relevance of the positive results by conducting additional ",{"italic":986},[987],{"#text":853},{"#text":898},{"italic":990},[991],{"#text":874},{"#text":993}," studies that use similar DNA damage sensing endpoints to explore a limited number of mechanisms, such as γH2AX, a marker for DNA double strand breaks (Redon et al., ",{"xref":995,":@":998},[996],{"#text":997},"2011",{"@_ref-type":909,"@_rid":999},"B33",{"#text":1001},"), phospho-Histone H3 (a marker for mitotic cells) (Ando et al., ",{"xref":1003,":@":1006},[1004],{"#text":1005},"2014",{"@_ref-type":909,"@_rid":1007},"B4",{"#text":1009},"; Bryce et al., ",{"xref":1011,":@":1013},[1012],{"#text":1005},{"@_ref-type":909,"@_rid":1014},"B6",{"#text":1016},"), and general apoptosis assays. These experimental follow-up strategies often have uncertain outcomes, are costly, laborious, and can lead to discontinuation of drug development and/or significant delays in the introduction of new medications to patients. The second approach, developed by the International Conference on Harmonization (ICH), relies on two ",{"italic":1018},[1019],{"#text":874},{"#text":1021}," tests as an alternative to the ",{"italic":1023},[1024],{"#text":853},{"#text":1026}," CD assays (",{"ext-link":1028,":@":1031},[1029],{"#text":1030},"https://www.fda.gov/downloads/drugs/guidances/ucm074931.pdf",{"@_ext-link-type":826,"@_xlink:href":1030},{"#text":1033},"). Although this approach increases human relevance via ",{"italic":1035},[1036],{"#text":874},{"#text":1038}," testing, the DNA damage endpoints in the ",{"italic":1040},[1041],{"#text":874},{"#text":1043}," studies are inherently difficult to assess and do not increase our understanding of the genotoxic mechanisms responsible for ",{"italic":1045},[1046],{"#text":853},{"#text":1048}," irrelevant positive results. Furthermore, in most cases this requires additional animal studies, unless the evaluation of ",{"italic":1050},[1051],{"#text":874},{"#text":1053}," endpoints is combined with, or included in, other toxicity studies. Often an important arbiter for conflicting ",{"italic":1055},[1056],{"#text":853},{"#text":1058}," results involves expensive and time-consuming ",{"italic":1060},[1061],{"#text":874},{"#text":1063}," carcinogenesis studies. Therefore, there is an urgent need for mechanistic tools that do not rely on animal use to aid in the interpretation and risk assessment of isolated positive findings from ",{"italic":1065},[1066],{"#text":853},{"#text":1068}," genotoxicity assays.",{"#text":878},{"p":1071},[1072,1074,1079,1081,1087,1089,1095,1097,1103,1105,1110,1112,1116,1118,1122,1124,1130],{"#text":1073},"Monitoring transcriptional changes as an indicator of the DNA damage response has been explored as a tool for assessing genotoxicity (Amundson et al., ",{"xref":1075,":@":1077},[1076],{"#text":948},{"@_ref-type":909,"@_rid":1078},"B3",{"#text":1080},"; Li et al., ",{"xref":1082,":@":1085},[1083],{"#text":1084},"2007",{"@_ref-type":909,"@_rid":1086},"B24",{"#text":1088},"). DNA damage responses initiate from damage sensing and signaling mediated by sensor molecules such as the MRN complex, Rad17, MDC1, 53BP1, and BRCA1 (Bakkenist and Kastan, ",{"xref":1090,":@":1093},[1091],{"#text":1092},"2004",{"@_ref-type":909,"@_rid":1094},"B5",{"#text":1096},"; O'Driscoll and Jeggo, ",{"xref":1098,":@":1101},[1099],{"#text":1100},"2006",{"@_ref-type":909,"@_rid":1102},"B32",{"#text":1104},"), and signaling kinases including ATM, ATR, DNA-PK, Chk1, and Chk2 (McGowan and Russell, ",{"xref":1106,":@":1108},[1107],{"#text":1092},{"@_ref-type":909,"@_rid":1109},"B29",{"#text":1111},"). Activation of this elaborate DNA damage response network induces transcription of DNA-damage responsive genes that are involved in DNA damage repair, cell cycle control, apoptosis, and metabolic regulation. Many of these responses are dependent on the p53 transcription factor, but additional genotoxic-stress induced transcriptional responses exist even in p53-deficient cells (Amundson et al., ",{"xref":1113,":@":1115},[1114],{"#text":948},{"@_ref-type":909,"@_rid":1078},{"#text":1117},"). Despite the complexity of biological responses to xenobiotics, the key transcriptional factors activated in DNA damage response can be distinguished from those induced by non-genotoxic stress (Amundson et al., ",{"xref":1119,":@":1121},[1120],{"#text":948},{"@_ref-type":909,"@_rid":1078},{"#text":1123},"; Jennings et al., ",{"xref":1125,":@":1128},[1126],{"#text":1127},"2013",{"@_ref-type":909,"@_rid":1129},"B21",{"#text":1131},"); the latter fundamental feature enables the identification of genotoxicity-induced transcriptomic modulations that can be distinguished from those triggered by other stresses.",{"#text":878},{"p":1134},[1135,1137,1143,1145,1148,1150,1153],{"#text":1136},"An approach applying transcriptomics to identify DNA damage inducing agents offers the advantage of informing whether an intact DNA damage response has been initiated by a toxicant that is consistent with the transcript profiles of known genotoxic carcinogens and distinct from non-genotoxic mechanisms. These transcriptomic biomarkers detect DNA damage as induction of a genotoxic stress response that is measured as transcriptional activation of early immediate DNA damage response genes, reflecting primary DNA damage. These cellular responses happen before activation of apoptosis or cell death, the latter of which might also occur following prolonged compound treatment (Ellinger-Ziegelbauer et al., ",{"xref":1138,":@":1141},[1139],{"#text":1140},"2009a",{"@_ref-type":909,"@_rid":1142},"B12",{"#text":1144},"). In contrast, mutations or chromosome damage occurring as a consequence of repair of damaged DNA are what is detected using the standard genetic toxicology assay battery. Thus, cellular stressor not primarily attacking DNA can induce chromosome damage that is detected using the conventional ",{"italic":1146},[1147],{"#text":853},{"#text":1149}," test systems. In addition to providing insight into the relevance and mechanisms associated with observed ",{"italic":1151},[1152],{"#text":853},{"#text":1154}," genotoxicity in conventional tests, it is envisioned that transcriptomic approaches could provide a tool for high-throughput genotoxicity screens for not only pharmaceutical compounds but also environmental and occupational toxicants. Below we describe the development, validation, and application of the TGx-DDI transcriptomic biomarker for these purposes.",{"#text":881},{"@_sec-type":1157,"@_id":1158},"intro","s1",{"#text":881},{"sec":1161,":@":5752},[1162,1163,1167,1168,1194,1195,1218,1219,2315,2316,5148,5149,5679,5680,5751],{"#text":878},{"title":1164},[1165],{"#text":1166},"Development of the TGx-DDI Transcriptomic Biomarker",{"#text":878},{"p":1169},[1170,1172,1175,1177,1183,1185,1192],{"#text":1171},"An ",{"italic":1173},[1174],{"#text":853},{"#text":1176}," transcriptome-based approach was used to develop a biomarker to assess genotoxicity and provide insights into mode of action (Li et al., ",{"xref":1178,":@":1181},[1179],{"#text":1180},"2015",{"@_ref-type":909,"@_rid":1182},"B26",{"#text":1184},"). The process involved in the development of the biomarker, including identification, testing and validation, as well as relevant case studies to explore context of use, are reviewed below. A schematic chart summarizing these stages is shown in ",{"xref":1186,":@":1189},[1187],{"#text":1188},"Figure 1",{"@_ref-type":1190,"@_rid":1191},"fig","F1",{"#text":1193},".",{"#text":878},{"fig":1196,":@":1216},[1197,1198,1201,1202,1210,1211,1215],{"#text":784},{"label":1199},[1200],{"#text":1188},{"#text":784},{"caption":1203},[1204,1205,1209],{"#text":778},{"p":1206},[1207],{"#text":1208},"Overview of the development phases of the transcriptomic genotoxicity biomarker TGx-DDI.",{"#text":784},{"#text":784},{"graphic":1212,":@":1213},[],{"@_xlink:href":1214},"fdata-02-00036-g0001.tif",{"#text":878},{"@_id":1191,"@_position":1217},"float",{"#text":878},{"sec":1220},[1221,1222,1226,1227,1305,1306,2251,2252,2314],{"#text":784},{"title":1223},[1224],{"#text":1225},"Identification of the TGx-DDI Biomarker",{"#text":784},{"sec":1228},[1229,1230,1234,1235,1288,1289,1304],{"#text":778},{"title":1231},[1232],{"#text":1233},"(1) Cell System and Model Agents",{"#text":778},{"p":1236},[1237,1239,1244,1246,1251,1253,1258,1260,1265,1267,1271,1273,1279,1281,1287],{"#text":1238},"Transcriptome perturbations were determined using the TK6 cell line as (a) it is a well-characterized cell line that is routinely used in genotoxicity testing, (b) it has proficient p53 signaling pathways, and (c) it responded in an expected manner in previous stress response studies (Akerman et al., ",{"xref":1240,":@":1242},[1241],{"#text":1092},{"@_ref-type":909,"@_rid":1243},"B1",{"#text":1245},"; Dickinson et al., ",{"xref":1247,":@":1249},[1248],{"#text":1092},{"@_ref-type":909,"@_rid":1250},"B11",{"#text":1252},"; Hu et al., ",{"xref":1254,":@":1256},[1255],{"#text":1092},{"@_ref-type":909,"@_rid":1257},"B17",{"#text":1259},"; Islaih et al., ",{"xref":1261,":@":1263},[1262],{"#text":1092},{"@_ref-type":909,"@_rid":1264},"B19",{"#text":1266},"; Amundson et al., ",{"xref":1268,":@":1270},[1269],{"#text":948},{"@_ref-type":909,"@_rid":1078},{"#text":1272},"). Unlike human cancer cell lines, the TK6 line was established by spontaneous immortalization of primary human lymphoid cells in culture, and probably doesn't have the myriad of genetic alterations typically seen in lines derived from human cancers (Skopek et al., ",{"xref":1274,":@":1277},[1275],{"#text":1276},"1978",{"@_ref-type":909,"@_rid":1278},"B34",{"#text":1280},"; Liber and Thilly, ",{"xref":1282,":@":1285},[1283],{"#text":1284},"1982",{"@_ref-type":909,"@_rid":1286},"B27",{"#text":912},{"#text":778},{"p":1290},[1291,1293,1297,1298,1302],{"#text":1292},"The TGx-DDI biomarker (TGx = toxicogenomic; DDI = DNA damage inducing) was identified using a dataset comprised of transcriptomic profiles of TK6 cells exposed to 28 model agents with well-characterized modes of action (Kirkland et al., ",{"xref":1294,":@":1296},[1295],{"#text":948},{"@_ref-type":909,"@_rid":950},{"#text":1009},{"xref":1299,":@":1301},[1300],{"#text":1005},{"@_ref-type":909,"@_rid":1014},{"#text":1303},"). The agents in this training set represent a wide range of DDI mechanisms and include DNA alkylating agents, DNA strand breaking agents, topoisomerase inhibitors, and nucleotide antimetabolites, and non-DDI agents such as endoplasmic reticulum (ER) stress agents, energy metabolism inhibitors, HDAC inhibitors, heat shock, and oxidative agents including heavy metals. The biomarker is specific to the identification of DNA damage; thus, it is important to note that aneugens are classified as non-DDI in this analysis as they operate via interaction with the mitotic spindle.",{"#text":784},{"#text":784},{"sec":1307},[1308,1309,1313,1314,1318,1319,1364,1365,1390,1391,2250],{"#text":778},{"title":1310},[1311],{"#text":1312},"(2) Study Design Considerations for Transcriptional Profiling",{"#text":778},{"p":1315},[1316],{"#text":1317},"Several study design parameters are critical for the development and use of transcriptomic biomarkers of DNA damage stress response. Complex cellular stress responses following treatment with chemicals are time- and dose-dependent. However, an experimental design that includes characterizing dose responses over a time course is not technically feasible across a large set of agents using conventional global transcriptomic approaches (i.e., DNA microarrays). Moreover, selection of single concentrations and time points facilitates extraction of relevant gene sets. Thus, the initial experimental design used a single dose and time point post-exposure for transcriptomic profiling.",{"#text":778},{"p":1320},[1321,1323,1329,1330,1334,1336,1341,1343,1349,1351,1355,1357,1363],{"#text":1322},"A 4 h post-exposure time point was selected for the development of the biomarker (Fornace et al., ",{"xref":1324,":@":1327},[1325],{"#text":1326},"1988",{"@_ref-type":909,"@_rid":1328},"B14",{"#text":1266},{"xref":1331,":@":1333},[1332],{"#text":948},{"@_ref-type":909,"@_rid":1078},{"#text":1335},"; Hyduke et al., ",{"xref":1337,":@":1339},[1338],{"#text":997},{"@_ref-type":909,"@_rid":1340},"B18",{"#text":1342},") as early gene expression changes reflect initial damage rather than subsequent cellular processes such as cell lethality events (Ellinger-Ziegelbauer et al., ",{"xref":1344,":@":1347},[1345],{"#text":1346},"2009b",{"@_ref-type":909,"@_rid":1348},"B13",{"#text":1350},"). In addition, 4 h is sufficient time to allow for accumulation of typical DNA damage response induced transcripts (Fornace et al., ",{"xref":1352,":@":1354},[1353],{"#text":1326},{"@_ref-type":909,"@_rid":1328},{"#text":1356},", ",{"xref":1358,":@":1361},[1359],{"#text":1360},"1989",{"@_ref-type":909,"@_rid":1362},"B15",{"#text":912},{"#text":778},{"p":1366},[1367,1369,1373,1375,1379,1381,1388],{"#text":1368},"To identify an appropriate concentration for each model agent and make sure that a sufficient cellular transcriptional response was achieved, mRNA levels of three well-characterized stress response genes (",{"italic":1370},[1371],{"#text":1372},"GADD45A, ATF3",{"#text":1374},", and ",{"italic":1376},[1377],{"#text":1378},"CDKN1A",{"#text":1380},") were assessed. The concentration of each agent employed for transcriptomics was the one that produced a robust increase of mRNA levels of one or more of these stress genes in this preliminary experiment. When more than one concentration met the criteria and behaved similarly, the lower concentration was selected. For agents included in the development of TGx-DDI biomarker (i.e., learning set), the concentration ranges tested, and final concentrations chosen for the microarray analyses are included in ",{"xref":1382,":@":1385},[1383],{"#text":1384},"Table 1",{"@_ref-type":1386,"@_rid":1387},"table","T1",{"#text":1389},". The concentrations selected showed no appreciable cytotoxicity at 4 h and the cell viability at 24 h post-treatment showed only moderate effects on viability for most agents. It should also be noted that the use of high-throughput approaches, such as the Nanostring approach discussed in this review, obviates the need for dose optimization, because a wide dose range is now feasible.",{"#text":778},{"table-wrap":1392,":@":2249},[1393,1395,1398,1399,1413,1414,2217,2218,2248],{"#text":1394},"\n            ",{"label":1396},[1397],{"#text":1384},{"#text":1394},{"caption":1400},[1401,1403,1412],{"#text":1402},"\n              ",{"p":1404},[1405,1407,1411],{"#text":1406},"Agents used in the development of the TGx-DDI transcriptomic biomarker (See also Li et al., ",{"xref":1408,":@":1410},[1409],{"#text":1180},{"@_ref-type":909,"@_rid":1182},{"#text":912},{"#text":1394},{"#text":1394},{"table":1415,":@":2214},[1416,1417,1479,1480,2213],{"#text":1402},{"thead":1418},[1419,1421,1478],{"#text":1420},"\n                ",{"tr":1422},[1423,1425,1437,1438,1447,1448,1457,1458,1467,1468,1477],{"#text":1424},"\n                  ",{"th":1426,":@":1434},[1427,1429,1433],{"#text":1428},"\n                    ",{"bold":1430},[1431],{"#text":1432},"Categories",{"#text":1424},{"@_valign":1435,"@_align":1436},"top","left",{"#text":1424},{"th":1439,":@":1446},[1440,1441,1445],{"#text":1428},{"bold":1442},[1443],{"#text":1444},"Compound names",{"#text":1424},{"@_valign":1435,"@_align":1436},{"#text":1424},{"th":1449,":@":1456},[1450,1451,1455],{"#text":1428},{"bold":1452},[1453],{"#text":1454},"Solvent",{"#text":1424},{"@_valign":1435,"@_align":1436},{"#text":1424},{"th":1459,":@":1466},[1460,1461,1465],{"#text":1428},{"bold":1462},[1463],{"#text":1464},"Dose range",{"#text":1424},{"@_valign":1435,"@_align":1436},{"#text":1424},{"th":1469,":@":1476},[1470,1471,1475],{"#text":1428},{"bold":1472},[1473],{"#text":1474},"Conc. for array",{"#text":1424},{"@_valign":1435,"@_align":1436},{"#text":1420},{"#text":1402},{"#text":1402},{"tbody":1481},[1482,1483,1537,1538,1571,1572,1604,1605,1653,1654,1710,1711,1796,1797,1874,1875,1955,1956,2007,2008,2044,2045,2080,2081,2154,2155,2212],{"#text":1420},{"tr":1484},[1485,1486,1491,1492,1501,1502,1516,1517,1526,1527,1536],{"#text":1424},{"td":1487,":@":1490},[1488],{"#text":1489},"Alkylating agents",{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":1493,":@":1500},[1494,1496,1498],{"#text":1495},"Cisplatin ",{"break":1497},[],{"#text":1499},"Methyl methane sulfonate (MMS)",{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":1503,":@":1515},[1504,1506,1508,1510,1513],{"#text":1505},"0.9% NaCl ",{"break":1507},[],{"#text":1509},"H",{"sub":1511},[1512],{"#text":608},{"#text":1514},"O",{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":1518,":@":1525},[1519,1521,1523],{"#text":1520},"10 ~ 80 μM ",{"break":1522},[],{"#text":1524},"20 ~ 200 μg/ml",{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":1528,":@":1535},[1529,1531,1533],{"#text":1530},"80 μM ",{"break":1532},[],{"#text":1534},"100 μg/ml",{"@_valign":1435,"@_align":1436},{"#text":1420},{"#text":1420},{"tr":1539},[1540,1541,1546,1547,1552,1553,1558,1559,1564,1565,1570],{"#text":1424},{"td":1542,":@":1545},[1543],{"#text":1544},"Topoisomerase I inhibitors",{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":1548,":@":1551},[1549],{"#text":1550},"Camptothecin",{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":1554,":@":1557},[1555],{"#text":1556},"DMSO",{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":1560,":@":1563},[1561],{"#text":1562},"62.5 ~ 500 nM",{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":1566,":@":1569},[1567],{"#text":1568},"125 nM",{"@_valign":1435,"@_align":1436},{"#text":1420},{"#text":1420},{"tr":1573},[1574,1575,1580,1581,1586,1587,1591,1592,1597,1598,1603],{"#t