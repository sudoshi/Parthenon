":346},"5D64838B-A589-4B8A-A4025D395F85ED92","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/5D64838B-A589-4B8A-A4025D395F85ED92/webimage-299656E7-F165-4CB6-BD5B4F2B6B1AA5AC.png","FDATA_Main Visual_Purple_Website",[],"image",4800,2700,0,"22C10171-81B3-4DA6-99342F272A32E8BB",4276100,1,"https://brand.frontiersin.org/m/664509524208c726/original/FDATA_Main-Visual_Purple_Website.jpg",[333],"jpg",{"mini":335,"thul":336,"original":331,"webimage":321,"Guidelines":337,"WebsiteJpg_XL":338,"WebsiteWebP_L":339,"WebsiteWebP_M":340,"WebsiteWebP_XL":341},"https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/5D64838B-A589-4B8A-A4025D395F85ED92/mini-DC66498A-9FDB-434C-B1A5BBF1835B624D.png","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/5D64838B-A589-4B8A-A4025D395F85ED92/thul-451354F9-2A11-4FA6-AA7A08D391BACC8E.png","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/5D64838B-A589-4B8A-A4025D395F85ED92/2AC3FFF6-4AEB-4DBB-9E7DBF2981C0BB53/Guidelines-FDATA_Main%20Visual_Purple_Website.png","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/5D64838B-A589-4B8A-A4025D395F85ED92/2AC3FFF6-4AEB-4DBB-9E7DBF2981C0BB53/WebsiteJpg_XL-FDATA_Main%20Visual_Purple_Website.jpg","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/5D64838B-A589-4B8A-A4025D395F85ED92/2AC3FFF6-4AEB-4DBB-9E7DBF2981C0BB53/WebsiteWebP_L-FDATA_Main%20Visual_Purple_Website.webp","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/5D64838B-A589-4B8A-A4025D395F85ED92/2AC3FFF6-4AEB-4DBB-9E7DBF2981C0BB53/WebsiteWebP_M-FDATA_Main%20Visual_Purple_Website.webp","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/5D64838B-A589-4B8A-A4025D395F85ED92/2AC3FFF6-4AEB-4DBB-9E7DBF2981C0BB53/WebsiteWebP_XL-FDATA_Main%20Visual_Purple_Website.webp","2022-06-27T09:59:18Z","landscape","2022-07-05T08:49:08Z","2022-06-27T09:27:09Z",[],"Explore research on big data's role in AI, machine learning, and data mining, with applications from cybersecurity to climate science.","\u003Cp>Frontiers in Big Data is an interdisciplinary journal that focuses on the advancements and applications of big data.\u003C/p>\n\n\u003Cp>Led by Field Chief Editor, Dr Huan Liu (Arizona State University, USA) the journal focuses on understanding and managing the power of big data, as well as acquiring intelligence from information to address and solve the biggest challenges of humankind. Frontiers in Big Data welcomes research contributions across the multifaceted and vast field, which advance new methodologies and develops data science, AI, data mining, and medical health informatics. Topics include, but are not limited to:\u003C/p>\n\n\u003Cul>\n  \u003Cli>big data networks\u003C/li>\n  \u003Cli>big data and AI in high energy physics\u003C/li>\n  \u003Cli>cybersecurity and privacy\u003C/li>\n  \u003Cli>data analytics for social impact\u003C/li>\n  \u003Cli>data mining and management\u003C/li>\n  \u003Cli>data science\u003C/li>\n  \u003Cli>data-driven climate sciences\u003C/li>\n  \u003Cli>machine learning and artificial intelligence\u003C/li>\n  \u003Cli>medicine and public health.\u003C/li>\n\u003C/ul>\n\n\u003Cp>In particular, the journal welcomes submissions that support and advance the UN’s Sustainable Development Goals (SDGs), notably SDG 9: industry, innovation and infrastructure.\u003C/p>\n\n\u003Cp>Frontiers in Big Data is committed to advancing developments in the field by allowing unrestricted access to articles, and communicating scientific knowledge to researchers and the public alike, to enable the scientific breakthroughs of the future.\u003C/p>","purple","3.1","4.6","10005","@FrontAIBigData",{"id":118,"name":119,"slug":120,"abbreviation":355,"isOnline":13,"isOpenForSubmissions":13,"citeScore":356,"impactFactor":357},"fdata",6.1,2.3,{"displayTitlePillLabels":13,"displayRelatedArticlesBox":13,"showEditors":13,"showReviewers":13,"showLoopImpactLink":13,"enableFigshare":315},{"isPublic":315,"allowCompanyUsers":315,"whiteListEmails":360,"enableAllJournals":315,"whiteListJournals":361},[],[],{"spaceId":330,"name":330,"availableJournalPages":363,"announcement":367,"useJournalPalettes":315},[222,227,224,364,365,366],"volumes","about","community-reviewers",{"__typename":368,"sys":369,"preHeader":371,"title":372,"description":373,"image":374,"link":396},"Announcement",{"id":370},"2IPv1l2IAkUt7RUrh3yJzz","Frontiers' quality","How do we build trust in science?","Behind each Frontiers journal is an editorial board committed to upholding research integrity and scientific quality",[375],{"id":376,"src":377,"name":378,"tags":379,"type":324,"width":380,"height":381,"archive":327,"brandId":328,"limited":327,"fileSize":382,"isPublic":327,"original":28,"copyright":28,"extension":383,"thumbnails":385,"dateCreated":392,"description":28,"orientation":343,"watermarked":327,"dateModified":392,"selectedFile":28,"datePublished":393,"videoPreviewURLs":394,"textMetaproperties":395},"1C167ADA-64D7-41F6-B87288EAF1BEC484","https://brand.frontiersin.org/m/47cd35867c2ab214/webimage-Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.png","Horizontal-Scientist looking at 3D rendered graphic scans from Magnetic Resonance Imaging (MRI) scanner, close up",[],1920,1080,2419221,[384],"png",{"mini":386,"thul":387,"webimage":377,"Guidelines":388,"WebsiteJpg_XL":389,"WebsiteWebP_L":390,"WebsiteWebP_M":391},"https://brand.frontiersin.org/m/47cd35867c2ab214/mini-Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.png","https://brand.frontiersin.org/m/47cd35867c2ab214/thul-Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.png","https://brand.frontiersin.org/asset/1c167ada-64d7-41f6-b872-88eaf1bec484/Guidelines/Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.png","https://brand.frontiersin.org/asset/1c167ada-64d7-41f6-b872-88eaf1bec484/WebsiteJpg_XL/Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.jpg","https://brand.frontiersin.org/asset/1c167ada-64d7-41f6-b872-88eaf1bec484/WebsiteWebP_L/Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.webp","https://brand.frontiersin.org/asset/1c167ada-64d7-41f6-b872-88eaf1bec484/WebsiteWebP_M/Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.webp","2026-03-06T11:24:30Z","2026-03-06T11:24:07Z",[],[],{"text":397,"url":398,"target":27,"ariaLabel":28},"Learn more","https://www.frontiersin.org/about/quality",{"loggedUserInfo":-1},{"currentArticle":401,"isPreviewPage":315,"hasSupplementalData":315,"showCrossmarkWidget":13,"articleTemplate":570,"currentArticlePageMetaInfo":571,"xmlParsedArticleContent":721,"xmlParsingError":-1},{"id":402,"doi":403,"title":404,"acceptanceDate":405,"receptionDate":406,"publicationDate":407,"lastModifiedDate":408,"isPublished":13,"abstract":409,"researchTopic":410,"articleType":416,"stage":419,"keywords":421,"authors":427,"editors":501,"reviewers":510,"journal":528,"section":535,"impactMetrics":537,"volume":541,"articleVolume":542,"relatedArticles":543,"isPublishedV2":315,"contents":544,"files":545},468242,"10.3389/fdata.2019.00036","TGx-DDI, a Transcriptomic Biomarker for Genotoxicity Hazard Assessment of Pharmaceuticals and Environmental Chemicals",["Date","2019-09-17T07:17:03.000Z"],["Date","2019-04-26T19:38:07.000Z"],["Date","2019-10-08T00:00:00.000Z"],["Date","2026-04-06T05:23:57.183Z"],"Genotoxicity testing is an essential component of the safety assessment paradigm required by regulatory agencies world-wide for analysis of drug candidates, and environmental and industrial chemicals. Current genotoxicity testing batteries feature a high incidence of irrelevant positive findings – particularly for in vitro chromosomal damage (CD) assays. The risk management of compounds with positive in vitro findings is a major challenge and requires complicated, time consuming and costly follow-up strategies including animal testing. Thus, regulators are urgently in need of new testing approaches to meet legislated mandates.  Using machine learning, we identified a set of transcripts that responds predictably to DNA-damage in human cells that we refer to as the TGx-DDI biomarker, which was originally referred to as TGx-28.65. We proposed to use this biomarker in conjunction with current genotoxicity testing batteries to differentiate compounds with irrelevant ‘false’ positive findings in the in vitro CD assays from true DNA damaging agents (i.e., for de-risking agents that are clastogenic in vitro but not in vivo). We validated the performance of the TGx-DDI biomarker to identify true DNA damaging agents, assessed intra- and inter- laboratory reproducibility, and cross-platform performance. Recently, to augment the application of this biomarker, we developed a high-throughput cell-based genotoxicity testing system using the NanoString nCounter® technology. Here, we review the status of TGx-DDI development, its integration in the genotoxicity testing paradigm, and progress to date in its qualification at the US Food and Drug Administration as a drug development tool. If successfully validated and implemented, the TGx-DDI biomarker assay is expected to significantly augment the current strategy for the assessment of genotoxic hazards for drugs and chemicals.",{"id":411,"title":412,"articlesCount":413,"isMagazinePage":13,"slug":414,"isOpenForSubmission":315,"views":415},8870,"Emerging Methodologies for Drug Safety- from in silico predictions to translational biomarkers",6,"emerging-methodologies-for-drug-safety--from-in-silico-predictions-to-translational-biomarkers",101393,{"id":417,"name":418},27,"Review",{"id":420,"name":19},18,[422,423,424,425,426],"TGx-DDI","toxicogenomics","Genotoxicity","biomarker","High-throughput (HT) approaches",[428,437,445,453,459,465,473,481,488,494],{"id":429,"firstName":430,"middleName":19,"lastName":431,"givenNames":432,"isCorresponding":315,"isProfilePublic":13,"userId":429,"email":-1,"affiliations":433},155511,"Heng-Hong","Li","Heng-Hong ",[434],{"organizationName":435,"countryName":436,"cityName":19,"stateName":19,"zipCode":19},"Department of Oncology, Department of Biochemistry and Molecular & Cellular Biology, Georgetown University Medical Center","United States",{"id":327,"firstName":438,"middleName":19,"lastName":439,"givenNames":440,"isCorresponding":315,"isProfilePublic":315,"userId":327,"email":-1,"affiliations":441},"Carole L.","Yauk","Carole L. ",[442],{"organizationName":443,"countryName":444,"cityName":19,"stateName":19,"zipCode":19},"Environmental Health Science and Research Bureau, Health Canada","Canada",{"id":327,"firstName":446,"middleName":19,"lastName":447,"givenNames":448,"isCorresponding":315,"isProfilePublic":315,"userId":327,"email":-1,"affiliations":449},"Renxiang","Chen","Renxiang ",[450,451],{"organizationName":435,"countryName":436,"cityName":19,"stateName":19,"zipCode":19},{"organizationName":452,"countryName":436,"cityName":19,"stateName":19,"zipCode":19},"Amelia Technologies LLC",{"id":327,"firstName":454,"middleName":19,"lastName":455,"givenNames":456,"isCorresponding":315,"isProfilePublic":315,"userId":327,"email":-1,"affiliations":457},"Daniel R.","Hyduke","Daniel R. ",[458],{"organizationName":435,"countryName":436,"cityName":19,"stateName":19,"zipCode":19},{"id":327,"firstName":460,"middleName":19,"lastName":461,"givenNames":462,"isCorresponding":315,"isProfilePublic":315,"userId":327,"email":-1,"affiliations":463},"Andrew","Williams","Andrew ",[464],{"organizationName":443,"countryName":444,"cityName":19,"stateName":19,"zipCode":19},{"id":327,"firstName":466,"middleName":19,"lastName":467,"givenNames":468,"isCorresponding":315,"isProfilePublic":315,"userId":327,"email":-1,"affiliations":469},"Roland","Frötschl","Roland ",[470],{"organizationName":471,"countryName":472,"cityName":19,"stateName":19,"zipCode":19},"Federal Institute for Drugs and Medical Devices","Germany",{"id":474,"firstName":475,"middleName":19,"lastName":476,"givenNames":477,"isCorresponding":315,"isProfilePublic":13,"userId":474,"email":-1,"affiliations":478},41592,"Heidrun","Ellinger-Ziegelbauer","Heidrun ",[479],{"organizationName":480,"countryName":472,"cityName":19,"stateName":19,"zipCode":19},"Investigational Toxicology, Bayer AG, Pharmaceuticals",{"id":327,"firstName":482,"middleName":19,"lastName":483,"givenNames":484,"isCorresponding":315,"isProfilePublic":315,"userId":327,"email":-1,"affiliations":485},"Syril","Pettit","Syril ",[486],{"organizationName":487,"countryName":436,"cityName":19,"stateName":19,"zipCode":19},"Health and Environmental Sciences Institute",{"id":327,"firstName":489,"middleName":19,"lastName":490,"givenNames":491,"isCorresponding":315,"isProfilePublic":315,"userId":327,"email":-1,"affiliations":492},"Jiri","Aubrecht","Jiri ",[493],{"organizationName":435,"countryName":436,"cityName":19,"stateName":19,"zipCode":19},{"id":495,"firstName":496,"middleName":19,"lastName":497,"givenNames":498,"isCorresponding":315,"isProfilePublic":13,"userId":495,"email":-1,"affiliations":499},26036,"Albert J.","Fornace","Albert J. ",[500],{"organizationName":435,"countryName":436,"cityName":19,"stateName":19,"zipCode":19},[502],{"id":503,"firstName":504,"middleName":19,"lastName":505,"givenNames":506,"isCorresponding":315,"isProfilePublic":13,"userId":503,"email":-1,"affiliations":507},569662,"Yvonne","Will","Yvonne ",[508],{"organizationName":509,"countryName":436,"cityName":19,"stateName":19,"zipCode":19},"Janssen Pharmaceuticals, Inc.",[511,520],{"id":512,"firstName":513,"middleName":514,"lastName":515,"givenNames":516,"isCorresponding":315,"isProfilePublic":13,"userId":512,"email":-1,"affiliations":517},578511,"Matthew","Thomas","Martin","Matthew  Thomas",[518],{"organizationName":519,"countryName":436,"cityName":19,"stateName":19,"zipCode":19},"Pfizer",{"id":521,"firstName":522,"middleName":19,"lastName":523,"givenNames":524,"isCorresponding":315,"isProfilePublic":13,"userId":521,"email":-1,"affiliations":525},612830,"Julia","Rager","Julia ",[526],{"organizationName":527,"countryName":436,"cityName":19,"stateName":19,"zipCode":19},"University of North Carolina at Chapel Hill",{"id":118,"slug":120,"name":119,"shortName":529,"electronicISSN":530,"field":531,"specialtyId":28,"journalSectionPaths":533},"Front. Big Data","2624-909X",{"id":532,"domainId":330},115,[534],{"section":535},{"id":155,"name":156,"slug":157,"specialtyId":536},1841,{"views":538,"downloads":539,"citations":540},8552,2560,39,2,"Volume 2 - 2019",[],{"titleHtml":19,"fullTextHtml":19,"menuHtml":19},[546,551,557,560,566],{"name":547,"fileServerPackageEntryId":19,"fileServerId":548,"fileServerVersionNumber":330,"type":549},"EPUB.epub","468242/epub",{"code":550,"name":550},"EPUB",{"name":552,"fileServerPackageEntryId":553,"fileServerId":554,"fileServerVersionNumber":330,"type":555},"fdata-02-00036.pdf","fdata-02-00036/fdata-02-00036.pdf","468242/pubmed-zip",{"code":556,"name":556},"PDF",{"name":552,"fileServerPackageEntryId":19,"fileServerId":558,"fileServerVersionNumber":330,"type":559},"468242/publishers-proof/pdf",{"code":556,"name":556},{"name":561,"fileServerPackageEntryId":562,"fileServerId":554,"fileServerVersionNumber":330,"type":563},"fdata-02-00036.xml","fdata-02-00036/fdata-02-00036.xml",{"code":564,"name":565},"NLM_XML","XML",{"name":567,"fileServerPackageEntryId":19,"fileServerId":568,"fileServerVersionNumber":330,"type":569},"Provisional PDF.pdf","468242/provisional-pdf",{"code":556,"name":556},"v4",{"title":572,"link":573,"meta":577,"script":709},"Frontiers | TGx-DDI, a Transcriptomic Biomarker for G