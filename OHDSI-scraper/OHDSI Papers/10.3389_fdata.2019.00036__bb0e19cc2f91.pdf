>–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--></tr><!--]--><!--[--><!--]--><!--[--><tr><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="left">Diethanolamine</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--></tr><!--]--><!--[--><!--]--><!--[--><tr><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="left">Melamine</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--></tr><!--]--><!--[--><!--]--><!--[--><tr><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="left"><!--[--><!--]--><!--[--><u>4C: Antibiotics</u><!--]--><!--[--><!--]--></td><!--]--><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--></tr><!--]--><!--[--><!--]--><!--[--><tr><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="left">Ampicillin</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--></tr><!--]--><!--[--><!--]--><!--[--><tr><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="left">Erythromycin Stearate</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--></tr><!--]--><!--[--><!--]--><!--[--><tr><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="left"><!--[--><!--]--><!--[--><u>4D: Others</u><!--]--><!--[--><!--]--></td><!--]--><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--></tr><!--]--><!--[--><!--]--><!--[--><tr><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="left">D-Mannitol</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--></tr><!--]--><!--[--><!--]--><!--[--><tr><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="left">n-Butyl Chloride</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--></tr><!--]--><!--[--><!--]--><!--[--><tr><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="left">3-Nitropropionic acid</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">–</td><!--]--><!--[--><!--]--></tr><!--]--><!--[--><!--]--><!--[--><tr><!--[--><!--]--><!--[--><td></td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="left">Methyl Carbamate</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">+</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">+/–</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">+</td><!--]--><!--[--><!--]--><!--[--><td valign="top" align="center">+</td><!--]--><!--[--><!--]--><!--