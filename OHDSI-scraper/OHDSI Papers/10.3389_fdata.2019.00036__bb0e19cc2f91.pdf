ext":1424},{"td":2049,":@":2056},[2050,2052,2054],{"#text":2051},"Energy metabolism inhibitor ",{"break":2053},[],{"#text":2055},"(uncoupling agent)",{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":2059,":@":2062},[2060],{"#text":2061},"Antimycin A",{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":2065,":@":2067},[2066],{"#text":1985},{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":2070,":@":2073},[2071],{"#text":2072},"25 ~ 200 μM",{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":2076,":@":2078},[2077],{"#text":1650},{"@_valign":1435,"@_align":1436},{"#text":1420},{"#text":1420},{"tr":2082},[2083,2084,2089,2090,2103,2104,2126,2127,2140,2141,2153],{"#text":1424},{"td":2085,":@":2088},[2086],{"#text":2087},"Heavy metals",{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":2091,":@":2102},[2092,2094,2096,2098,2100],{"#text":2093},"Cadmium chloride ",{"break":2095},[],{"#text":2097},"Potassium chromate (VI) ",{"break":2099},[],{"#text":2101},"Sodium arsenite",{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":2105,":@":2125},[2106,2107,2110,2111,2113,2114,2117,2118,2120,2121,2124],{"#text":1509},{"sub":2108},[2109],{"#text":608},{"#text":1680},{"break":2112},[],{"#text":1509},{"sub":2115},[2116],{"#text":608},{"#text":1680},{"break":2119},[],{"#text":1509},{"sub":2122},[2123],{"#text":608},{"#text":1514},{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":2128,":@":2139},[2129,2131,2133,2135,2137],{"#text":2130},"50 ~ 800 μM ",{"break":2132},[],{"#text":2134},"25 ~ 400 μM ",{"break":2136},[],{"#text":2138},"10 ~ 90 μM",{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":2142,":@":2152},[2143,2144,2146,2148,2150],{"#text":1703},{"break":2145},[],{"#text":2147},"100 μM ",{"break":2149},[],{"#text":2151},"30 μM",{"@_valign":1435,"@_align":1436},{"#text":1420},{"#text":1420},{"tr":2156},[2157,2158,2163,2164,2173,2174,2193,2194,2203,2204,2211],{"#text":1424},{"td":2159,":@":2162},[2160],{"#text":2161},"Other stresses",{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":2165,":@":2172},[2166,2168,2170],{"#text":2167},"Heat shock ",{"break":2169},[],{"#text":2171},"ethanol",{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":2175,":@":2192},[2176,2177,2183,2185,2186],{"#text":1741},{"xref":2178,":@":2182},[2179],{"sup":2180},[2181],{"#text":1747},{"@_ref-type":1749,"@_rid":1750},{"break":2184},[],{"#text":1741},{"xref":2187,":@":2191},[2188],{"sup":2189},[2190],{"#text":1747},{"@_ref-type":1749,"@_rid":1750},{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":2195,":@":2202},[2196,2198,2200],{"#text":2197},"47°C ",{"break":2199},[],{"#text":2201},"2%, 4%",{"@_valign":1435,"@_align":1436},{"#text":1424},{"td":2205,":@":2210},[2206,2207,2209],{"#text":2197},{"break":2208},[],{"#text":2201},{"@_valign":1435,"@_align":1436},{"#text":1420},{"#text":1402},{"#text":1394},{"@_frame":2215,"@_rules":2216},"hsides","groups",{"#text":1394},{"table-wrap-foot":2219},[2220,2221,2229,2230,2247],{"#text":1402},{"p":2222},[2223,2224,2228],{"#text":1420},{"italic":2225},[2226],{"#text":2227},"The first column indicates the mechanisms of action as described in the text. The last three columns list the solvent used, the dose range tested, and the final dose selected for transcriptomic analyses.",{"#text":1402},{"#text":1402},{"fn":2231,":@":2246},[2232,2233,2236,2237,2245],{"#text":1420},{"label":2234},[2235],{"#text":1747},{"#text":1420},{"p":2238},[2239,2240,2244],{"#text":1424},{"italic":2241},[2242],{"#text":2243},"N/A, not applicable.",{"#text":1420},{"#text":1402},{"@_id":1750},{"#text":1394},{"#text":778},{"@_position":1217,"@_id":1387},{"#text":784},{"#text":784},{"sec":2253},[2254,2255,2259,2260,2278,2279,2313],{"#text":778},{"title":2256},[2257],{"#text":2258},"(3) Data Analysis Pipeline Used to Identify the TGx-DDI Biomarker",{"#text":778},{"p":2261},[2262,2264,2270,2272,2276],{"#text":2263},"The global transcriptomic responses to treatment with the 28 model agents at the selected concentrations were measured using Agilent human whole genome oligonucleotide arrays. The individual gene expression profiles were then compiled in a database for further analysis. To limit noise in the data and enable interrogation of the database of gene expression profiles for gene signatures, genes that were significantly perturbed in three or more of the treatment conditions were selected. Although the gene expression profiles of the individual agents in the reference database displayed significant diversity, subsets of genes often formed clusters that were consistent with their mode of action. Visualization of the expression profiles highlighted the pleiotropic nature of these agents (i.e., gene expression profiles consisting of more than one defined gene cluster) (",{"xref":2265,":@":2268},[2266],{"#text":2267},"Figure 2",{"@_ref-type":1190,"@_rid":2269},"F2",{"#text":2271},"). Further analysis using the nearest shrunken centroids (NSC) method led to the identification of a biomarker capable of identifying DDI agents. In brief, the standardized centroid for each class was computed, where the standardized centroid was the mean expression level for each gene in a class divided by its within-class standard deviation. The standard centroid for each class was shrunken toward the overall centroid to produce the NSC. The method employed a shrinkage parameter to control the number of features used to construct the classifier. With a shrinkage threshold of 2.2, a 65-transcript panel was identified. The prediction for DDI probability reached 100% accuracy as assessed by 10-fold cross validation for the agents in this reference database. This transcriptomic biomarker was initially referred to as TGx-28.65 (reflecting 28 model agents in the training set, and 65 probes used in the signature). The 65 transcripts on the microarray probe design were later aligned to 64 genes as two of the transcripts were annotated to a single gene. To avoid confusion relating to the number of genes included in this biomarker, the biomarker was later renamed TGx-DDI. For a complete list of the genes in the TGx-DDI biomarker refer to Table 2 in Li et al. (",{"xref":2273,":@":2275},[2274],{"#text":1180},{"@_ref-type":909,"@_rid":1182},{"#text":2277},"). Pathway analysis of the biomarker genes revealed that p53 signaling and cell cycle regulation are the top two enriched pathways in this gene set.",{"#text":778},{"fig":2280,":@":2312},[2281,2282,2285,2286,2306,2307,2311],{"#text":1394},{"label":2283},[2284],{"#text":2267},{"#text":1394},{"caption":2287},[2288,2289,2305],{"#text":1402},{"p":2290},[2291,2293,2297,2299,2303],{"#text":2292},"Heatmap of transcriptome profiling data illustrating co-expressed sets of genes associated with various toxicants, such as genotoxic agents (red side bars). Some agents also exhibit obvious pleiotropy; e.g., chromate induced expression of genes associated with genotoxic agents (red side bars) and genes associated with cadmium and heat shock (blue side bars). This heatmap contains 1,628 genes that were significantly (",{"italic":2294},[2295],{"#text":2296},"P",{"#text":2298}," \u003C 0.01; ",{"italic":2300},[2301],{"#text":2302},"t",{"#text":2304},"-test) perturbed at least 1.7-fold, relative to the control, by at least one stress agent. The genes in the heatmap were organized by hierarchical clustering with complete linkage based on their error-weighted Pearson distances. The genotoxic (red side bars) and cadmium and heat shock (blue side bars) signatures were identified using coupled two-way clustering. The arrow highlights a cluster of genes responding to ER stress agents thapsigargin and tunicamycin as well as certain other agents.",{"#text":1394},{"#text":1394},{"graphic":2308,":@":2309},[],{"@_xlink:href":2310},"fdata-02-00036-g0002.tif",{"#text":778},{"@_id":2269,"@_position":1217},{"#text":784},{"#text":878},{"#text":878},{"sec":2317},[2318,2319,2323,2324,2363,2364,4993,4994,5055,5056,5147],{"#text":784},{"title":2320},[2321],{"#text":2322},"Validation of TGx-DDI—A Robust Biomarker for Genotoxicity",{"#text":784},{"p":2325},[2326,2328,2332,2333,2339,2341,2347,2349,2354,2356,2361],{"#text":2327},"To evaluate the sensitivity and specificity of the TGx-DDI biomarker for the assessment of genotoxic hazard associated with DNA damage, 45 chemicals were tested, which covered five classes of distinct genotoxic mechanisms and phenotypes (Kirkland et al., ",{"xref":2329,":@":2331},[2330],{"#text":948},{"@_ref-type":909,"@_rid":950},{"#text":1080},{"xref":2334,":@":2337},[2335],{"#text":2336},"2017",{"@_ref-type":909,"@_rid":2338},"B25",{"#text":2340},") (",{"xref":2342,":@":2345},[2343],{"#text":2344},"Table 2",{"@_ref-type":1386,"@_rid":2346},"T2",{"#text":2348},"). These compounds were selected based on adjudication of published data that included expert input from members of the FDA biomarker qualification team, and information from databases including the carcinogenicity potency database (",{"ext-link":2350,":@":2353},[2351],{"#text":2352},"https://toxnet.nlm.nih.gov/newtoxnet/cpdb.htm",{"@_ext-link-type":826,"@_xlink:href":2352},{"#text":2355},") and genotox databases also available via TOXNET (",{"ext-link":2357,":@":2360},[2358],{"#text":2359},"https://toxnet.nlm.nih.gov/",{"@_ext-link-type":826,"@_xlink:href":2359},{"#text":2362},"). For chemicals in the validation study, initial cell viability assessment guided the selection of concentrations analyzed in dose setting experiments using the three gene stress response panel described above. Transcriptomic profiling using DNA microarrays was performed on the single concentration selected for each chemical following the described selection process above.",{"#text":784},{"table-wrap":2365,":@":4992},[2366,2367,2370,2371,2379,2380,4888,4889,4991],{"#text":778},{"label":2368},[2369],{"#text":2344},{"#text":778},{"caption":2372},[2373,2374,2378],{"#text":1394},{"p":2375},[2376],{"#text":2377},"Summary of the TGx-DDI validation results on 48 external test agents.",{"#text":778},{"#text":778},{"table":2381,":@":4887},[2382,2383,2555,2556,4886],{"#text":1394},{"thead":2384},[2385,2386,2446,2447,2554],{"#text":1402},{"tr":2387},[2388,2389,2408,2409,2418,2419,2435,2436,2445],{"#text":1420},{"th":2390,":@":2407},[2391,2392,2406],{"#text":1424},{"bold":2393},[2394,2396],{"#text":2395},"Class",{"xref":2397,":@":2404},[2398],{"sup":2399},[2400],{"bold":2401},[2402],{"#text":2403},"&",{"@_ref-type":1749,"@_rid":2405},"TN2",{"#text":1420},{"@_valign":1435,"@_align":1436},{"#text":1420},{"th":2410,":@":2417},[2411,2412,2416],{"#text":1424},{"bold":2413},[2414],{"#text":2415},"Agents",{"#text":1420},{"@_valign":1435,"@_align":1436},{"#text":1420},{"th":2420,":@":2432},[2421,2422,2426,2428],{"#text":1424},{"bold":2423},[2424],{"#text":2425},"TGx",{"#text":2427},"-",{"bold":2429},[2430],{"#text":2431},"DDI",{"@_valign":1435,"@_align":2433,"@_colspan":741,"@_style":2434},"center","border-bottom: thin solid #000000;",{"#text":1420},{"th":2437,":@":2444},[2438,2439,2443],{"#text":1424},{"bold":2440},[2441],{"#text":2442},"Genotoxicity test",{"#text":1420},{"@_valign":1435,"@_align":2433,"@_colspan":541,"@_style":2434},{"#text":1402},{"#text":1402},{"tr":2448,":@":2553},[2449,2450,2452,2453,2455,2456,2472,2473,2492,2493,2512,2513,2522,2523,2542,2543,2552],{"#text":1420},{"th":2451},[],{"#text":1420},{"th":2454},[],{"#text":1420},{"th":2457,":@":2471},[2458,2459,2470],{"#text":1424},{"bold":2460},[2461,2463],{"#text":2462},"PA",{"xref":2464,":@":2468},[2465],{"sup":2466},[2467],{"#text":1747},{"@_ref-type":1749,"@_rid":2469},"TN3",{"#text":1420},{"@_valign":1435,"@_align":2433},{"#text":1420},{"th":2474,":@":2491},[2475,2476,2490],{"#text":1424},{"bold":2477},[2478,2480],{"#text":2479},"2DC",{"xref":2481,":@":2488},[2482],{"sup":2483},[2484],{"bold":2485},[2486],{"#text":2487},"#",{"@_ref-type":1749,"@_rid":2489},"TN4",{"#text":1420},{"@_valign":1435,"@_align":2433},{"#text":1420},{"th":2494,":@":2511},[2495,2496,2510],{"#text":1424},{"bold":2497},[2498,2500],{"#text":2499},"PCA",{"xref":2501,":@":2508},[2502],{"sup":2503},[2504],{"bold":2505},[2506],{"#text":2507},"@",{"@_ref-type":1749,"@_rid":2509},"TN5",{"#text":1420},{"@_valign":1435,"@_align":2433},{"#text":1420},{"th":2514,":@":2521},[2515,2516,2520],{"#text":1424},{"bold":2517},[2518],{"#text":2519},"Overall",{"#text":1420},{"@_valign":1435,"@_align":2433},{"#text":1420},{"th":2524,":@":2541},[2525,2526,2540],{"#text":1424},{"bold":2527},[2528,2530],{"#text":2529},"CD",{"xref":2531,":@":2538},[2532],{"sup":2533},[2534],{"bold":2535},[2536],{"#text":2537},"%",{"@_ref-type":1749,"@_rid":2539},"TN6",{"#text":1420},{"@_valign":1435,"@_align":2433},{"#text":1420},{"th":2544,":@":2551},[2545,2546,2550],{"#text":1424},{"bold":2547},[2548],{"#text":2549},"AMES",{"#text":1420},{"@_valign":1435,"@_align":2433},{"#text":1402},{"@_style":2434},{"#text":1394},{"#text":1394},{"tbody":2557},[2558,2559,2605,2606,2648,2649,2691,2692,2734,2735,2777,2778,2820,2821,2864,2865,2907,2908,2951,2952,2989,2990,3032,3033,3075,3076,3118,3119,3161,3162,3204,3205,3239,3240,3282,3283,3325,3326,3368,3369,3411,3412,3454,3455,3492,3493,3535,3536,3578,3579,3621,3622,3656,3657,3699,3700,3742,3743,3785,3786,3823,3824,3866,3867,3909,3910,3952,3953,3995,3996,4038,4039,4073,4074,4116,4117,4159,4160,4194,4195,4237,4238,4280,4281,4323,4324,4366,4367,4412,4413,4455,4456,4498,4499,4541,4542,4584,4585,4627,4628,4670,4671,4713,4714,4756,4757,4799,4800,4842,4843,4885],{"#text":1402},{"tr":2560},[2561,2562,2567,2568,2573,2574,2579,2580,2584,2585,2589,2590,2594,2595,2599,2600,2604],{"#text":1420},{"td":2563,":@":2566},[2564],{"#text":2565},"Class 1",{"@_valign":1435,"@_align":1436},{"#text":1420},{"td":2569,":@":2572},[2570],{"#text":2571},"N-Ethyl-N-Nitrosourea (ENU)",{"@_valign":1435,"@_align":1436},{"#text":1420},{"td":2575,":@":2578},[2576],{"#text":2577},"+",{"@_valign":1435,"@_align":2433},{"#text":1420},{"td":2581,":@":2583},[2582],{"#text":2577},{"@_valign":1435,"@_align":2433},{"#text":