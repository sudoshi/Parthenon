										jQuery(e.parentNode).css("background-image","url(/themes/CONICETDigital/images/BracketB.png)");
										if(e.parentNode.parentNode.parentNode.tagName=="DIV"){
											jQuery(e.parentElement).css("padding-bottom","0px");
										}
									}
									
									
								} 
								
