147a-fa57-4bd6-8778-520731dd4abe", "key": "aeolus_v1.zip", "links": {"content": "https://zenodo.org/api/records/5008609/files/aeolus_v1.zip/content", "self": "https://zenodo.org/api/records/5008609/files/aeolus_v1.zip"}, "metadata": null, "mimetype": "application/zip", "size": 1016916837, "storage_class": "L"}}, "order": [], "total_bytes": 1016926412}, "id": "5008609", "is_draft": false, "is_published": true, "links": {"access": "https://zenodo.org/api/records/5008609/access", "access_grants": "https://zenodo.org/api/records/5008609/access/grants", "access_links": "https://zenodo.org/api/records/5008609/access/links", "access_request": "https://zenodo.org/api/records/5008609/access/request", "access_users": "https://zenodo.org/api/records/5008609/access/users", "archive": "https://zenodo.org/api/records/5008609/files-archive", "archive_media": "https://zenodo.org/api/records/5008609/media-files-archive", "communities": "https://zenodo.org/api/records/5008609/communities", "communities-suggestions": "https://zenodo.org/api/records/5008609/communities-suggestions", "doi": "https://doi.org/10.5061/dryad.8q0s4", "draft": "https://zenodo.org/api/records/5008609/draft", "file_modification": "https://zenodo.org/api/records/5008609/file-modification", "files": "https://zenodo.org/api/records/5008609/files", "latest": "https://zenodo.org/api/records/5008609/versions/latest", "latest_html": "https://zenodo.org/records/5008609/latest", "media_files": "https://zenodo.org/api/records/5008609/media-files", "parent": "https://zenodo.org/api/records/5008608", "parent_html": "https://zenodo.org/records/5008608", "preview_html": "https://zenodo.org/records/5008609?preview=1", "request_deletion": "https://zenodo.org/api/records/5008609/request-deletion", "requests": "https://zenodo.org/api/records/5008609/requests", "reserve_doi": "https://zenodo.org/api/records/5008609/draft/pids/doi", "self": "https://zenodo.org/api/records/5008609", "self_doi": "https://doi.org/10.5061/dryad.8q0s4", "self_doi_html": "https://zenodo.org/doi/10.5061/dryad.8q0s4", "self_html": "https://zenodo.org/records/5008609", "self_iiif_manifest": "https://zenodo.org/api/iiif/record:5008609/manifest", "self_iiif_sequence": "https://zenodo.org/api/iiif/record:5008609/sequence/default", "versions": "https://zenodo.org/api/records/5008609/versions"}, "media_files": {"count": 0, "enabled": false, "entries": {}, "order": [], "total_bytes": 0}, "metadata": {"additional_descriptions": [{"description": "\u003cdiv class=\"o-metadata__file-usage-entry\"\u003eAEOLUS master file\u003cdiv class=\"o-metadata__file-description\"\u003eThis zipped file includes all the files needed to load a copy of AEOLUS into a RDBMS\u003c/div\u003e\u003cdiv class=\"o-metadata__file-name\"\u003eaeolus_v1.zip\u003cbr\u003e\u003c/div\u003e\u003cdiv class=\"o-metadata__file-name\"\u003e\u003c/div\u003e\u003c/div\u003e", "type": {"id": "notes", "title": {"de": "Anmerkungen", "en": "Notes"}}}], "creators": [{"affiliations": [{"name": "Stanford University"}], "person_or_org": {"family_name": "Banda", "given_name": "Juan M.", "name": "Banda, Juan M.", "type": "personal"}}, {"affiliations": [{"name": "LTS Computing LLC, West Chester, USA*"}], "person_or_org": {"family_name": "Evans", "given_name": "Lee", "name": "Evans, Lee", "type": "personal"}}, {"affiliations": [{"name": "Columbia University"}], "person_or_org": {"family_name": "Vanguri", "given_name": "Rami S.", "name": "Vanguri, Rami S.", "type": "personal"}}, {"affiliations": [{"name": "Columbia University"}], "person_or_org": {"family_name": "Tatonetti", "given_name": "Nicholas P.", "name": "Tatonetti, Nicholas P.", "type": "personal"}}, {"affiliations": [{"name": "Janssen Research \u0026 Development, LLC, Titusville, USA*"}], "person_or_org": {"family_name": "Ryan", "given_name": "Patrick B.", "name": "Ryan, Patrick B.", "type": "personal"}}, {"affiliations": [{"name": "Stanford University"}], "person_or_org": {"family_name": "Shah", "given_name": "Nigam H.", "name": "Shah, Nigam H.", "type": "personal"}}], "description": "Identification of adverse drug reactions (ADRs) during the post-marketing phase is one of the most important goals of drug safety surveillance. Spontaneous reporting systems (SRS) data, which are the mainstay of traditional drug safety surveillance, are used for hypothesis generation and to validate the newer approaches. The publicly available US Food and Drug Administration (FDA) Adverse Event Reporting System (FAERS) data requires substantial curation before they can be used appropriately, and applying different strategies for data cleaning and normalization can have material impact on analysis results. We provide a curated and standardized version of FAERS removing duplicate case records, applying standardized vocabularies with drug names mapped to RxNorm concepts and outcomes mapped to SNOMED-CT concepts, and pre-computed summary statistics about drug-outcome relationships for general consumption. This publicly available resource, along with the source code, will accelerate drug safety research by reducing the amount of time spent performing data management on the source FAERS reports, improving the quality of the underlying data, and enabling standardized analyses using common vocabularies.", "locations": {"features": [{"place": "United States"}]}, "publication_date": "2017-04-08", "publisher": "Zenodo", "related_identifiers": [{"identifier": "10.1038/sdata.2016.26", "relation_type": {"id": "iscitedby", "title": {"de": "Wird zitiert von", "en": "Is cited by"}}, "scheme": "doi"}], "resource_type": {"id": "dataset", "title": {"de": "Datensatz", "en": "Dataset"}}, "rights": [{"description": {"en": "CC0 waives copyright interest in a work you\u0027ve created and dedicates it to the world-wide public domain. Use CC0 to opt out of copyright entirely and ensure your work has the widest reach."}, "icon": "cc-cc0-icon", "id": "cc0-1.0", "props": {"scheme": "spdx", "url": "https://creativecommons.org/publicdomain/zero/1.0/legalcode"}, "title": {"en": "Creative Commons Zero v1.0 Universal"}}], "subjects": [{"subject": "Drug Safety"}, {"subject": "Adverse Drug Events"}, {"subject": "pharmacovigilance"}], "title": "Data from: A curated and standardized adverse drug event resource to accelerate drug safety research"}, "parent": {"access": {"owned_by": {"user": "90070"}, "settings": {"accept_conditions_text": null, "allow_guest_requests": false, "allow_user_requests": false, "secret_link_expiration": 0}}, "communities": {"default": "734b6452-1f40-4db0-b218-08ab1d568b7f", "entries": [{"access": {"member_policy": "open", "members_visibility": "public", "record_submission_policy": "open", "review_policy": "open", "visibility": "public"}, "children": {"allow": false}, "created": "2020-02-04T14:03:17.992421+00:00", "custom_fields": {}, "deletion_status": {"is_deleted": false, "status": "P"}, "id": "734b6452-1f40-4db0-b218-08ab1d568b7f", "links": {}, "metadata": {"curation_policy": "\u003cp\u003eThe Dryad collection in Zenodo contains datasets mirrored from the Dryad Digital Repository. If you want your dataset to appear here, submit it through \u003ca href=\"https://datadryad.org\"\u003ehttps://datadryad.org\u003c/a\u003e. No other datasets will be accepted.\u003c/p\u003e", "description": "Dryad is an international open-access repository of research data, especially data underlying scientific and medical publications. Dryad is a curated general-purpose repository that makes data discoverable, freely reusable, and citable.", "organizations": [{"id": "00x6h5n95"}], "page": "\u003cp\u003eDryad is a community-governed open data publishing and curation repository. Through Dryad and Zenodo\u0026#39;s partnership, Zenodo hosts a preservation copy of Dryad datasets, available through this Zenodo Community. For more information or to access the original published datasets, visit\u0026nbsp;\u003ca href=\"https://datadryad.org/\"\u003ehttps://datadryad.org\u003c/a\u003e.\u003c/p\u003e", "title": "Dryad", "type": {"id": "organization"}, "website": "https://datadryad.org"}, "revision_id": 3, "slug": "dryad", "updated": "2024-02-01T21:26:57.292847+00:00"}], "ids": ["734b6452-1f40-4db0-b218-08ab1d568b7f"]}, "id": "5008608", "pids": {}}, "pids": {"doi": {"identifier": "10.5061/dryad.8q0s4", "provider": "external"}, "oai": {"identifier": "oai:zenodo.org:5008609", "provider": "oai"}}, "revision_id": 3, "stats": {"all_versions": {"data_volume": 28473949111.0, "downloads": 57, "unique_downloads": 54, "unique_views": 256, "views": 260}, "this_version": {"data_volume": 28473949111.0, "downloads": 57, "unique_downloads": 54, "unique_views": 254, "views": 258}}, "status": "published", "swh": {}, "ui": {"access_status": {"description_l10n": "The record and files are publicly accessible.", "embargo_date_l10n": null, "icon": "unlock", "id": "open", "message_class": "", "title_l10n": "Open"}, "additional_descriptions": [{"description": "\u003cdiv class=\"o-metadata__file-usage-entry\"\u003eAEOLUS master file\u003cdiv class=\"o-metadata__file-description\"\u003eThis zipped file includes all the files needed to load a copy of AEOLUS into a RDBMS\u003c/div\u003e\u003cdiv class=\"o-metadata__file-name\"\u003eaeolus_v1.zip\u003cbr\u003e\u003c/div\u003e\u003cdiv class=\"o-metadata__file-name\"\u003e\u003c/div\u003e\u003c/div\u003e", "type": {"id": "notes", "title_l10n": "Notes"}}], "created_date_l10n_long": "June 21, 2021", "creators": {"affiliations": [[1, "Stanford University", null], [2, "LTS Computing LLC, West Chester, USA*", null], [3, "Columbia University", null], [4, "Janssen Research \u0026 Development, LLC, Titusville, USA*", null]], "creators": [{"affiliations": [[1, "Stanford University"]], "person_or_org": {"family_name": "Banda", "given_name": "Juan M.", "name": "Banda, Juan M.", "type": "personal"}}, {"affiliations": [[2, "LTS Computing LLC, West Chester, USA*"]], "person_or_org": {"family_name": "Evans", "given_name": "Lee", "name": "Evans, Lee", "type": "personal"}}, {"affiliations": [[3, "Columbia University"]], "person_or_org": {"family_name": "Vanguri", "given_name": "Rami S.", "name": "Vanguri, Rami S.", "type": "personal"}}, {"affiliations": [[3, "Columbia University"]], "person_or_org": {"family_name": "Tatonetti", "given_name": "Nicholas P.", "name": "Tatonetti, Nicholas P.", "type": "personal"}}, {"affiliations": [[4, "Janssen Research \u0026 Development, LLC, Titusville, USA*"]], "person_or_org": {"family_name": "Ryan", "given_name": "Patrick B.", "name": "Ryan, Patrick B.", "type": "personal"}}, {"affiliations": [[1, "Stanford University"]], "person_or_org": {"family_name": "Shah", "given_name": "Nigam H.", "name": "Shah, Nigam H.", "type": "personal"}}]}, "custom_fields": {}, "description_stripped": "Identification of adverse drug reactions (ADRs) during the post-marketing phase is one of the most important goals of drug safety surveillance. Spontaneous reporting systems (SRS) data, which are the mainstay of traditional drug safety surveillance, are used for hypothesis generation and to validate the newer approaches. The publicly available US Food and Drug Administration (FDA) Adverse Event Reporting System (FAERS) data requires substantial curation before they can be used appropriately, and applying different strategies for data cleaning and normalization can have material impact on analysis results. We provide a curated and standardized version of FAERS removing duplicate case records, applying standardized vocabularies with drug names mapped to RxNorm concepts and outcomes mapped to SNOMED-CT concepts, and pre-computed summary statistics about drug-outcome relationships for general consumption. This publicly available resource, along with the source code, will accelerate drug safety research by reducing the amount of time spent performing data management on the source FAERS reports, improving the quality of the underlying data, and enabling standardized analyses using common vocabularies.", "is_draft": false, "locations": {"features": [{"place": "United States"}]}, "publication_date_l10n_long": "April 8, 2017", "publication_date_l10n_medium": "Apr 8, 2017", "related_identifiers": [{"identifier": "10.1038/sdata.2016.26", "relation_type": {"id": "iscitedby", "title_l10n": "Is cited by"}, "scheme": "doi"}], "resource_type": {"id": "dataset", "title_l10n": "Dataset"}, "rights": [{"description_l10n": "CC0 waives copyright interest in a work you\u0027ve created and dedicates it to the world-wide public domain. Use CC0 to opt out of copyright entirely and ensure your work has the widest reach.", "icon": "cc-cc0-icon", "id": "cc0-1.0", "props": {"scheme": "spdx", "url": "https://creativecommons.org/publicdomain/zero/1.0/legalcode"}, "title_l10n": "Creative Commons Zero v1.0 Universal"}], "updated_date_l10n_long": "May 31, 2022", "version": "v1"}, "updated": "2022-05-31T06:13:34.538085+00:00", "versions": {"index": 1, "is_latest": true}}'
