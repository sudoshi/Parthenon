"uuid":"18071598-241d-436d-9a81-ca642175a8fd","language":null,"value":"Cerqueira, Gustavo Maia de","place":1,"authority":null,"confidence":-1},{"uuid":"7f667337-f2cc-403a-b0ec-33050a84a760","language":null,"value":"Suchard, Marc A.","place":2,"authority":null,"confidence":-1},{"uuid":"1ca990af-51b9-446e-afc7-f9a8a6235b5c","language":null,"value":"Moreira, Ângela N.","place":3,"authority":null,"confidence":-1},{"uuid":"2e6de288-1c28-4a20-843c-52e4238efaf4","language":null,"value":"Zuerner, Richard L.","place":4,"authority":null,"confidence":-1},{"uuid":"3b6b876b-fa2c-45aa-aae4-94c9ae978ef6","language":null,"value":"Reis, Mitermayer Galvão dos","place":5,"authority":null,"confidence":-1},{"uuid":"c90023e7-924a-4283-bc4e-40033459f1c0","language":null,"value":"Haake, David A.","place":6,"authority":null,"confidence":-1},{"uuid":"c7aca9ca-f634-44ac-89d3-d228f473b2be","language":null,"value":"Ko, Albert Icksang","place":7,"authority":null,"confidence":-1},{"uuid":"a22cf21e-9f57-428a-a1c9-9b3ab1456183","language":null,"value":"Dellagostin, Odir Antonio","place":8,"authority":null,"confidence":-1}],"dc.creator.affilliation":[{"uuid":"c3e7c3e6-c4fb-4e09-9111-a7db18b286d5","language":null,"value":"Fundação Oswaldo Cruz. Centro de Pesquisa Gonçalo Moniz. Salvador, BA, Brasil","place":0,"authority":null,"confidence":-1},{"uuid":"09991d72-567f-4ca5-b706-34156dbfb321","language":null,"value":"Universidade Federal de Pelotas. Centro de Biotecnologia. Pelotas, RS, Brasil","place":1,"authority":null,"confidence":-1},{"uuid":"c12de986-2f1b-4857-a228-36e1f6b41b94","language":null,"value":"David Geffen School of Medicine at UCLA. Department of Biomathematics. Department of Human Genetics. Department of Biostatistics. Los Angeles, CA, USA","place":2,"authority":null,"confidence":-1},{"uuid":"fad797f5-fdb5-4fce-89fc-549dcee83943","language":null,"value":"Universidade Federal de Pelotas. Centro de Biotecnologia. Pelotas, RS, Brasil","place":3,"authority":null,"confidence":-1},{"uuid":"8a443a7c-5f0e-4427-a9a9-6540f58778ad","language":null,"value":"National Animal Disease Centre. Agricultural Research Service. U.S. Department of Agriculture Ames. Iowa, USA","place":4,"authority":null,"confidence":-1},{"uuid":"efa4c84f-b05d-40de-9b33-a9f4d14f46c5","language":null,"value":"Fundação Oswaldo Cruz. Centro de Pesquisa Gonçalo Moniz. Salvador, BA, Brasil","place":5,"authority":null,"confidence":-1},{"uuid":"5fbdcfa2-171f-439e-8b83-3b34f7d4bd3d","language":null,"value":"Veterans Affairs Greater Los Angeles Healthcare System. Los Angeles, CA, USA / David Geffen School of Medicine at UCLA. Department of Medicine. Los Angeles, CA, USA","place":6,"authority":null,"confidence":-1},{"uuid":"ebb65ed7-358d-4dae-b582-b5db12526602","language":null,"value":"Fundação Oswaldo Cruz. Centro de Pesquisa Gonçalo Moniz. Salvador, BA, Brasil / Division of International Medicine and Infectious Disease. Weill Medical College of Cornell University. New York, NY, USA","place":7,"authority":null,"confidence":-1},{"uuid":"102f980a-9e82-4e83-ae76-dae1263a6432","language":null,"value":"Universidade Federal de Pelotas. Centro de Biotecnologia. Pelotas, RS, Brasil","place":8,"authority":null,"confidence":-1}],"dc.date.accessioned":[{"uuid":"6e7a880b-42bb-4992-a8e1-84cb0b048728","language":null,"value":"2014-04-25T11:49:23Z","place":0,"authority":null,"confidence":-1}],"dc.date.available":[{"uuid":"26cc1b3b-f3d1-4cae-8279-adaff299d470","language":null,"value":"2014-04-25T11:49:23Z","place":0,"authority":null,"confidence":-1}],"dc.date.issued":[{"uuid":"f7c65e84-0be8-4931-bc84-417e2f1a30b2","language":null,"value":"2008","place":0,"authority":null,"confidence":-1}],"dc.description.abstracten":[{"uuid":"053c7f80-b765-4eda-9352-44cdae495243","language":null,"value":"Recent serologic, immunoprotection, and pathogenesis studies identified the Lig proteins as key virulence determinants in interactions of leptospiral pathogens with the mammalian host. We examined the sequence variation and recombination patterns of ligA, ligB, and ligC among 10 pathogenic strains from five Leptospira species. All strains were found to have intact ligB genes and genetic drift accounting for most of the ligB genetic diversity observed. The ligA gene was found exclusively in L. interrogans and L. kirschneri strains, and was created from ligB by a two-step partial gene duplication process. The aminoterminal domain of LigB and the LigA paralog were essentially identical (98.5 ± 0.8% mean identity) in strains with both genes. Like ligB, ligC gene variation also followed phylogenetic patterns, suggesting an early gene duplication event. However, ligC is a pseudogene in several strains, suggesting that LigC is not essential for virulence. Two ligB genes and one ligC gene had mosaic compositions and evidence for recombination events between related Leptospira species was also found for some ligA genes. In conclusion, the results presented here indicate that Lig diversity has important ramifications for the selection of Lig polypeptides for use in diagnosis and as vaccine candidates. This sequence information will aid the identification of highly conserved regions within the Lig proteins and improve upon the performance characteristics of the Lig proteins in diagnostic assays and in subunit vaccine formulations with the potential to confer heterologous protection.","place":0,"authority":null,"confidence":-1}],"dc.identifier.citation":[{"uuid":"14ebe31d-0999-4a3d-88ca-c8963eb84f25","language":null,"value":"McBRIDE, A. J. A. et al. Genetic diversity of the Leptospiral immunoglobulin-like (Lig) genes in pathogenic Leptospira spp. Infections, Genetics and Evolution, v. 9, n. 2, p. 196-205, 2009.","place":0,"authority":null,"confidence":-1}],"dc.identifier.doi":[{"uuid":"90a5a529-2a1d-4bb4-a94e-aa579a567e93","language":null,"value":"10.1016/j.meegid.2008.10.012.","place":0,"authority":null,"confidence":-1}],"dc.identifier.issn":[{"uuid":"3bdb9ac3-9249-459d-940f-7f56bc6fa240","language":null,"value":"1567-7257","place":0,"authority":null,"confidence":-1}],"dc.identifier.uri":[{"uuid":"e5254d63-6d21-4598-876e-74a60f4d148c","language":null,"value":"https://arca.fiocruz.br/handle/icict/7536","place":0,"authority":null,"confidence":-1}],"dc.language.iso":[{"uuid":"a9bd2366-d9eb-4d45-a2ab-37807b0546d2","language":null,"value":"eng","place":0,"authority":null,"confidence":-1}],"dc.publisher":[{"uuid":"ead3a22f-3ae1-4ae0-b713-31e3f20e5b86","language":null,"value":"National Institute of Health","place":0,"authority":null,"confidence":-1}],"dc.rights":[{"uuid":"b7385bf3-574e-472c-af2f-1cca28517017","language":null,"value":"open access","place":0,"authority":null,"confidence":-1}],"dc.subject.decs":[{"uuid":"3e8a74ad-78c1-47e8-a929-13f28bbad3c6","language":null,"value":"Antígenos de Bactérias/genética","place":0,"authority":null,"confidence":-1},{"uuid":"0fcc7230-9240-4d0c-887f-4129f9412d24","language":null,"value":"DNA Bacteriano/genética","place":1,"authority":null,"confidence":-1},{"uuid":"06cfb794-2e1f-4245-8ee5-423044092a32","language":null,"value":"Variação Genética","place":2,"authority":null,"confidence":-1},{"uuid":"b0d2a138-fc02-4d13-b92b-624b186f2a2d","language":null,"value":"Animais","place":3,"authority":null,"confidence":-1},{"uuid":"31517c1a-b3f4-4680-bd72-b00af38d023a","language":null,"value":"Leptospira/fisiologia","place":4,"authority":null,"confidence":-1},{"uuid":"6bc3c893-38a8-43bf-89d1-fe0a4c234deb","language":null,"value":"Leptospira/genética","place":5,"authority":null,"confidence":-1},{"uuid":"f9d9abdf-84be-497e-ae53-dc3cde0dfba6","language":null,"value":"Leptospira/imunologia","place":6,"authority":null,"confidence":-1},{"uuid":"f7adab53-0451-424d-96cd-aa6122ce4723","language":null,"value":"Leptospirose/imunologia","place":7,"authority":null,"confidence":-1},{"uuid":"2a95e80f-433d-4e23-8197-35af21e01860","language":null,"value":"Dados de Sequência Molecular","place":8,"authority":null,"confidence":-1},{"uuid":"d5053274-1838-4e3f-a1bc