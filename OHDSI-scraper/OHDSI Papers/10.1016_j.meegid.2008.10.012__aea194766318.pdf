:"https://api.arca.fiocruz.br/api/core/communities/fd5adfc5-49b3-4f8f-aada-1a1a52feab8f/collections"},"logo":{"href":"https://api.arca.fiocruz.br/api/core/communities/fd5adfc5-49b3-4f8f-aada-1a1a52feab8f/logo"},"subcommunities":{"href":"https://api.arca.fiocruz.br/api/core/communities/fd5adfc5-49b3-4f8f-aada-1a1a52feab8f/subcommunities"},"parentCommunity":{"href":"https://api.arca.fiocruz.br/api/core/communities/fd5adfc5-49b3-4f8f-aada-1a1a52feab8f/parentCommunity"},"adminGroup":{"href":"https://api.arca.fiocruz.br/api/core/communities/fd5adfc5-49b3-4f8f-aada-1a1a52feab8f/adminGroup"},"self":{"href":"https://api.arca.fiocruz.br/api/core/communities/fd5adfc5-49b3-4f8f-aada-1a1a52feab8f"}},"_name":"Fiocruz Bahia - Instituto Gonçalo Moniz","id":"fd5adfc5-49b3-4f8f-aada-1a1a52feab8f","uuid":"fd5adfc5-49b3-4f8f-aada-1a1a52feab8f","type":"community","metadata":{"dc.description":[{"uuid":"40fb026c-6ad3-41cb-b1be-8e30fc71474f","language":null,"value":"\u003Cp style=\"text-align: justify;\">O Instituto Gonçalo Moniz na Bahia, antigo CPqGM, vem desenvolvendo diversas ações na área biomédica, de ensino, de serviço de referência em saúde, em informação em saúde e formação de recursos humanos para o SUS. Atua principalmente no estudo de doenças infecciosas e parasitárias, na realização de exames anatomopatológicos, além de abrigar dois cursos de pós-graduação stricto sensu em nível de mestrado e doutorado, através de um convênio com a Universidade Federal da Bahia – UFBA. Saiba mais sobre o IGM em: \u003Ca href=\"https://www.bahia.fiocruz.br/\" target=\"_blank\">https://www.bahia.fiocruz.br/\u003C/a>\u003Cbr />\r\n\u003Cstrong>Gestor da Comunidade:\u003C/strong> \u003Ca href=\"mailto:eneida.nascimento@fiocruz.br\">Eneida de Paula Nascimento\u003C/a>\u003C/p>","place":0,"authority":null,"confidence":-1}],"dc.identifier.uri":[{"uuid":"67b286b5-84cc-4d11-b31e-989f88491d92","language":null,"value":"https://arca.fiocruz.br/handle/icict/1744","place":0,"authority":null,"confidence":-1