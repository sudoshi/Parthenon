      <script type="81632e6b4ee8cb106ffb000e-text/javascript">
        window.__PRELOADED_STATE__ = {"abstracts":{"content":[{"$$":[{"$":{"id":"st005"},"#name":"section-title","_":"Graphical abstract"},{"$$":[{"$$":[{"$$":[{"$$":[{"$":{"role":"http://data.elsevier.com/vocabulary/ElsevierContentTypes/23.4","xmlns:xlink":true,"id":"lk00050","href":"pii:S0968089616309592/fx1","locator":"fx1"},"#name":"link"}],"$":{"id":"f0050"},"#name":"figure"}],"#name":"display"}],"$":{"view":"all","id":"sp0005"},"#name":"simple-para"}],"$":{"view":"all","id":"as005"},"#name":"abstract-sec"}],"$":{"view":"all","id":"ab005","lang":"en","class":"graphical"},"#name":"abstract"},{"$$":[{"$":{"id":"st010"},"#name":"section-title","_":"Abstract"},{"$$":[{"$$":[{"#name":"text","$$":[{"#name":"text","$$":[{"#name":"__text__","_":"Melanogenesis is a physiological pathway for the formation of "},{"#name":"topic-link","_":"melanin","$":{"href":"/topics/chemistry/melanin","term":"melanin"}},{"#name":"__text__","_":". "}]},{"#name":"topic-link","_":"Tyrosinase","$":{"href":"/topics/pharmacology-toxicology-and-pharmaceutical-science/tyrosinase","term":"Tyrosinase"}},{"#name":"text","$$":[{"#name":"__text__","_":" catalyzes the first step of this process and down-regulation of its activity is responsible for the inhibition of melanogenesis. The search for molecules capable of controlling "},{"#name":"topic-link","_":"hyperpigmentation","$":{"href":"/topics/pharmacology-toxicology-and-pharmaceutical-science/hyperpigmentation","term":"hyperpigmentation"}},{"#name":"__text__","_":" is a trend topic in health and cosmetics. A series of heteroarylcoumarins have been synthesized and evaluated. Compounds "}]}]},{"#name":"bold","_":"4"},{"#name":"__text__","_":" and "},{"#name":"bold","_":"8"},{"#name":"__text__","_":" exhibited higher tyrosinase inhibitory activities (IC"},{"$":{"loc":"post"},"#name":"inf","_":"50"},{"$":{"sp":"0.25"},"#name":"hsp"},{"#name":"__text__","_":"="},{"$":{"sp":"0.25"},"#name":"hsp"},{"#name":"__text__","_":"0.15 and 0.38"},{"$":{"sp":"0.25"},"#name":"hsp"},{"#name":"text","$$":[{"#name":"__text__","_":"μM, respectively), than the reference compound, "},{"#name":"topic-link","_":"kojic acid","$":{"href":"/topics/chemistry/kojic-acid","term":"kojic acid"}},{"#name":"__text__","_":" (IC"}]},{"$":{"loc":"post"},"#name":"inf","_":"50"},{"$":{"sp":"0.25"},"#name":"hsp"},{"#name":"__text__","_":"="},{"$":{"sp":"0.25"},"#name":"hsp"},{"#name":"__text__","_":"17.9"},{"$":{"sp":"0.25"},"#name":"hsp"},{"#name":"__text__","_":"μM). Compound "},{"#name":"bold","_":"4"},{"#name":"__text__","_":" acts as competitive, while compound "},{"#name":"bold","_":"8"},{"#name":"__text__","_":" as uncompetitive inhibitor of mushroom tyrosinase. Furthermore, compounds "},{"#name":"bold","_":"2"},{"#name":"__text__","_":" and "},{"#name":"bold","_":"8"},{"#name":"text","$$":[{"#name":"__text__","_":" inhibited tyrosinase activity and "},{"#name":"topic-link","_":"melanin","$":{"href":"/topics/pharmacology-toxicology-and-pharmaceutical-science/melanin","term":"melanin"}},{"#name":"__text__","_":" production in B16F10 cells. In addition, compounds "}]},{"#name":"bold","_":"2"},{"#name":"__text__","_":"–"},{"#name":"bold","_":"4"},{"#name":"__text__","_":" and "},{"#name":"bold","_":"8"},{"#name":"text","$$":[{"#name":"text","$$":[{"#name":"text","$$":[{"#name":"__text__","_":" proved to have an interesting "},{"#name":"topic-link","_":"antioxidant","$":{"href":"/topics/chemistry/antioxidant-agent","term":"antioxidant"}},{"#name":"__text__","_":" profile in both "}]},{"#name":"topic-link","_":"ABTS","$":{"href":"/topics/pharmacology-toxicology-and-pharmaceutical-science/abts","term":"ABTS"}},{"#name":"__text__","_":" and "}]},{"#name":"topic-link","_":"DPPH","$":{"href":"/topics/pharmacology-toxicology-and-pharmaceutical-science/1-1-diphenyl-2-picrylhydrazyl","term":"DPPH"}},{"#name":"__text__","_":" radicals scavenging assays. Docking experiments were carried out in order to study the interactions between these heteroarylcoumarins and mushroom tyrosinase."}]}],"$":{"view":"all","id":"sp0010"},"#name":"simple-para"}],"$":{"view":"all","id":"as010"},"#name":"abstract-sec"}],"$":{"view":"all","id":"ab010","lang":"en","class":"author"},"#name":"abstract"}],"floats":[],"footnotes":[],"attachments":[{"attachment-eid":"1-s2.0-S0968089616309592-fx1.sml","ucs-locator":"https://s3.amazonaws.com/prod-ucs-content-store-us-east/content/pii:S0968089616309592/fx1/THUMBNAIL/image/gif/832d632726e9f5375d4cda59ddecb889/fx1.sml","file-basename":"fx1","abstract-attachment":"true","filename":"fx1.sml","extension":"sml","filesize":"4757","pixel-height":"88","pixel-width":"219","attachment-type":"IMAGE-THUMBNAIL"},{"attachment-eid":"1-s2.0-S0968089616309592-fx1.jpg","ucs-locator":"https://s3.amazonaws.com/prod-ucs-content-store-us-east/content/pii:S0968089616309592/fx1/DOWNSAMPLED/image/jpeg/093f4050a15375f335661886769526f7/fx1.jpg","file-basename":"fx1","abstract-attachment":"true","filename":"fx1.jpg","extension":"jpg","filesize":"23568","pixel-height":"200","pixel-width":"499","attachment-type":"IMAGE-DOWNSAMPLED"},{"attachment-eid":"1-s2.0-S0968089616309592-fx1_lrg.jpg","ucs-locator":"https://s3.amazonaws.com/prod-ucs-content-store-us-east/content/pii:S0968089616309592/fx1/HIGHRES/image/jpeg/e15a49d1d7818414414cf1714f686639/fx1_lrg.jpg","file-basename":"fx1","abstract-attachment":"true","filename":"fx1_lrg.jpg","extension":"jpg","filesize":"89961","pixel-height":"531","pixel-width":"1326","attachment-type":"IMAGE-HIGH-RES"}]},"accessbarConfig":{"fallback":false,"id":"accessbar","version":"0.0.1","analytics":{"location":"accessbar","eventName":"ctaImpression"},"ariaLabel":{"accessbar":"Download options and search","componentsList":"PDF Options"},"banners":[{"id":"BannerSsrn"}],"components":[{"ariaLabel":"Access through your organization","institutionLogoAltText":"Seamless access","analytics":[{"ids":["accessbar:accesscta:inst-unknown:sdcust-unknown:ent-unknown:ra-yes:source-seamlessaccess:method-shib"],"event