,{"#name":"pixel-width","_":"2213"},{"#name":"attachment-type","_":"IMAGE-HIGH-RES"}],"$":{"xmlns:xocs":true},"#name":"attachment"}],"#name":"attachments"},{"$$":[{"$":{"id":"sectitle0010"},"#name":"section-title","_":"Abstract"},{"$$":[{"$":{"view":"all","id":"abspara0010"},"#name":"simple-para","_":"Tyrosinase is a copper-containing metalloenzyme that is responsible for the rate-limiting catalytic step in the melanin biosynthesis and enzymatic browning. As a promising target, tyrosinase inhibitors can be used as skin whitening agents and food preservatives, thus having broad potential in the fields of food, cosmetics, agriculture and medicine. From 2015 to 2020, numerous synthetic inhibitors of tyrosinase have been developed to overcome the challenges of low efficacy and side effects. This review summarizes the enzyme structure and biological functions of tyrosinase and demonstrates the recent advances of synthetic tyrosinase inhibitors from the perspective of medicinal chemistry, providing a better understanding of the catalytic mechanisms and more effective tyrosinase inhibitors."}],"$":{"view":"all","id":"abssec0010"},"#name":"abstract-sec"}],"$":{"view":"all","id":"abs0010","lang":"en","class":"author"},"#name":"abstract"},{"$$":[{"$":{"id":"sectitle0015"},"#name":"section-title","_":"Graphical abstract"},{"$$":[{"$$":[{"$$":[{"$$":[{"$":{"role":"short","id":"alttext0010"},"#name":"alt-text","_":"Image 1"},{"$":{"role":"http://data.elsevier.com/vocabulary/ElsevierContentTypes/23.4","xmlns:xlink":true,"href":"pii:S0223523421005936/ga1","id":"aep-link-id15","type":"simple","locator":"ga1"},"#name":"link"}],"$":{"id":"undfig1"},"#name":"figure"}],"#name":"display"}],"$":{"view":"all","id":"abspara0015"},"#name":"simple-para"}],"$":{"view":"all","id":"abssec0015"},"#name":"abstract-sec"}],"$":{"view":"all","id":"abs0015","class":"graphical"},"#name":"abstract"},{"$$":[{"$":{"id":"sectitle0020"},"#name":"section-title","_":"Highlights"},{"$$":[{"$$":[{"$$":[{"$$":[{"#name":"label","_":"•"},{"$":{"view":"all","id":"p0010"},"#name":"para","_":"Tyrosinase is a type 3 copper-containing metalloenzyme."}],"$":{"id":"u0010"},"#name":"list-item"},{"$$":[{"#name":"label","_":"•"},{"$":{"view":"all","id":"p0015"},"#name":"para","_":"Tyrosinase plays the key rate-limiting catalytic role in melanin biosynthesis."}],"$":{"id":"u0015"},"#name":"list-item"},{"$$":[{"#name":"label","_":"•"},{"$":{"view":"all","id":"p0020"},"#name":"para","_":"Synthetic tyrosinase inhibitors and structure-activity relationships are discussed."}],"$":{"id":"u0020"},"#name":"list-item"},{"$$":[{"#name":"label","_":"•"},{"$":{"view":"all","id":"p0025"},"#name":"para","_":"This review provides novel insights for designing efficient tyrosinase inhibitors."}],"$":{"id":"u0025"},"#name":"list-item"}],"$":{"id":"ulist0010"},"#name":"list"}],"$":{"view":"all","id":"abspara0020"},"#name":"simple-para"}],"$":{"view":"all","id":"abssec0020"},"#name":"abstract-sec"}],"$":{"view":"all","id":"abs0020","lang":"en","class":"author-highlights"},"#name":"abstract"}],"$":{"xmlns:ce":true,"xmlns:dm":true,"xmlns:sb":true},"#name":"abstracts"}},{"articleTitle":"Exploiting the 1-(4-fluorobenzyl)piperazine fragment for the development of novel tyrosinase inhibitors as anti-melanogenic agents: Design, synthesis, structural insights and biological profile","authors":"Ielo L., Deri-Zenaty B., De Luca L.","doi":"10.1016/j.ejmech.2019.06.019","documentTypeLabel":"Research article","externalArticle":false,"issn":"02235234","openAccess":0,"page":"380-389","pii":"S0223523419305380","publicationDate":"2019-09-15","publicationTitle":"European Journal of Medicinal Chemistry","publicationYear":"2019","scopusArticleUrl":"http://www.scopus.com/scopus/inward/record.url?partnerID=10&rel=3.0.0&view=basic&eid=2-s2.0-85067130624&md5=356a642e89d8fe398f81157a113f63c2","scopusEid":"2-s2.0-85067130624","thirdParty":false,"volume":"Volume 178","abstract":{"$$":[{"$$":[{"$$":[{"#name":"attachment-eid","_":"1-s2.0-S0223523419305380-fx1.sml"},{"#name":"ucs-locator","_":"https://s3.amazonaws.com/prod-ucs-content-store-us-east/content/pii:S0223523419305380/fx1/THUMBNAIL/image/gif/2418959604b4ad04e52a46ad70410534/fx1.sml"},{"#name":"file-basename","_":"fx1"},{"#name":"abstract-attachment","_":"true"},{"#name":"filename","_":"fx1.sml"},{"#name":"extension","_":"sml"},{"#name":"filesize","_":"22532"},{"#name":"pixel-height","_":"88"},{"#name":"pixel-width","_":"219"},{"#name":"attachment-type","_":"IMAGE-THUMBNAIL"}],"$":{"xmlns:xocs":true},"#name":"attachment"},{"$$":[{"#name":"attachment-eid","_":"1-s2.0-S0223523419305380-fx1.jpg"},{"#name":"ucs-locator","_":"https://s3.amazonaws.com/prod-ucs-content-store-us-east/content/pii:S0223523419305380/fx1/DOWNSAMPLED/image/jpeg/3ed2a4d7841be0329d69726039b82f38/fx1.jpg"},{"#name":"file-basename","_":"fx1"},{"#name":"abstract-attachment","_":"true"},{"#name":"filename","_":"fx1.jpg"},{"#name":"extension","_":"jpg"},{"#name":"filesize","_":"80026"},{"#name":"pixel-height","_":"200"},{"#name":"pixel-width","_":"500"},{"#name":"attachment-type","_":"IMAGE-DOWNSAMPLED"}],"$":{"xmlns:xocs":true},"#name":"attachment"},{"$$":[{"#name":"attachment-eid","_":"1-s2.0-S0223523419305380-fx1_lrg.jpg"},{"#name":"ucs-locator","_":"https://s3.amazonaws.com/prod-ucs-content-store-us-east/content/pii:S0223523419305380/fx1/HIGHRES/image/jpeg/834561f73ad2dc6247d89db96cc62ae1/fx1_lrg.jpg"},{"#name":"file-basename","_":"fx1"},{"#name":"abstract-attachment","_":"true"},{"#name":"filename","_":"fx1_lrg.jpg"},{"#name":"extension","_":"jpg"},{"#name":"filesize","_":"541659"},{"#name":"pixel-height","_":"885"},{"#name":"pixel-width","_":"2213"},{"#name":"attachment-type","_":"IMAGE-HIGH-RES"}],"$":{"xmlns:xocs":true},"#name":"attachment"}],"#name":"attachments"},{"$$":[{"$":{"id":"sectitle0010"},"#name":"section-title","_":"Abstract"},{"$$":[{"$$":[{"#name":"__text__","_":"The development of Tyrosinase inhibitors (TYRIs) could represent an efficacious strategy for pharmacological intervention on skin pathologies related to aberrant production of melanin. Based on "},{"#name":"italic","_":"in silico"},{"#name":"__text__","_":" studies we designed and tested a library of twenty-four compounds bearing the 4-(4-fluorobenzyl)piperazin-1-yl]-fragment. As result, we identified several compounds with excellent inhibit effects at low micromolar concentration against TYR from "},{"#name":"italic","_":"Agaricus bisporus"},{"#name":"__text__","_":" (TyM). Among them, compound "},{"#name":"bold","_":"25"},{"#name":"__text__","_":" (IC"},{"$":{"loc":"post"},"#name":"inf","_":"50"},{"#name":"__text__","_":" = 0.96 μM) proved to be ∼20-fold more potent than the reference compound kojic acid (IC"},{"$":{"loc":"post"},"#name":"inf","_":"50"},{"#name":"__text__","_":" = 17.76 μM) having wide applications in the cosmetics and pharmaceutical industries. The mode of interaction of active inhibitor "},{"#name":"bold","_":"25"},{"#name":"__text__","_":" was deciphered by means of crystallography as well as molecular docking and these results were consistent with kinetic experiments. Moreover, the identified compound "},{"#name":"bold","_":"25"},{"#name":"__text__","_":" exhibited no considerable cytotoxicity and showed anti-melanogenic effects on B16F10 melanoma cells. Therefore, a combination of computational and biochemical approaches could represent a rational guidelines for further structural modification of this class of compounds as future anti-melanogenic agents."}],"$":{"view":"all","id":"abspara0010"},"#name":"simple-para"}],"$":{"view":"all","id":"abssec0010"},"#name":"abstract-sec"}],"$":{"view":"all","id":"abs0010","lang":"en","class":"author"},"#name":"abstract"},{"$$":[{"$":{"id":"sectitle0015"},"#name":"section-title","_":"Graphical abstract"},{"$$":[{"$$":[{"$$":[{"$$":[{"$":{"role":"short","id":"alttext0010"},"#name":"alt-text","_":"Image 1"},{"$":{"role":"http://data.elsevier.com/vocabulary/ElsevierContentTypes/23.4","xmlns:xlink":true,"href":"pii:S0223523419305380/fx1","id":"aep-link-id12","type":"simple","locator":"fx1"},"#name":"link"}],"$":{"id":"undfig1"},"#name":"figure"}],"#name":"display"}],"$":{"view":"all","id":"abspara0015"},"#name":"simple-para"}],"$":{"view":"all","id":"abssec0015"},"#name":"abstract-sec"}],"$":{"view":"all","id":"abs0015","class":"graphical"},"#name":"abstract"},{"$$":[{"$":{"id":"sectitle0020"},"#name":"section-title","_":"Highlights"},{"$$":[{"$$":[{"$$":[{"$$":[{"#name":"label","_":"•"},{"$":{"view":"all","id":"p0010"},"#name":"para","_":"Computational studies suggested the rational design of new tyrosinase inhibitors."}],"$":{"id":"u0010"},"#name":"list-item"},{"$$":[{"#name":"label","_":"•"},{"$":{"view":"all","id":"p0015"},"#name":"para","_":"Twenty-four 4-(4-fluorobenzyl)piperazine derivatives were synthesized and screened."}],"$":{"id":"u0015"},"#name":"list-item"},{"$$":[{"#name":"label","_":"•"},{"$":{"view":"all","id":"p0020"},"#name":"para","_":"All compounds inhibited tyrosinase (TyM) at low micromolar concentration."}],"$":{"id":"u0020"},"#name":"list-item"},{"$$":[{"#name":"label","_":"•"},{"$$":[{"#name":"__text__","_":"Compound "},{"#name":"bold","_":"25"},{"#name":"__text__","_":" demonstrated antimelanogenic effects and low cytotoxicity."}],"$":{"view":"all","id":"p0025"},"#name":"para"}],"$":{"id":"u0025"},"#name":"list-item"},{"$$":[{"#name":"label","_":"•"},{"$":{"view":"all","id":"p0030"},"#name":"para","_":"Crystal complex with TyBm demonstrated the interaction within enzymatic cavity."}],"$":{"id":"u0030"},"#name":"list-item"}],"$":{"id":"ulist0010"},"#name":"list"}],"$":{"view":"all","id":"abspara0020"},"#name":"simple-para"}],"$":{"view":"all","id":"abssec0020"},"#name":"abstract-sec"}],"$":{"view":"all","id":"abs0020","lang":"en","class":"author-highlights"},"#name":"abstract"}],"$":{"xmlns:ce":true,"xmlns:dm":true,"xmlns:sb":true},"#name":"abstracts"}},{"articleTitle":"Design, synthesis and biological evaluation of novel 1,2,3-tr