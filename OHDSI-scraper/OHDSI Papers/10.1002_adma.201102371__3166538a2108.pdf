<hgroup><h1>Nanogel Star Polymer Architectures: A Nanoparticle Platform for Modular Programmable Macromolecular Self-Assembly, Intercellular Transport, and Dual-Mode Cargo Delivery</h1></hgroup><div class="cg p">
<a href='https://pubmed.ncbi.nlm.nih.gov/?term="Lee%20VY"[Author]' class="usa-link" aria-describedby="id1"><span class="name western">Victor Y Lee</span></a><div hidden="hidden" id="id1">
<h3><span class="name western">Victor Y Lee</span></h3>
<div class="p">
<sup>1</sup>IBM Almaden Research Center San Jose, CA 95120, USA</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Lee%20VY"[Author]' class="usa-link"><span class="name western">Victor Y Lee</span></a>
</div>
</div>
<sup>1</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Havenstrite%20K"[Author]' class="usa-link" aria-describedby="id2"><span class="name western">Karen Havenstrite</span></a><div hidden="hidden" id="id2">
<h3><span class="name western">Karen Havenstrite</span></h3>
<div class="p">
<sup>2</sup>School of Medicine Stanford University Stanford, CA 94305, USA</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Havenstrite%20K"[Author]' class="usa-link"><span class="name western">Karen Havenstrite</span></a>
</div>
</div>
<sup>2</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Tjio%20M"[Author]' class="usa-link" aria-describedby="id3"><span class="name western">Melia Tjio</span></a><div hidden="hidden" id="id3">
<h3><span class="name western">Melia Tjio</span></h3>
<div class="p">
<sup>3</sup>Department of Chemical and Materials Engineering San Jose State University San Jose, CA 95192, USA</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Tjio%20M"[Author]' class="usa-link"><span class="name western">Melia Tjio</span></a>
</div>
</div>
<sup>3</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="McNeil%20M"[Author]' class="usa-link" aria-describedby="id4"><span class="name western">Melanie McNeil</span></a><div hidden="hidden" id="id4">
<h3><span class="name western">Melanie McNeil</span></h3>
<div class="p">
<sup>4</sup>Department of Chemical and Materials Engineering San Jose State University San Jose, CA 95192, USA</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="McNeil%20M"[Author]' class="usa-link"><span class="name western">Melanie McNeil</span></a>
</div>
</div>
<sup>4</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Blau%20HM"[Author]' class="usa-link" aria-describedby="id5"><span class="name western">Helen M Blau</span></a><div hidden="hidden" id="id5">
<h3><span class="name western">Helen M Blau</span></h3>
<div class="p">
<sup>5</sup>School of Medicine Stanford University Stanford, CA 94305, USA</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Blau%20HM"[Author]' class="usa-link"><span class="name western">Helen M Blau</span></a>
</div>
</div>
<sup>5</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Miller%20RD"[Author]' class="usa-link" aria-describedby="id6"><span class="name western">Robert D Miller</span></a><div hidden="hidden" id="id6">
<h3><span class="name western">Robert D Miller</span></h3>
<div class="p">
<sup>6</sup>IBM Almaden Research Center San Jose, CA 95120, USA</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Miller%20RD"[Author]' class="usa-link"><span class="name western">Robert D Miller</span></a>
</div>
</div>
<sup>6,</sup><sup>*</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Sly%20J"[Author]' class="usa-link" aria-describedby="id7"><span class="name western">Joseph Sly</span></a><div hidden="hidden" id="id7">
<h3><span class="name western">Joseph Sly</span></h3>
<div class="p">
<sup>7</sup>IBM Almaden Research Center San Jose, CA 95120, USA</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Sly%20J"[Author]' class="usa-link"><span class="name western">Joseph Sly</span></a>
</div>
</div>
<sup>7,</sup><sup>*</sup>
</div>
<ul class="d-buttons inline-list">
<li><button class="d-button" aria-controls="aip_a" aria-expanded="false">Author information</button></li>
