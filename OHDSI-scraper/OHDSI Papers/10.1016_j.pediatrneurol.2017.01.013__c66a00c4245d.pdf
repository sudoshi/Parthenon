<td align="left" valign="top" rowspan="1" colspan="1">&gt;.99</td>
</tr>
<tr>
<td align="left" valign="top" rowspan="1" colspan="1">Death in hospital</td>
<td align="left" valign="top" rowspan="1" colspan="1">≤ 10</td>
<td align="left" valign="top" rowspan="1" colspan="1">311 (10%)</td>
<td align="left" valign="top" rowspan="1" colspan="1">&gt;.99</td>
</tr>
<tr>
<td align="left" valign="top" rowspan="1" colspan="1">Routine discharge</td>
<td align="left" valign="top" rowspan="1" colspan="1">17 (45%)</td>
<td align="left" valign="top" rowspan="1" colspan="1">1801 (57%)</td>
<td align="left" valign="top" rowspan="1" colspan="1">.14</td>
</tr>
<tr>
<td align="left" valign="top" rowspan="1" colspan="1">Poor outcome</td>
<td align="left" valign="top" rowspan="1" colspan="1">17 (45%)</td>
