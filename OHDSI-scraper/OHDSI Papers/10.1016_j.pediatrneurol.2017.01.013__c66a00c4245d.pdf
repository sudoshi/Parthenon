<td align="left" valign="top" rowspan="1" colspan="1">11.2 (1.3)</td>
<td align="left" valign="top" rowspan="1" colspan="1">16.1 (.6)</td>
<td align="left" valign="top" rowspan="1" colspan="1">.40</td>
</tr>
