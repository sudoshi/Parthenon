<td rowspan="1" colspan="1">10.3</td>
<td rowspan="1" colspan="1">0.24</td>
<td rowspan="1" colspan="1">finance</td>
<td rowspan="1" colspan="1">4.0</td>
<td rowspan="1" colspan="1">0.78</td>
</tr>
<tr>
<td rowspan="1" colspan="1">BS21 (people not friendly)</td>
<td rowspan="1" colspan="1">5.4</td>
<td rowspan="1" colspan="1">0.72</td>
<td rowspan="1" colspan="1">marijuana</td>
<td rowspan="1" colspan="1">6.2</td>
<td rowspan="1" colspan="1">0.52</td>
</tr>
<tr>
<td rowspan="1" colspan="1">BS31 (avoid frighten)</td>
<td rowspan="1" colspan="1">9.0</td>
<td rowspan="1" colspan="1">0.34</td>
<td rowspan="1" colspan="1">hard drugs</td>
<td rowspan="1" colspan="1">9.6</td>
<td rowspan="1" colspan="1">0.21</td>
</tr>
<tr>
<td rowspan="1" colspan="1">anxiety</td>
<td rowspan="1" colspan="1">15.6</td>
<td rowspan="1" colspan="1">0.05</td>
<td rowspan="1" colspan="1">AIDS symptoms</td>
<td rowspan="1" colspan="1">6.8</td>
<td rowspan="1" colspan="1">0.45</td>
</tr>
<tr>
<td rowspan="1" colspan="1">somatization</td>
<td rowspan="1" colspan="1">13.7</td>
<td rowspan="1" colspan="1">0.09</td>
