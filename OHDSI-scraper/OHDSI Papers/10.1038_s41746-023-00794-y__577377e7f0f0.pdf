                    <h1 class="c-article-title" data-test="article-title" data-article-title="">A standardized framework for risk-based assessment of treatment effect heterogeneity in observational healthcare databases</h1>
                    <ul class="c-article-author-list c-article-author-list--short" data-test="authors-list" data-component-authors-activator="authors-list"><li class="c-article-author-list__item"><a data-test="author-name" data-track="click" data-track-action="open author" data-track-label="link" data-track-index="1_6" data-track-context="researcher popup with no profile" href="#auth-Alexandros-Rekkas-Aff1" data-author-popup="auth-Alexandros-Rekkas-Aff1" data-author-search="Rekkas, Alexandros" data-corresp-id="c1">Alexandros Rekkas<svg width="16" height="16" focusable="false" role="img" aria-hidden="true" class="u-icon"><use xmlns:xlink="http://www.w3.org/1999/xlink" xlink:href="#icon-eds-i-mail-medium"></use></svg></a><span class="u-js-hide"> 
            <a class="js-orcid" href="https://orcid.org/0000-0002-5352-943X"><span class="u-visually-hidden">ORCID: </span>orcid.org/0000-0002-5352-943X</a></span><sup class="u-js-hide"><a href="#Aff1">1</a></sup>, </li><li class="c-article-author-list__item"><a data-test="author-name" data-track="click" data-track-action="open author" data-track-label="link" data-track-index="2_6" data-track-context="researcher popup with no profile" href="#auth-David-Klaveren-Aff2-Aff3" data-author-popup="auth-David-Klaveren-Aff2-Aff3" data-author-search="van Klaveren, David">David van Klaveren</a><sup class="u-js-hide"><a href="#Aff2">2</a>,<a href="#Aff3">3</a></sup>, </li><li class="c-article-author-list__item c-article-author-list__item--hide-small-screen"><a data-test="author-name" data-track="click" data-track-action="open author" data-track-label="link" data-track-index="3_6" data-track-context="researcher popup with no profile" href="#auth-Patrick_B_-Ryan-Aff4-Aff5" data-author-popup="auth-Patrick_B_-Ryan-Aff4-Aff5" data-author-search="Ryan, Patrick B.">Patrick B. Ryan</a><sup class="u-js-hide"><a href="#Aff4">4</a>,<a href="#Aff5">5</a></sup>, </li><li class="c-article-author-list__item c-article-author-list__item--hide-small-screen"><a data-test="author-name" data-track="click" data-track-action="open author" data-track-label="link" data-track-index="4_6" data-track-context="researcher popup with no profile" href="#auth-Ewout_W_-Steyerberg-Aff6" data-author-popup="auth-Ewout_W_-Steyerberg-Aff6" data-author-search="Steyerberg, Ewout W.">Ewout W. Steyerberg</a><span class="u-js-hide"> 
            <a class="js-orcid" href="https://orcid.org/0000-0002-7787-0122"><span class="u-visually-hidden">ORCID: </span>orcid.org/0000-0002-7787-0122</a></span><sup class="u-js-hide"><a href="#Aff6">6</a></sup>, </li><li class="c-article-author-list__item c-article-author-list__item--hide-small-screen"><a data-test="author-name" data-track="click" data-track-action="open author" data-track-label="link" data-track-index="5_6" data-track-context="researcher popup with no profile" href="#auth-David_M_-Kent-Aff3" data-author-popup="auth-David_M_-Kent-Aff3" data-author-search="Kent, David M.">David M. Kent</a><span class="u-js-hide"> 
            <a class="js-orcid" href="https://orcid.org/0000-0002-9205-5070"><span class="u-visually-hidden">ORCID: </span>orcid.org/0000-0002-9205-5070</a></span><sup class="u-js-hide"><a href="#Aff3">3</a></sup> &amp; </li><li class="c-article-author-list__show-more" aria-label="Show all 6 authors for this article" title="Show all 6 authors for this article">…</li><li class="c-article-author-list__item"><a data-test="author-name" data-track="click" data-track-action="open author" data-track-label="link" data-track-index="6_6" data-track-context="researcher popup with no profile" href="#auth-Peter_R_-Rijnbeek-Aff1" data-author-popup="auth-Peter_R_-Rijnbeek-Aff1" data-author-search="Rijnbeek, Peter R.">Peter R. Rijnbeek</a><sup class="u-js-hide"><a href="#Aff1">1</a></sup> </li></ul><button aria-expanded="false" class="c-article-author-list__button"><svg width="16" height="16" focusable="false" role="img" aria-hidden="true" class="u-icon"><use xmlns:xlink="http://www.w3.org/1999/xlink" xlink:href="#icon-eds-i-chevron-down-medium"></use></svg><span>Show authors</span></button>

                    

