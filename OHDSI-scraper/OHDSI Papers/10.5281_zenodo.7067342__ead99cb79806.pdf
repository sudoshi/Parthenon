O_Overview_Figure.png": {"access": {"hidden": false}, "checksum": "md5:cba8543e7575364de20f138efebd4266", "ext": "png", "id": "6e0d0f67-a3c6-42ad-943e-8e84fb6414d5", "key": "OMOP2OBO_Overview_Figure.png", "links": {"content": "https://zenodo.org/api/records/7067342/files/OMOP2OBO_Overview_Figure.png/content", "iiif_api": "https://zenodo.org/api/iiif/record:7067342:OMOP2OBO_Overview_Figure.png/full/full/0/default.png", "iiif_base": "https://zenodo.org/api/iiif/record:7067342:OMOP2OBO_Overview_Figure.png", "iiif_canvas": "https://zenodo.org/api/iiif/record:7067342/canvas/OMOP2OBO_Overview_Figure.png", "iiif_info": "https://zenodo.org/api/iiif/record:7067342:OMOP2OBO_Overview_Figure.png/info.json", "self": "https://zenodo.org/api/records/7067342/files/OMOP2OBO_Overview_Figure.png"}, "metadata": {"height": 1125, "width": 2000}, "mimetype": "image/png", "size": 567854, "storage_class": "L"}, "OMOP2OBO_Supplementary_Material_v2.pdf": {"access": {"hidden": false}, "checksum": "md5:b0b9249093cb7c78a9f5a0d911030be7", "ext": "pdf", "id": "e93fad41-439b-4621-ad1e-578ef0fc8482", "key": "OMOP2OBO_Supplementary_Material_v2.pdf", "links": {"content": "https://zenodo.org/api/records/7067342/files/OMOP2OBO_Supplementary_Material_v2.pdf/content", "iiif_api": "https://zenodo.org/api/iiif/record:7067342:OMOP2OBO_Supplementary_Material_v2.pdf/full/full/0/default.png", "iiif_base": "https://zenodo.org/api/iiif/record:7067342:OMOP2OBO_Supplementary_Material_v2.pdf", "iiif_canvas": "https://zenodo.org/api/iiif/record:7067342/canvas/OMOP2OBO_Supplementary_Material_v2.pdf", "iiif_info": "https://zenodo.org/api/iiif/record:7067342:OMOP2OBO_Supplementary_Material_v2.pdf/info.json", "self": "https://zenodo.org/api/records/7067342/files/OMOP2OBO_Supplementary_Material_v2.pdf"}, "metadata": null, "mimetype": "application/pdf", "size": 5925666, "storage_class": "L"}}, "order": [], "total_bytes": 10138289}, "id": "7067342", "is_draft": false, "is_published": true, "links": {"access": "https://zenod