        <span class="text-muted language">
          
        </span>
      </h2>
      
      
        <div class="ui message warning">
          This work was supported by funding from the National Library of Medicine (T15LM009451) to Lawrence E. Hunter and (T15LM007079) to George Hripcsak.
        </div>
      
    </section>
  
