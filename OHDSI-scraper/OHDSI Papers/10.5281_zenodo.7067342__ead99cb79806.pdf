, "given_name": "Blake", "identifiers": [{"identifier": "0000-0001-5683-8310", "scheme": "orcid"}], "name": "Martin, Blake", "type": "personal"}}, {"affiliations": [[13, "Semanticly"]], "person_or_org": {"family_name": "Matentzoglu", "given_name": "Nico", "identifiers": [{"identifier": "0000-0002-7356-1779", "scheme": "orcid"}], "name": "Matentzoglu, Nico", "type": "personal"}}, {"affiliations": [[14, "University of Southern California"]], "person_or_org": {"family_name": "Meeker", "given_name": "Daniella", "identifiers": [{"identifier": "0000-0002-1034-7628", "scheme": "orcid"}], "name": "Meeker, Daniella", "type": "personal"}}, {"affiliations": [[15, "Lawrence Berkeley National Laboratory"]], "person_or_org": {"family_name": "Reese", "given_name": "Justin", "identifiers": [{"identifier": "0000-0002-2170-2250", "scheme": "orcid"}], "name": "Reese, Justin", "type": "personal"}}, {"affiliations": [[16, "HealthLinc"]], "person_or_org": {"family_name": "Sinclair", "given_name": "Jessica", "name": "Sinclair, Jessica", "type": "personal"}}, {"affiliations": [[17, "University of Pittsburgh"]], "person_or_org": {"family_name": "Taneja", "given_name": "Sanya B", "identifiers": [{"identifier": "0000-0003-1707-1617", "scheme": "orcid"}], "name": "Taneja, Sanya B", "type": "personal"}}, {"affiliations": [[18, "University of Colorado Anschutz Skaggs School of Pharmacy and Pharmaceutical Sciences and School of Medicine"]], "person_or_org": {"family_name": "Trinkley", "given_name": "Katy E", "identifiers": [{"identifier": "0000-0003-2041-7404", "scheme": "orcid"}], "name": "Trinkley, Katy E", "type": "personal"}}, {"affiliations": [[2, "University of Colorado Anschutz Medical Campus"]], "person_or_org": {"family_name": "Vasilevsky", "given_name": "Nicole A", "identifiers": [{"identifier": "0000-0001-5208-3432", "scheme": "orcid"}], "name": "Vasilevsky, Nicole A", "type": "personal"}}, {"affiliations": [[19, "Tufts University"]], "person_or_org": {"family_name": "Williams", "given_name": "Andrew", "identifiers": [{"identifier": "0000-0002-0692-412X", "scheme": "orcid"}], "name": "Williams, Andrew", "type": "personal"}}, {"affiliations": [[20, "Sema4"]], "person_or_org": {"family_name": "Zhang", "given_name": "Xingman A", "identifiers": [{"identifier": "0000-0002-7284-3950", "scheme": "orcid"}], "name": "Zhang, Xingman A", "type": "personal"}}, {"affiliations": [[8, "The Jackson Laboratory for Genomic Medicine"]], "person_or_org": {"family_name": "Robinson", "given_name": "Peter N", "identifiers": [{"identifier": "0000-0002-0736-9199", "scheme": "orcid"}], "name": "Robinson, Peter N", "type": "personal"}}, {"affiliations": [[21, "Janssen Research and Development"]], "person_or_org": {"family_name": "Ryan", "given_name": "Patrick B", "name": "Ryan, Patrick B", "type": "personal"}}, {"affiliations": [[4, "Columbia University Irving Medical Center"]], "person_or_org": {"family_name": "Hripcsak", "given_name": "George", "identifiers": [{"identifier": "0000-0003-2664-7614", "scheme": "orcid"}], "name": "Hripcsak, George", "type": "personal"}}, {"affiliations": [[12, "University of Colorado School of Medicine"]], "person_or_org": {"family_name": "Bennett", "given_name": "Tellen D", "identifiers": [{"identifier": "0000-0003-1483-4236", "scheme": "orcid"}], "name": "Bennett, Tellen D", "type": "personal"}}, {"affiliations": [[12, "University of Colorado School of Medicine"]], "person_or_org": {"family_name": "Hunter", "given_name": "Lawrence E", "identifiers": [{"identifier": "0000-0003-1455-3370", "scheme": "orcid"}], "name": "Hunter, Lawrence E", "type": "personal"}}, {"affiliations": [[12, "University of Colorado School of Medicine"]], "person_or_org": {"family_name": "Kahn", "given_name": "Michael G", "identifiers": [{"identifier": "0000-0003-4786-6875", "scheme": "orcid"}], "name": "Kahn, Michael G", "type": "personal"}}]}, "custom_fields": {}, "description_stripped": "Common data models solve many challenges of standardizing electronic health record (EHR) data, but are unable to semantically integrate the resources needed for deep phenotyping. Open Biological and Biomedical Ontology (OBO) Foundry ontologies provide semantically computable representations of biological knowledge and enable the integration of a variety of biomedical data. However, mapping EHR data to OBO Foundry ontologies requires significant manual curation and domain expertise. We introduce a framework for mapping Observational Medical Outcomes Partnership (OMOP) standard vocabularies to OBO Foundry ontologies. Using this framework, we produced mappings for 92,367 conditions, 8,615 drug ingredients, and 10,673 measurement results. Mapping accuracy was verified by domain experts and when examined across 24 hospitals, the mappings covered 99% of conditions and drug ingredients and 68% of measurements. Finally, we demonstrate that OMOP2OBO mappings can aid in the systematic identification of undiagnosed rare disease patients who might benefit from genetic testing.", "is_draft": false, "languages": [{"id": "eng", "title_l10n": "English"}], "publication_date_l10n_long": "September 10, 2022", "publication_date_l10n_medium": "Sep 10, 2022", "related_identifiers": [{"identifier": "https://github.com/callahantiff/OMOP2OBO", "relation_type": {"id": "references", "title_l10n": "References"}, "resource_type": {"id": "software", "title_l10n": "Software"}, "scheme": "url"}], "resource_type": {"id": "publication-preprint", "title_l10n": "Preprint"}, "rights": [{"description_l10n": "The Creative Commons Attribution license allows re-distribution and re-use of a licensed work on the condition that the creator is appropriately credited.", "icon": "cc-by-icon", "id": "cc-by-4.0", "props": {"scheme": "spdx", "url": "https://creativecommons.org/licenses/by/4.0/legalcode"}, "title_l10n": "Creative Commons Attribution 4.0 International"}], "updated_date_l10n_long": "July 16, 2024", "version": "V2.0.1"}, "updated": "2024-07-16T03:29:38.667322+00:00", "versions": {"index": 4, "is_latest": false}}'
