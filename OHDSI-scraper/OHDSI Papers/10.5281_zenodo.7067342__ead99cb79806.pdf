J"}, {"@id": "https://orcid.org/0000-0002-7355-7745", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "University of Colorado Anschutz Medical Campus"}], "familyName": "Stefanski", "givenName": "Adrianne L", "name": "Stefanski, Adrianne L"}, {"@id": "https://orcid.org/0000-0002-5455-5859", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "University of Colorado Anschutz Medical Campus"}], "familyName": "Wyrwa", "givenName": "Jordan M", "name": "Wyrwa, Jordan M"}, {"@id": "https://orcid.org/0000-0002-0149-5661", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "National Institutes of Health"}], "familyName": "Zeng", "givenName": "Chenjie", "name": "Zeng, Chenjie"}, {"@id": "https://orcid.org/0000-0002-0847-6682", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "Columbia University Irving Medical Center"}], "familyName": "Ostropolets", "givenName": "Anna", "name": "Ostropolets, Anna"}, {"@id": "https://orcid.org/0000-0001-8499-824X", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "Georgia State University"}], "familyName": "Banda", "givenName": "Juan M", "name": "Banda, Juan M"}, {"@id": "https://orcid.org/0000-0001-6717-5313", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "University of Colorado Anschutz Medical Campus"}], "familyName": "Baumgartner Jr", "givenName": "William A", "name": "Baumgartner Jr, William A"}, {"@id": "https://orcid.org/0000-0002-2993-2085", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "University of Pittsburgh School of Medicine"}], "familyName": "Boyce", "givenName": "Richard D", "name": "Boyce, Richard D"}, {"@id": "https://orcid.org/0000-0003-2024-7572", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "Universit\u00e0 degli Studi di Milano"}], "familyName": "Casiraghi", "givenName": "Elena", "name": "Casiraghi, Elena"}, {"@id": "https://orcid.org/0000-0002-4422-1708", "@