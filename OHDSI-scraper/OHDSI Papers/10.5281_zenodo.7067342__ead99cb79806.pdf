milyName": "Meeker", "givenName": "Daniella", "name": "Meeker, Daniella"}, {"@id": "https://orcid.org/0000-0002-2170-2250", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "Lawrence Berkeley National Laboratory"}], "familyName": "Reese", "givenName": "Justin", "name": "Reese, Justin"}, {"@type": "Person", "affiliation": [{"@type": "Organization", "name": "HealthLinc"}], "familyName": "Sinclair", "givenName": "Jessica", "name": "Sinclair, Jessica"}, {"@id": "https://orcid.org/0000-0003-1707-1617", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "University of Pittsburgh"}], "familyName": "Taneja", "givenName": "Sanya B", "name": "Taneja, Sanya B"}, {"@id": "https://orcid.org/0000-0003-2041-7404", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "University of Colorado Anschutz Skaggs School of Pharmacy and Pharmaceutical Sciences and School of Medicine"}], "familyName": "Trinkley", "givenName": "Katy E", "name": "Trinkley, Katy E"}, {"@id": "https://orcid.org/0000-0001-5208-3432", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "University of Colorado Anschutz Medical Campus"}], "familyName": "Vasilevsky", "givenName": "Nicole A", "name": "Vasilevsky, Nicole A"}, {"@id": "https://orcid.org/0000-0002-0692-412X", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "Tufts University"}], "familyName": "Williams", "givenName": "Andrew", "name": "Williams, Andrew"}, {"@id": "https://orcid.org/0000-0002-7284-3950", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "Sema4"}], "familyName": "Zhang", "givenName": "Xingman A", "name": "Zhang, Xingman A"}, {"@id": "https://orcid.org/0000-0002-0736-9199", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "The Jackson Laboratory for Genomic Medicine"}], "familyName": "Robinson", "givenName": "Peter N", "name": "Robinson, Peter N"}, {"@type": "Person", "affiliation": [{"@type": "Organization", "name": "Janssen Research and Development"}], "familyName": "Ryan", "givenName": "Patrick B", "name": "Ryan, Patrick B"}, {"@id": "https://orcid.org/0000-0003-2664-7614", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "Columbia University Irving Medical Center"}], "familyName": "Hripcsak", "givenName": "George", "name": "Hripcsak, George"}, {"@id": "https://orcid.org/0000-0003-1483-4236", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "University of Colorado School of Medicine"}], "familyName": "Bennett", "givenName": "Tellen D", "name": "Bennett, Tellen D"}, {"@id": "https://orcid.org/0000-0003-1455-3370", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "University of Colorado School of Medicine"}], "familyName": "Hunter", "givenName": "Lawrence E", "name": "Hunter, Lawrence E"}, {"@id": "https://orcid.org/0000-0003-4786-6875", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "University of Colorado School of Medicine"}], "familyName": "Kahn", "givenName": "Michael G", "name": "Kahn, Michael G"}], "dateCreated": "2022-09-10T18:49:21.396134+00:00", "dateModified": "2024-07-16T03:29:38.667322+00:00", "datePublished": "2022-09-10", "description": "\u003cp\u003eCommon data models solve many challenges of standardizing electronic health record (EHR) data, but are unable to semantically integrate the resources needed for deep phenotyping. Open Biological and Biomedical Ontology (OBO) Foundry ontologies provide semantically computable representations of biological knowledge and enable the integration of a variety of biomedical data. However, mapping EHR data to OBO Foundry ontologies requires significant manual curation and domain expertise. We introduce a framework for mapping Observational Medical Outcomes Partnership (OMOP) standard vocabularies to OBO Foundry ontologies. Using this framework, we produced mappings for 92,367 conditions, 8,615 drug ingredients, and 10,673 measurement results. Mapping accuracy was verified by domain experts and when examined across 24 hospitals, the mappings covered 99% of conditions and drug ingredients and 68% of measurements. Finally, we demonstrate that OMOP2OBO mappings can aid in the systematic identification of undiagnosed rare disease patients who might benefit from genetic testing.\u003c/p\u003e", "identifier": "https://doi.org/10.5281/zenodo.7067342", "inLanguage": {"@type": "Language", "alternateName": "eng", "name": "English"}, "keywords": "OMOP, Open Biomedical Ontologies, Semantic Alignment, Interoperability, Mappings", "license": "https://creativecommons.org/licenses/by/4.0/legalcode", "name": "Ontologizing Health Systems Data at Scale: Making Translational Discovery a Reality", "publisher": {"@type": "Organization", "name": "Zenodo"}, "size": "9.67 MB", "url": "https://zenodo.org/records/7067342", "version": "V2.0.1"}</script>

