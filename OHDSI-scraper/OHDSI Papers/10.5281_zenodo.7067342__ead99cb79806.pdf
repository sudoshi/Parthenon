: "Columbia University Irving Medical Center"}], "person_or_org": {"family_name": "Ostropolets", "given_name": "Anna", "identifiers": [{"identifier": "0000-0002-0847-6682", "scheme": "orcid"}], "name": "Ostropolets, Anna", "type": "personal"}}, {"affiliations": [{"name": "Georgia State University"}], "person_or_org": {"family_name": "Banda", "given_name": "Juan M", "identifiers": [{"identifier": "0000-0001-8499-824X", "scheme": "orcid"}], "name": "Banda, Juan M", "type": "personal"}}, {"affiliations": [{"name": "University of Colorado Anschutz Medical Campus"}], "person_or_org": {"family_name": "Baumgartner Jr", "given_name": "William A", "identifiers": [{"identifier": "0000-0001-6717-5313", "scheme": "orcid"}], "name": "Baumgartner Jr, William A", "type": "personal"}}, {"affiliations": [{"name": "University of Pittsburgh School of Medicine"}], "person_or_org": {"family_name": "Boyce", "given_name": "Richard D", "identifiers": [{"identifier": "0000-0002-2993-2085", "scheme": "orcid"}], "name": "Boyce, Richard D", "type": "personal"}}, {"affiliations": [{"name": "Universit\u00e0 degli Studi di Milano"}], "person_or_org": {"family_name": "Casiraghi", "given_name": "Elena", "identifiers": [{"identifier": "0000-0003-2024-7572", "scheme": "orcid"}], "name": "Casiraghi, Elena", "type": "personal"}}, {"affiliations": [{"name": "The Jackson Laboratory for Genomic Medicine"}], "person_or_org": {"family_name": "Coleman", "given_name": "B", "identifiers": [{"identifier": "0000-0002-4422-1708", "scheme": "orcid"}], "name": "Coleman, B", "type": "personal"}}, {"affiliations": [{"name": "University of Cambridge"}], "person_or_org": {"family_name": "Collins", "given_name": "Janine H", "identifiers": [{"identifier": "0000-0002-8716-3261", "scheme": "orcid"}], "name": "Collins, Janine H", "type": "personal"}}, {"affiliations": [{"name": "Children\u0027s Hospital Colorado"}], "person_or_org": {"family_name": "Deakyne Davies", "given_name": "Sara J", "identifiers": [{"identifier": "0000-0002-8602-1624", "scheme": "orcid"}], "name": "Deakyne Davies, Sara J", "type": "personal"}}, {"affiliations": [{"name": "University of Colorado Anschutz School of Medicine"}], "person_or_org": {"family_name": "Feinstein", "given_name": "James A", "identifiers": [{"identifier": "0000-0003-3074-8805", "scheme": "orcid"}], "name": "Feinstein, James A", "type": "personal"}}, {"affiliations": [{"name": "University of Colorado Anschutz Medical Campus"}], "person_or_org": {"family_name": "Haendel", "given_name": "Melissa A", "identifiers": [{"identifier": "0000-0001-9114-8737", "scheme": "orcid"}], "name": "Haendel, Melissa A", "type": "personal"}}, {"affiliations": [{"name": "National Institutes of Health"}], "person_or_org": {"family_name": "Lin", "given_name": "Asiyah Y", "identifiers": [{"identifier": "0000-0003-2620-0345", "scheme": "orcid"}], "name": "Lin, Asiyah Y", "type": "personal"}}, {"affiliations": [{"name": "University of Colorado School of Medicine"}], "person_or_org": {"family_name": "Martin", "given_name": "Blake", "identifiers": [{"identifier": "0000-0001-5683-8310", "scheme": "orcid"}], "name": "Martin, Blake", "type": "personal"}}, {"affiliations": [{"name": "Semanticly"}], "person_or_org": {"family_name": "Matentzoglu", "given_name": "Nico", "identifiers": [{"identifier": "0000-0002-7356-1779", "scheme": "orcid"}], "name": "Matentzoglu, Nico", "type": "personal"}}, {"affiliations": [{"name": "University of Southern California"}], "person_or_org": {"family_name": "Meeker", "given_name": "Daniella", "identifiers": [{"identifier": "0000-0002-1034-7628", "scheme": "orcid"}], "name": "Meeker, Daniella", "type": "personal"}}, {"affiliations": [{"name": "Lawrence Berkeley National Laboratory"}], "person_or_org": {"family_name": "Reese", "given_name": "Justin", "identifiers": [{"identifier": "0000-0002-2170-2250", "scheme": "orcid"}], "name": "Reese, Justin", "type": "personal"}}, {"affiliations": [{"name": "HealthLinc"}], "person_or_org": {"family_name": "Sinclair", "given_name": "Jessica", "name": "Sinclair, Jessica", "type": "personal"}}, {"affiliations": [{"name": "University of Pittsburgh"}], "person_or_org": {"family_name": "Taneja", "given_name": "Sanya B", "identifiers": [{"identifier": "0000-0003-1707-1617", "scheme": "orcid"}], "name": "Taneja, Sanya B", "type": "personal"}}, {"affiliations": [{"name": "University of Colorado Anschutz Skaggs School of Pharmacy and Pharmaceutical Sciences and School of Medicine"}], "person_or_org": {"family_name": "Trinkley", "given_name": "Katy E", "identifiers": [{"identifier": "0000-0003-2041-7404", "scheme": "orcid"}], "name": "Trinkley, Katy E", "type": "personal"}}, {"affiliations": [{"name": "University of Colorado Anschutz Medical Campus"}], "person_or_org": {"family_name": "Vasilevsky", "given_name": "Nicole A", "identifiers": [{"identifier": "0000-0001-5208-3432", "scheme": "orcid"}], "name": "Vasilevsky, Nicole A", "type": "personal"}}, {"affiliations": [{"name": "Tufts University"}], "person_or_org": {"family_name": "Williams", "given_name": "Andrew", "identifiers": [{"identifier": "0000-0002-0692-412X", "scheme": "orcid"}], "name": "Williams, Andrew", "type": "personal"}}, {"affiliations": [{"name": "Sema4"}], "person_or_org": {"family_name": "Zhang", "given_name": "Xingman A", "identifiers": [{"identifier": "0000-0002-7284-3950", "scheme": "orcid"}], "name": "Zhang, Xingman A", "type": "personal"}}, {"affiliations": [{"name": "The Jackson Laboratory for Genomic Medicine"}], "person_or_org": {"family_name": "Robinson", "given_name": "Peter N", "identifiers": [{"identifier": "0000-0002-0736-9199", "scheme": "orcid"}], "name": "Robinson, Peter N", "type": "personal"}}, {"affiliations": [{"name": "Janssen Research and Development"}], "person_or_org": {"family_name": "Ryan", "given_name": "Patrick B", "name": "Ryan, Patrick B", "type": "personal"}}, {"affiliations": [{"name": "Columbia University Irving Medical Center"}], "person_or_org": {"family_name": "Hripcsak", "given_name": "George", "identifiers": [{"identifier": "0000-0003-2664-7614", "scheme": "orcid"}], "name": "Hripcsak, George", "type": "personal"}}, {"affiliations": [{"name": "University of Colorado School of Medicine"}], "person_or_org": {"family_name": "Bennett", "given_name": "Tellen D", "identifiers": [{"identifier": "0000-0003-1483-4236", "scheme": "orcid"}], "name": "Bennett, Tellen D", "type": "personal"}}, {"affiliations": [{"name": "University of Colorado School of Medicine"}], "person_or_org": {"family_name": "Hunter", "given_name": "Lawrence E", "identifiers": [{"identifier": "0000-0003-1455-3370", "scheme": "orcid"}], "name": "Hunter, Lawrence E", "type": "personal"}}, {"affiliations": [{"name": "University of Colorado School of Medicine"}], "person_or_org": {"family_name": "Kahn", "given_name": "Michael G", "identifiers": [{"identifier": "0000-0003-4786-6875", "scheme": "orcid"}], "name": "Kahn, Michael G", "type": "personal"}}], "description": "\u003cp\u003eCommon data models solve many challenges of standardizing electronic health record (EHR) data, but are unable to semantically integrate the resources needed for deep phenotyping. Open Biological and Biomedical Ontology (OBO) Foundry ontologies provide semantically computable representations of biological knowledge and enable the integration of a variety of biomedical data. However, mapping EHR data to OBO Foundry ontologies requires significant manual curation and domain expertise. We introduce a framework for mapping Observational Medical Outcomes Partnership (OMOP) standard vocabularies to OBO Foundry ontologies. Using this framework, we produced mappings for 92,367 conditions, 8,615 drug ingredients, and 10,673 measurement results. Mapping accuracy was verified by domain experts and when examined across 24 hospitals, the mappings covered 99% of conditions and drug ingredients and 68% of measurements. Finally, we demonstrate that OMOP2OBO mappings can aid in the systematic identification of undiagnosed rare disease patients who might benefit from genetic testing.\u003c/p\u003e", "languages": [{"id": "eng", "title": {"en": "English"}}], "publication_date": "2022-09-10", "publisher": "Zenodo", "related_identifiers": [{"identifier": "https://github.com/callahantiff/OMOP2OBO", "relation_type": {"id": "references", "title": {"de": "Referenziert", "en": "References"}}, "resource_type": {"id": "software", "title": {"de": "Software", "en": "Software"}}, "scheme": "url"}], "resource_type": {"id": "publication-preprint", "title": {"de": "Preprint", "en": "Preprint"}}, "rights": [{"description": {"en": "The Creative Commons Attribution license allows re-distribution and re-use of a licensed work on the condition that the creator is appropriately credited."}, "icon": "cc-by-icon", "id": "cc-by-4.0", "props": {"scheme": "spdx", "url": "https://creativecommons.org/licenses/by/4.0/legalcode"}, "title": {"en": "Creative Commons Attribution 4.0 International"}}], "subjects": [{"subject": "OMOP"}, {"subject": "Open Biomedical Ontologies"}, {"subject": "Semantic Alignment"}, {"subject": "Interoperability"}, {"subject": "Mappings"}], "title": "Ontologizing Health Systems Data at Scale: Making Translational Discovery a Reality", "version": "V2.0.1"}, "parent": {"access": {"owned_by": {"user": "62793"}, "settings": {"accept_conditions_text": null, "allow_guest_requests": false, "allow_user_requests": false, "secret_link_expiration": 0}}, "communities": {"default": "d5edc788-2914-4e51-8405-9f29894062d5", "entries": [{"access": {"member_policy": "open", "members_visibility": "public", "record_submission_policy": "open", "review_policy": "open", "visibility": "public"}, "children": {"allow": false}, "created": "2021-11-20T22:23:17.528402+00:00", "custom_fields": {}, "deletion_status": {"is_deleted": false, "status": "P"}, "id": "d5edc788-2914-4e51-8405-9f29894062d5", "links": {}, "metadata": {"curation_policy": "\u003cp\u003eThis community is meant to store publications, presentations, code, and output that are relevant to OMOP2OBO.\u003c/p\u003e\r\n", "page": "\u003cp\u003e\u003cstrong\u003eTools to Support Semantic Interoperability between Biomedical Ontologies and Clinical Terminologies\u003c/strong\u003e\u003c/p\u003e\r\n\r\n\u003cp\u003e\u0026nbsp;\u003c/p\u003e\r\n\r\n\u003cp\u003e\u003ccode\u003eomop2obo\u003c/code\u003e\u0026nbsp;is a semantic alignment\u0026nbsp;algorithm and a collection of health system-wide, disease-agnostic mappings between clinical terminologies, like those available\u0026nbsp;in the Observational Medical Outcomes Partnership (\u003ca href=\"https://www.ohdsi.org/data-standardization/the-common-data-model/\"\u003eOMOP\u003c/a\u003e) Common Data Model, and Open Biomedical Foundry Ontologies (\u003ca href=\"http://www.obofoundry.org/\"\u003eOBOs\u003c/a\u003e)\u003c/p\u003e\r\n\r\n\u003cp\u003e\u0026nbsp;\u003c/p\u003e\r\n\r\n\u003cp\u003e\u003ca href=\"https://github.com/callahantiff/OMOP2OBO\"\u003ehttps://github.com/callahantiff/OMOP2OBO\u003c/a\u003e\u003c/p\u003e\r\n\r\n\u003cp\u003e\u003ccode\u003eomop2obo\u003c/code\u003e\u0026nbsp;is a semantic alignment\u0026nbsp;algorithm and a collection of health system-wide, disease-agnostic mappings between clinical terminologies, like those available\u0026nbsp;in the Observational Medical Outcomes Partnership (\u003ca href=\"https://www.ohdsi.org/data-standardization/the-common-data-model/\"\u003eOMOP\u003c/a\u003e) Common Data Model, and Open Biomedical Foundry Ontologies (\u003ca href=\"http://www.obofoundry.org/\"\u003eOBOs\u003c/a\u003e).\u003c/p\u003e\r\n\r\n\u003cp\u003e\u0026nbsp;\u003c/p\u003e\r\n\r\n\u003cp\u003e\u003cstrong\u003e\u003cem\u003eMotivation\u003c/em\u003e\u003c/strong\u003e\u003c/p\u003e\r\n\r\n\u003cp\u003eCommon data models have solved many challenges of utilizing electronic health records, but have not yet meaningfully integrated clinical and molecular data. Aligning clinical data to open biological ontologies (\u003ca href=\"http://www.obofoundry.org/\"\u003eOBOs\u003c/a\u003e), which provide semantically computable representations of biological knowledge, requires extensive manual curation and expertise.\u003c/p\u003e\r\n\r\n\u003cp\u003e\u0026nbsp;\u003c/p\u003e\r\n\r\n\u003cp\u003e\u003cstrong\u003e\u003cem\u003eObjective\u003c/em\u003e\u003c/strong\u003e\u003c/p\u003e\r\n\r\n\u003cp\u003eTo address these limitations, we have developed\u0026nbsp;\u003ccode\u003eOMOP2OBO\u003c/code\u003e, the first health system-wide integration and alignment between the Observational Health Data Sciences and Informatics\u0026#39; Observational Medical Outcomes Partnership (\u003ca href=\"https://www.ohdsi.org/data-standardization/the-common-data-model/\"\u003eOMOP\u003c/a\u003e) standardized clinical terminologies and eight OBO biomedical ontologies spanning diseases, phenotypes, anatomical entities, cell types, organisms, chemicals, metabolites, hormones, vaccines, and proteins. To verify that the mappings are both clinically and biologically meaningful, we have performed extensive experiments to verify the\u0026nbsp;\u003ca href=\"https://github.com/callahantiff/OMOP2OBO/wiki/Accuracy\"\u003eaccuracy\u003c/a\u003e,\u0026nbsp;\u003ca href=\"https://github.com/callahantiff/OMOP2OBO/wiki/Generalizability\"\u003egeneralizability\u003c/a\u003e, and\u0026nbsp;\u003ca href=\"https://github.com/callahantiff/OMOP2OBO/wiki/Consistency\"\u003elogical consistency\u003c/a\u003e\u0026nbsp;of each released mapping set.\u003c/p\u003e", "title": "OMOP2OBO"}, "revision_id": 0, "slug": "omop2obo", "updated": "2021-11-20T22:29:51.127764+00:00"}], "ids": ["d5edc788-2914-4e51-8405-9f29894062d5"]}, "id": "5716421", "pids": {"doi": {"client": "datacite", "identifier": "10.5281/zenodo.5716421", "provider": "datacite"}}}, "pids": {"doi": {"client": "datacite", "identifier": "10.5281/zenodo.7067342", "provider": "datacite"}, "oai": {"identifier": "oai:zenodo.org:7067342", "provider": "oai"}}, "revision_id": 11, "stats": {"all_versions": {"data_volume": 5639026571.0, "downloads": 1635, "unique_downloads": 1587, "unique_views": 1002, "views": 1036}, "this_version": {"data_volume": 980092964.0, "downloads": 260, "unique_downloads": 256, "unique_views": 144, "views": 146}}, "status": "published", "swh": {}, "ui": {"access_status": {"description_l10n": "The record and files are publicly accessible.", "embargo_date_l10n": null, "icon": "unlock", "id": "open", "message_class": "", "title_l10n": "Open"}, "additional_descriptions": [{"description": "This work was supported by funding from the National Library of Medicine (T15LM009451) to Lawrence E. Hunter and (T15LM007079) to George Hripcsak.", "type": {"id": "notes", "title_l10n": "Notes"}}], "created_date_l10n_long": "September 10, 2022", "creators": {"affiliations": [[1, "University of Colorado Anschutz Medical Campus; Columbia University Irving Medical Center", null], [2, "University of Colorado Anschutz Medical Campus", null], [3, "National Institutes of Health", null], [4, "Columbia University Irving Medical Center", null], [5, "Georgia State University", null], [6, "University of Pittsburgh School of Medicine", null], [7, "Universit\u00e0 degli Studi di Milano", null], [8, "The Jackson Laboratory for Genomic Medicine", null], [9, "University of Cambridge", null], [10, "Children\u0027s Hospital Colorado", null], [11, "University of Colorado Anschutz School of Medicine", null], [12, "University of Colorado School of Medicine", null], [13, "Semanticly", null], [14, "University of Southern California", null], [15, "Lawrence Berkeley National Laboratory", null], [16, "HealthLinc", null], [17, "University of Pittsburgh", null], [18, "University of Colorado Anschutz Skaggs School of Pharmacy and Pharmaceutical Sciences and School of Medicine", null], [19, "Tufts University", null], [20, "Sema4", null], [21, "Janssen Research and Development", null]], "creators": [{"affiliations": [[1, "University of Colorado Anschutz Medical Campus; Columbia University Irv