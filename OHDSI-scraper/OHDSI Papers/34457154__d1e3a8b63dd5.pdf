<sup>1</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Sun%20Y"[Author]' class="usa-link" aria-describedby="id6"><span class="name western">Yingcheng Sun</span></a><div hidden="hidden" id="id6">
<h3><span class="name western">Yingcheng Sun</span></h3>
<div class="p">
<sup>1</sup>Department of Biomedical Informatics, Columbia University, New York, NY, USA</div>
