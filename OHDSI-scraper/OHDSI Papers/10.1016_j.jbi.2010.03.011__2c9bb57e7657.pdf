<td align="center" rowspan="1" colspan="1">0.92 (0.88-0.95)</td>
<td align="center" rowspan="1" colspan="1">0.16 (0.12-0.20)</td>
<td align="center" rowspan="1" colspan="1">0.19 (0.13-0.22)</td>
<td align="center" rowspan="1" colspan="1">0.23 (0.19-0.26)</td>
