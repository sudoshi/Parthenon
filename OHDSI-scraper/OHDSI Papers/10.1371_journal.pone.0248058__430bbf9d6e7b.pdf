<script id="figure-lightbox-template" type="text/template">
  <div id="figure-lightbox" class="reveal-modal full" data-reveal aria-hidden="true"
       role="dialog">
    <div class="lb-header">
      <h1 id="lb-title"><%= articleTitle %></h1>

      <div id="lb-authors">
              <span>Jungchan Park</span>
              <span>Seung-Hwa Lee</span>
          <a class="more-authors" href="/plosone/article/authors?id=10.1371/journal.pone.0248058">...</a>
          <span>Kwangmo Yang</span>
      </div>

