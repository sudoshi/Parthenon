                                    <pdfaField:valueType>Text</pdfaField:valueType>
                                    <pdfaField:description>Gives the name of an editor.</pdfaField:description>
                                 </rdf:li>
                                 <rdf:li rdf:parseType="Resource">
                                    <pdfaField:name>orcid</pdfaField:name>
                                    <pdfaField:valueType>URI</pdfaField:valueType>
                                    <pdfaField:description>Gives the ORCID of an editor.</pdfaField:description>
                                 </rdf:li>
