                                 <rdf:li rdf:parseType="Resource">
                                    <pdfaField:name>orcid</pdfaField:name>
                                    <pdfaField:valueType>URI</pdfaField:valueType>
                                    <pdfaField:description>Gives the ORCID of an author.</pdfaField:description>
                                 </rdf:li>
                              </rdf:Seq>
                           </pdfaType:field>
                        </rdf:li>
                        <rdf:li rdf:parseType="Resource">
