                        </rdf:li>
                        <rdf:li rdf:parseType="Resource">
                           <pdfaProperty:name>seriesEditorInfo</pdfaProperty:name>
                           <pdfaProperty:valueType>Bag SeriesEditorInformation</pdfaProperty:valueType>
                           <pdfaProperty:category>external</pdfaProperty:category>
                           <pdfaProperty:description>Series editor information: contains the name of each series editor and his/her ORCID identifier.</pdfaProperty:description>
                        </rdf:li>
                     </rdf:Seq>
                  </pdfaSchema:property>
                  <pdfaSchema:valueType>
                     <rdf:Seq>
