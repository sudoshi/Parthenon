torage_class": "L"}}, "order": [], "total_bytes": 316420}, "id": "6525735", "is_draft": false, "is_published": true, "links": {"access": "https://zenodo.org/api/records/6525735/access", "access_grants": "https://zenodo.org/api/records/6525735/access/grants", "access_links": "https://zenodo.org/api/records/6525735/access/links", "access_request": "https://zenodo.org/api/records/6525735/access/request", "access_users": "https://zenodo.org/api/records/6525735/access/users", "archive": "https://zenodo.org/api/records/6525735/files-archive", "archive_media": "https://zenodo.org/api/records/6525735/media-files-archive", "communities": "https://zenodo.org/api/records/6525735/communities", "communities-suggestions": "https://zenodo.org/api/records/6525735/communities-suggestions", "doi": "https://doi.org/10.5281/zenodo.6525735", "draft": "https://zenodo.org/api/records/6525735/draft", "file_modification": "https://zenodo.org/api/records/6525735/file-modification", "files": "https://zenodo.org/api/records/6525735/files", "latest": "https://zenodo.org/api/records/6525735/versions/latest", "latest_html": "https://zenodo.org/records/6525735/latest", "media_files": "https://zenodo.org/api/records/6525735/media-files", "parent": "https://zenodo.org/api/records/6525734", "parent_doi": "https://doi.org/10.5281/zenodo.6525734", "parent_doi_html": "https://zenodo.org/doi/10.5281/zenodo.6525734", "parent_html": "https://zenodo.org/records/6525734", "preview_html": "https://zenodo.org/records/6525735?preview=1", "request_deletion": "https://zenodo.org/api/records/6525735/request-deletion", "requests": "https://zenodo.org/api/records/6525735/requests", "reserve_doi": "https://zenodo.org/api/records/6525735/draft/pids/doi", "self": "https://zenodo.org/api/records/6525735", "self_doi": "https://doi.org/10.5281/zenodo.6525735", "self_doi_html": "https://zenodo.org/doi/10.5281/zenodo.6525735", "self_html": "https://zenodo.org/records/6525735", "self_iiif_manifest": "https://zenodo.org/api/iiif/record:6525735/manifest", "self_iiif_sequence": "https://zenodo.org/api/iiif/record:6525735/sequence/default", "thumbnails": {"10": "https://zenodo.org/api/iiif/record:6525735:RFI%20Executive%20Summary.pdf/full/%5E10,/0/default.jpg", "100": "https://zenodo.org/api/iiif/record:6525735:RFI%20Executive%20Summary.pdf/full/%5E100,/0/default.jpg", "1200": "https://zenodo.org/api/iiif/record:6525735:RFI%20Executive%20Summary.pdf/full/%5E1200,/0/default.jpg", "250": "https://zenodo.org/api/iiif/record:6525735:RFI%20Executive%20Summary.pdf/full/%5E250,/0/default.jpg", "50": "https://zenodo.org/api/iiif/record:6525735:RFI%20Executive%20Summary.pdf/full/%5E50,/0/default.jpg", "750": "https://zenodo.org/api/iiif/record:6525735:RFI%20Executive%20Summary.pdf/full/%5E750,/0/default.jpg"}, "versions": "https://zenodo.org/api/records/6525735/versions"}, "media_files": {"count": 1, "enabled": true, "entries": {"RFI Executive Summary.pdf.ptif": {"access": {"hidden": true}, "ext": "ptif", "id": "26dd19ef-f282-4426-8db5-38607ab93ba9", "key": "RFI Executive Summary.pdf.ptif", "links": {"content": "https://zenodo.org/api/records/6525735/files/RFI%20Executive%20Summary.pdf.ptif/content", "self": "https://zenodo.org/api/records/6525735/files/RFI%20Executive%20Summary.pdf.ptif"}, "metadata": null, "mimetype": "application/octet-stream", "processor": {"source_file_id": "23fae3f8-477c-458a-9dc6-710b426fdffa", "status": "finished", "type": "image-tiles"}, "size": 0, "storage_class": "L"}}, "order": [], "total_bytes": 0}, "metadata": {"additional_descriptions": [{"description": "related to NEI-FDA-ONC Joint Workshop on Promoting Adoption of Ocular Imaging Standards", "type": {"id": "notes", "title": {"de": "Anmerkungen", "en": "Notes"}}}], "creators": [{"affiliations": [{"name": "NEI/NIH"}], "person_or_org": {"family_name": "Kerry Goetz", "identifiers": [{"identifier": "0000-0002-9821-7704", "scheme": "orcid"}], "name": "Kerry Goetz", "type": "personal"}}, {"affiliations": [{"name": "NEI/NIH"}], "person_or_org": {"family_name": "Amberlynn Reed", "name": "Amberlynn Reed", "type": "personal"}}, {"affiliations": [{"name": "NEI/NIH"}], "person_or_org": {"family_name": "Syed Haqqani", "name": "Syed Haqqani", "type": "personal"}}], "description": "\u003cp\u003eClinicians and researchers using ocular imaging have struggled for years to efficiently share files and access pre-processed components of image files. If ocular imaging files and corresponding data could be more easily diffused it would enable care providers to capture and transmit imaging to collaborating eye health professionals, who could aid in interpreting the images and offer treatment guidance. Additionally, broad adoption of a sharing culture would allow greater access to necessary data for development of artificial intelligence techniques to aid in screening for early sign of potentially blinding eye conditions, such as diabetic retinopathy, for which 25% of Medicare Beneficiaries with diabetes do not receive recommended retinal screenings.\u202f\u003c/p\u003e\n\n\u003cp\u003e\u003ca href=\"https://www.dicomstandard.org/about-home\"\u003eDICOM\u0026reg;\u003c/a\u003e, Digital Imaging and Communications in Medicine, is the international standard for all medical images and related information. It defines the formats for images that can be exchanged with the data and quality necessary for clinical use. Currently, meeting these standards is optional and broad DICOM compliance is low for ophthalmic imaging technologies.\u0026nbsp;\u003c/p\u003e\n\n\u003cp\u003eIn early 2022, the National Eye Institute (NEI) issued a Request for Information (RFI) regarding ocular imaging standards. This RFI requested input regarding eight questions. An executive summary of the responses is provided below.\u202f\u202f\u0026nbsp;\u003c/p\u003e", "languages": [{"id": "eng", "title": {"en": "English"}}], "publication_date": "2022-05-06", "publisher": "Zenodo", "related_identifiers": [{"identifier": "https://zenodo.org/record/6917905#.YuIGlHbMKUk", "relation_type": {"id": "issupplementedby", "title": {"de": "Wird erg\u00e4nzt durch", "en": "Is supplemented by"}}, "scheme": "url"}], "resource_type": {"id": "publication-milestone", "title": {"de": "Projektmeilenstein", "en": "Project milestone"}}, "rights": [{"description": {"en": "The Creative Commons Attribution license allows re-distribution and re-use of a licensed work on the condition that the creator is appropriately credited."}, "icon": "cc-by-icon", "id": "cc-by-4.0", "props": {"scheme": "spdx", "url": "https://creativecommons.org/licenses/by/4.0/legalcode"}, "title": {"en": "Creative Commons Attribution 4.0 International"}}], "subjects": [{"subject": "DICOM"}, {"subject": "ocular imaging"}], "title": "NEI Ocular Imaging Standards RFI:  Executive Summary\u202f May 2022", "version": "v1"}, "parent": {"access": {"owned_by": {"user": "158975"}, "settings": {"accept_conditions_text": null, "allow_guest_requests": false, "allow_user_requests": false, "secret_link_expiration": 0}}, "communities": {}, "id": "6525734", "pids": {"doi": {"client": "datacite", "identifier": "10.5281/zenodo.6525734", "provider": "datacite"}}}, "pids": {"doi": {"client": "datacite", "identifier": "10.5281/zenodo.6525735", "provider": "datacite"}, "oai": {"identifier": "oai:zenodo.org:6525735", "provider": "oai"}}, "revision_id": 7, "stats": {"all_versions": {"data_volume": 201243120.0, "downloads": 636, "unique_downloads": 576, "unique_views": 1155, "views": 1220}, "this_version": {"data_volume": 198395340.0, "downloads": 627, "unique_downloads": 567, "unique_views": 1143, "views": 1208}}, "status": "published", "swh": {}, "ui": {"access_status": {"description_l10n": "The record and files are publicly accessible.", "embargo_date_l10n": null, "icon": "unlock", "id": "open", "message_class": "", "title_l10n": "Open"}, "additional_descriptions": [{"description": "related to NEI-FDA-ONC Joint Workshop on Promoting Adoption of Ocular Imaging Standards", "type": {"id": "notes", "title_l10n": "Notes"}}], "conference": {"dates": "May 10, 2022", "title": "NEI-FDA-ONC Joint Workshop on Promoting Adoption of Ocular Imaging Standards", "url": "https://www.nei.nih.gov/about/goals-and-accomplishments/nei-research-initiatives/data-science-and-health-informatics/nei-fda-onc-joint-workshop-promoting-adoption-ocular-imaging-standards"}, "created_date_l10n_long": "May 6, 2022", "creators": {"affiliations": [[1, "NEI/NIH", null]], "creators": [{"affiliations": [[1, "NEI/NIH"]], "person_or_org": {"family_name": "Kerry Goetz", "identifiers": [{"identifier": "0000-0002-9821-7704", "scheme": "orcid"}], "name": "Kerry Goetz", "type": "personal"}}, {"affiliations": [[1, "NEI/NIH"]], "person_or_org": {"family_name": "Amberlynn Reed", "name": "Amberlynn Reed", "type": "personal"}}, {"affiliations": [[1, "NEI/NIH"]], "person_or_org": {"family_name": "Syed Haqqani", "name": "Syed Haqqani", "type": "personal"}}]}, "custom_fields": {"meeting:meeting": {"dates": "May 10, 2022", "title": "NEI-FDA-ONC Joint Workshop on Promoting Adoption of Ocular Imaging Standards", "url": "https://www.nei.nih.gov/about/goals-and-accomplishments/nei-research-initiatives/data-science-and-health-informatics/nei-fda-onc-joint-workshop-promoting-adoption-ocular-imaging-standards"}}, "description_stripped": "Clinicians and researchers using ocular imaging have struggled for years to efficiently share files and access pre-processed components of image files. If ocular imaging files and corresponding data could be more easily diffused it would enable care providers to capture and transmit imaging to collaborating eye health professionals, who could aid in interpreting the images and offer treatment guidance. Additionally, broad adoption of a sharing culture would allow greater access to necessary data for development of artificial intelligence techniques to aid in screening for early sign of potentially blinding eye conditions, such as diabetic retinopathy, for which 25% of Medicare Beneficiaries with diabetes do not receive recommended retinal screenings.\u202f\n\n\nDICOM\u00ae, Digital Imaging and Communications in Medicine, is the international standard for all medical images and related information. It defines the formats for images that can be exchanged with the data and quality necessary for clinical use. Currently, meeting these standards is optional and broad DICOM compliance is low for ophthalmic imaging technologies.\u00a0\n\n\nIn early 2022, the National Eye Institute (NEI) issued a Request for Information (RFI) regarding ocular imaging standards. This RFI requested input regarding eight questions. An executive summary of the responses is provided below.\u202f\u202f\u00a0", "is_draft": false, "languages": [{"id": "eng", "title_l10n": "English"}], "publication_date_l10n_long": "May 6, 2022", "publication_date_l10n_medium": "May 6, 2022", "related_identifiers": [{"identifier": "https://zenodo.org/record/6917905#.YuIGlHbMKUk", "relation_type": {"id": "issupplementedby", "title_l10n": "Is supplemented by"}, "scheme": "url"}], "resource_type": {"id": "publication-milestone", "title_l10n": "Project milestone"}, "rights": [{"description_l10n": "The Creative Commons Attribution license allows re-distribution and re-use of a licensed work on the condition that the creator is appropriately credited.", "icon": "cc-by-icon", "id": "cc-by-4.0", "props": {"scheme": "spdx", "url": "https://creativecommons.org/licenses/by/4.0/legalcode"}, "title_l10n": "Creative Commons Attribution 4.0 International"}], "updated_date_l10n_long": "July 16, 2024", "version": "v1"}, "updated": "2024-07-16T19:26:40.866338+00:00", "versions": {"index": 1, "is_latest": true}}' data-preview='false'>
