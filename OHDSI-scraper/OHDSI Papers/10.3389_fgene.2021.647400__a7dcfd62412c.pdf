ign":1528,"@_valign":1586},{"#text":1522},{"td":2550,":@":2553},[2551],{"#text":2552},"65 y.o.",{"@_align":1528,"@_valign":1586},{"#text":1522},{"td":2556,":@":2558},[2557],{"#text":2334},{"@_align":1528,"@_valign":1586},{"#text":1522},{"td":2561,":@":2564},[2562],{"#text":2563},"60",{"@_align":2252,"@_valign":1586},{"#text":1522},{"td":2567},[],{"#text":1522},{"td":2570},[],{"#text":1522},{"td":2573},[],{"#text":1518},{"#text":1518},{"tr":2577},[2578,2579,2583,2584,2589,2590,2594,2595,2600,2601,2606,2607,2612,2613,2617,2618,2622,2623,2625],{"#text":1522},{"td":2580,":@":2582},[2581],{"#text":1966},{"@_align":1528,"@_valign":1586},{"#text":1522},{"td":2585,":@":2588},[2586],{"#text":2587},"Achromatopsia",{"@_align":1528,"@_valign":1586},{"#text":1522},{"td":2591,":@":2593},[2592],{"#text":2431},{"@_align":1528,"@_valign":1586},{"#text":1522},{"td":2596,":@":2599},[2597],{"#text":2598},"5 y.o.",{"@_align":1528,"@_valign":1586},{"#text":1522},{"td":2602,":@":2605},[2603],{"#text":2604},"Hispanic",{"@_align":1528,"@_valign":1586},{"#text":1522},{"td":2608,":@":2611},[2609],{"#text":2610},"2 m.o.",{"@_align":2252,"@_valign":1586},{"#text":1522},{"td":2614,":@":2616},[2615],{"#text":2401},{"@_align":2252,"@_valign":1586},{"#text":1522},{"td":2619,":@":2621},[2620],{"#text":2460},{"@_align":2252,"@_valign":1586},{"#text":1522},{"td":2624},[],{"#text":1518},{"#text":1518},{"tr":2628},[2629,2630,2634,2635,2639,2640,2644,2645,2650,2651,2655,2656,2661,2662,2667,2668,2673,2674,2676],{"#text":1522},{"td":2631,":@":2633},[2632],{"#text":2049},{"@_align":1528,"@_valign":1586},{"#text":1522},{"td":2636,":@":2638},[2637],{"#text":2587},{"@_align":1528,"@_valign":1586},{"#text":1522},{"td":2641,":@":2643},[2642],{"#text":2322},{"@_align":1528,"@_valign":1586},{"#text":1522},{"td":2646,":@":2649},[2647],{"#text":2648},"13 y.o.",{"@_align":1528,"@_valign":1586},{"#text":1522},{"td":2652,":@":2654},[2653],{"#text":2604},{"@_align":1528,"@_valign":1586},{"#text":1522},{"td":2657,":@":2660},[2658],{"#text":2659},"1 m.o.",{"@_align":2252,"@_valign":1586},{"#text":1522},{"td":2663,":@":2666},[2664],{"#text":2665},"20/150",{"@_align":2252,"@_valign":1586},{"#text":1522},{"td":2669,":@":2672},[2670],{"#text":2671},"20/150-",{"@_align":2252,"@_valign":1586},{"#text":1522},{"td":2675},[],{"#text":1518},{"#text":1518},{"tr":2679},[2680,2681,2685,2686,2690,2691,2695,2696,2701,2702,2706,2707,2712,2713,2718,2719,2724,2725,2727],{"#text":1522},{"td":2682,":@":2684},[2683],{"#text":2126},{"@_align":1528,"@_valign":1586},{"#text":1522},{"td":2687,":@":2689},[2688],{"#text":2541},{"@_align":1528,"@_valign":1586},{"#text":1522},{"td":2692,":@":2694},[2693],{"#text":2431},{"@_align":1528,"@_valign":1586},{"#text":1522},{"td":2697,":@":2700},[2698],{"#text":2699},"67 y.o.",{"@_align":1528,"@_valign":1586},{"#text":1522},{"td":2703,":@":2705},[2704],{"#text":2334},{"@_align":1528,"@_valign":1586},{"#text":1522},{"td":2708,":@":2711},[2709],{"#text":2710},"42",{"@_align":2252,"@_valign":1586},{"#text":1522},{"td":2714,":@":2717},[2715],{"#text":2716},"20/25+2",{"@_align":2252,"@_valign":1586},{"#text":1522},{"td":2720,":@":2723},[2721],{"#text":2722},"20/30-2+2",{"@_align":2252,"@_valign":1586},{"#text":1522},{"td":2726},[],{"#text":1518},{"#text":873},{"#text":879},{"@_frame":2205,"@_rules":2206},{"#text":879},{"table-wrap-foot":2733},[2734,2735,2739,2740,2753],{"#text":873},{"p":2736},[2737],{"#text":2738},"LP, light perception (the ability to perceive the difference between light and dark); BCVA, best corrected visual acuity; RP, retinitis pigmentosa; CRD, cone-rod dystrophy.",{"#text":873},{"fn":2741,":@":2752},[2742,2743,2746,2747,2751],{"#text":1518},{"label":2744},[2745],{"#text":2505},{"#text":1518},{"p":2748},[2749],{"#text":2750},"Born with hearing loss.",{"#text":873},{"@_id":2507},{"#text":879},{"#text":965},{"@_position":2209,"@_id":1492},{"#text":965},{"sec":2758,":@":2900},[2759,2760,2764,2765,2826,2827,2899],{"#text":879},{"title":2761},[2762],{"#text":2763},"Identification of One Known Deep-Intronic Splicing Variant in Two IRD Patients",{"#text":879},{"p":2766},[2767,2769,2776,2778,2783,2785,2788,2790,2794,2796,2799,2800,2806,2808,2814,2816,2819,2821,2825],{"#text":2768},"MEP129 and MEP130 are two affected siblings from the same family and were diagnosed with achromatopsia (",{"xref":2770,":@":2773},[2771],{"#text":2772},"Figures 1A",{"@_rid":2774,"@_ref-type":2775},"fig1","fig",{"#text":2777},",",{"xref":2779,":@":2782},[2780],{"#text":2781},"B",{"@_rid":2774,"@_ref-type":2775},{"#text":2784},"). WGS of patient DNA revealed that they both have two heterozygous variants, c.1148delC and c.1663-1205G>A, in exon 7 and intron 11 of ",{"italic":2786},[2787],{"#text":1972},{"#text":2789},", respectively. Mutation in ",{"italic":2791},[2792],{"#text":2793},"CNGB",{"#text":2795}," is the most common cause of achromatopsia. The coding variant c.1148delC is a recurrent pathogenic mutation found in ",{"italic":2797},[2798],{"#text":1972},{"#text":1120},{"xref":2801,":@":2804},[2802],{"#text":2803},"Kohl et al., 2005",{"@_ref-type":986,"@_rid":2805},"ref15",{"#text":2807},"), while the c.1663-1205G>A intronic splicing variant was previously observed in 18 patients (",{"xref":2809,":@":2812},[2810],{"#text":2811},"Weisschuh et al., 2020",{"@_ref-type":986,"@_rid":2813},"ref44",{"#text":2815},"). Based on the results of ",{"italic":2817},[2818],{"#text":950},{"#text":2820}," splicing assays, the c.1663-1205G>A allele yielded two RT-PCR products; the major product comprised not only exons 14 and 15, but also a pseudo-exon of 34 nucleotides spliced between both canonical exons, while the minor product corresponds to the correctly processed transcript (",{"xref":2822,":@":2824},[2823],{"#text":2811},{"@_ref-type":986,"@_rid":2813},{"#text":1162},{"#text":879},{"fig":2828,":@":2898},[2829,2830,2834,2835,2891,2892,2897],{"#text":873},{"label":2831},[2832],{"#text":2833},"Figure 1",{"#text":873},{"caption":2836},[2837,2838,2890],{"#text":1518},{"p":2839},[2840,2842,2846,2848,2852,2854,2858,2860,2864,2866,2870,2872,2876,2878,2882,2884,2888],{"#text":2841},"Clinical data supported the splicing variants’ deleterious effects based on known genotype-phenotype associations. ",{"bold":2843},[2844],{"#text":2845},"(A)",{"#text":2847}," Fundus autofluorescence (AF) and optical coherence tomography (OCT) of MEP129. ",{"bold":2849},[2850],{"#text":2851},"(B)",{"#text":2853}," OCT and fundus images of MEP130. ",{"bold":2855},[2856],{"#text":2857},"(C)",{"#text":2859}," AF and OCT of MEP337; the right panel shows the pedigree of proband MEP337. Circles represent females; squares represent males. Empty shapes are unaffected relatives. The arrow indicates proband MEP337. M1: c.G11864A; M2: c.8682-654C>G. ",{"bold":2861},[2862],{"#text":2863},"(D)",{"#text":2865}," AF and OCT of DGB289. ",{"bold":2867},[2868],{"#text":2869},"(E)",{"#text":2871}," OCT and fundus images of MEP344. ",{"bold":2873},[2874],{"#text":2875},"(F)",{"#text":2877}," AF and OCT of DGB288. ",{"bold":2879},[2880],{"#text":2881},"(G)",{"#text":2883}," AF and OCT of NEI4320. ",{"bold":2885},[2886],{"#text":2887},"(H)",{"#text":2889}," OCT and fundus images of MEP105.",{"#text":873},{"#text":873},{"graphic":2893,":@":2894},[],{"@_xmlns:xlink":2895,"@_xlink:href":2896},"http://www.w3.org/1999/xlink","fgene-12-647400-g001.tif",{"#text":879},{"@_position":2209,"@_id":2774},{"#text":965},{"@_id":2901},"sec9",{"#text":965},{"sec":2904,":@":3440},[2905,2906,2910,2911,2950,2951,3015,3016,3151,3152,3215,3216,3269,3270,3338,3339,3405,3406,3439],{"#text":879},{"title":2907},[2908],{"#text":2909},"Identification and Validation of Five Novel Deep-Intronic Splicing Variants",{"#text":879},{"p":2912},[2913,2915,2919,2921,2924,2926,2929,2931,2935,2937,2940,2942,2948],{"#text":2914},"Among the five newly identified deep-intronic splicing variants, four were predicted to create both cryptic donor and acceptor sites, and one was predicted to activate a novel cryptic acceptor site while disrupting the original canonical acceptor site (",{"xref":2916,":@":2918},[2917],{"#text":1490},{"@_rid":1492,"@_ref-type":1484},{"#text":2920},"). To further confirm the prediction made by ",{"italic":2922},[2923],{"#text":956},{"#text":2925}," tools and reveal the functional impact of identified candidate variants on mRNA splicing, we performed a functional splicing assay using the ",{"italic":2927},[2928],{"#text":950},{"#text":2930}," RHCglo minigene system (",{"xref":2932,":@":2934},[2933],{"#text":1059},{"@_ref-type":986,"@_rid":1061},{"#text":2936},"). Consistent with the ",{"italic":2938},[2939],{"#text":956},{"#text":2941}," prediction, RT-PCR products indicated that all predicted candidate splicing variants produced new bands with different lengths compared to the wild-type controls (",{"xref":2943,":@":2946},[2944],{"#text":2945},"Figure 2",{"@_rid":2947,"@_ref-type":2775},"fig2",{"#text":2949},"). Detailed information for each mutant allele is described below.",{"#text":879},{"fig":2952,":@":3014},[2953,2954,2957,2958,3008,3009,3013],{"#text":873},{"label":2955},[2956],{"#text":2945},{"#text":873},{"caption":2959},[2960,2961,3007],{"#text":1518},{"p":2962},[2963,2965,2969,2971,2974,2976,2979,2981,2984,2986,2989,2991,2994,2996,2999,3001,3005],{"#text":2964},"A minigene splicing assay reveals variant-induced aberrant splicing. ",{"bold":2966},[2967],{"#text":2968},"(A–E)",{"#text":2970}," Demonstrate the splicing results of variants identified in patients: ",{"bold":2972},[2973],{"#text":2845},{"#text":2975}," MEP337 and DGB289, ",{"bold":2977},[2978],{"#text":2851},{"#text":2980}," MEP344, ",{"bold":2982},[2983],{"#text":2857},{"#text":2985}," DGB288, ",{"bold":2987},[2988],{"#text":2863},{"#text":2990}," NEI4320, and ",{"bold":2992},[2993],{"#text":2869},{"#text":2995}," MEP105. The left panels of ",{"bold":2997},[2998],{"#text":2968},{"#text":3000}," plot the chromosomal positions of mutations as well as those of the cryptic exons and the stop codons generated by each variant; the middle panels show gel electrophoresis of reverse transcription PCR (RT-PCR) products of all tested minigenes. All the gel bands were longer than the control exons and predicted exons as RT-PCR primers were designed to include partial regions (92 bp) of the first and the third exons (the exons before and after the replaceable exon as shown in ",{"xref":3002,":@":3004},[3003],{"#text":1418},{"@_ref-type":1371,"@_rid":1372},{"#text":3006},") in the minigene vector. The diagrams in the right panel, which are not to scale, are provided as a schematic of the variant-induced changes in transcript configuration. WT, splicing results of wild-type control; Var, splicing results of identified variants.",{"#text":873},{"#text":873},{"graphic":3010,":@":3011},[],{"@_xlink:href":3012},"fgene-12-647400-g002.tif",{"#text":879},{"@_position":2209,"@_id":2947},{"#text":879},{"p":3017},[3018,3020,3023,3025,3028,3030,3036,3038,3041,3043,3048,3050,3053,3055,3061,3063,3066,3068,3071,3073,3079,3080,3086,3087,3091,3092,3098,3100,3103,3105,3111,3112,3118,3120,3123,3125,3130,3132,3136,3138,3142,3144,3149],{"#text":3019},"A heterozygous deep-intronic splicing variant (c.8682-654C>G) was found in intron 43 of ",{"italic":3021},[3022],{"#text":1679},{"#text":3024}," in two unrelated patients diagnosed with Usher syndrome type II (Usher II), MEP337 and DGB289. Usher II is primarily caused by mutations in three genes with ",{"italic":3026},[3027],{"#text":1679},{"#text":3029}," most commonly affected. This splicing allele is extremely rare as it has not been observed in population sequencing databases such as gnomAD. SpliceAI predicts the variant to create a novel splice donor site and a novel splice acceptor site upstream the predicted donor site, causing an in-frame insertion of a 129-bp-long cryptic exon. The cryptic exon contains a stop codon downstream of the cryptic acceptor splice site, resulting in the generation of a premature stop codon downstream of amino acid position 2,894 out of a total of 5,202 amino acids in the wild-type protein. There are three annotated functional domains downstream of position 2,894, including a fibronectin III domain, a transmembrane domain, and a PDZ1 domain. In addition, numerous pathogenic mutations have been reported downstream of exon 44 (",{"xref":3031,":@":3034},[3032],{"#text":3033},"McGee et al., 2010",{"@_ref-type":986,"@_rid":3035},"ref100",{"#text":3037},"). Consistent with the prediction, ",{"italic":3039},[3040],{"#text":950},{"#text":3042}," minigene assay showed that constructs containing the c.8682-654C>G variant produced two splicing isoforms (",{"xref":3044,":@":3047},[3045],{"#text":3046},"Figure 2A",{"@_rid":2947,"@_ref-type":2775},{"#text":3049},"). Based on the gel band intensity, we estimated the relative abundance of the two RT-PCR products at 72 and 28%, respectively. The major isoform contains the original exon and a cryptic exon of 129 bp, which exactly matched ",{"italic":3051},[3052],{"#text":956},{"#text":3054}," prediction as confirmed by Sanger sequencing (",{"xref":3056,":@":3059},[3057],{"#text":3058},"Figure 3A",{"@_rid":3060,"@_ref-type":2775},"fig3",{"#text":3062},"). Consistent with the idea that this novel splicing mutation is likely to be the causal mutation in the proband, additional coding mutations have been identified in ",{"italic":3064},[3065],{"#text":1679},{"#text":3067}," in both probands. Patient DGB289 carries a missense pathogenic mutation in the coding region of ",{"italic":3069},[3070],{"#text":1679},{"#text":3072},", c.10073C>T (p.C3358Y), that has been previously reported (",{"xref":3074,":@":3077},[3075],{"#text":3076},"Garcia-Garcia et al., 2011",{"@_ref-type":986,"@_rid":3078},"ref10",{"#text":1048},{"xref":3081,":@":3084},[3082],{"#text":3083},"Le Quesne Stabej et al., 2012",{"@_ref-type":986,"@_rid":3085},"ref18",{"#text":1048},{"xref":3088,":@":3090},[3089],{"#text":1009},{"@_ref-type":986,"@_rid":1011},{"#text":1048},{"xref":3093,":@":3096},[3094],{"#text":3095},"Stone et al., 2017",{"@_ref-type":986,"@_rid":3097},"ref36",{"#text":3099},"). Similarly, in patient MEP337, a previously reported nonsense coding mutation in ",{"italic":3101},[3102],{"#text":1679},{"#text":3104},", c.11864G>A (p.W3955X), has been identified (",{"xref":3106,":@":3109},[3107],{"#text":3108},"Lenarduzzi et al., 2015",{"@_ref-type":986,"@_rid":3110},"ref20",{"#text":1048},{"xref":3113,":@":3116},[3114],{"#text":3115},"Likar et al., 2018",{"@_ref-type":986,"@_rid":3117},"ref22",{"#text":3119},"). The clinical phenotypes of both patients lend support to the pathogenicity of their ",{"italic":3121},[3122],{"#text":1679},{"#text":3124}," mutations. Segregation analysis was performed for MEP337 (",{"xref":3126,":@":3129},[3127],{"#text":3128},"Figure 1C",{"@_rid":2774,"@_ref-type":2775},{"#text":3131},"). The parents and brothers of MEP337 are asymptomatic. The mother of MEP337 is heterozygous of the coding variant, c.11864G>A, while the father carries neither allele identified in MEP337. Consequently, the splicing variant c.8682-654C>G is caused by ",{"italic":3133},[3134],{"#text":3135},"de novo",{"#text":3137}," mutation. Patient MEP337, diagnosed with Usher II, demonstrated decreased night vision and congenital hearing loss of 30% in both ears (",{"xref":3139,":@":3141},[3140],{"#text":3128},{"@_rid":2774,"@_ref-type":2775},{"#text":3143},"). Patient DGB289, who was diagnosed with RP, presented night vision difficulties and a decrease in the visual field (",{"xref":3145,":@":3148},[3146],{"#text":3147},"Figure 1D",{"@_rid":2774,"@_ref-type":2775},{"#text":3150},"). Additionally, this patient has no family history of progressive retinal degeneration.",{"#text":879},{"fig":3153,":@":3214},[3154,3155,3159,3160,3208,3209,3213],{"#text":873},{"label":3156},[3157],{"#text":3158},"Figure 3",{"#text":873},{"caption":3161},[3162,3163,3207],{"#text":1518},{"p":3164},[3165,3167,3170,3173,3175,3178,3181,3183,3186,3189,3191,3194,3197,3199,3202,3205],{"#text":3166},"Cryptic exon sequences of ",{"bold":3168},[3169],{"#text":2845},{"italic":3171},[3172],{"#text":1679},{"#text":3174}," splice variant (chr1:216041166C>G) of MEP337 and DGB289, ",{"bold":3176},[3177],{"#text":2851},{"italic":3179},[3180],{"#text":1844},{"#text":3182}," splice variant (chr3:193362516A>G) of MEP344, ",{"bold":3184},[3185],{"#text":2857},{"italic":3187},[3188],{"#text":1591},{"#text":3190}," splice variant (chr5:90099416A>G) of DGB288, ",{"bold":3192},[3193],{"#text":2863},{"italic":3195},[3196],{"#text":1153},{"#text":3198}," splice variant (chr14:21793624A>G) of NEI4320, and ",{"bold":3200},[3201],{"#text":2869},{"italic":3203},[3204],{"#text":2132},{"#text":3206}," splice variant (chr10:55597057T>G) of MEP105.",{"#text":873},{"#text":873},{"graphic":3210,":@":3211},[],{"@_xlink:href":3212},"fgene-12-647400-g003.tif",{"#text":879},{"@_position":2209,"@_id":3060},{"#text":879},{"p":3217},[3218,3220,3225,3227,3230,3232,3238,3240,3245,3247,3252,3254,3260,3261,3267],{"#text":3219},"MEP344 is a 17-year-old male who was diagnosed with optic atrophy type 1 (",{"xref":3221,":@":3224},[3222],{"#text":3223},"Figure 1E",{"@_rid":2774,"@_ref-type":2775},{"#text":3226},") and has no family history. In this patient, a heterozygous variant (c.1608+622A>G) was found in intron 16 of ",{"italic":3228},[3229],{"#text":1844},{"#text":3231},", mutations in which lead to autosomal dominant optic atrophy (ADOA). This variant is extremely rare in the population as it has not been observed in genome sequencing databases such as gnomAD. The variant was predicted to result in the formation of a novel splicing donor site downstream of exon 16, causing an in-frame-insertion of a new cryptic exon of 54 bp between exons 16 and 17. Exon 16 and exon 17 reside in a GTPase domain (exons 9–16) and a linker region (exons 17–18), respectively, in which more than 25% of reported mutations are localized (",{"xref":3233,":@":3236},[3234],{"#text":3235},"Li et al., 2019",{"@_ref-type":986,"@_rid":3237},"ref200",{"#text":3239},"). Although the insertion of the cryptic exon was not predicted to result in a shift in the open reading frame, an insertion of 18 amino acids right between the essential GTPase domain and the linker region is likely to affect the normal functionality of OPA1 protein. Minigene assay confirmed the SpliceAI prediction, as a transcript of the 54-bp-long cryptic exon was generated (",{"xref":3241,":@":3244},[3242],{"#text":3243},"Figures 2B",{"@_rid":2947,"@_ref-type":2775},{"#text":3246},", ",{"xref":3248,":@":3251},[3249],{"#text":3250},"3B",{"@_rid":3060,"@_ref-type":2775},{"#text":3253},"). Indeed, many pathogenic mutations have been reported around exons 16 and 17 (",{"xref":3255,":@":3258},[3256],{"#text":3257},"Toomes et al., 2001",{"@_ref-type":986,"@_rid":3259},"ref39",{"#text":1048},{"xref":3262,":@":3265},[3263],{"#text":3264},"Le Roux et al., 2019",{"@_ref-type":986,"@_rid":3266},"ref19",{"#text":3268},"). Taken together, this allele is likely to be pathogenic.",{"#text":879},{"p":3271},[3272,3274,3279,3280,3285,3287,3290,3292,3295,3297,3300,3302,3307,3308,3313,3315,3321,3323,3329,3330,3336],{"#text":3273},"Patient DGB288 was diagnosed with Usher II (",{"xref":3275,":@":3278},[3276],{"#text":3277},"Figure 1F",{"@_rid":2774,"@_ref-type":2775},{"#text":1048},{"xref":3281,":@":3284},[3282],{"#text":3283},"Supplementary Figure S3",{"@_ref-type":1371,"@_rid":1372},{"#text":3286},"). In patient DGB288, we identified two heterozygous variants in ",{"italic":3288},[3289],{"#text":1591},{"#text":3291}," (c.5965dupA and c.14661+717A>G). The ",{"italic":3293},[3294],{"#text":1591},{"#text":3296}," splicing variant c.14661+717A>G is a novel variant, and it has not been observed in genome sequencing databases such as gnomAD. It was predicted to contribute to the usage of cryptic donor and acceptor splice sites deep inside intron 71, leading to a non-frameshift insertion of an 84-bp-long cryptic exon downstream of exon 71. Interestingly, the minigene assay result of this splicing candidate did not fully agree with ",{"italic":3298},[3299],{"#text":956},{"#text":3301}," predictions, as a 119-bp-long cryptic exon was included instead (",{"xref":3303,":@":3306},[3304],{"#text":3305},"Figures 2C",{"@_rid":2947,"@_ref-type":2775},{"#text":3246},{"xref":3309,":@":3312},[3310],{"#text":3311},"3C",{"@_rid":3060,"@_ref-type":2775},{"#text":3314},"). The relative abundance of the normal and aberrant transcripts generated by the minigene construct containing the variant was 37 vs. 63%, respectively. A premature stop codon is introduced 17 amino acids downstream of the cryptic exon’s acceptor site as a result of the mutation, presumably triggering nonsense-mediated decay (NMD) or deleting both the GPCR autoproteolysis inducing domain (GAIN) and the transmembrane domains (",{"xref":3316,":@":3319},[3317],{"#text":3318},"Sun et al., 2013",{"@_ref-type":986,"@_rid":3320},"ref400",{"#text":3322},"). Moreover, many pathogenic mutations have been reported downstream of exon 71 (",{"xref":3324,":@":3327},[3325],{"#text":3326},"Richards et al., 2015",{"@_ref-type":986,"@_rid":3328},"ref28",{"#text":1048},{"xref":3331,":@":3334},[3332],{"#text":3333},"Sun et al., 2018",{"@_ref-type":986,"@_rid":3335},"ref37",{"#text":3337},"). Taken together, the c.14661+717A>G variant is a likely pathogenic mutation leading to Usher II. The second mutation observed in the patient (c.5965dupA) is a pathogenic frameshift mutation in the coding region with a very low population frequency of 1.43 × 10.5. It causes an early frameshift (codon position 1,990 out of 6,306 in total), resulting in NMD or a severe truncation of ADGRV1 protein.",{"#text":879},{"p":3340},[3341,3343,3348,3350,3353,3355,3358,3360,3363,3365,3371,3373,3379,3381,3384,3386,3391,3393,3396,3398,3403],{"#text":3342},"Patient NEI4320 was diagnosed with cone-rod dystrophy (",{"xref":3344,":@":3347},[3345],{"#text":3346},"Figure 1G",{"@_rid":2774,"@_ref-type":2775},{"#text":3349},"). WGS identified two heterozygous variants in ",{"italic":3351},[3352],{"#text":1153},{"#text":3354},", a coding variant c.2114A>C in exon 14 and a splicing variant c.2367+82A>G in intron 15. The nonsynonymous coding variant, c.2114A>C, is a novel variant that has not been reported in population databases like gnomAD, and multiple ",{"italic":3356},[3357],{"#text":956},{"#text":3359}," algorithms predicted this variant to have a deleterious effect (CADD rank core = 0.78; VEST3 rank score = 0.91, GERP++ rank score = 0.74). This sequence change replaces a glutamine residue with a proline residue at codon 705 of the RPGRIP1 protein (p.Q705P), which is likely to impact secondary protein structure as there is a large physicochemical difference between the two residues. The intronic splicing variant c.2367+82A>G has not been observed in the genome sequencing database either, and it was predicted to activate a downstream cryptic donor site, leading to an in-frame insertion of 81 bp between exons 15 and 16 that generates a premature stop codon 19 amino acid downstream of the original donor splice site of exon 15. The creation of a premature stop codon results in either NMD of mRNA or the production of a truncated protein that potentially lacks the functionality of normal RPGRIP1 proteins. Previous studies identified many nonsense mutations downstream of exon 16 of ",{"italic":3361},[3362],{"#text":1153},{"#text":3364},", including p.R814X (",{"xref":3366,":@":3369},[3367],{"#text":3368},"Weisschuh et al., 2018",{"@_ref-type":986,"@_rid":3370},"ref43",{"#text":3372},") and p.981X (",{"xref":3374,":@":3377},[3375],{"#text":3376},"Carss et al., 2017",{"@_ref-type":986,"@_rid":3378},"ref300",{"#text":3380},"). Based on ",{"italic":3382},[3383],{"#text":950},{"#text":3385}," minigene assay, the c.2367+82A>G variant produced two bands (",{"xref":3387,":@":3390},[3388],{"#text":3389},"Figure 2D",{"@_rid":2947,"@_ref-type":2775},{"#text":3392},"), with a relative band intensity of 65 and 35%, respectively. The major band caused by this variant was composed of the aberrant transcript of the exon 15 and addition of 81 bp downstream, which exactly matched ",{"italic":3394},[3395],{"#text":956},{"#text":3397}," prediction (",{"xref":3399,":@":3402},[3400],{"#text":3401},"Figure 3D",{"@_rid":3060,"@_ref-type":2775},{"#text":3404},"), while the minor band was identified as the wild-type. Taken together, the c.2367+82A>G variant is a likely pathogenic mutation leading to cone-rod dystrophy.",{"#text":879},{"p":3407},[3408,3410,3413,3415,3420,3421,3426,3428,3431,3433,3438],{"#text":3409},"In patient MEP105, two heterozygous variants were identified (c.1163G>T and c.3998+3023T>G), in exon 12 and intron 30 of PCDH15, respectively. Neither allele has been observed in the genome sequencing databases. The nonsynonymous sequence change caused by the coding variant c.1163G>T replaces a highly conserved leucine residue with a proline at codon 429 of the PCDH15 protein (p.L429P). In addition, multiple ",{"italic":3411},[3412],{"#text":956},{"#text":3414}," algorithms predict this variant to have a deleterious effect (GERP++ rank score = 0.69; CADD rank score = 0.74; VEST3 rank score = 0.72). The splicing variant c.3998+3023T>G was predicted to create a cryptic acceptor site at the mutation site and a donor site 29 bp downstream of the novel acceptor site. The insertion of a 29-bp-long cryptic exon downstream of exon 30 results in a shift in the open reading frame, leading to the generation of a stop codon 98 bp downstream of the canonical acceptor site of exon 31. The premature stop codon production presumably results in NMD or truncated PCDH15 proteins without the transmembrane and cytoplasmic domain. Minigene assay confirmed the SpliceAI prediction, as a transcript of the 29-bp-long cryptic exon was generated (",{"xref":3416,":@":3419},[3417],{"#text":3418},"Figures 2E",{"@_rid":2947,"@_ref-type":2775},{"#text":3246},{"xref":3422,":@":3425},[3423],{"#text":3424},"3E",{"@_rid":3060,"@_ref-type":2775},{"#text":3427},"). Mutations in ",{"italic":3429},[3430],{"#text":2132},{"#text":3432}," have been associated with Usher syndrome type I (Usher I) and non-syndromic hearing loss. Patient MEP105 was diagnosed with Goldman Farve disease and did not present any hearing problem but complained about some decrease in vision and visual fields (",{"xref":3434,":@":3437},[3435],{"#text":3436},"Figure 1H",{"@_rid":2774,"@_ref-type":2775},{"#text":1162},{"#text":965},{"@_id":3441},"sec10",{"#text":968},{"@_id":3444,"@_sec-type":3445},"sec8","results",{"#text":968},{"sec":3448,":@":3609},[3449,3450,3454,3455,3484,3485,3494,3495,3504,3505,3533,3534,3577,3578,3603,3604,3608],{"#text":965},{"title":3451},[3452],{"#text":3453},"Discussion",{"#text":965},{"p":3456},[3457,3459,3462,3464,3467,3469,3472,3474,3477,3479,3482],{"#text":3458},"Deep-intronic splicing variants that alter splicing patterns may affect protein functions and have a remarkable contribution to diseases. To identify missing noncoding variants in unsolved IRD cases, we performed WGS in 571 probands and identified one known and five novel deep-intronic variants in nine probands, representing 1.1% of the cohort. Four novel deep-intronic variants (c.14661+717A>G variant in ",{"italic":3460},[3461],{"#text":1591},{"#text":3463},", c.8682-654C>G variant in ",{"italic":3465},[3466],{"#text":1679},{"#text":3468},", c.1608+622A>G variant in ",{"italic":3470},[3471],{"#text":1844},{"#text":3473},", and c.3998+3023T>G variant in ",{"italic":3475},[3476],{"#text":2132},{"#text":3478},") activate cryptic donor and acceptor splice sites close to the mutation sites and thereby result in cryptic exon inclusion. Variant c.2367+82A>G in ",{"italic":3480},[3481],{"#text":1153},{"#text":3483}," creates a cryptic donor site and leads to exon elongation. All five novel splicing variants are deleterious for the following reasons: (1) they are rare in population; (2) they are predicted to lead to frameshift, premature stop, disruption of functional domains, and likely mRNA NMD; (3) the predictions are further validated using the minigene assay; and (4) clinical phenotype is consistent with the molecular diagnosis. It is worth noting that out of the six deep intronic variants that we identified, only one has been reported previously, suggesting that a significant portion of cryptic splicing mutations remain undiscovered.",{"#text":965},{"p":3486},[3487,3489,3492],{"#text":3488},"Interestingly, the c.8682-654C>G variant in ",{"italic":3490},[3491],{"#text":1679},{"#text":3493}," appears in two unrelated patients with different clinical features. This discrepancy could be explained by the severity of different coding variants carried by the two patients. MEP337, carrying a loss-of-function (LOF) frameshift coding mutation, was born with congenital sensorineural hearing loss and diagnosed with Usher II. DGB289, carrying a nonsynonymous mutation that is likely to be a hypomorph allele, exhibiting a milder phenotype with nonsyndromic RP.",{"#text":965},{"p":3496},[3497,3499,3502],{"#text":3498},"Another interesting case is MEP105. The patient MEP105 was diagnosed with RP, and we identified two novel deleterious alleles (c.1163G>T and c.3998+3023T>G). The coding variant is a missense variant that is likely to cause a partial loss of function of PCDH15. The splicing variant is likely to be a severe allele, as it is likely to cause LOF frameshift, and complete splicing was observed based on minigene assay results. However, mutations in ",{"italic":3500},[3501],{"#text":2132},{"#text":3503}," have so far been associated with Usher I and nonsyndromic recessive hearing loss (DFNB23), but not yet with nonsyndromic vision loss. Interestingly, patient MEP105 is reported to have only retinal dysfunction and a late disease onset at age 42, a much milder disease progression compared to that of USH1F. We hypothesized that the milder phenotype is due to a partial loss of function mutations carried by the patient. However, further investigation is needed as we cannot rule out the possibility that the patient phenotype is due to mutations in other IRD associated genes.",{"#text":965},{"p":3506},[3507,3509,3512,3513,3516,3518,3521,3523,3526,3528,3531],{"#text":3508},"With a cutoff of 0.5, high specificity is achieved with all of the splicing mutations predicted by SpliceAI confirmed by minigene assays. Furthermore, in most cases, the predicted splicing junctions were also confirmed by minigene assay results. However, we did observe one inconsistency between the minigene test and predictions. Comparing the ",{"italic":3510},[3511],{"#text":950},{"#text":958},{"italic":3514},[3515],{"#text":956},{"#text":3517}," results, we observed a shift in the splicing junction in the case of c.14661+717A>G in ",{"italic":3519},[3520],{"#text":1591},{"#text":3522},". This difference might be due to the inaccuracy of either the ",{"italic":3524},[3525],{"#text":956},{"#text":3527}," predictions or the ",{"italic":3529},[3530],{"#text":950},{"#text":3532}," functional assay. Further investigation is needed to resolve the discrepancy.",{"#text":965},{"p":3535},[3536,3538,3541,3543,3546,3548,3551,3553,3556,3558,3561,3563,3566,3568,3571,3573,3576],{"#text":3537},"The prediction scores assigned to splice site disruption seem to positively correlate with the impact of mutations on splicing. Based on the minigene assay results, variant c.1608+622A>G in ",{"italic":3539},[3540],{"#text":1844},{"#text":3542},", and variant c.3998+3,023 T>G in ",{"italic":3544},[3545],{"#text":2132},{"#text":3547}," only generated aberrant splicing, while variant c.14661+717A>G in ",{"italic":3549},[3550],{"#text":1591},{"#text":3552},", variant c.8682-654C>G in ",{"italic":3554},[3555],{"#text":1679},{"#text":3557},", and variant c.2367+82A>G in ",{"italic":3559},[3560],{"#text":1153},{"#text":3562}," produced both normal and aberrant transcript. The variants showing complete abnormal splicing had high prediction scores on both donor and acceptor sites (all of them are ≥0.5), while the ones that presented partial cryptic splicing were predicted to have lower scores for acceptor gain sites (variant c.14661+717A>G in ",{"italic":3564},[3565],{"#text":1591},{"#text":3567}," and variant c.8682-654C>G in ",{"italic":3569},[3570],{"#text":1679},{"#text":3572},") or donor loss sites (variant c.2367+82A>G in ",{"italic":3574},[3575],{"#text":1153},{"#text":1162},{"#text":965},{"p":3579},[3580,3582,3586,3588,3591,3593,3596,3598,3601],{"#text":3581},"With a high cut-off score, a high specificity of cryptic splicing mutation can be achieved. However, it is likely that a significant proportion of deep intronic cryptic splicing mutations was missed with our current cut off. To increase sensitivity, one could lower the threshold. However, as the SpliceAI RNA-seq validation rate and sensitivity are proportional to the prediction score (i.e., 20% at 0.2; 80% at 0.8; ",{"xref":3583,":@":3585},[3584],{"#text":1209},{"@_ref-type":986,"@_rid":1211},{"#text":3587},"), the frequency of false-positives can increase dramatically. One potential way to circumvent this issue is to complement ",{"italic":3589},[3590],{"#text":956},{"#text":3592}," prediction with high-throughput functional splicing assays. In addition, although SpliceAI is quite accurate given the current threshold, improvement on splice site prediction is likely needed, especially for the variants with a lower score than 0.5. Our data and results of other studies alike can be used as positive control training sets for further improvements of predictions made by SpliceAI or other ",{"italic":3594},[3595],{"#text":956},{"#text":3597}," tools. Another limitation of current splicing mutation prediction tools is that they do not predict the ratio of normal and aberrant splice isoforms, which is a critical factor to consider when assessing the strength of the mutant allele. Therefore, further improvement on ",{"italic":3599},[3600],{"#text":956},{"#text":3602}," prediction and high-throughput functional assays might be needed if we would like to enable efficient large-scale examination of intronic variants’ impact on splicing.",{"#text":965},{"p":3605},[3606],{"#text":3607},"In conclusion, the identification of five novel noncoding splicing variants highlights the relevance of discovering hidden deleterious variants in noncoding regions that alter splicing to increasing the genetic diagnostic yield of IRDs. Given that five out of six variants we identified were novel, the contribution of intronic variants, especially those deep within introns, to genetic diseases might be underestimated. Therefore, massively parallel approaches that can effectively characterize splicing-altering sequence variation have great potentials to accelerate the discovery process, facilitating clinical molecular diagnoses by identifying abundant pathogenic non-canonical splicing variants as the cause of human diseases.",{"#text":968},{"@_id":3610,"@_sec-type":3611},"sec11","discussions",{"#text":968},{"sec":3614,":@":3626},[3615,3616,3620,3621,3625],{"#text":965},{"title":3617},[3618],{"#text":3619},"Data Availability Statement",{"#text":965},{"p":3622},[3623],{"#text":3624},"The datasets for this article are not publicly available due to concerns regarding participant/patient anonymity. Requests to access the datasets should be directed to the corresponding author.",{"#text":968},{"@_id":3627},"sec12",{"#text":968},{"sec":3630,":@":3642},[3631,3632,3636,3637,3641],{"#text":965},{"title":3633},[3634],{"#text":3635},"Ethics Statement",{"#text":965},{"p":3638},[3639],{"#text":3640},"The studies involving human participants were reviewed and approved by Baylor College of Medicine. Written informed consent to participate in this study was provided by the participants’ legal guardian/next of kin. Written informed consent was obtained from the individual(s), and minor(s)’ legal guardian/next of kin, for the publication of any potentially identifiable images or data included in this article.",{"#text":968},{"@_id":3643},"sec13",{"#text":968},{"sec":3646,":@":3675},[3647,3648,3652,3653,3657,3658,3674],{"#text":965},{"title":3649},[3650],{"#text":3651},"Author Contributions",{"#text":965},{"p":3654},[3655],{"#text":3656},"XQ and RC designed the study. XQ was responsible for writing, collecting data, analysis, interpretation, and revision of the present article. JW and MW were responsible for data collecting and analysis partly. AI, KJ, DB, KG, and MP were responsible for clinical data collection and analysis. All authors contributed to the writing and revision of the manuscript. The final manuscript was approved by all authors.",{"#text":965},{"sec":3659,":@":3671},[3660,3661,3665,3666,3670],{"#text":879},{"title":3662},[3663],{"#text":3664},"Conflict of Interest",{"#text":879},{"p":3667},[3668],{"#text":3669},"The authors declare that the research was conducted in the absence of any commercial or financial relationships that could be construed as a potential conflict of interest.",{"#text":965},{"@_sec-type":3672,"@_id":3673},"COI-statement","conf1",{"#text":968},{"@_id":3676},"sec14",{"#text":3678},"\n  ",[],[3681,3693,3705,3730,3744,3753,3766],{"title":3682,"order":378,"content":3683},"Data availability statement",[3684,3685,3688,3689,3692],{"#text":965},{"title":3686},[3687],{"#text":3619},{"#text":965},{"p":3690},[3691],{"#text":3624},{"#text":968},{"title":3694,"order":818,"content":3695},"Ethics statement",[3696,3697,3700,3701,3704],{"#text":965},{"title":3698},[3699],{"#text":3635},{"#text":965},{"p":3702},[3703],{"#text":3640},{"#text":968},{"title":3706,"order":822,"content":3707},"Author contributions",[3708,3709,3712,3713,3716,3717,3729],{"#text":965},{"title":3710},[3711],{"#text":3651},{"#text":965},{"p":3714},[3715],{"#text":3656},{"#text":965},{"sec":3718,":@":3728},[3719,3720,3723,3724,3727],{"#text":879},{"title":3721},[3722],{"#text":3664},{"#text":879},{"p":3725},[3726],{"#text":3669},{"#text":965},{"@_sec-type":3672,"@_id":3673},{"#text":968},{"title":3731,"order":832,"content":3732},"Funding",[3733,3734,3743],{"#text":879},{"p":3735},[3736,3737,3741],{"#text":873},{"bold":3738},[3739],{"#text":3740},"Funding.",{"#text":3742}," This work was supported by grants from the National Eye Institute (EY022356, EY018571, and EY002520), EY09076 (DB), Retinal Research Foundation, and NIH shared instrument grant S10OD023469 to RC.",{"#text":965},{"title":3745,"order":477,"content":3746},"Acknowledgments",[3747,3748,3752],{"#text":965},{"p":3749},[3750],{"#text":3751},"We would like to thank the patients and families for their enthusiastic participation. The DNA sample and data for participant NEI4320 described in this manuscript were obtained from the National Eye Institute – National Ophthalmic Genotyping and Phenotyping Network (eyeGENE® – Protocol 06-EI-0236 which has been funded in part from the National Institutes of Health/National Eye Institute, under contract no. HHS-N-260-2007-00001-C). We would also like to thank the eyeGENE® Research Group for their contribution.",{"#text":968},{"title":3754,"order":3755,"content":3756},"Conflict of interest",8,[3757,3758,3761,3762,3765],{"#text":879},{"title":3759},[3760],{"#text":3664},{"#text":879},{"p":3763},[3764],{"#text":3669},{"#text":965},{"title":3767,"order":3768,"content":3769},"Supplementary material",14,[3770,3771,3775,3776,3785,3786,3791],{"#text":965},{"title":3772},[3773],{"#text":3774},"Supplementary Material",{"#text":965},{"p":3777},[3778,3780],{"#text":3779},"The Supplementary Material for this article can be found online at: ",{"ext-link":3781,":@":3784},[3782],{"#text":3783},"https://www.frontiersin.org/articles/10.3389/fgene.2021.647400/full#supplementary-material",{"@_xmlns:xlink":2895,"@_xlink:href":3783,"@_ext-link-type":920},{"#text":965},{"supplementary-material":378