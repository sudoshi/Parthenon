":603,"isCorresponding":363,"isProfilePublic":13,"userId":599,"email":-1,"affiliations":604},424926,"James","A","Poulter","James  A",[605],{"organizationName":606,"countryName":597,"cityName":19,"stateName":19,"zipCode":19},"University of Leeds",{"id":118,"slug":120,"name":119,"shortName":608,"electronicISSN":609,"field":610,"specialtyId":28,"journalSectionPaths":612},"Front. Genet.","1664-8021",{"id":611,"domainId":378},30,[613],{"section":614},{"id":175,"name":176,"slug":177,"specialtyId":615},1872,{"views":617,"downloads":618,"citations":619},11659,2691,61,12,"Volume 12 - 2021",[],{"titleHtml":19,"fullTextHtml":19,"menuHtml":19},[625,630,636,639,645],{"name":626,"fileServerPackageEntryId":19,"fileServerId":627,"fileServerVersionNumber":378,"type":628},"EPUB.epub","647400/epub",{"code":629,"name":629},"EPUB",{"name":631,"fileServerPackageEntryId":632,"fileServerId":633,"fileServerVersionNumber":378,"type":634},"fgene-12-647400.pdf","fgene-12-647400/fgene-12-647400.pdf","647400/pubmed-zip",{"code":635,"name":635},"PDF",{"name":631,"fileServerPackageEntryId":19,"fileServerId":637,"fileServerVersionNumber":378,"type":638},"647400/publishers-proof/pdf",{"code":635,"name":635},{"name":640,"fileServerPackageEntryId":641,"fileServerId":633,"fileServerVersionNumber":378,"type":642},"fgene-12-647400.xml","fgene-12-647400/fgene-12-647400.xml",{"code":643,"name":644},"NLM_XML","XML",{"name":646,"fileServerPackageEntryId":19,"fileServerId":647,"fileServerVersionNumber":378,"type":648},"Provisional PDF.pdf","647400/provisional-pdf",{"code":635,"name":635},"v4",{"title":651,"link":652,"meta":656,"script":798},"Frontiers | Identification of Deep-Intronic Splice Mutations in a Large Cohort of Patients With Inherited Retinal Diseases",[653],{"rel":654,"href":655},"canonical","https://www.frontiersin.org/journals/genetics/articles/10.3389/fgene.2021.647400/full",[657,660,663,665,668,672,675,679,682,685,688,690,692,694,696,698,701,704,706,709,711,713,716,719,722,725,728,732,736,739,742,745,747,750,753,756,759,762,764,767,769,772,775,778,780,783,785,788,790,793,795],{"hid":658,"property":658,"name":658,"content":659},"description","High throughput sequencing technologies have revolutionized the identification of mutations responsible for a diverse set of Mendelian disorders, including i...",{"hid":661,"property":661,"name":662,"content":651},"og:title","title",{"hid":664,"property":664,"name":658,"content":659},"og:description",{"hid":666,"name":666,"content":667},"keywords","Inherited Retinal Dystrophies,WGS,Splicing,Deep-intronic mutations,Minigenes",{"hid":669,"property":669,"name":670,"content":671},"og:site_name","site_name","Frontiers",{"hid":673,"property":673,"name":371,"content":674},"og:image","https://images-provider.frontiersin.org/api/ipx/w=1200&f=png/https://www.frontiersin.org/files/Articles/647400/fgene-12-647400-HTML/image_m/fgene-12-647400-g001.jpg",{"hid":676,"property":676,"name":677,"content":678},"og:type","type","article",{"hid":680,"property":680,"name":681,"content":655},"og:url","url",{"hid":683,"name":683,"content":684},"twitter:card","summary_large_image",{"hid":686,"name":686,"content":687},"citation_volume","12",{"hid":689,"name":689,"content":119},"citation_journal_title",{"hid":691,"name":691,"content":671},"citation_publisher",{"hid":693,"name":693,"content":608},"citation_journal_abbrev",{"hid":695,"name":695,"content":609},"citation_issn",{"hid":697,"name":697,"content":467},"citation_doi",{"hid":699,"name":699,"content":700},"citation_firstpage","647400",{"hid":702,"name":702,"content":703},"citation_language","English",{"hid":705,"name":705,"content":468},"citation_title",{"hid":707,"name":707,"content":708},"citation_keywords","Inherited Retinal Dystrophies; WGS; Splicing; Deep-intronic mutations; Minigenes",{"hid":710,"name":710,"content":473},"citation_abstract",{"hid":712,"name":712,"content":482},"citation_article_type",{"hid":714,"name":714,"content":715},"citation_pdf_url","https://public-pages-files-2025.frontiersin.org/journals/genetics/articles/10.3389/fgene.2021.647400/pdf",{"hid":717,"name":717,"content":718},"citation_xml_url","https://public-pages-files-2025.frontiersin.org/journals/genetics/articles/10.3389/fgene.2021.647400/xml",{"hid":720,"name":720,"content":721},"citation_fulltext_world_readable","yes",{"hid":723,"name":723,"content":724},"citation_online_date","2021/02/11",{"hid":726,"name":726,"content":727},"citation_publication_date","2021/03/02",{"hid":729,"name":730,"content":731},"citation_author_0","citation_author","Qian, Xinye ",{"hid":733,"name":734,"content":735},"citation_author_institution_0","citation_author_institution","Verna and Marrs McLean Department of Biochemistry and Molecular Biology, Baylor College of Medicine, United States",{"hid":737,"name":730,"content":738},"citation_author_1","Wang, Jun ",{"hid":740,"name":734,"content":741},"citation_author_institution_1","Human Genome Sequencing Center, Baylor College of Medicine, United States",{"hid":743,"name":730,"content":744},"citation_author_2","Wang, Meng ",{"hid":746,"name":734,"content":741},"citation_author_institution_2",{"hid":748,"name":730,"content":749},"citation_author_3","Igelman, Austin D. ",{"hid":751,"name":734,"content":752},"citation_author_institution_3","Department of Ophthalmology, Casey Eye Institute, Oregon Health & Science University, United States",{"hid":754,"name":730,"content":755},"citation_author_4","Jones, Kaylie D. ",{"hid":757,"name":734,"content":758},"citation_author_institution_4","Retina Foundation of the Southwest and Department of Ophthalmology, University of Texas Southwestern Medical Center, United States",{"hid":760,"name":730,"content":761},"citation_author_5","Li, Yumei ",{"hid":763,"name":734,"content":741},"citation_author_institution_5",{"hid":765,"name":730,"content":766},"citation_author_6","Wang, Keqing ",{"hid":768,"name":734,"content":741},"citation_author_institution_6",{"hid":770,"name":730,"content":771},"citation_author_7","Goetz, Kerry E. ",{"hid":773,"name":734,"content":774},"citation_author_institution_7","Office of the Director, National Eye Institute/National Institutes of Health, United States",{"hid":776,"name":730,"content":777},"citation_author_8","Birch, David G. ",{"hid":779,"name":734,"content":758},"citation_author_institution_8",{"hid":781,"name":730,"content":782},"citation_author_9","Yang, Paul ",{"hid":784,"name":734,"content":752},"citation_author_institution_9",{"hid":786,"name":730,"content":787},"citation_author_10","Pennesi, Mark E. ",{"hid":789,"name":734,"content":752},"citation_author_institution_10",{"hid":791,"name":730,"content":792},"citation_author_11","Chen, Rui ",{"hid":794,"name":734,"content":741},"citation_author_institution_11",{"hid":796,"name":796,"content":797},"dc.identifier","doi:10.3389/fgene.2021.647400",[799,802,804,806,808],{"src":800,"body":13,"type":801,"async":13},"https://cdnjs.cloudflare.com/polyfill/v3/polyfill.min.js?features=es6","text/javascript",{"src":803,"body":13,"type":801,"async":13},"https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.1/MathJax.js?config=TeX-MML-AM_CHTML",{"src":805,"body":13,"type":801,"async":13},"https://d1bxh8uas1mnw7.cloudfront.net/assets/altmetric_badges-f0bc9b243ff5677d05460c1eb71834ca998946d764eb3bc244ab4b18ba50d21e.js",{"src":807,"body":13,"type":801,"async":13},"https://api.altmetric.com/v1/doi/10.3389/fgene.2021.647400?callback=_altmetric.embed_callback&domain=www.frontiersin.org&key=3c130976ca2b8f2e88f8377633751ba1&cache_until=14-15",{"src":809,"body":13,"type":801,"async":13},"https://crossmark-cdn.crossref.org/widget/v2.0/widget.js",{"journal":811,"doi":467,"articleType":482,"title":813,"authors":815,"onBehalfOf":19,"affiliations":850,"authorNotes":867,"publicationDate":901,"acceptedDate":902,"receivedDate":903,"correctedDate":19,"retractedDate":19,"volume":620,"elocationId":466,"permissions":904,"keywords":924,"relatedArticles":940,"abstractContent":941,"bodyContent":966,"appendixContent":3679,"statements":3680,"references":3792,"otherBackSections":10380,"figures":10381,"toc":11624,"correspondingAuthors":11649},{"title":119,"abbreviation":608,"issn":609,"publisherName":812},"Frontiers Media S.A.",[814],{"#text":468},[816,820,824,827,830,834,836,838,840,843,845,847],{"surname":495,"givenNames":494,"suffix":19,"affiliationsIndexes":817,"isCorresponding":363,"equalContrib":363,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":819,"onBehalfOf":19},[378,818],2,"https://loop.frontiersin.org/people/980761/overview",{"surname":506,"givenNames":505,"suffix":19,"affiliationsIndexes":821,"isCorresponding":363,"equalContrib":363,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":823,"onBehalfOf":19},[818,822],3,"https://loop.frontiersin.org/people/1228686/overview",{"surname":506,"givenNames":514,"suffix":19,"affiliationsIndexes":825,"isCorresponding":363,"equalContrib":363,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":826,"onBehalfOf":19},[818,822],"https://loop.frontiersin.org/people/1185018/overview",{"surname":521,"givenNames":520,"suffix":19,"affiliationsIndexes":828,"isCorresponding":363,"equalContrib":363,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[829],4,{"surname":529,"givenNames":528,"suffix":19,"affiliationsIndexes":831,"isCorresponding":363,"equalContrib":363,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":833,"onBehalfOf":19},[832],5,"https://loop.frontiersin.org/people/1120409/overview",{"surname":536,"givenNames":535,"suffix":19,"affiliationsIndexes":835,"isCorresponding":363,"equalContrib":363,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[818],{"surname":506,"givenNames":541,"suffix":19,"affiliationsIndexes":837,"isCorresponding":363,"equalContrib":363,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[818],{"surname":547,"givenNames":546,"suffix":19,"affiliationsIndexes":839,"isCorresponding":363,"equalContrib":363,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[477],{"surname":555,"givenNames":554,"suffix":19,"affiliationsIndexes":841,"isCorresponding":363,"equalContrib":363,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":842,"onBehalfOf":19},[832],"https://loop.frontiersin.org/people/941917/overview",{"surname":561,"givenNames":560,"suffix":19,"affiliationsIndexes":844,"isCorresponding":363,"equalContrib":363,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[829],{"surname":567,"givenNames":566,"suffix":19,"affiliationsIndexes":846,"isCorresponding":363,"equalContrib":363,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[829],{"surname":574,"givenNames":573,"suffix":19,"affiliationsIndexes":848,"isCorresponding":13,"equalContrib":363,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":849,"onBehalfOf":19},[818,822],"https://loop.frontiersin.org/people/37583/overview",[851,854,856,858,861,864],{"index":378,"baseText":19,"institution":499,"country":500,"address":852,"textContent":853},"Houston, TX","Verna and Marrs McLean Department of Biochemistry and Molecular Biology, Baylor College of Medicine, Houston, TX, United States",{"index":818,"baseText":19,"institution":502,"country":500,"address":852,"textContent":855},"Human Genome Sequencing Center, Baylor College of Medicine, Houston, TX, United States",{"index":822,"baseText":19,"institution":511,"country":500,"address":852,"textContent":857},"Department of Molecular and Human Genetics, Baylor College of Medicine, Houston, TX, United States",{"index":829,"baseText":19,"institution":525,"country":500,"address":859,"textContent":860},"Portland, OR","Department of Ophthalmology, Casey Eye Institute, Oregon Health & Science University, Portland, OR, United States",{"index":832,"baseText":19,"institution":533,"country":500,"address":862,"textContent":863},"Dallas, TX","Retina Foundation of the Southwest and Department of Ophthalmology, University of Texas Southwestern Medical Center, Dallas, TX, United States",{"index":477,"baseText":19,"institution":551,"country":500,"address":865,"textContent":866},"Bethesda, MD","Office of the Director, National Eye Institute/National Institutes of Health, Bethesda, MD, United States",{"editedBy":868,"editedByContent":871,"reviewedBy":880,"reviewedByContent":883,"approvedBy":890,"approvedByContent":891,"correspondence":892,"equalContribution":893,"presentAddress":19,"other":894},[869],{"textContent":870},"Edited by: Dan Koboldt, Nationwide Children’s Hospital, United States",[872,874,878],{"#text":873},"\n          ",{"p":875},[876],{"#text":877}," Dan Koboldt, Nationwide Children’s Hospital, United States",{"#text":879},"\n        ",[881],{"textContent":882},"Reviewed by: James A. Poulter, University of Leeds, United Kingdom; Gabrielle Wheway, University of Southampton, United Kingdom",[884,885,889],{"#text":873},{"p":886},[887],{"#text":888}," James A. Poulter, University of Leeds, United Kingdom; Gabrielle Wheway, University of Southampton, United Kingdom",{"#text":879},[],[],"*Correspondence: Rui Chen, cnVpY2hlbkBiY20uZWR1",[],[895,896,900],{"#text":873},{"p":897},[898],{"#text":899},"This article was submitted to Human and Medical Genomics, a section of the journal Frontiers in Genetics",{"#text":879},"2021-03-02","2021-02-11","2020-12-29",{"copyrightStatement":905,"copyrightYear":906,"copyrightHolder":907,"licenseUrl":908,"licenseText":909},"Copyright © 2021 Qian, Wang, Wang, Igelman, Jones, Li, Wang, Goetz, Birch, Yang, Pennesi and Chen.",2021,"Qian, Wang, Wang, Igelman, Jones, Li, Wang, Goetz, Birch, Yang, Pennesi and Chen","http://creativecommons.org/licenses/by/4.0/",[910,911,923],{"#text":873},{"p":912},[913,915,921],{"#text":914},"This is an open-access article distributed under the terms of the ",{"ext-link":916,":@":919},[917],{"#text":918},"Creative Commons Attribution License (CC BY)",{"@_ext-link-type":920,"@_xlink:href":908},"uri",{"#text":922},". The use, distribution or reproduction in other forums is permitted, provided the original author(s) and the copyright owner(s) are credited and that the original publication in this journal is cited, in accordance with accepted academic practice. No use, distribution or reproduction is permitted which does not comply with these terms.",{"#text":879},[925,928,931,934,937],[926],{"#text":927},"inherited retinal dystrophies",[929],{"#text":930},"whole-genome sequencing",[932],{"#text":933},"splicing",[935],{"#text":936},"deep-intronic mutations",[938],{"#text":939},"minigenes",[],[942,943,964],{"#text":879},{"p":944},[945,947,951,953,957,959,962],{"#text":946},"High throughput sequencing technologies have revolutionized the identification of mutations responsible for a diverse set of Mendelian disorders, including inherited retinal disorders (IRDs). However, the causal mutations remain elusive for a significant proportion of patients. This may be partially due to pathogenic mutations located in non-coding regions, which are largely missed by capture sequencing targeting the coding regions. The advent of whole-genome sequencing (WGS) allows us to systematically detect non-coding variations. However, the interpretation of these variations remains a significant bottleneck. In this study, we investigated the contribution of deep-intronic splice variants to IRDs. WGS was performed for a cohort of 571 IRD patients who lack a confident molecular diagnosis, and potential deep intronic variants that affect proper splicing were identified using SpliceAI. A total of six deleterious deep intronic variants were identified in eight patients. An ",{"italic":948},[949],{"#text":950},"in vitro",{"#text":952}," minigene system was applied to further validate the effect of these variants on the splicing pattern of the associated genes. The prediction scores assigned to splice-site disruption positively correlated with the impact of mutations on splicing, as those with lower prediction scores demonstrated partial splicing. Through this study, we estimated the contribution of deep-intronic splice mutations to unassigned IRD patients and leveraged ",{"italic":954},[955],{"#text":956},"in silico",{"#text":958}," and ",{"italic":960},[961],{"#text":950},{"#text":963}," methods to establish a framework for prioritizing deep intronic variant candidates for mechanistic and functional analyses.",{"#text":965},"\n      ",[967,969,1252,1253,1465,1466,3446,3447,3612,3613,3628,3629,3644,3645,3677],{"#text":968},"\n    ",{"sec":970,":@":1249},[971,972,976,977,1036,1037,1163,1164,1201,1202,1233,1234,1248],{"#text":965},{"title":973},[974],{"#text":975},"Introduction",{"#text":965},{"p":978},[979,981,988,990,996,998,1004,1006,1012,1014,1020,1022,1028,1030,1034],{"#text":980},"Inherited retinal diseases (IRDs) are a diverse set of Mendelian disorders that are clinically heterogeneous and are a major cause of inherited blindness. They are caused by the progressive deterioration or the early loss of cells fundamental for the normal function of the retina (",{"xref":982,":@":985},[983],{"#text":984},"den Hollander et al., 2010",{"@_ref-type":986,"@_rid":987},"bibr","ref6",{"#text":989},"). Decades of studies have illustrated the genetic basis of IRDs by revealing mutations in over 200 genes (",{"xref":991,":@":994},[992],{"#text":993},"Ellingford et al., 2016",{"@_ref-type":986,"@_rid":995},"ref8",{"#text":997},"). Conventional molecular diagnoses focus on coding and flanking canonical splice site sequences that harbor the majority of genetic defects, enabling a molecular diagnosis discovery rate of 66% for Stargardt disease (",{"xref":999,":@":1002},[1000],{"#text":1001},"Zaneveld et al., 2015",{"@_ref-type":986,"@_rid":1003},"ref46",{"#text":1005},"), 60% for retinitis pigmentosa (RP; ",{"xref":1007,":@":1010},[1008],{"#text":1009},"Zhao et al., 2015",{"@_ref-type":986,"@_rid":1011},"ref48",{"#text":1013},"), 75% for Leber congenital amaurosis (LCA; ",{"xref":1015,":@":1018},[1016],{"#text":1017},"Wang et al., 2015",{"@_ref-type":986,"@_rid":1019},"ref42",{"#text":1021},"), and 70% for Usher syndrome (",{"xref":1023,":@":1026},[1024],{"#text":1025},"Jiang et al., 2015",{"@_ref-type":986,"@_rid":1027},"ref13",{"#text":1029},"). Despite that the applications of next-generation sequencing (NGS) for molecular diagnostics increasing the diagnostic yield for individuals with IRDs to 70% (",{"xref":1031,":@":1033},[1032],{"#text":993},{"@_ref-type":986,"@_rid":995},{"#text":1035},"), 30% of patients with a clinical diagnosis of IRD still have no causal mutation identified. The remaining unsolved cases could be attributed to various reasons such as (1) variants in known retinal disease genes that are missed by sequencing or not interpreted as pathogenic, (2) variants in genes have not yet been associated with retinal phenotypes, or (3) novel genetic mechanisms that have not been linked to Mendelian disease. In this study, we evaluated the contribution of deep-intronic splicing variants in known retinal disease genes in unsolved IRD cases.",{"#text":965},{"p":1038},[1039,1041,1047,1049,1055,1056,1062,1063,1069,1070,1076,1077,1083,1084,1090,1092,1098,1100,1106,1107,1113,1115,1119,1121,1127,1128,1134,1135,1141,1142,1148,1150,1154,1155,1161],{"#text":1040},"Precise pre-mRNA splicing is essential for appropriate protein translation, and defective splicing has been increasingly recognized as disease-causing (",{"xref":1042,":@":1045},[1043],{"#text":1044},"Krawczak et al., 2007",{"@_ref-type":986,"@_rid":1046},"ref17",{"#text":1048},"; ",{"xref":1050,":@":1053},[1051],{"#text":1052},"Padgett, 2012",{"@_ref-type":986,"@_rid":1054},"ref24",{"#text":1048},{"xref":1057,":@":1060},[1058],{"#text":1059},"Singh and Cooper, 2012",{"@_ref-type":986,"@_rid":1061},"ref31",{"#text":1048},{"xref":1064,":@":1067},[1065],{"#text":1066},"Pedrotti and Cooper, 2014",{"@_ref-type":986,"@_rid":1068},"ref25",{"#text":1048},{"xref":1071,":@":1074},[1072],{"#text":1073},"Sterne-Weiler and Sanford, 2014",{"@_ref-type":986,"@_rid":1075},"ref35",{"#text":1048},{"xref":1078,":@":1081},[1079],{"#text":1080},"Chabot and Shkreta, 2016",{"@_ref-type":986,"@_rid":1082},"ref4",{"#text":1048},{"xref":1085,":@":1088},[1086],{"#text":1087},"Scotti and Swanson, 2016",{"@_ref-type":986,"@_rid":1089},"ref30",{"#text":1091},"). Predicting the impact of splicing-altering variants is essential to understanding human diseases, as mutations that affect pre-mRNA splicing contribute to at least 15% of disease-causing mutations (",{"xref":1093,":@":1096},[1094],{"#text":1095},"Krawczak et al., 1992",{"@_ref-type":986,"@_rid":1097},"ref16",{"#text":1099},") and, in some genes, up to 50% of all mutations described in some genes (",{"xref":1101,":@":1104},[1102],{"#text":1103},"Teraoka et al., 1999",{"@_ref-type":986,"@_rid":1105},"ref38",{"#text":1048},{"xref":1108,":@":1111},[1109],{"#text":1110},"Ars et al., 2000",{"@_ref-type":986,"@_rid":1112},"ref2",{"#text":1114},"). Due to the size of intronic regions, identifying deep intronic variants that affect splicing is challenging. The recent applications of whole-genome sequencing (WGS) to clinical screening studies enable the investigation of noncoding variation and identification of pathogenic deep intronic variants that lie >100 bp away from the nearest canonical splice sites in several IRD genes, such as ",{"italic":1116},[1117],{"#text":1118},"ABCA4",{"#text":1120}," (",{"xref":1122,":@":1125},[1123],{"#text":1124},"Albert et al., 2018",{"@_ref-type":986,"@_rid":1126},"ref1",{"#text":1048},{"xref":1129,":@":1132},[1130],{"#text":1131},"Fadaie et al., 2019",{"@_ref-type":986,"@_rid":1133},"ref9",{"#text":1048},{"xref":1136,":@":1139},[1137],{"#text":1138},"Nassisi et al., 2019",{"@_ref-type":986,"@_rid":1140},"ref23",{"#text":1048},{"xref":1143,":@":1146},[1144],{"#text":1145},"Sangermano et al., 2019",{"@_ref-type":986,"@_rid":1147},"ref29",{"#text":1149},") and ",{"italic":1151},[1152],{"#text":1153},"RPGRIP1",{"#text":1120},{"xref":1156,":@":1159},[1157],{"#text":1158},"Jamshidi et al., 2019",{"@_ref-type":986,"@_rid":1160},"ref12",{"#text":1162},").",{"#text":965},{"p":1165},[1166,1168,1171,1173,1179,1180,1186,1187,1193,1194,1200],{"#text":1167},"To identify disease-causing deep intronic mutations and investigate their effects on splicing, we need to combine sequencing of intronic or whole genomic regions with approaches that enable the assessment of a variant’s effect on mRNA transcript. The ideal method to determine how a variant affects splicing is to perform reverse transcription PCR (RT-PCR) on transcripts affected by the variant using extracted RNA from the affected tissue of patients. However, direct RNA analyses on patient biopsy materials are greatly limited, especially in the case of IRDs, where it is not practical to biopsy retinal tissues. One alternative to circumvent these obstacles is to use ",{"italic":1169},[1170],{"#text":950},{"#text":1172}," minigenes, which directly determine whether single nucleotide polymorphisms (SNPs) disrupt splicing regulation. Many previous studies have validated the minigene assay as a viable approach to evaluate splicing alterations (",{"xref":1174,":@":1177},[1175],{"#text":1176},"Spickett et al., 2016",{"@_ref-type":986,"@_rid":1178},"ref34",{"#text":1048},{"xref":1181,":@":1184},[1182],{"#text":1183},"Zernant et al., 2018",{"@_ref-type":986,"@_rid":1185},"ref47",{"#text":1048},{"xref":1188,":@":1191},[1189],{"#text":1190},"Bauwens et al., 2019",{"@_ref-type":986,"@_rid":1192},"ref3",{"#text":1048},{"xref":1195,":@":1198},[1196],{"#text":1197},"Toulis et al., 2020",{"@_ref-type":986,"@_rid":1199},"ref40",{"#text":1162},{"#text":965},{"p":1203},[1204,1206,1212,1214,1220,1222,1226,1228,1231],{"#text":1205},"In recent years, the development of a new computational tool based on the deep-learning network, SpliceAI, has greatly improved our ability to predict cryptic splice variants. SpliceAI is different from previous bioinformatic approaches that focused on shorter nucleotide windows within or close to exon-intron junctions. Instead, it uses a wider window (up to 10 k base pairs) to predict splice junctions (",{"xref":1207,":@":1210},[1208],{"#text":1209},"Jaganathan et al., 2019",{"@_ref-type":986,"@_rid":1211},"ref11",{"#text":1213},"). It outperforms previous tools in sensitivity and specificity (",{"xref":1215,":@":1218},[1216],{"#text":1217},"Wai et al., 2020",{"@_ref-type":986,"@_rid":1219},"ref41",{"#text":1221},"). However, despite a dramatically improved performance, there is significant room for improvement. For example, with a score cutoff ≥0.5, SpliceAI has a sensitivity of 71% when the variant is near exons, but the sensitivity drops to 41% with an unknown specificity when the variant is in the deep intronic regions (",{"xref":1223,":@":1225},[1224],{"#text":1209},{"@_ref-type":986,"@_rid":1211},{"#text":1227},"). To overcome this challenge, we supplemented SpliceAI predictions with ",{"italic":1229},[1230],{"#text":950},{"#text":1232}," functional assays to identify and validate putative deep-intronic splicing variants.",{"#text":965},{"p":1235},[1236,1238,1241,1243,1246],{"#text":1237},"In this study, we focused on the contribution of deep-intronic variants that disrupt splicing to diseases of 571 patients diagnosed with IRDs but had no molecular diagnosis by conventional clinical molecular diagnostic approaches, which provide information restricted to the protein-coding exons and exon-intron boundaries. We leveraged the ",{"italic":1239},[1240],{"#text":956},{"#text":1242}," SpliceAI prediction on variant-induced splicing alterations and an ",{"italic":1244},[1245],{"#text":950},{"#text":1247}," minigene system to validate the predictions made on splicing alterations. All patient variants that we identified based on our prioritization strategy demonstrated RNA splicing patterns that deviate from wild-type controls, indicating the deleterious effects of identified variants.",{"#text":968},{"@_id":1250,"@_sec-type":1251},"sec1","intro",{"#text":968},{"sec":1254,":@":1462},[1255,1256,1260,1261,1276,1277,1353,1354,1396,1397,1433,1434,1461],{"#text":965},{"title":1257},[1258],{"#text":1259},"Materials And Methods",{"#text":965},{"sec":1262,":@":1274},[1263,1264,1268,1269,1273],{"#text":879},{"title":1265},[1266],{"#text":1267},"Clinical Diagnosis and Patient Recruitment",{"#text":879},{"p":1270},[1271],{"#text":1272},"All probands discussed herein were clinically diagnosed with retinal diseases following a thorough ophthalmologic examination by a qualified collaborating ophthalmologist. This study was approved by the institutional ethics boards at each affiliated institution and adhered to the tenets of the declaration of Helsinki. Before blood collection, all probands and family members provided written informed consent for DNA analysis and received genetic counseling in accordance with guidelines. DNA samples from patients and available relatives were obtained using the Qiagen blood genomic DNA extraction kit (Qiagen, Hilden, Germany).",{"#text":965},{"@_id":1275},"sec3",{"#text":965},{"sec":1278,":@":1351},[1279,1280,1284,1285,1350],{"#text":879},{"title":1281},[1282],{"#text":1283},"Variant Annotation and Variant Prioritization for Splicing Functional Validation",{"#text":879},{"p":1286},[1287,1289,1295,1297,1303,1305,1311,1313,1319,1320,1326,1327,1333,1335,1341,1342,1348],{"#text":1288},"All patients in our cohort first underwent panel testing to identify disease-causing mutations. For the ones who lack a confident molecular diagnosis, we assigned them as “unsolved” and proceed to further in-depth analyses of these patients. All patient DNAs which underwent WGS were further studied at the Human Genome Sequencing Center, Baylor College of Medicine. WGS data were processed using a pipeline modified from our previous WES data analysis pipeline (",{"xref":1290,":@":1293},[1291],{"#text":1292},"Soens et al., 2016",{"@_ref-type":986,"@_rid":1294},"ref33",{"#text":1296},"). Briefly, NGS sequencing reads were aligned to the human genome assembly (hg19) with BWA (",{"xref":1298,":@":1301},[1299],{"#text":1300},"Li and Durbin, 2009",{"@_ref-type":986,"@_rid":1302},"ref21",{"#text":1304},"). Single nucleotide variants/small insertion-deletion variants (SNVs/INDELs) were identified using GATK 4, while structure variants/copy number variants (SVs/CNVs) were identified using CNVnator v0.3, Delly v0.7.8, Lumpy 0.2.13, and Manta 1.2.2. A population frequency threshold of 0.5% was used to filter out common variants that occur too frequently to be the cause of rare IRDs. SNVs/INDELs that were mapped to the coding region were annotated with ANNOVAR and searched against the dbNSFP 3.5a database. The conservation of the remaining variants was estimated based on phastCons.hg19.100way downloaded from UCSC Genome Browser (",{"xref":1306,":@":1309},[1307],{"#text":1308},"Pollard et al., 2010",{"@_ref-type":986,"@_rid":1310},"ref26",{"#text":1312},"). The effect of coding variants was predicted using CADD v1.3 (",{"xref":1314,":@":1317},[1315],{"#text":1316},"Kircher et al., 2014",{"@_ref-type":986,"@_rid":1318},"ref14",{"#text":1048},{"xref":1321,":@":1324},[1322],{"#text":1323},"Xu et al., 2017",{"@_ref-type":986,"@_rid":1325},"ref45",{"#text":1048},{"xref":1328,":@":1331},[1329],{"#text":1330},"Rentzsch et al., 2019",{"@_ref-type":986,"@_rid":1332},"ref27",{"#text":1334},"). SVs/CNVs were annotated to the RefSeq gene database and filtered by svtyper 0.7.0 (score cutoff 100; ",{"xref":1336,":@":1339},[1337],{"#text":1338},"Chiang et al., 2015",{"@_ref-type":986,"@_rid":1340},"ref5",{"#text":1048},{"xref":1343,":@":1346},[1344],{"#text":1345},"Ebler et al., 2017",{"@_ref-type":986,"@_rid":1347},"ref7",{"#text":1349},"). Raw bam files that contained candidate SVs/CNVs were checked manually through IGV to rule out potential false-positive calls from mapping errors and sequencing errors.",{"#text":965},{"@_id":1352},"sec4",{"#text":965},{"sec":1355,":@":1394},[1356,1357,1361,1362,1393],{"#text":879},{"title":1358},[1359],{"#text":1360},"Variant Prioritization Strategy for Splicing Functional Validation",{"#text":879},{"p":1363},[1364,1366,1373,1375,1379,1381,1384,1386,1391],{"#text":1365},"Our scheme for variant prioritization for splicing functional validation was as follows (",{"xref":1367,":@":1370},[1368],{"#text":1369},"Supplementary Figure S1",{"@_ref-type":1371,"@_rid":1372},"supplementary-material","SM1",{"#text":1374},"). Starting with single-nucleotide variant (SNVs) captured by WGS from all 571 unsolved IRD patients, we filtered and annotated genomic alterations with a custom pipeline and predicted the effects of intronic variants on splicing using Splice AI (",{"xref":1376,":@":1378},[1377],{"#text":1209},{"@_ref-type":986,"@_rid":1211},{"#text":1380},"). SpliceAI (spliceai-1.2.1) was run on the variants passing the allele frequency filtering. The ",{"italic":1382},[1383],{"#text":956},{"#text":1385}," splicing variant predictor SpliceAI assigns a score to each variant, providing predictions of how the variant affects splicing. The score value lies between the range of 0 and 1, and the higher the score, the more confident we are that the candidate variant may affect splicing. The candidate splicing variants were restricted to those found in previously reported IRD genes and were selected with a SpliceAI prediction score cutoff of 0.5 (",{"xref":1387,":@":1390},[1388],{"#text":1389},"Supplementary Table S1",{"@_ref-type":1371,"@_rid":1372},{"#text":1392},"). Then variants were analyzed based on genes’ inheritance patterns. If the detected splicing variant is on IRD genes that are associated with dominant diseases or are X-linked hemizygous, only one hit of the splicing variant was considered to be sufficient. The variants on genes that are associated with recessive diseases require one more allele that is either in the coding region or also affects splicing in addition to the detected splicing variant. The candidates were further filtered by their distance from the exon-intron junctions (>10 bp) to eliminate any variants that are too close to the canonical splice sites, leaving only the deep-intronic candidate splicing variants.",{"#text":965},{"@_id":1395},"sec5",{"#text":965},{"sec":1398,":@":1431},[1399,1400,1404,1405,1430],{"#text":879},{"title":1401},[1402],{"#text":1403},"Minigene Molecular Cloning, Transfection, and RT-PCR",{"#text":879},{"p":1406},[1407,1409,1413,1415,1420,1422,1428],{"#text":1408},"Next, to assess the effects on splicing of the prioritized variants, we used an established minigene reporter assay called the RHCglo minigene (",{"xref":1410,":@":1412},[1411],{"#text":1059},{"@_ref-type":986,"@_rid":1061},{"#text":1414},"). A genomic region from each patient, consisting of the exon closest to the candidate splicing variant (the test exon), the predicted cryptic exon and between approximately 150 base pairs of surrounding introns, was PCR-amplified (",{"xref":1416,":@":1419},[1417],{"#text":1418},"Supplementary Figure S2",{"@_ref-type":1371,"@_rid":1372},{"#text":1421},"). A wild-type (WT) amplicon and a variant (Var) amplicon were obtained by using heterozygous patient DNA as a template, or a wild-type sequence was amplified from control placenta DNA when the patient was homozygous for a variant. The PCR products obtained were cloned into the RHCglo vector. For the patients who have more than one mutation in the PCR-amplified region based on Sanger sequencing results, site-directed mutagenesis was performed using the wild-type-amplicon-containing vector as the template. The impact of splicing variants was examined by transfecting plasmids into HEK293 cells, followed by an RT-PCR assay as previously described (",{"xref":1423,":@":1426},[1424],{"#text":1425},"Soens et al., 2017",{"@_ref-type":986,"@_rid":1427},"ref32",{"#text":1429},"). The intensities of DNA bands were quantitated using ImageJ Gel Analysis program.",{"#text":965},{"@_id":1432},"sec6",{"#text":965},{"sec":1435,":@":1459},[1436,1437,1441,1442,1458],{"#text":879},{"title":1438},[1439],{"#text":1440},"Sanger Sequencing",{"#text":879},{"p":1443},[1444,1446,1450,1452,1456],{"#text":1445},"Sequencing was performed as previously described (",{"xref":1447,":@":1449},[1448],{"#text":1292},{"@_ref-type":986,"@_rid":1294},{"#text":1451},"), and primer designs are described in ",{"xref":1453,":@":1455},[1454],{"#text":1389},{"@_ref-type":1371,"@_rid":1372},{"#text":1457},". Sanger sequencing was performed to confirm (1) proper variant segregation within patients’ family, (2) the authenticity of variants identified by NGS, and (3) the sequence of gel-extracted RT-PCR bands.",{"#text":965},{"@_id":1460},"sec7",{"#text":968},{"@_id":1463,"@_sec-type":1464},"sec2","materials|methods",{"#text":968},{"sec":1467,":@":3443},[1468,1469,1473,1474,1495,1496,2210,2211,2756,2757,2902,2903,3442],{"#text":965},{"title":1470},[1471],{"#text":1472},"Results",{"#text":965},{"p":1475},[1476,1478,1485,1487,1493],{"#text":1477},"To assess the prevalence of deep-intronic splicing mutations in patients with IRD, we analyzed the WGS data from a cohort of 571 IRD patients whose mutations have not been identified by panel testing. As described in the Materials and Methods section, six deleterious deep-intronic variants (",{"xref":1479,":@":1482},[1480],{"#text":1481},"Table 1",{"@_rid":1483,"@_ref-type":1484},"tab1","table",{"#text":1486},") were identified in eight probands (",{"xref":1488,":@":1491},[1489],{"#text":1490},"Table 2",{"@_rid":1492,"@_ref-type":1484},"tab2",{"#text":1494},"). One variant has been previously reported, and five are novel mutations in regions beyond 50 bp of the exon-intron boundary in known IRD genes.",{"#text":965},{"table-wrap":1497,":@":2208},[1498,1499,1502,1503,1511,1512,2207],{"#text":879},{"label":1500},[1501],{"#text":1481},{"#text":879},{"caption":1504},[1505,1506,1510],{"#text":873},{"p":1507},[1508],{"#text":1509},"Patient variant information.",{"#text":879}