<td rowspan="1" colspan="1">Total expression count, where clause expression depth</td>
</tr>
<tr>
<td rowspan="1" colspan="1">Literals</td>
<td rowspan="1" colspan="1">Explicit values, codes, and quantities</td>
<td rowspan="1" colspan="1">
<strong>
<kbd>23</kbd>
</strong>, <strong><kbd>5</kbd><kbd>months,</kbd></strong> or <strong><kbd>0.5 mg/dL</kbd></strong>
</td>
</tr>
<tr>
<td rowspan="1" colspan="1">Logical</td>
<td rowspan="1" colspan="1">Boolean logical operators</td>
<td rowspan="1" colspan="1">
<strong>
<kbd>and</kbd>
</strong> or <strong><kbd>not</kbd></strong>
</td>
</tr>
<tr>
<td rowspan="1" colspan="1">Temporal</td>
<td rowspan="1" colspan="1">Operators relating to dates and times</td>
<td rowspan="1" colspan="1">
<strong>
<kbd>before</kbd>
</strong>, <strong><kbd>starts,</kbd></strong> or <strong><kbd>overlaps</kbd></strong>
</td>
</tr>
