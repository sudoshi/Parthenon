    <div class="tab-container">
        
            <div id="cite-apa" class="tab selected" role="tabpanel" aria-labelledby="tab-0" tabindex="-1" aria-hidden="true">
                <div class="rendering rendering_researchoutput  rendering_researchoutput_apa rendering_contributiontojournal rendering_apa rendering_contributiontojournal_apa">Fedirko, V., Romieu, I., Aleksandrova, K., Pischon, T., Trichopoulos, D., Peeters, P. H., Romaguera-Bosch, D., Bueno-de-Mesquita, H. B., Dahm, C. C., Overvad, K., Chirlaque, M.-D., Johansen, C., Bidstrup, P. E. H., Dalton, S. O., Gunter, M. J., Wark, P. A., Norat, T., Halkjaer, J., Tjønneland, A., ... Jenab, M. (2014). <a rel="ContributionToJournal" href="https://vbn.aau.dk/da/publications/pre-diagnostic-anthropometry-and-survival-after-colorectal-cancer/" class="link"><span>Pre-diagnostic anthropometry and survival after colorectal cancer diagnosis in Western European populations</span></a>. <a rel="Journal" href="#" class="link"><span><em>International Journal of Cancer</em></span></a>, <em>135</em>(8), 1949-1960. <a onclick="window.open(this.href, '_blank','noopener,noreferrer'); return false;" href="https://doi.org/10.1002/ijc.28841" class="link"><span>https://doi.org/10.1002/ijc.28841</span></a></div>
            </div>
        
            <div id="cite-author" class="tab " role="tabpanel" aria-labelledby="tab-1" tabindex="-1" aria-hidden="true">
                <div class="rendering rendering_researchoutput  rendering_researchoutput_author rendering_contributiontojournal rendering_author rendering_contributiontojournal_author">Fedirko, Veronika ; Romieu, Isabelle ; Aleksandrova, Krasimira et al. / <a rel="ContributionToJournal" href="https://vbn.aau.dk/da/publications/pre-diagnostic-anthropometry-and-survival-after-colorectal-cancer/" class="link"><span><strong>Pre-diagnostic anthropometry and survival after colorectal cancer diagnosis in Western European populations</strong></span></a>. I: <a rel="Journal" href="#" class="link"><span>International Journal of Cancer</span></a>. 2014 ; Bind 135, Nr. 8. s. 1949-1960.</div>
            </div>
        
            <div id="cite-BIBTEX" class="tab " role="tabpanel" aria-labelledby="tab-2" tabindex="-1" aria-hidden="true">
                <div class="rendering rendering_researchoutput  rendering_researchoutput_bibtex rendering_contributiontojournal rendering_bibtex rendering_contributiontojournal_bibtex"><div>@article{4991529991ee401a86693407baef7fca,</div><div>  title     = "Pre-diagnostic anthropometry and survival after colorectal cancer diagnosis in Western European populations",</div><div>  abstract  = "General and abdominal adiposity are associated with a high risk of developing colorectal cancer (CRC), but the role of these exposures on cancer survival has been less studied. The association between pre-diagnostic anthropometric characteristics and CRC-specific and all-cause death was examined among 3,924 men and women diagnosed with CRC between 1992 and 2009 in the European Prospective Investigation into Cancer and Nutrition (EPIC) cohort. Multivariable Cox proportional hazards models were used to calculate hazard ratios (HRs) and corresponding 95\% confidence intervals (CIs). Over a mean follow-up period of 49 months, 1,309 deaths occurred of which 1,043 (79.7\%) were due to CRC. In multivariable analysis, pre-diagnostic BMI ≥30 kg/m(2) was associated with a high risk for CRC-specific (HR = 1.26, 95\% CI = 1.04-1.52) and all-cause (HR = 1.32, 95\% CI = 1.12-1.56) death relative to BMI &lt;25 kg/m(2) . Every 5 kg/m(2) increase in BMI was associated with a high risk for CRC-specific (HR = 1.10, 95\% CI = 1.02-1.19) and all-cause death (HR = 1.12, 95\% CI = 1.05-1.20); and every 10 cm increase in waist circumference was associated with a high risk for CRC-specific (HR = 1.09, 95\% CI = 1.02-1.16) and all-cause death (HR = 1.11, 95\% CI = 1.05-1.18). Similar associations were observed for waist-to-hip and waist-to-height ratios. Height was not associated with CRC-specific or all-cause death. Associations tended to be stronger among men than in women. Possible interactions by age at diagnosis, cancer stage, tumour location, and hormone replacement therapy use among postmenopausal women were noted. Pre-diagnostic general and abdominal adiposity are associated with lower survival after CRC diagnosis.",</div><div>  author    = "Veronika Fedirko and Isabelle Romieu and Krasimira Aleksandrova and Tobias Pischon and Dimitrios Trichopoulos and Peeters, \{Petra H\} and Dora Romaguera-Bosch and Bueno-de-Mesquita, \{H Bas\} and Dahm, \{Christina C\} and Kim Overvad and Maria-Dolores Chirlaque and Christoffer Johansen and Bidstrup, \{Pernille Envold Hansen\} and Dalton, \{Susanne O\} and Gunter, \{Marc J\} and Wark, \{Petra A\} and Teresa Norat and Jytte Halkjaer and Anne Tj{\o}nneland and Dik, \{Vincent K\} and Siersema, \{Peter D\} and Marie-Christine Boutron-Ruault and Laure Dossus and Nadia Bastide and Tilman K{\"u}hn and Rudolf Kaaks and Heiner Boeing and Antonia Trichopoulou and Eleni Klinaki and Michalis Katsoulis and Valeria Pala and Salvatore Panico and Rosario Tumino and Domenico Palli and Paolo Vineis and Elisabete Weiderpass and Guri Skeie and Gonz{\'a}lez, \{Carlos A\} and Mar{\'i}a-Jos{\'e} S{\'a}nchez and Aurelio Barricarte and Pilar Amiano and Quiros, \{J Ramon\} and Jonas Manjer and Karin Jirstr{\"o}m and Ingrid Ljuslinder and Richard Palmqvist and Kay-Tee Khaw and Nick Wareham and Bradbury, \{Kathryn E\} and Magdalena Stepien and Talita Duarte-Salles and Elio Riboli and Mazda Jenab",</div><div>  note      = "{\textcopyright} 2014 UICC.",</div><div>  year      = "2014",</div><div>  month     = mar,</div><div>  day       = "13",</div><div>  doi       = "10.1002/ijc.28841",</div><div>  language  = "English",</div><div>  volume    = "135",</div><div>  pages     = "1949--1960",</div><div>  journal   = "International Journal of Cancer",</div><div>  issn      = "0020-7136",</div><div>  publisher = "Wiley",</div><div>  number    = "8",</div><p>}</p></div>
            </div>
        
