<td align="right" valign="middle" rowspan="1" colspan="1">32.45%</td>
</tr>
<tr>
<td align="center" valign="middle" rowspan="1" colspan="1">1</td>
<td align="right" valign="middle" rowspan="1" colspan="1">210</td>
<td align="right" valign="middle" rowspan="1" colspan="1">46.05%</td>
</tr>
<tr>
<td align="center" valign="middle" rowspan="1" colspan="1">2</td>
