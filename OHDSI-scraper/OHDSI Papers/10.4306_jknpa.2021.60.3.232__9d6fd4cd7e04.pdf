            $(".PageViewLink").on("click", function(){

                new Chartist.Line('#my-chart', aPageViewCount, {
                    plugins: [
                        Chartist.plugins.tooltip({
                            pointClass: 'ct-point',
                            tooltipOffset: {
                                x: 15,
                                y: 35
                            },
                            transformTooltipTextFnc: function(value){
                                return	'Counts: ' + value;
                            }
                        })
                    ],
                    fullWidth: false,
                    lineSmooth: Chartist.Interpolation.cardinal({
                        tension: 0
                    }),						
