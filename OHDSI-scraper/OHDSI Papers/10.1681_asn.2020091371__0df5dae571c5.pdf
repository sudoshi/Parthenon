<sup>9,</sup><sup>10,</sup><sup>11,</sup><sup>12,</sup><sup>13,</sup><sup>14</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Karlson%20EW"[Author]' class="usa-link" aria-describedby="id12"><span class="name western">Elizabeth W Karlson</span></a><div hidden="hidden" id="id12">
<h3><span class="name western">Elizabeth W Karlson</span></h3>
<div class="p">
<sup>15</sup>Division of Rheumatology, Department of Medicine, Brigham and Women’s Hospital, Boston, Massachusetts</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Karlson%20EW"[Author]' class="usa-link"><span class="name western">Elizabeth W Karlson</span></a>
</div>
</div>
<sup>15</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Harley%20JB"[Author]' class="usa-link" aria-describedby="id13"><span class="name western">John B Harley</span></a><div hidden="hidden" id="id13">
