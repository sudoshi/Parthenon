<script id="serverApp-state" type="application/json">{&q;http://ntrs-proxy-auto-deploy:3001/auth/user&q;:null,&q;G.json./api/auth/user?&q;:{&q;body&q;:null,&q;headers&q;:{&q;x-powered-by&q;:[&q;Express&q;],&q;x-ratelimit-limit&q;:[&q;500&q;],&q;x-ratelimit-remaining&q;:[&q;499&q;],&q;date&q;:[&q;Tue, 07 Apr 2026 01:28:18 GMT&q;],&q;x-ratelimit-reset&q;:[&q;1775525519&q;],&q;connection&q;:[&q;keep-alive&q;],&q;keep-alive&q;:[&q;timeout=5&q;],&q;transfer-encoding&q;:[&q;chunked&q;]},&q;status&q;:200,&q;statusText&q;:&q;OK&q;,&q;url&q;:&q;http://ntrs-proxy-auto-deploy:3001/auth/user&q;,&q;responseType&q;:&q;json&q;},&q;http://ntrs-proxy-auto-deploy:3001/citations/20020057888&q;:{&q;copyright&q;:{&q;thirdPartyPermissionsProduced&q;:false,&q;disclosedToPublic&q;:false,&q;containsIndication&q;:false,&q;publisherPermissionOrRightsToDistribute&q;:false,&q;belongsToUsGov&q;:false,&q;determinationType&q;:&q;GOV_PUBLIC_USE_PERMITTED&q;,&q;thirdPartyContentCondition&q;:&q;NOT_SET&q;,&q;belongsToContractor&q;:false,&q;disclosedInvention&q;:false,&q;submissionId&q;:20020057888,&q;containsThirdPartyMaterial&q;:false,&q;belongsToPublisher&q;:false,&q;id&q;:&q;bbac2e69d56a457c96be2f1580b17967&q;,&q;belongsToAuthors&q;:false},&q;subjectCategories&q;:[&q;Computer Programming And Software&q;],&q;exportControl&q;:{&q;isExportControl&q;:&q;NO&q;,&q;submissionId&q;:20020057888,&q;ear&q;:&q;NO&q;,&q;id&q;:&q;3d65598a50eb4e939398c1b50e58b885&q;,&q;itar&q;:&q;NO&q;},&q;distributionDate&q;:&q;2019-07-12T00:00:00.0000000+00:00&q;,&q;fundingNumbers&q;:[{&q;number&q;:&q;RTOP 519-40-12&q;,&q;submissionId&q;:20020057888,&q;id&q;:&q;0fa884409e694eac9ea4da488bea20ee&q;,&q;type&q;:&q;PROJECT&q;},{&q;number&q;:&q;NAS2-14303&q;,&q;submissionId&q;:20020057888,&q;id&q;:&q;d0d6bdd1f4404744a78d10047e29cd3b&q;,&q;type&q;:&q;CONTRACT_GRANT&q;}],&q;title&q;:&q;Automated Generation of Message-Passing Programs: An Evaluation Using CAPTools&q;,&q;stiType&q;:&q;PREPRINT&q;,&q;distribution&q;:&q;PUBLIC&q;,&q;submittedDate&q;:&q;2013-09-07T12:46:00.0000000+00:00&q;,&q;authorAffiliations&q;:[{&q;sequence&q;:0,&q;submissionId&q;:20020057888,&q;meta&q;:{&q;author&q;:{&q;name&q;:&q;Hribar, Michelle R.&q;},&q;organization&q;:{&q;name&q;:&q;NASA Ames Research Center&q;,&q;location&q;:&q;Moffett Field, CA United States&q;}},&q;id&q;:&q;9744cc32d00a4c018a5673cde487bcba&q;},{&q;sequence&q;:1,&q;submissionId&q;:20020057888,&q;meta&q;:{&q;author&q;:{&q;name&q;:&q;Jin, Haoqiang&q;},&q;organization&q;:{&q;name&q;:&q;NASA Ames Research Center&q;,&q;location&q;:&q;Moffett Field, CA United States&q;}},&q;id&q;:&q;703f0c7146434bea89b49325f334e453&q;},{&q;sequence&q;:2,&q;submissionId&q;:20020057888,&q;meta&q;:{&q;author&q;:{&q;name&q;:&q;Yan, Jerry C.&q;},&q;organization&q;:{&q;name&q;:&q;MRJ Technology Solutions, Inc.&q;,&q;location&q;:&q;Moffett Field, CA United States&q;}},&q;id&q;:&q;0aabd98900b540659a7e5d387bbd0141&q;},{&q;sequence&q;:3,&q;submissionId&q;:20020057888,&q;meta&q;:{&q;author&q;:{&q;name&q;:&q;Saini, Subhash&q;},&q;organization&q;:{}},&q;id&q;:&q;fd7908baafc34c06bf3c0c9693207ad2&q;}],&q;stiTypeDetails&q;:&q;Preprint (Draft being sent to journal)&q;,&q;technicalReviewType&q;:&q;TECHNICAL_REVIEW_TYPE_NONE&q;,&q;modified&q;:&q;2025-08-31T18:39:21.7150190+00:00&q;,&q;id&q;:20020057888,&q;legacyMeta&q;:{&q;__type&q;:&q;LegacyMetaIndex, StrivesApi.ServiceModel&q;,&q;accessionNumber&q;:&q;&q;},&q;created&q;:&q;2013-09-07T12:46:00.0000000+00:00&q;,&q;center&q;:{&q;code&q;:&q;ARC&q;,&q;name&q;:&q;Ames Research Center&q;,&q;id&q;:&q;4540cd94d24c4bf29f8773a27faf96b2&q;},&q;onlyAbstract&q;:false,&q;sensitiveInformation&q;:2,&q;abstract&q;:&q;Scientists at NASA Ames Research Center have been developing computational aeroscience applications on highly parallel architectures over the past ten years. During that same time period, a steady transition of hardware and system software also occurred, forcing us to expend great efforts into migrating and re-coding our applications. As applications and machine architectures become increasingly complex, the cost and time required for this process will become prohibitive. In this paper, we present the first set of results in our evaluation of interactive parallelization tools. In particular, we evaluate CAPTool&s;s ability to parallelize computational aeroscience applications. CAPTools was tested on serial versions of the NAS Parallel Benchmarks and ARC3D, a computational fluid dynamics application, on two platforms: the SGI Origin 2000 and the Cray T3E. This evaluation includes performance, amount of user interaction required, limitations and portability. Based on these results, a discussion on the feasibility of computer aided parallelization of aerospace applications is presented along with suggestions for future work.&q;,&q;isLessonsLearned&q;:false,&q;disseminated&q;:&q;DOCUMENT_AND_METADATA&q;,&q;meetings&q;:[{&q;country&q;:&q;United States&q;,&q;submissionId&q;:20020057888,&q;name&q;:&q;PDCS &s;&s;98&q;,&q;location&q;:&q;Las Vegas, NV&q;,&q;id&q;:&q;c2f0ca3faa0c481782a47c56f6f86792&q;,&q;startDate&q;:&q;1998-10-01T00:00:00.0000000+00:00&q;}],&q;publications&q;:[{&q;submissionId&q;:20020057888,&q;id&q;:&q;b742b891888947b88840beebd766c6f8&q;,&q;publicationDate&q;:&q;1998-01-01T00:00:00.0000000+00:00&q;}],&q;status&q;:&q;CURATED&q;,&q;related&q;:[],&q;downloads&q;:[{&q;draft&q;:false,&q;mimetype&q;:&q;application/pdf&q;,&q;name&q;:&q;20020057888.pdf&q;,&q;type&q;:&q;STI&q;,&q;links&q;:{&q;original&q;:&q;/api/citations/20020057888/downloads/20020057888.pdf&q;,&q;pdf&q;:&q;/api/citations/20020057888/downloads/20020057888.pdf&q;,&q;fulltext&q;:&q;/api/citations/20020057888/downloads/20020057888.txt&q;}}],&q;downloadsAvailable&q;:true,&q;index&q;:&q;submissions-2026-04-02-04-12&q;},&q;G.json./api/citations/20020057888?&q;:{&q;body&q;:{&q;copyright&q;:{&q;thirdPartyPermissionsProduced&q;:false,&q;disclosedToPublic&q;:false,&q;containsIndication&q;:false,&q;publisherPermissionOrRightsToDistribute&q;:false,&q;belongsToUsGov&q;:false,&q;determinationType&q;:&q;GOV_PUBLIC_USE_PERMITTED&q;,&q;thirdPartyContentCondition&q;:&q;NOT_SET&q;,&q;belongsToContractor&q;:false,&q;disclosedInvention&q;:false,&q;submissionId&q;:20020057888,&q;containsThirdPartyMaterial&q;:false,&q;belongsToPublisher&q;:false,&q;id&q;:&q;bbac2e69d56a457c96be2f1580b17967&q;,&q;belongsToAuthors&q;:false},&q;subjectCategories&q;:[&q;Computer Programming And Software&q;],&q;exportControl&q;:{&q;isExportControl&q;:&q;NO&q;,&q;submissionId&q;:20020057888,&q;ear&q;:&q;NO&q;,&q;id&q;:&q;3d65598a50eb4e939398c1b50e58b885&q;,&q;itar&q;:&q;NO&q;},&q;distributionDate&q;:&q;2019-07-12T00:00:00.0000000+00:00&q;,&q;fundingNumbers&q;:[{&q;number&q;:&q;RTOP 519-40-12&q;,&q;submissionId&q;:20020057888,&q;id&q;:&q;0fa884409e694eac9ea4da488bea20ee&q;,&q;type&q;:&q;PROJECT&q;},{&q;number&q;:&q;NAS2-14303&q;,&q;submissionId&q;:20020057888,&q;id&q;:&q;d0d6bdd1f4404744a78d10047e29cd3b&q;,&q;type&q;:&q;CONTRACT_GRANT&q;}],&q;title&q;:&q;Automated Generation of Message-Passing Programs: An Evaluation Using CAPTools&q;,&q;stiType&q;:&q;PREPRINT&q;,&q;distribution&q;:&q;PUBLIC&q;,&q;submittedDate&q;:&q;2013-09-07T12:46:00.0000000+00:00&q;,&q;authorAffiliations&q;:[{&q;sequence&q;:0,&q;submissionId&q;:20020057888,&q;meta&q;:{&q;author&q;:{&q;name&q;:&q;Hribar, Michelle R.&q;},&q;organization&q;:{&q;name&q;:&q;NASA Ames Research Center&q;,&q;location&q;:&q;Moffett Field, CA United States&q;}},&q;id&q;:&q;9744cc32d00a4c018a5673cde487bcba&q;},{&q;sequence&q;:1,&q;submissionId&q;:20020057888,&q;meta&q;:{&q;author&q;:{&q;name&q;:&q;Jin, Haoqiang&q;},&q;organization&q;:{&q;name&q;:&q;NASA Ames Research Center&q;,&q;location&q;:&q;Moffett Field, CA United States&q;}},&q;id&q;:&q;703f0c7146434bea89b49325f334e453&q;},{&q;sequence&q;:2,&q;submissionId&q;:20020057888,&q;meta&q;:{&q;author&q;:{&q;name&q;:&q;Yan, Jerry C.&q;},&q;organization&q;:{&q;name&q;:&q;MRJ Technology Solutions, Inc.&q;,&q;location&q;:&q;Moffett Field, CA United States&q;}},&q;id&q;:&q;0aabd98900b540659a7e5d387bbd0141&q;},{&q;sequence&q;:3,&q;submissionId&q;:20020057888,&q;meta&q;:{&q;author&q;:{&q;name&q;:&q;Saini, Subhash&q;},&q;organization&q;:{}},&q;id&q;:&q;fd7908baafc34c06bf3c0c9693207ad2&q;}],&q;stiTypeDetails&q;:&q;Preprint (Draft being sent to journal)&q;,&q;technicalReviewType&q;:&q;TECHNICAL_REVIEW_TYPE_NONE&q;,&q;modified&q;:&q;2025-08-31T18:39:21.7150190+00:00&q;,&q;id&q;:20020057888,&q;legacyMeta&q;:{&q;__type&q;:&q;LegacyMetaIndex, StrivesApi.ServiceModel&q;,&q;accessionNumber&q;:&q;&q;},&q;created&q;:&q;2013-09-07T12:46:00.0000000+00:00&q;,&q;center&q;:{&q;code&q;:&q;ARC&q;,&q;name&q;:&q;Ames Research Center&q;,&q;id&q;:&q;4540cd94d24c4bf29f8773a27faf96b2&q;},&q;onlyAbstract&q;:false,&q;sensitiveInformation&q;:2,&q;abstract&q;:&q;Scientists at NASA Ames Research Center have been developing computational aeroscience applications on highly parallel architectures over the past ten years. During that same time period, a steady transition of hardware and system software also occurred, forcing us to expend great efforts into migrating and re-coding our applications. As applications and machine architectures become increasingly complex, the cost and time required for this process will become prohibitive. In this paper, we present the first set of results in our evaluation of interactive parallelization tools. In particular, we evaluate CAPTool&s;s ability to parallelize computational aeroscience applications. CAPTools was tested on serial versions of the NAS Parallel Benchmarks and ARC3D, a computational fluid dynamics application, on two platforms: the SGI Origin 2000 and the Cray T3E. This evaluation includes performance, amount of user interaction required, limitations and portability. Based on these results, a discussion on the feasibility of computer aided parallelization of aerospace applications is presented along with suggestions for future work.&q;,&q;isLessonsLearned&q;:false,&q;disseminated&q;:&q;DOCUMENT_AND_METADATA&q;,&q;meetings&q;:[{&q;country&q;:&q;United States&q;,&q;submissionId&q;:20020057888,&q;name&q;:&q;PDCS &s;&s;98&q;,&q;location&q;:&q;Las Vegas, NV&q;,&q;id&q;:&q;c2f0ca3faa0c481782a47c56f6f86792&q;,&q;startDate&q;:&q;1998-10-01T00:00:00.0000000+00:00&q;}],&q;publications&q;:[{&q;submissionId&q;:20020057888,&q;id&q;:&q;b742b891888947b88840beebd766c6f8&q;,&q;publicationDate&q;:&q;1998-01-01T00:00:00.0000000+00:00&q;}],&q;status&q;:&q;CURATED&q;,&q;related&q;:[],&q;downloads&q;:[{&q;draft&q;:false,&q;mimetype&q;:&q;application/pdf&q;,&q;name&q;:&q;20020057888.pdf&q;,&q;type&q;:&q;STI&q;,&q;links&q;:{&q;original&q;:&q;/api/citations/20020057888/downloads/20020057888.pdf&q;,&q;pdf&q;:&q;/api/citations/20020057888/downloads/20020057888.pdf&q;,&q;fulltext&q;:&q;/api/citations/20020057888/downloads/20020057888.txt&q;}}],&q;downloadsAvailable&q;:true,&q;index&q;:&q;submissions-2026-04-02-04-12&q;},&q;headers&q;:{&q;x-powered-by&q;:[&q;Express&q;],&q;x-ratelimit-limit&q;:[&q;500&q;],&q;x-ratelimit-remaining&q;:[&q;499&q;],&q;date&q;:[&q;Tue, 07 Apr 2026 01:28:18 GMT&q;],&q;x-ratelimit-reset&q;:[&q;1775525520&q;],&q;content-type&q;:[&q;application/json; charset=utf-8&q;],&q;content-length&q;:[&q;4393&q;],&q;etag&q;:[&q;W/\&q;1129-AYbZErS13UvPwpBnOyyqIREkz3g\&q;&q;],&q;connection&q;:[&q;keep-alive&q;],&q;keep-alive&q;:[&q;timeout=5&q;]},&q;status&q;:200,&q;statusText&q;:&q;OK&q;,&q;url&q;:&q;http://ntrs-proxy-auto-deploy:3001/citations/20020057888&q;,&q;responseType&q;:&q;json&q;}}</script></body></html>