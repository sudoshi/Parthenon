  });
  // Download button click event tracker for native files
  $(".aside.download-button").on("click", "a#native", function(event) {
    pageDataTracker.trackEvent('navigationClick', {
        link: {
            location: 'aside download-button',
            name: 'native'
        }
     });
  });
});
</script>
