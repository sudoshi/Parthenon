Lee"],"givenNames":["SW"]},{"type":"Person","familyNames":["Ka"],"givenNames":["SH"]},{"type":"Person","familyNames":["Sou"],"givenNames":["YS"]},{"type":"Person","familyNames":["Komatsu"],"givenNames":["M"]},{"type":"Person","familyNames":["Tanaka"],"givenNames":["K"]},{"type":"Person","familyNames":["et","al"]}],"datePublished":{"type":"Date","value":"2014-01-01T00:00:00.000Z"},"isPartOf":{"type":"PublicationVolume","isPartOf":{"type":"Periodical","name":"Mol Cell"},"volumeNumber":"56"},"pageEnd":274,"pageStart":261,"title":"Modification of ASC1 by UFM1 is crucial for ERalpha transactivation and breast cancer development","meta":{"yearPublished":"2014","publicationType":"journal"}},{"type":"Article","id":"c62","authors":[{"type":"Person","familyNames":["Zhu"],"givenNames":["H"]},{"type":"Person","familyNames":["Bhatt"],"givenNames":["B"]},{"type":"Person","familyNames":["Sivaprakasam"],"givenNames":["S"]},{"type":"Person","familyNames":["Cai"],"givenNames":["Y"]},{"type":"Person","familyNames":["Liu"],"givenNames":["S"]},{"type":"Person","familyNames":["Kodeboyina"],"givenNames":["SK"]},{"type":"Person","familyNames":["Patel"],"givenNames":["N"]},{"type":"Person","familyNames":["Savage"],"givenNames":["NM"]},{"type":"Person","familyNames":["Sharma"],"givenNames":["A"]},{"type":"Person","familyNames":["Kaufman"],"givenNames":["RJ"]},{"type":"Person","familyNames":["et","al"]}],"datePublished":{"type":"Date","value":"2019-01-01T00:00:00.000Z"},"identifiers":[{"type":"PropertyValue","name":"elocation-id","value":"1084"}],"isPartOf":{"type":"PublicationVolume","isPartOf":{"type":"Periodical","name":"Nat Commun"},"volumeNumber":"10"},"title":"Ufbp1 promotes plasma cell development and ER expansion by modulating distinct branches of UPR","meta":{"yearPublished":"2019","publicationType":"journal"}},{"type":"Article","id":"c63","authors":[{"type":"Person","familyNames":["Zirin"],"givenNames":["J"]},{"type":"Person","familyNames":["Hu"],"givenNames":["Y"]},{"type":"Person","familyNames":["Liu"],"givenNames":["L"]},{"type":"Person","familyNames":["Yang-Zhou"],"givenNames":["D"]},{"type":"Person","familyNames":["Colbeth"],"givenNames":["R"]},{"type":"Person","familyNames":["Yan"],"givenNames":["D"]},{"type":"Person","familyNames":["Ewen-Campen"],"givenNames":["B"]},{"type":"Person","familyNames":["Tao"],"givenNames":["R"]},{"type":"Person","familyNames":["Vogt"],"givenNames":["E"]},{"type":"Person","familyNames":["VanNest"],"givenNames":["S"]},{"type":"Person","familyNames":["et","al"]}],"datePublished":{"type":"Date","value":"2020-01-01T00:00:00.000Z"},"isPartOf":{"type":"PublicationVolume","isPartOf":{"type":"Periodical","name":"Genetics"},"volumeNumber":"214"},"pageEnd":767,"pageStart":755,"title":"Large-Scale Transgenic Drosophila Resource Collections for Loss- and Gain-of-Function Studies","meta":{"yearPublished":"2020","publicationType":"journal"}}],"meta":{"authorNotes":[{"type":"corresp","id":"cor1","label":"#","text":"Correspondence: hbellen@bcm.edu, pruneda@ohsu.edu"}]}},"preprintDoi":"10.1101/2023.07.17.23292782","preprintUrl":"https://www.medrxiv.org/content/10.1101/2023.07.17.23292782v2","preprintPosted":"2023-10-02T00:00:00.000Z","sentForReview":"2023-10-02T16:17:35.000Z","peerReview":{"evaluationSummary":{"date":"2023-11-03T09:14:12.828Z","doi":"10.7554/eLife.89891.2.sa3","participants":[{"name":"Murim Choi","role":"editor","institution":"Seoul National University, Seoul, Republic of Korea"},{"name":"Murim Choi","role":"senior-editor","institution":"Seoul National University, Seoul, Republic of Korea"}],"reviewType":"evaluation-summary","text":"\u003cp\u003e\u003cstrong\u003eeLife assessment\u003c/strong\u003e\u003c/p\u003e\n\u003cp\u003eThe authors establish a Drosophila model to assess the severity of disease-linked alleles of Uba5. Using both in vivo and in vitro experiments, this valuable study demonstrates the alleles fall into mild, intermediate, and severe classes, with convincing evidence to support their conclusion. This well-executed study establishes a model for further characterization of Uba5-related phenotypes in a powerful model system.\u003c/p\u003e"},"authorResponse":{"date":"2023-11-03T10:07:00.721Z","doi":"10.7554/eLife.89891.2.sa4","participants":[],"reviewType":"author-response","text":"\u003cp\u003e\u003cstrong\u003eAuthor Response\u003c/strong\u003e\u003c/p\u003e\n\u003cp\u003eThe following is the authors’ response to the original reviews.\u003c/p\u003e\n\u003cp\u003eWe greatly appreciate the valuable and constructive review of our manuscript. The reviewers’ comments have helped us to improve the quality of the paper. Here we provide detailed responses to the reviewers’ comments and discuss the new experiments we performed. \u003c/p\u003e\n\u003cblockquote\u003e\n\u003cp\u003e\u003cstrong\u003eReviewer #1\u003c/strong\u003e\u003c/p\u003e\n\u003cp\u003eSummary:\u003c/p\u003e\n\u003cp\u003eIn this study, the authors generate a Drosophila model to assess disease-linked allelic variants in the UBA5 gene. In humans, variants in UBA5 have been associated with DEE44, characterized by developmental delay, seizures, and encephalopathy. Here, the authors set out to characterize the relationship between 12 disease-linked variants in UBA5 using a variety of assays in their Drosophila Uba5 model. They first show that human UBA5 can substitute all essential functions of the Drosophila Uba5 ortholog, and then assess phenotypes in flies expressing the various disease variants. Using these assays, the authors classify the alleles into mild, intermediate, and severe loss-of-function alleles. Further, the authors establish several important in vitro assays to determine the impacts of the disease alleles on Uba5 stability and function. Together, they find a relatively close correlation between in vivo and in vitro relationships between Uba5 alleles and establish a new Drosophila model to probe the etiology of Uba5-related disorders.\u003c/p\u003e\n\u003cp\u003eStrengths:\u003c/p\u003e\n\u003cp\u003eOverall, this is a convincing and well-executed study. There is clearly a need to assess disease-associated allelic variants to better understand human disorders, particularly for rare diseases, and this humanized fly model of Uba5 is a powerful system to rapidly evaluate variants and relationships to various phenotypes. The manuscript is well written, and the experiments are appropriately controlled.\u003c/p\u003e\n\u003cp\u003eRecommendations For The Authors:\u003c/p\u003e\n\u003cp\u003e1) It would seem of value to determine what tissue(s) the essential function of Uba5 resides. The authors nicely detail the expression of Uba5 in a subset of neurons and glia, and indicate it is expressed in a variety of other tissues. Null mutants are embryonic lethal, suggesting an essential function. From the mouse study cited, it appears Uba5 functions early in development in the hematopoietic system. The authors can express their UAS-Uba5 rescue construct using a variety of tissue-specific Gal4 lines to determine whether the essential function of Uba5 is in the nervous system or other tissues, which would be of interest in understanding key functions of Uba5.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eWe thank the reviewer for the suggestion. We tried to rescue the lethality of the Uba5 mutants by expressing human UBA5 reference protein in different tissues. We found that ubiquitous expression of UBA5 (da-GAL4 or act-GAL4) successfully rescues the lethality, however, expression of UBA5 in neurons (elav-GAL4), glia (repo-GAL4), or both neurons and glia does not. In addition, expression of UBA5 in fat body (SPARC-GAL4) or muscles (Mef2-GAL4) does not rescue the lethality either. These results suggest that Uba5 is required in multiple tissues in flies. These data are included in the revised manuscript.\u003c/p\u003e\n\u003cblockquote\u003e\n\u003cp\u003e2). Do intermediate Uba5 alleles impact synaptic function or growth? The etiology of the disease is linked with epilepsy and neurodevelopmental disorders, and the interesting parallels the authors note between Uba5 and Para expression indicate perhaps shared roles in neurons that drive firing activity. Together, these lines of evidence may suggest the Uba5 alleles may have possible impacts on synaptic growth, morphology, and/or function. It would be of interest to examine the larval neuromuscular junction and assess NMJ growth, morphology, and perform some basic electrophysiology to determine if there are any functional defects.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eFollowing the reviewer’s suggestion, we tested the morphology of NMJs in the humanized flies. We did not observe any obvious changes in the number or size of the synaptic boutons caused by the Group II variants. Hence, we conclude that the Uba5 variants do not cause an obvious defect in synaptic growth. The results are included in the Figure S3.\u003c/p\u003e\n\u003cblockquote\u003e\n\u003cp\u003eMore generally, can the authors comment on the expression pattern of Uba5? One might consider something like Uba5 to be a \"housekeeping\" gene and expressed/required in most if not all cell types. From the data presented in Fig. 2, it appears expression is more sparse, perhaps, as the authors point out, because of roles in mature neurons that actively fire (like Para). Are neuronal targets of Uba5 known, which might suggest key pathways it modulates?\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eWe showed that Uba5 is broadly expressed in third instar larvae. FlyAtlas2 and FlyCellAtlas datasets show that Uba5 is broadly expressed but not in all the cells. In the larval CNS and adult brain, Uba5 is not expressed in all cells either. Hence, we cannot say Uba5 is a “housekeeping” gene. Regarding the neuronal targets of Uba5, we do not know which types of neurons express Uba5 and which pathways Uba5 modulates. This could be studied in the future. \u003c/p\u003e\n\u003cblockquote\u003e\n\u003cp\u003e3) Does strong overexpression of the various Uba5 alleles in otherwise wild-type flies cause any phenotypes? This might support possible antimorphic/dominant negative functions of some of the variants. Is it plausible that any of the alleles could impact oligomerization of Uba5?\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eWe have not observed compromised viability or any obvious phenotype in flies overexpressing human reference UBA5 or UBA5 variants. So, our results do not support a dominant negative effect of any of the variants.\u003c/p\u003e\n\u003cp\u003eTo our knowledge, people do not have sufficient knowledge on UBA5 dimerization to speculate on whether some variants could play a dominant negative role. There is one variant, V260M, that lies at the dimer interface. We showed that the V260M variant biochemically affects ATP binding as well as UFM1 activation, but we do not have evidence to support that it causes dominant negative effects by affecting UBA5 dimerization.\u003c/p\u003e\n\u003cblockquote\u003e\n\u003cp\u003eMinor points:\u003c/p\u003e\n\u003cp\u003e1) Page 5 line 45: It seems a reference is missing about the temperature dependence of Gal4 activity.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eWe apologize for the missing reference. We have incorporated a reference to PMID 25824290.\u003c/p\u003e\n\u003cblockquote\u003e\n\u003cp\u003e2) It might be of interest to assay the various transgenic rescue alleles at a higher temperature (say 29C) in addition to the nice work looking at 18/25C survival. Perhaps some of the alleles display temperature sensitivity at low (18) and high (29) temperatures.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eWe now include the survival rate data at 29C. The enzyme dead and severe LoF variants fail to rescue the lethality at 29C, while the mild (Group IA and IB) variants fully rescue. For the three Group II variants, the survival rate at 29C is higher than that at 25C and 18C. The results support the dosage sensitive effects of UBA5 overexpression, but do not support any variant to be temperature sensitive within this range.\u003c/p\u003e\n\u003cblockquote\u003e\n\u003cp\u003e\u003cstrong\u003eReviewer #2\u003c/strong\u003e\u003c/p\u003e\n\u003cp\u003eRelative simplicity and genetic accessibility of the fly brain make it a premier model system for studying the function of genes linked to various diseases in humans. Here, Pan et al. show that human UBA5, whose mutations cause developmental and epileptic encephalopathy, can functionally replace the fly homolog Uba5. The authors then systematically express in flies the different versions of the gene carrying clinically relevant SNPs and perform extensive phenotypic characterization such as survival rate, developmental timing, lifespan, locomotor and seizure activity, as well as in vitro biochemical characterization (stability, ATP binding, UFM-1 activation) of the corresponding recombinant proteins. The biochemical effects are well predicted by (or at least consistent with) the location of affected amino acids in the previously described Uba5 protein structure. Most strikingly, the severity of biochemical defects appears to closely track the severity of phenotypic defects observed in vivo in flies. While the paper does not provide many novel insights into the function of Uba5, it convincingly establishes the fly nervous system as a powerful model for future mechanistic studies.\u003c/p\u003e\n\u003cp\u003eOne potential limitation is the design of the expression system in this work. Even though the authors state that \"human cDNA is expressed under the control of the endogenous Uba5 enhancer and promoter\", it is in fact the Gal4 gene that is expressed from the endogenous locus, meaning that the cDNA expression level would inevitably be amplified in comparison. The fact that different effects were observed when some experiments were performed at different temperatures (18 vs. 25) is also consistent with this. While I do not think this caveat weakens the conclusions of this paper, it may impact the interpretation of future experiments that use these tools, and thus should be clearly discussed in the paper. Especially considering the authors argue that most disease variants of UBA5 are partial loss-of-functions, the amplification effect could potentially mask the phenotypes of milder hypomorphic alleles. If the authors could also show that the T2A-Gal4 expression pattern in the brain matches well with that of endogenous RNA or protein (e.g. using HCR-FISH or antibody), it would help to alleviate this concern.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eWe thank the reviewer for pointing out the issue.\u003c/p\u003e\n\u003cp\u003eRegarding the humanization strategy we used in the study, we agree that this is a binary system which could induce overexpression of the target protein. However, as the reviewer also points out, this temperature sensitive system also enables us to flexibly adjust the expression level of the target protein (PMIDs 34113007, 35348658, 36206744), which is especially useful to study partial LoF variants. In our study we have successfully compared the relevant allelic strength of most of the variants.\u003c/p\u003e\n\u003cp\u003eWe agree with the reviewer that a masking effect may exist in our system due to its gene overexpression nature. However, we cannot conclude that this masking effect really affects the three Group IA variants in our tests. The three variants are mild LoF, which is supported by our biochemical assays. Individuals homozygous for one of the Group IA variants, p.A371T, do not have any obvious phenotype, which is also consistent with our findings in flies.\u003c/p\u003e\n\u003cp\u003eRegarding the expression pattern of the T2A-GAL4, the Bellen lab has generated T2A-GAL4 lines for more than 3,000 genes. The expression pattern of many GAL4 lines faithfully reflect the expression pattern of the endogenous genes, which has been shown in our previous publications (PMIDs 25824290, 29565247, 31674908).\u003c/p\u003e\n\u003cblockquote\u003e\n\u003cp\u003eRecommendations For The Authors:\u003c/p\u003e\n\u003cp\u003eAs related to the expression pattern comment in the public review, I think the authors could also take advantage of Fly Cell Atlas or other available scRNA-seq atlases of the fly brain to present a much more detailed description of the Uba5 expression profile with minimal additional effort. If the cells that express it share other features or genes (other than the para that the authors mention), this could lead to further insights about the gene's neuronal or glial functions.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eIn response to the reviewer, we show the expression pattern of Uba5 documented in FlyCellAtlas and another adult brain single-cell RNA seq profile (PMID 29909982) in the revised manuscript.\u003c/p\u003e\n\u003cblockquote\u003e\n\u003cp\u003eIn addition, one of the mutants (assuming the same one) is referred to as Leu254Pro in some parts of the manuscript while in some other parts (including tables 1-2) it is Lys254Pro.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eWe apologize for the mistakes. The variant should be Leu254Pro and we have made these corrections in the revised manuscript.\u003c/p\u003e\n\u003cblockquote\u003e\n\u003cp\u003e\u003cstrong\u003eReviewer #3\u003c/strong\u003e\u003c/p\u003e\n\u003cp\u003eSummary:\u003c/p\u003e\n\u003cp\u003eVariants in the UBA5 gene are associated with rare developmental and epileptic encephalopathy, DEE44. This research developed a system to assess in vivo and in vitro genotype-phenotype relationships between UBA5 allele series by humanized UBA5 fly models and biochemical activity assays. This study provides a basis for evaluating current and future individuals afflicted with this rare disease.\u003c/p\u003e\n\u003cp\u003eStrengths:\u003c/p\u003e\n\u003cp\u003eThe authors developed a method to measure the enzymatic reaction activity of UBA5 mutants over time by applying the UbiReal method, which can monitor each reaction step of ubiquitination in real time using fluorescence polarization. They also classified fruit fly carrying humanized UBA5 variants into groups based on phenotype. They found a correlation between biochemical UBA5 activity and phenotype severity.\u003c/p\u003e\n\u003cp\u003eWeaknesses:\u003c/p\u003e\n\u003cp\u003eIn the case of human DEE44, compound heterozygotes with both loss-of-function and hypomorphic forms (e.g., p.Ala371Thr, p.Asp389Gly, p.Asp389Tyr) may cause disease states. The presented models have failed to evaluate such cases.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eWe agree with the reviewer that our current system has a limitation that it evaluates one variant at a time rather than any combination of variants. However, our biochemical data do show that the three Group IA variants are mild LoF variants rather than benign variants. One of these variants, p.A371T, does not cause any obvious phenotype in homozygous individuals, which is also consistent with our findings in flies. The modeling of variant combinations, especially the Group IA/Group III combinations could be carried out in future studies. \u003c/p\u003e\n\u003cblockquote\u003e\n\u003cp\u003eRecommendations For The Authors:\u003c/p\u003e\n\u003cp\u003eFigure 3G. Typo. \"ContonS\" should be replaced by \"CantonS.\"\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eWe apologize for the spelling mistake. We correct the typo in the revised manuscript.\u003c/p\u003e\n\u003cblockquote\u003e\n\u003cp\u003eFigure 5. The labels should be in uppercase instead of lowercase.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eWe correct the panel labels in the revised manuscript.\u003c/p\u003e\n\u003cblockquote\u003e\n\u003cp\u003eFigure 6A. Is the molecular weight of UBA5~UFM1 intermediate (99 kDa) in model Figure correct? In Fig. 6B, the molecular weight of UBA5~UFM1 intermediate seems to be 70-75 kDa. \u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eBoth are correct. The molecular weight depicted in the schematic of Figure 6A is based on the UBA5 dimer, which dissociates in the SDS-PAGE gel shown in Figure 6B. We have reconfigured the schematic to make this more apparent.\u003c/p\u003e\n\u003cblockquote\u003e\n\u003cp\u003eFigure. 6E, F, H, and I. The time points for quantification in these figures should be specified.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eWe apologize for the confusion. The details on data quantification are now more thoroughly explained in the Methods.\u003c/p\u003e"},"reviews":[{"date":"2023-11-03T09:14:12.103Z","doi":"10.7554/eLife.89891.2.sa2","participants":[{"name":"anonymous","role":"peer-reviewer"}],"reviewType":"review-article","text":"\u003cp\u003e\u003cstrong\u003eReviewer #1 (Public Review):\u003c/strong\u003e\u003c/p\u003e\n\u003cp\u003eSummary:\u003cbr\u003e\nIn this study, the authors generate a Drosophila model to assess disease-linked allelic variants in the UBA5 gene. In humans, variants in UBA5 have been associated with DEE44, characterized by developmental delay, seizures, and encephalopathy. Here, the authors set out to characterize the relationship between 12 disease-linked variants in UBA5 using a variety of assays in their Drosophila Uba5 model. They first show that human UBA5 can substitute all essential functions of the Drosophila Uba5 ortholog, and then assess phenotypes in flies expressing the various disease variants. Using these assays, the authors classify the alleles into mild, intermediate, and severe loss-of-function alleles. Further, the authors establish several important in vitro assays to determine the impacts of the disease alleles on Uba5 stability and function. Together, they find a relatively close correlation between in vivo and in vitro relationships between Uba5 alleles and establish a new Drosophila model to probe the etiology of Uba5-related disorders.\u003c/p\u003e\n\u003cp\u003eStrengths:\u003cbr\u003e\nOverall, this is a convincing and well-executed study. There is clearly a need to assess disease-associated allelic variants to better understand human disorders, particularly for rare diseases, and this humanized fly model of Uba5 is a powerful system to rapidly evaluate variants and relationships to various phenotypes. The manuscript is well written, and the experiments are appropriately controlled.\u003c/p\u003e"},{"date":"2023-11-03T09:14:11.376Z","doi":"10.7554/eLife.89891.2.sa1","participants":[{"name":"anonymous","role":"peer-reviewer"}],"reviewType":"review-article","text":"\u003cp\u003e\u003cstrong\u003eReviewer #2 (Public Review):\u003c/strong\u003e\u003c/p\u003e\n\u003cp\u003eRelative simplicity and genetic accessibility of the fly brain makes it a premier model system for studying the function of genes linked to various diseases in humans. Here, Pan et al. show that human UBA5, whose mutations cause developmental and epileptic encephalopathy, can functionally replace the fly homolog Uba5. The authors then systematically express in flies the different versions of the gene carrying clinically relevant SNPs and perform extensive phenotypic characterization such as survival rate, developmental timing, lifespan, locomotor and seizure activity, as well as in vitro biochemical characterization (stability, ATP binding, UFM-1 activation) of the corresponding recombinant proteins. The biochemical effects are well predicted by (or at least consistent with) the location of affected amino acids in the previously described Uba5 protein structure. Most strikingly, the severity of biochemical defects appears to closely track the severity of phenotypic defects observed in vivo in flies. While the paper does not provide many novel insights into the function of Uba5, it convincingly establishes the fly nervous system as a powerful model for future mechanistic studies.\u003c/p\u003e\n\u003cp\u003eOne potential limitation is the design of the expression system in this work. Even though the authors state (ln. 127-128) that \"human cDNA is expressed under the control of the endogenous Uba5 enhancer and promoter\", it is in fact the Gal4 gene that is expressed from the endogenous locus (which authors also note in the same paragraph 138-139), meaning that the cDNA expression level would inevitably be amplified in comparison. While I do not think this weakens the conclusions of this paper, it may impact the interpretation of future experiments that use these tools. Especially considering the authors argue that most disease variants of UBA5 are partial loss-of-functions, the amplification effect could potentially mask the phenotypes of milder hypomorphic alleles. Temperature sensitivity of Gal4 expression may allow calibrating levels to reduce the impact of this amplification, but the revised manuscript still does not openly acknowledge or discuss this potential caveat.\u003c/p\u003e"},{"date":"2023-11-03T09:14:10.617Z","doi":"10.7554/eLife.89891.2.sa0","participants":[{"name":"anonymous","role":"peer-reviewer"}],"reviewType":"review-article","text":"\u003cp\u003e\u003cstrong\u003eReviewer #3 (Public Review):\u003c/strong\u003e\u003c/p\u003e\n\u003cp\u003eSummary:\u003cbr\u003e\nVariants in the UBA5 gene are associated with rare developmental and epileptic encephalopathy, DEE44. This research developed a system to assess in vivo and in vitro genotype-phenotype relationships between UBA5 allele series by humanized UBA5 fly models and biochemical activity assays. This study provides a basis for evaluating current and future individuals afflicted with this rare disease.\u003c/p\u003e\n\u003cp\u003eStrengths:\u003cbr\u003e\nThe authors developed a method to measure the enzymatic reaction activity of UBA5 mutants over time by applying the UbiReal method, which can monitor each reaction step of ubiquitination in real time using fluorescence polarization. They also classified fruit fly carrying humanized UBA5 variants into groups based on phenotype. They found a correlation between biochemical UBA5 activity and phenotype severity.\u003c/p\u003e\n\u003cp\u003eWeaknesses:\u003cbr\u003e\nIn the case of human DEE44, compound heterozygotes with both loss-of-function and hypomorphic forms (e.g., p.Ala371Thr, p.Asp389Gly, p.Asp389Tyr) may cause disease states. The presented models have failed to evaluate such cases.\u003c/p\u003e"}]},"published":"2023-11-06T14:00:00.000Z","publishedYear":2023,"volume":"12","eLocationId":"RP89891","subjects":["Genetics and Genomics","Medicine"],"pdfUrl":"https://elifesciences.org/reviewed-preprints/89891v2.pdf","relatedContent":[],"license":"https://creativecommons.org/publicdomain/zero/1.0/","xmlUrl":"https://elifesciences.org/reviewed-preprints/89891v2.xml","title":["Allelic strengths of encephalopathy-associated ",{"type":"Emphasis","content":["UBA5"]}," variants correlate between ",{"type":"Emphasis","content":["in vivo"]}," and ",{"type":"Emphasis","content":["in vitro"]}," assays"],"authors":[{"type":"Person","affiliations":[{"type":"Organization","name":"Department of Molecular and Human Genetics, Baylor College of Medicine, Houston, TX 77030, USA"},{"type":"Organization","name":"Jan \u0026 Dan Duncan Neurological Research Institute, Texas Children’s Hospital, Houston, TX 77030, USA"}],"familyNames":["Pan"],"givenNames":["Xueyang"],"identifiers":[{"type":"PropertyValue","propertyID":"https://registry.identifiers.org/registry/orcid","value":"http://orcid.org/0000-0003-4453-4971"}]},{"type":"Person","affiliations":[{"type":"Organization","name":"Department of Molecular Microbiology \u0026 Immunology, Oregon Health \u0026 Science University, Portland, OR 97239, USA"}],"familyNames":["Alvarez"],"givenNames":["Albert","N."]},{"type":"Person","affiliations":[{"type":"Organization","name":"Department of Molecular and Human Genetics, Baylor College of Medicine, Houston, TX 77030, USA"},{"type":"Organization","name":"Jan \u0026 Dan Duncan Neurological Research Institute, Texas Children’s Hospital, Houston, TX 77030, USA"}],"familyNames":["Ma"],"givenNames":["Mengqi"],"identifiers":[{"type":"PropertyValue","propertyID":"https://registry.identifiers.org/registry/orcid","value":"http://orcid.org/0000-0001-7345-575X"}]},{"type":"Person","affiliations":[{"type":"Organization","name":"Department of Molecular and Human Genetics, Baylor College of Medicine, Houston, TX 77030, USA"},{"type":"Organization","name":"Jan \u0026 Dan Duncan Neurological Research Institute, Texas Children’s Hospital, Houston, TX 77030, USA"}],"familyNames":["Lu"],"givenNames":["Shenzhao"],"identifiers":[{"type":"PropertyValue","propertyID":"https://registry.identifiers.org/registry/orcid","value":"http://orcid.org/0000-0003-3117-3900"}]},{"type":"Person","affiliations":[{"type":"Organization","name":"Department of Molecular Microbiology \u0026 Immunology, Oregon Health \u0026 Science University, Portland, OR 97239, USA"}],"familyNames":["Crawford"],"givenNames":["Michael","W."]},{"type":"Person","affiliations":[{"type":"Organization","name":"Center for Genomic Medicine, Massachusetts General Hospital, Boston, MA 02114, USA"}],"familyNames":["Briere"],"givenNames":["Lauren","C."]},{"type":"Person","affiliations":[{"type":"Organization","name":"Department of Molecular and Human Genetics, Baylor College of Medicine, Houston, TX 77030, USA"},{"type":"Organization","name":"Jan \u0026 Dan Duncan Neurological Research Institute, Texas Children’s Hospital, Houston, TX 77030, USA"}],"familyNames":["Kanca"],"givenNames":["Oguz"],"identifiers":[{"type":"PropertyValue","propertyID":"https://registry.identifiers.org/registry/orcid","value":"http://orcid.org/0000-0001-5438-0879"}]},{"type":"Person","affiliations":[{"type":"Organization","name":"Department of Molecular and Human Genetics, Baylor College of Medicine, Houston, TX 77030, USA"},{"type":"Organization","name":"Jan \u0026 Dan Duncan Neurological Research Institute, Texas Children’s Hospital, Houston, TX 77030, USA"},{"type":"Organization","name":"Department of Neuroscience, Baylor College of Medicine, Houston, TX 77030, USA"}],"familyNames":["Yamamoto"],"givenNames":["Shinya"],"identifiers":[{"type":"PropertyValue","propertyID":"https://registry.identifiers.org/registry/orcid","value":"http://orcid.org/0000-0003-2172-8036"}]},{"type":"Person","affiliations":[{"type":"Organization","name":"Center for Genomic Medicine, Massachusetts General Hospital, Boston, MA 02114, USA"},{"type":"Organization","name":"Division of Medical Genetics \u0026 Metabolism, Massachusetts General Hospital for Children, Boston, MA 02114, USA"}],"familyNames":["Sweetser"],"givenNames":["David","A."]},{"type":"Person","affiliations":[{"type":"Organization","name":"Division of Pediatric Neurology, Department of Pediatrics, Oregon Health \u0026 Science University, Portland, OR 97239, USA"}],"familyNames":["Wilson"],"givenNames":["Jenny","L."]},{"type":"Person","affiliations":[{"type":"Organization","name":"Department of Molecular Microbiology \u0026 Immunology, Oregon Health \u0026 Science University, Portland, OR 97239, USA"},{"type":"Organization","name":"VA Portland Health Care System, Portland, OR 97239, USA"},{"type":"Organization","name":"Division of Arthritis \u0026 Rheumatic Diseases, Oregon Health \u0026 Science University, Portland, OR 97239, USA"}],"familyNames":["Napier"],"givenNames":["Ruth","J."]},{"type":"Person","affiliations":[{"type":"Organization","name":"Department of Molecular Microbiology \u0026 Immunology, Oregon Health \u0026 Science University, Portland, OR 97239, USA"}],"familyNames":["Pruneda"],"givenNames":["Jonathan","N."],"identifiers":[{"type":"PropertyValue","propertyID":"https://registry.identifiers.org/registry/orcid","value":"http://orcid.org/0000-0002-0304-4418"}],"meta":{"notes":[{"type":"corresp","label":"#","rid":"cor1"}]}},{"type":"Person","affiliations":[{"type":"Organization","name":"Department of Molecular and Human Genetics, Baylor College of Medicine, Houston, TX 77030, USA"},{"type":"Organization","name":"Jan \u0026 Dan Duncan Neurological Research Institute, Texas Children’s Hospital, Houston, TX 77030, USA"},{"type":"Organization","name":"Department of Neuroscience, Baylor College of Medicine, Houston, TX 77030, USA"}],"familyNames":["Bellen"],"givenNames":["Hugo","J."],"identifiers":[{"type":"PropertyValue","propertyID":"https://registry.identifiers.org/registry/orcid","value":"http://orcid.org/0000-0001-5992-5989"}],"meta":{"notes":[{"type":"corresp","label":"#","rid":"cor1"}]}}],"abstract":[{"type":"Paragraph","content":["Protein UFMylation downstream of the E1 enzyme UBA5 plays essential roles in development and ER stress. Variants in the ",{"type":"Emphasis","content":["UBA5"]}," gene are associated with developmental and epileptic encephalopathy 44 (DEE44), an autosomal recessive disorder characterized by early-onset encephalopathy, movement abnormalities, global developmental delay, intellectual disability, and seizures. DEE44 is caused by at least twelve different missense variants described as loss of function (LoF), but the relationships between genotypes and molecular or clinical phenotypes remains to be established. We developed a humanized ",{"type":"Emphasis","content":["UBA5"]}," fly model and biochemical activity assays in order to describe ",{"type":"Emphasis","content":["in vivo"]}," and ",{"type":"Emphasis","content":["in vitro"]}," genotype-phenotype relationships across the ",{"type":"Emphasis","content":["UBA5"]}," allelic series. ",{"type":"Emphasis","content":["In vivo"]},", we observed a broad spectrum of phenotypes in viability, developmental timing, lifespan, locomotor activity, and bang sensitivity. A range of functional effects was also observed ",{"type":"Emphasis","content":["in vitro"]}," across comprehensive biochemical assays for protein stability, ATP binding, UFM1 activation, and UFM1 transthiolation. Importantly, there is a strong correlation between ",{"type":"Emphasis","content":["in vivo"]}," and ",{"type":"Emphasis","content":["in vitro"]}," phenotypes, establishing a classification of LoF variants into mild, intermediate, and severe allelic strengths. By systemically evaluating ",{"type":"Emphasis","content":["UBA5"]}," variants across ",{"type":"Emphasis","content":["in vivo"]}," and ",{"type":"Emphasis","content":["in vitro"]}," platforms, this study provides a foundation for more basic and translational UBA5 research, as well as a basis for evaluating current and future individuals afflicted with this rare disease."]}],"licenses":[{"type":"CreativeWork","url":"https://creativecommons.org/publicdomain/zero/1.0/","content":[{"type":"Paragraph","content":["This is an open-access article, free of all copyright, and may be freely reproduced, distributed, transmitted, modified, built upon, or otherwise used by anyone for any lawful purpose. The work is made available under the ",{"type":"Link","target":"https://creativecommons.org/publicdomain/zero/1.0/","content":["Creative Commons CC0 public domain dedication"]},"."]}]}],"content":[{"type":"Heading","id":"s1","depth":1,"content":["Introduction"]},{"type":"Paragraph","content":["Variants in the human ",{"type":"Emphasis","content":["ubiquitin like modifier activating enzyme 5"]}," (",{"type":"Emphasis","content":["UBA5"]},") gene have been associated with three autosomal recessive disorders. In most reported cases, biallelic ",{"type":"Emphasis","content":["UBA5"]}," variants cause developmental and epileptic encephalopathy 44 (DEE44, OMIM: #617132). The disease is characterized by early-onset encephalopathy, movement abnormalities, global developmental delay, and intellectual disability. Many individuals also have seizures, failure to thrive, and microcephaly. Delayed myelination, thinning of the corpus callosum, and white matter hyperintensities have also been documented with magnetic resonance imaging (MRI) (",{"type":"Cite","target":"c8","content":["Colin ",{"type":"Emphasis","content":["et al"]},", 2016"]},"; ",{"type":"Cite","target":"c37","content":["Muona ",{"type":"Emphasis","content":["et al"]},", 2016"]},"). Biallelic ",{"type":"Emphasis","content":["UBA5"]}," has also been associated with spinocerebellar ataxia 24 (OMIM: #617133), which is characterized by a childhood-onset gait and limb ataxia (",{"type":"Cite","target":"c12","content":["Duan ",{"type":"Emphasis","content":["et al"]},", 2016"]},"). Another family has been reported with a rare homozygous missense variant in ",{"type":"Emphasis","content":["UBA5"]}," that segregates with severe congenital neuropathy (",{"type":"Cite","target":"c6","content":["Cabrera-Serrano ",{"type":"Emphasis","content":["et al"]},", 2020"]},")."]},{"type":"Paragraph","content":["UBA5 is a key component in UFMylation, a post-translational modification pathway mediated by a ubiquitin-like protein (UBL) ubiquitin fold modifier 1 (UFM1) (",{"type":"Cite","target":"c36","content":["Millrine ",{"type":"Emphasis","content":["et al"]},", 2023"]},"). UBL modifications play an essential role in eukaryotic biology by regulating protein stability and function via different enzymatic complexes (",{"type":"Cite","target":"c7","content":["Cappadocia \u0026 Lima, 2018"]},"; ",{"type":"Cite","target":"c53","content":["van der Veen \u0026 Ploegh, 2012"]},"). UFMylation is conserved in metazoans and plants (",{"type":"Link","relation":"fig","target":"#fig1","content":["Figure 1A"]},") (",{"type":"Cite","target":"c36","content":["Millrine ",{"type":"Emphasis","content":["et al"]},"., 2023"]},"). In this pathway, UFM1 is first proteolytically processed by a UFM1 specific peptidase 1/2 (UFSP1/2) to expose a C-terminal Gly (",{"type":"Cite","target":"c21","content":["Kang ",{"type":"Emphasis","content":["et al"]},", 2007"]},"; ",{"type":"Cite","target":"c22","content":["Komatsu ",{"type":"Emphasis","content":["et al"]},", 2004"]},"; ",{"type":"Cite","target":"c35","content":["Millrine ",{"type":"Emphasis","content":["et al"]},", 2022"]},"). The ensuing conjugation process involves three steps. The first two steps are facilitated by UBA5, an E1 activating enzyme specific to UFMylation. UBA5 activates UFM1 through ATP-dependent adenylation of the UFM1 C-terminal Gly, which is then transferred onto the UBA5 active site Cys 250, forming a high-energy thioester intermediate. Next, the UFM1-specific E2 conjugating enzyme, UFC1, binds to the activated UBA5∼UFM1 intermediate and receives UFM1 onto its active site Cys through a transthiolation reaction (",{"type":"Link","relation":"fig","target":"#fig1","content":["Figure 1A"]},") (",{"type":"Cite","target":"c15","content":["Gavin ",{"type":"Emphasis","content":["et al"]},", 2014"]},"; ",{"type":"Cite","target":"c22","content":["Komatsu ",{"type":"Emphasis","content":["et al"]},"., 2004"]},"). The UFM1 activation and transthiolation processes are achieved by a trans-binding mechanism involving two molecules each of UBA5, UFM1, and UFC1, wherein one UBA5 protomer performs the enzymatic processes while the other provides essential UFM1- and UFC1-binding sites ",{"type":"Emphasis","content":["in trans"]}," (",{"type":"Link","relation":"fig","target":"#fig1","content":["Figure 1B"]},") (",{"type":"Cite","target":"c23","content":["Kumar ",{"type":"Emphasis","content":["et al"]},", 2021"]},"; ",{"type":"Cite","target":"c33","content":["Mashahreh ",{"type":"Emphasis","content":["et al"]},", 2018"]},"; ",{"type":"Cite","target":"c41","content":["Oweis ",{"type":"Emphasis","content":["et al"]},", 2016"]},"). Next, the E3 ligase UFL1 functions as a scaffold to bring the activated UFC1∼UFM1 conjugate to the substrate protein and facilitate the conjugation of UFM1 to a substrate Lys residue (",{"type":"Cite","target":"c43","content":["Peter ",{"type":"Emphasis","content":["et al"]},", 2022"]},"; ",{"type":"Cite","target":"c50","content":["Tatsumi ",{"type":"Emphasis","content":["et al"]},", 2010"]},")."]},{"type":"Figure","id":"fig1","caption":[{"type":"Heading","depth":1,"content":["UFMylation pathway, conservation of UBA5, and generation of fly ",{"type":"Emphasis","content":["Uba5"]}," LoF alleles"]},{"type":"Paragraph","content":["(A) A diagram showing the UFMylation pathway. Details of the biochemical processes in the pathway are described in the main text. In UBA5 proteins, only the adenylation domains are shown in the diagram. (B) A diagram of the UBA5:UFM1:UFC1 complex. In the complex, two copies of UBA5 form a homodimer that interacts with UFM1 via a trans-binding mechanism. The activation of UFM1 requires the adenylation domain of one UBA5 subunit and the UFM1-interacting sequence (UIS) of the other UBA5 subunit in the complex. The opposing protomer of the UBA5 homodimer also contributes a UFC1-binding sequence (UBS) that is required for UFM1 transthiolation. (C) Alignment of the human UBA5 and fly Uba5 protein sequences. The functional domains of UBA5 are marked in colored boxes. The DEE44-associated variants are marked in the protein topology diagram and the protein sequence alignment (letters in red). (D) Generation of the ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}]}," allele and the uses of the allele in flippase (FLP)-mediated conversion. The expression of the GAL4 to drive a fluorescent protein allows assessment of gene expression, and humanization of the flies by expression of human ",{"type":"Emphasis","content":["UBA5"]}," cDNA. (E) Generation of ",{"type":"Emphasis","content":["Uba5"]}," null allele by CRISPR-mediated indel formation. (F) Loss of ",{"type":"Emphasis","content":["Uba5"]}," causes lethality in early developmental stage. The lethality is rescued by a genomic rescue construct, the expression of FLP (",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}]}," mutants only), and the expression of human ",{"type":"Emphasis","content":["UBA5"]}," cDNA."]}],"label":"Figure 1.","content":[{"type":"ImageObject","contentUrl":"89891/v2/content/23292782v2_fig1.tif","mediaType":"image/tiff","meta":{"inline":false}}]},{"type":"Paragraph","content":["UFMylation has been implicated in regulating many processes such as genome stability and receptor activation (",{"type":"Cite","target":"c28","content":["Liu ",{"type":"Emphasis","content":["et al"]},", 2020"]},"; ",{"type":"Cite","target":"c45","content":["Qin ",{"type":"Emphasis","content":["et al"]},", 2019"]},"; ",{"type":"Cite","target":"c58","content":["Wang ",{"type":"Emphasis","content":["et al"]},", 2019"]},"; ",{"type":"Cite","target":"c61","content":["Yoo ",{"type":"Emphasis","content":["et al"]},", 2014"]},"), but the principal role is believed to be in regulating proteotoxic stress at the endoplasmic reticulum (ER), where UFMylation of stalled ribosomes initiates quality control measures (",{"type":"Cite","target":"c27","content":["Liang ",{"type":"Emphasis","content":["et al"]},", 2020"]},"; ",{"type":"Cite","target":"c47","content":["Scavone ",{"type":"Emphasis","content":["et al"]},", 2023"]},"; ",{"type":"Cite","target":"c56","content":["Walczak ",{"type":"Emphasis","content":["et al"]},", 2019"]},"; ",{"type":"Cite","target":"c57","content":["Wang ",{"type":"Emphasis","content":["et al"]},", 2020"]},"). So far, the only well-characterized ",{"type":"Emphasis","content":["Uba5"]}," mutant animal model is a mouse model in which removal of the gene causes embryonic lethality due to hematopoietic defects (",{"type":"Cite","target":"c51","content":["Tatsumi ",{"type":"Emphasis","content":["et al"]},", 2011"]},"). Tissue-specific mouse knockouts of other genes within the UFMylation pathway support a role in regulating ER stress within secretory cells, as well as a critical developmental role within the central nervous system (",{"type":"Cite","target":"c37","content":["Muona ",{"type":"Emphasis","content":["et al"]},"., 2016"]},"; ",{"type":"Cite","target":"c62","content":["Zhu ",{"type":"Emphasis","content":["et al"]},", 2019"]},")."]},{"type":"Paragraph","content":["To date, 24 individuals from 17 families who have ",{"type":"Emphasis","content":["UBA5"]},"-associated DEE44 have been reported (",{"type":"Cite","target":"c1","content":["Arnadottir ",{"type":"Emphasis","content":["et al"]},", 2017"]},"; ",{"type":"Cite","target":"c5","content":["Briere ",{"type":"Emphasis","content":["et al"]},", 2021"]},"; ",{"type":"Cite","target":"c8","content":["Colin ",{"type":"Emphasis","content":["et al"]},"., 2016"]},"; ",{"type":"Cite","target":"c9","content":["Daida ",{"type":"Emphasis","content":["et al"]},", 2018"]},"; ",{"type":"Cite","target":"c29","content":["Low ",{"type":"Emphasis","content":["et al"]},", 2019"]},"; ",{"type":"Cite","target":"c34","content":["Mignon-Ravix ",{"type":"Emphasis","content":["et al"]},", 2018"]},"; ",{"type":"Cite","target":"c37","content":["Muona ",{"type":"Emphasis","content":["et al"]},"., 2016"]},"). The genotypes (Table S1) and clinical features (Table S2) of the affected individuals are summarized in Supplemental Information. Prior functional studies using cultured cells or patient cells show that many reported ",{"type":"Emphasis","content":["UBA5"]}," variants cause various levels of loss of function (LoF). However, the study of the genotype-phenotype relationship is hampered by the limited number of affected individuals, incomplete description of clinical presentations and the heterogeneous genetic background. Variant-specific ",{"type":"Emphasis","content":["in vivo"]}," models are powerful tools for studying genotype-phenotype relationship, especially for rare diseases (",{"type":"Cite","target":"c1","content":["Arnadottir ",{"type":"Emphasis","content":["et al"]},"., 2017"]},"; ",{"type":"Cite","target":"c16","content":["Goodman ",{"type":"Emphasis","content":["et al"]},", 2021"]},"; ",{"type":"Cite","target":"c30","content":["Lu ",{"type":"Emphasis","content":["et al"]},", 2022a"]},"; ",{"type":"Cite","target":"c31","content":["Lu ",{"type":"Emphasis","content":["et al"]},", 2022b"]},"; ",{"type":"Cite","target":"c32","content":["Ma ",{"type":"Emphasis","content":["et al"]},", 2023"]},"; ",{"type":"Cite","target":"c52","content":["Tepe ",{"type":"Emphasis","content":["et al"]},", 2023"]},"). However, systematic assessment of the effects of disease-causing variants ",{"type":"Emphasis","content":["in vivo"]}," is a challenge as it can be very labor intensive. Moreover, the ",{"type":"Emphasis","content":["in vivo"]}," assays should be compared to functional studies of the variant proteins, which typically relies on biochemical or other cell-based assays that are not available for most proteins/genes. By combining phenotypic studies and biochemical assays it should be possible to assess the severity of each variant, providing valuable information for the affected individuals and for assessing possible therapeutic interventions. In addition, genotype-phenotype relationships offer information about the molecular basis underlying variants LoF, paving the way for future therapeutic development."]},{"type":"Paragraph","content":["In this study, we assess the genotype-phenotype relationship in ",{"type":"Emphasis","content":["UBA5"]},"-associated DEE44 variants by determining the phenotypes of variant-specific fruit fly models. In conjunction with the ",{"type":"Emphasis","content":["in vivo"]}," data, we also comprehensively assess the biochemical properties of each variant using assays that report on protein stability, ATP binding, UFM1 activation, and UFM1 transthiolation. The presence and severity of the phenotypes in flies are highly variant-dependent. Similarly, the enzymatic activities of the variants vary widely ",{"type":"Emphasis","content":["in vitro"]},". Interestingly, both ",{"type":"Emphasis","content":["in vivo"]}," and ",{"type":"Emphasis","content":["in vitro"]}," assays produce a very similar allelic series for the variants, suggesting a correlation between specific enzymatic properties and the phenotypes in the animal models. Finally, combining our animal model work with available insights into UBA5 enzymology provides us with a much better understanding of the structure-function relationship of the UBA5 variants."]},{"type":"Heading","id":"s2","depth":1,"content":["Results"]},{"type":"Heading","id":"s2a","depth":2,"content":["Establishment of a variant-specific UBA5-associated disease model in fruit flies"]},{"type":"Paragraph","content":["To investigate the functions of ",{"type":"Emphasis","content":["UBA5"]}," variants ",{"type":"Emphasis","content":["in vivo"]},", we utilized ",{"type":"Emphasis","content":["Drosophila melanogaster"]}," as a model organism. ",{"type":"Emphasis","content":["Uba5"]}," is the ortholog of human ",{"type":"Emphasis","content":["UBA5"]}," in flies (",{"type":"Emphasis","content":["UBA5"]}," refers to the human gene; ",{"type":"Emphasis","content":["Uba5"]}," refers to the fly gene). The two proteins share 64% identity and 75% similarity in amino acid sequence, and the ",{"type":"Emphasis","content":["Drosophila"]}," Integrative Ortholog Prediction Tool (DIOPT) score between ",{"type":"Emphasis","content":["UBA5"]}," and ",{"type":"Emphasis","content":["Uba5"]}," is 15/16, indicating a high degree of homology (",{"type":"Link","relation":"fig","target":"#fig1","content":["Figure 1C"]},") (",{"type":"Cite","target":"c20","content":["Hu ",{"type":"Emphasis","content":["et al"]},", 2021"]},"). The UBA5 protein has an adenylation domain, a UFM1-interacting sequence (UIS) and a UFC1-binding sequence (UBS), all of which are required for UFM1 activation and transthiolation (",{"type":"Cite","target":"c2","content":["Bacik ",{"type":"Emphasis","content":["et al"]},", 2010"]},"; ",{"type":"Cite","target":"c17","content":["Habisov ",{"type":"Emphasis","content":["et al"]},", 2016"]},"; ",{"type":"Cite","target":"c23","content":["Kumar ",{"type":"Emphasis","content":["et al"]},"., 2021"]},"; ",{"type":"Cite","target":"c42","content":["Padala ",{"type":"Emphasis","content":["et al"]},", 2017"]},"; ",{"type":"Cite","target":"c60","content":["Xie, 2014"]},") (",{"type":"Link","relation":"fig","target":"#fig1","content":["Figure 1C"]},"). Similarly, Uba5 has all three highly conserved functional domains, and all of the amino acid residues affected by the DEE44-associated variants reported so far are conserved in the fly protein (",{"type":"Link","relation":"fig","target":"#fig1","content":["Figure 1C"]},")."]},{"type":"Paragraph","content":["To study the variant-specific functions, we generated humanized fruit fly models in which the expression of the endogenous ",{"type":"Emphasis","content":["Uba5"]}," gene is removed or severely suppressed and a human ",{"type":"Emphasis","content":["UBA5"]}," cDNA is expressed under the control of the endogenous ",{"type":"Emphasis","content":["Uba5"]}," enhancer and promoter. If the human reference UBA5 functions in flies and rescues the ",{"type":"Emphasis","content":["Uba5"]}," severe LoF phenotypes, the DEE44-associated variants can be expressed and their functions can be assessed by the phenotypes of flies. To achieve this, we generated a ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}]}," allele using a CRISPR-Mediated Integration Cassette (CRIMIC) strategy (",{"type":"Cite","target":"c25","content":["Lee ",{"type":"Emphasis","content":["et al"]},", 2018"]},"). In the ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}]}," allele, an ",{"type":"Emphasis","content":["FRT"]},"-",{"type":"Emphasis","content":["Splice Acceptor (SA)-T2A-GAL4-polyA-FRT"]}," cassette was inserted into a coding intron of the ",{"type":"Emphasis","content":["Uba5"]}," gene. The SA causes the inclusion of the cassette during transcription, while the polyA sequence arrests the transcription generating a truncated transcript. The translation of the transcript is arrested at the viral ribosomal skipping site (T2A) and reinitiated after the site, producing an untagged GAL4 protein (",{"type":"Link","relation":"fig","target":"#fig1","content":["Figure 1D"]},") (",{"type":"Cite","target":"c11","content":["Diao ",{"type":"Emphasis","content":["et al"]},", 2015"]},"; ",{"type":"Cite","target":"c25","content":["Lee ",{"type":"Emphasis","content":["et al"]},"., 2018"]},"). The ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}]}," allele is likely a severe LoF allele (see below) (",{"type":"Cite","target":"c25","content":["Lee ",{"type":"Emphasis","content":["et al"]},"., 2018"]},"). In addition, this allele also results in the expression of GAL4 under the control of the endogenous ",{"type":"Emphasis","content":["Uba5"]}," enhancer and promoter, which enables the assessment of native gene expression pattern as well as the expression of human ",{"type":"Emphasis","content":["UBA5"]}," cDNA (",{"type":"Link","relation":"fig","target":"#fig1","content":["Figure 1D"]},"). We also generated a ",{"type":"Emphasis","content":["Uba5"]}," null allele by CRISPR-induced indel formation (",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["p.Arg55Profs*87"]}]},", named ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["KO"]}]},") (",{"type":"Link","relation":"fig","target":"#fig1","content":["Figure 1E"]},")."]},{"type":"Paragraph","content":["We first tested the viability of the flies with the ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}]}," and the ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["KO"]}]}," alleles. The fly ",{"type":"Emphasis","content":["Uba5"]}," gene is located on the X chromosome. For both alleles, homozygous female and hemizygous male flies are lethal at the embryonic stage, although a few ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}]}," escapers survive to the L1 larval stage (",{"type":"Link","relation":"fig","target":"#fig1","content":["Figure 1F"]},"). The lethality is rescued by a genomic rescue (GR) construct that carries the ",{"type":"Emphasis","content":["Uba5"]}," locus (P[acman] clone CH321-02B13) (",{"type":"Cite","target":"c55","content":["Venken ",{"type":"Emphasis","content":["et al"]},", 2010"]},"), indicating that the lethality in both lines is caused by the LoF of ",{"type":"Emphasis","content":["Uba5"]},". Moreover, expression of flippase (FLP) using ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}]}," removes the insertion of the CRIMIC cassette and reverts the lethality of the ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}]}," hemizygous males, showing that the lethality is indeed caused by the ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}]}," allele (",{"type":"Link","relation":"fig","target":"#fig1","content":["Figure 1F"]},") (",{"type":"Cite","target":"c25","content":["Lee ",{"type":"Emphasis","content":["et al"]},"., 2018"]},"). Finally, expression of reference human ",{"type":"Emphasis","content":["UBA5"]}," cDNA using ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}]}," rescues the lethality of the mutants, showing that the functions of the fly and human proteins are evolutionarily conserved (",{"type":"Link","relation":"fig","target":"#fig1","content":["Figure 1F"]},")."]},{"type":"Heading","id":"s2b","depth":2,"content":["Uba5 is expressed in a subset of neurons and glia in the fly central nervous system"]},{"type":"Paragraph","content":["Next, we examined the expression pattern of ",{"type":"Emphasis","content":["Uba5"]}," by expressing a nuclear localized mCherry fluorescent protein (",{"type":"Emphasis","content":["UAS-mCherry.nls"]},") under the control of ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}]},". ",{"type":"Emphasis","content":["Uba5"]}," is expressed in multiple tissues in L3 larvae and adult flies (",{"type":"Link","relation":"fig","target":"#fig2","content":["Figure 2A"]},"), consistent with high-throughput gene expression profiling results (Fig. S2A) (",{"type":"Cite","target":"c24","content":["Leader ",{"type":"Emphasis","content":["et al"]},", 2018"]},"; ",{"type":"Cite","target":"c26","content":["Li ",{"type":"Emphasis","content":["et al"]},", 2022"]},"). We next analyzed the expression of ",{"type":"Emphasis","content":["Uba5"]}," in the central nervous system (CNS). We stained the ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]},"\u003emCherry.nls"]}," larval CNS and adult brain with anti-Elav and anti-Repo antibodies to mark the nuclei of neurons and glial cells, respectively. In both larval CNS and adult brain, the mCherry.nls signals are found in a subset of neurons and glia (",{"type":"Link","relation":"fig","target":"#fig2","content":["Figures 2B"]}," and ",{"type":"Link","relation":"fig","target":"#fig2","content":["2C"]},"), suggesting that ",{"type":"Emphasis","content":["Uba5"]}," is expressed in the fly CNS but not in all cells. This finding is also consistent with the previously published single-cell RNA sequencing profile (Fig. S2B) (",{"type":"Cite","target":"c10","content":["Davie ",{"type":"Emphasis","content":["et al"]},", 2018"]},"). ",{"type":"Emphasis","content":["Uba5"]}," is expressed more widely in the adult brains than in the larval CNS. In larval CNS, it is expressed in many fewer neurons than Elav (",{"type":"Link","relation":"fig","target":"#fig2","content":["Figures 2A"]}," and ",{"type":"Link","relation":"fig","target":"#fig2","content":["2B"]},"). The expression pattern resembles that of the ",{"type":"Emphasis","content":["para"]}," gene, which encodes the sole voltage-gated sodium channel in ",{"type":"Emphasis","content":["Drosophila"]}," that is only expressed in differentiated, actively firing neurons (",{"type":"Cite","target":"c46","content":["Ravenscroft ",{"type":"Emphasis","content":["et al"]},", 2020"]},"). This suggests that UBA5 may be required for the activity of neurons."]},{"type":"Figure","id":"fig2","caption":[{"type":"Heading","depth":1,"content":[{"type":"Emphasis","content":["Uba5"]}," is expressed in a subset of neurons and glial cells in fly CNS"]},{"type":"Paragraph","content":["(A) The expression of nuclear localized mCherry (mCherry.nls) driven by the ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}]}," allele (",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}," \u003e mCherry.nls"]},") shows that ",{"type":"Emphasis","content":["Uba5"]}," is expressed in L3 larvae and adult flies. (B and C) The larval CNS and adult brain of ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}," \u003e mCherry.nls"]}," animals were immunostained with a neuronal (Elav, Panel B) or glial marker (Repo, Panel C). Maximum projections of confocal z-stack images are shown. Single plane, high magnification images of the regions indicated by the dashed squares are shown on the right to visualize the colocalizations between mCherry and the immunostaining signals. Arrows indicate cells that colocalize both markers. Scale bar, 100 μm."]}],"label":"Figure 2.","content":[{"type":"ImageObject","contentUrl":"89891/v2/content/23292782v2_fig2.tif","mediaType":"image/tiff","meta":{"inline":false}}]},{"type":"Paragraph","content":["Since ",{"type":"Emphasis","content":["Uba5"]}," is expressed in multiple tissues in flies, we sought to determine the tissue specific requirement of ",{"type":"Emphasis","content":["Uba5"]}," for fly development. We expressed the reference ",{"type":"Emphasis","content":["UBA5"]}," cDNA in ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["KO"]}]}," hemizygous mutants using various GAL4 drivers and examined the viability of the animals. Ubiquitous expression of ",{"type":"Emphasis","content":["UBA5"]}," by ",{"type":"Emphasis","content":["da-Gal4"]}," or ",{"type":"Emphasis","content":["Act-Gal4"]}," fully rescues the lethality of the mutant animals. However, tissue-specific expression of ",{"type":"Emphasis","content":["UBA5"]}," in fat body (",{"type":"Emphasis","content":["lpp-Gal4"]},"), muscles (",{"type":"Emphasis","content":["Mef2-Gal4"]},"), neurons (",{"type":"Emphasis","content":["Elav-Gal4"]},"), or glial cells (",{"type":"Emphasis","content":["Repo-Gal4"]},") fails to rescue the lethality (Fig. S2C). Hence, we conclude that ",{"type":"Emphasis","content":["Uba5"]}," is required in multiple tissues. Interestingly, overexpression of ",{"type":"Emphasis","content":["UBA5"]}," in ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["KO"]},"/+"]}," heterozygous flies does not cause any obvious phenotype (Fig. S2C), showing that ",{"type":"Emphasis","content":["Uba5"]}," overexpression is not overtly toxic."]},{"type":"Heading","id":"s2c","depth":2,"content":["DEE44-associated variants exhibit different rescuing abilities in flies"]},{"type":"Paragraph","content":["Next, we sought to evaluate the function of ",{"type":"Emphasis","content":["UBA5"]}," variants using the humanized fly model (",{"type":"Cite","target":"c3","content":["Bellen \u0026 Yamamoto, 2015"]},"). We expressed reference or variant ",{"type":"Emphasis","content":["UBA5"]}," cDNA and DEE44-associated ",{"type":"Emphasis","content":["UBA5"]}," variants using ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}]}," and measured phenotypes including survival rate, developmental timing, lifespan, locomotor activity, and seizure-like activity following mechanical stimulation in ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}]}," hemizygous male flies. The variants we tested include all previously reported variants (",{"type":"Cite","target":"c1","content":["Arnadottir ",{"type":"Emphasis","content":["et al"]},"., 2017"]},"; ",{"type":"Cite","target":"c5","content":["Briere ",{"type":"Emphasis","content":["et al"]},"., 2021"]},"; ",{"type":"Cite","target":"c8","content":["Colin ",{"type":"Emphasis","content":["et al"]},"., 2016"]},"; ",{"type":"Cite","target":"c9","content":["Daida ",{"type":"Emphasis","content":["et al"]},"., 2018"]},"; ",{"type":"Cite","target":"c29","content":["Low ",{"type":"Emphasis","content":["et al"]},"., 2019"]},"; ",{"type":"Cite","target":"c34","content":["Mignon-Ravix ",{"type":"Emphasis","content":["et al"]},"., 2018"]},"; ",{"type":"Cite","target":"c37","content":["Muona ",{"type":"Emphasis","content":["et al"]},"., 2016"]},"), as well as a novel variant from an individual we report in this study. This individual has compound heterozygous variants in ",{"type":"Emphasis","content":["UBA5"]},", p.Met57Val and p.Gln312Leu (Table S3), and presents with hypotonia, generalized dystonia, lower extremity spasticity, global developmental delay, and failure to thrive. However, this individual is so far seizure free. Further clinical details of the individual are summarized in Supplemental Information."]},{"type":"Paragraph","content":["We first assessed the ability of the variants to rescue the lethality of ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}]}," mutants. Flies were raised at three different temperatures: 29 °C, 25 °C, and 18 °C. Lower temperatures lead to lower expression levels of ",{"type":"Emphasis","content":["UBA5"]}," when compared to higher temperatures (",{"type":"Cite","target":"c38","content":["Nagarkar-Jaiswal ",{"type":"Emphasis","content":["et al"]},", 2015"]},"). At all temperatures, a synthetic enzyme-dead ",{"type":"Emphasis","content":["UBA5"]}," mutant p.Cys250Ala failed to rescue lethality (",{"type":"Link","relation":"fig","target":"#fig3","content":["Figure 3A"]},"). Similarly, four DEE44-associated variants (p.Arg55His, p.Gly168Glu, p.Leu254Pro, p.Cys303Arg) failed to rescue the lethality at all temperatures tested, indicating that they are severe LoF. Three variants (p.Tyr53Phe, p.Met57Val, p.Val260Met) partially rescued the lethality at 18 °C and the survival rate increased at elevated temperatures (",{"type":"Link","relation":"fig","target":"#fig3","content":["Figure 3A"]},"). This suggests that the three variants are likely hypomorphic alleles and supports a dosage-sensitive effect of ",{"type":"Emphasis","content":["Uba5"]},". However, six variants (p.Arg72Cys, p.Val260Met, p.Gln312Leu, p.Ala371Thr, p.Asp389Gly, p.Asp389Tyr) fully rescued lethality, suggesting they are mild LoF or do not affect protein function. Based on these results, we stratified the variants into three groups according to the activity of rescuing lethality: Group I, full rescue; Group II, partial rescue; Group III, failure to rescue (",{"type":"Link","relation":"table","target":"#tbl1","content":["Table 1"]},", Group I was further divided into IA and IB according to the other phenotypes described below)."]},{"type":"Figure","id":"fig3","caption":[{"type":"Heading","depth":1,"content":["DEE44-associated variants exhibit different rescuing abilities in flies"]},{"type":"Paragraph","content":["(A) The DEE44-associated ",{"type":"Emphasis","content":["UBA5"]}," variants rescued the lethality of ",{"type":"Emphasis","content":["Uba5"]}," mutant flies with varying efficiency. ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]},"/FM7"]}," females were crossed with ",{"type":"Emphasis","content":["UAS-UBA5"]}," males and the viability of ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]},"/Y; UAS-UBA5/+"]}," progenies were measured by Mendelian ratio and indicated by color codes: red, zero viability; yellow, partial viability (\u003c 90% of expected number); green, full viability (90% and above). (B) Three variants caused developmental delay in ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]},"/Y; UAS-UBA5/+"]}," flies. The embryos were collected within 6 hours and the number of eclosed adult flies was counted at the same time every day. Three replicates were performed in each group. (C) Five variants caused reduced lifespan in ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]},"/Y; UAS-UBA5/+"]}," flies. (D) Five variants caused progressive climbing defects in ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]},"/Y; UAS-UBA5/+"]}," flies. Flies were tested on Day 7 and Day 30. The climbing activity of ",{"type":"Emphasis","content":["CantonS"]}," wildtype flies is shown as reference. Numbers of animals (n values) in each group are indicated under the bars. (E) Three variants caused a bang-sensitive phenotype in ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]},"/Y; UAS-UBA5/+"]}," flies. Flies were tested on Day 30. The bang-sensitivity of ",{"type":"Emphasis","content":["CantonS"]}," wildtype flies is shown as reference. Numbers of animals (n values) in each group are indicated under the bars. (B-E) Flies were cultured under 25 °C. The results of DEE4 variant-expressing flies are compared with the result of reference ",{"type":"Emphasis","content":["UBA5"]},"-expressing flies. Results are presented as means ± SEM. Statistical analyses were performed via two-sided, unpaired Student’s t-test. ns, not significant; *p\u003c0.05; **p\u003c0.01; ***p\u003c0.001; ****p\u003c0.0001."]}],"label":"Figure 3.","content":[{"type":"ImageObject","contentUrl":"89891/v2/content/23292782v2_fig3.tif","mediaType":"image/tiff","meta":{"inline":false}}]},{"type":"Figure","id":"tbl1","caption":[{"type":"Heading","depth":3,"content":["Summary of phenotypes of humanized flies expressing ",{"type":"Emphasis","content":["UBA5"]}," variants"]}],"label":"Table 1.","content":[{"type":"ImageObject","contentUrl":"89891/v2/content/23292782v2_tbl1.tif","mediaType":"image/tiff","meta":{"inline":false}}]},{"type":"Paragraph","content":["The variants that survive to adults were next tested for the time it takes for animals to eclose as adults, and lifespan. The variants in Group II exhibited significant developmental delay as well as a shortened lifespan, showing that they are partial LoF (",{"type":"Link","relation":"fig","target":"#fig3","content":["Figures 3B"]}," and ",{"type":"Link","relation":"fig","target":"#fig3","content":["3C"]},"). In contrast, some variants in Group I (Group 1A: p.Ala371Thr, p.Asp389Gly, and p.Asp389Tyr) caused neither defect. Other Group I variants (Group 1B: p.Arg72Cys and p.Gln312Leu) caused a shortened lifespan but did not affect the timing of development (",{"type":"Link","relation":"fig","target":"#fig3","content":["Figures 3B"]}," and ",{"type":"Link","relation":"fig","target":"#fig3","content":["3C"]},"), indicating that they are also partial LoF variants but could cause milder defects than Group II variants."]},{"type":"Paragraph","content":["To determine if the flies display features that are associated with dysfunction of the nervous system, we measured locomotor activity using a climbing assay and assessed susceptibility to seizures using a bang sensitivity assay (",{"type":"Cite","target":"c48","content":["Song \u0026 Tanouye, 2008"]},"). Flies with variants in Groups IB and II displayed reduced climbing activity at Day 7 and more severe defects by Day 30, showing a progressive worsening of the defects (",{"type":"Link","relation":"fig","target":"#fig3","content":["Figure 3D"]},"). Moreover, the variants in Group II exhibited a bang-sensitive phenotype by displaying seizure-like behavior and paralysis following mechanical stimulation (",{"type":"Link","relation":"fig","target":"#fig3","content":["Figure 3E"]},"). However, the Group IA variants displayed neither a climbing defect nor bang sensitivity (",{"type":"Link","relation":"fig","target":"#fig3","content":["Figures 3D"]}," and ",{"type":"Link","relation":"fig","target":"#fig3","content":["3E"]},"). These results are consistent with our classification of variants based on other assays: Group IA, no obvious LoF or benign; Groups IB and II, intermediate LoF; and Group III, severe LoF."]},{"type":"Paragraph","content":["Given the observed neurological defects, we tested whether the variants affect the synapse morphology of the neuromuscular junctions (NMJs) in third instar larvae. Although a previous study reported that knockdown of ",{"type":"Emphasis","content":["Uba5"]}," in motor neurons caused decreased number and increased size of synaptic boutons at the NMJs (",{"type":"Cite","target":"c12","content":["Duan ",{"type":"Emphasis","content":["et al"]},"., 2016"]},"), we did not observe any obvious changes in bouton number or size caused by the Group II variants (Figure S3A-S3C). Hence, we conclude that the synaptic growth of fly larvae is not affected by the ",{"type":"Emphasis","content":["UBA5"]}," variants."]},{"type":"Heading","id":"s2d","depth":2,"content":["Structural analysis of UBA5 variants"]},{"type":"Paragraph","content":["In order to link our findings in the fly model with functional changes in UBA5, we first analyzed the potential structural changes caused by the UBA5 variants. Extensive structural analyses have been performed on UBA5, including its ability to bind ATP and homodimerize within the adenylation domain, its interaction with UFM1 in the process of activation, and its engagement of UFC1 prior to UFM1 transthiolation (",{"type":"Cite","target":"c2","content":["Bacik ",{"type":"Emphasis","content":["et al"]},"., 2010"]},"; ",{"type":"Cite","target":"c23","content":["Kumar ",{"type":"Emphasis","content":["et al"]},"., 2021"]},"; ",{"type":"Cite","target":"c41","content":["Oweis ",{"type":"Emphasis","content":["et al"]},"., 2016"]},"; ",{"type":"Cite","target":"c42","content":["Padala ",{"type":"Emphasis","content":["et al"]},"., 2017"]},"; ",{"type":"Cite","target":"c49","content":["Soudah ",{"type":"Emphasis","content":["et al"]},", 2019"]},"; ",{"type":"Cite","target":"c59","content":["Wesch ",{"type":"Emphasis","content":["et al"]},", 2021"]},"). This structural detail of UBA5 function offers a unique opportunity to visualize the location of variants and categorize their predicted effects. We compiled a series of UBA5 structures to create a composite model that illustrates a) UBA5 homodimerization, b) ATP coordination, c) UFM1 binding, and d) UFC1 binding (",{"type":"Link","relation":"fig","target":"#fig4","content":["Figure 4A"]},"). Focusing on the UFM1 C-terminal Gly and the active site Cys residues of UBA5 and UFC1, the movements that occur during UFM1 activation and transthiolation can be mapped (",{"type":"Link","relation":"fig","target":"#fig4","content":["Figure 4A"]},", yellow spheres)."]},{"type":"Figure","id":"fig4","caption":[{"type":"Heading","depth":1,"content":["Structural analysis of UBA5 variants"]},{"type":"Paragraph","content":["(A) Composite model of a UBA5 homodimer (green and blue) bound to ATP (grey sticks), UFM1 (magenta), and UFC1 (gold). The model was built using a series of UBA5 complex structures with UFM1 and UFC1 (PDB 6H77, 7NW1, and a modelled UBA5:UFC1 complex(",{"type":"Cite","target":"c23","content":["Kumar ",{"type":"Emphasis","content":["et al"]},"., 2021"]},"; ",{"type":"Cite","target":"c49","content":["Soudah ",{"type":"Emphasis","content":["et al"]},"., 2019"]},"). Functional residues comprising the active site cysteines of UBA5 and UFC1, as well as the C-terminus of UFM1 are shown in yellow spheres. UBA5 variants are shown in red spheres and are labeled with their predicted structural effects. (B) Close-up view of variants (red sticks) within the UBA5 active site (yellow sphere), ATP binding pocket, and homodimerization interface. (C) Close-up view of variants (red sticks) expected to impact UBA5 protein stability (results shown in the following figures)."]}],"label":"Figure 4.","content":[{"type":"ImageObject","contentUrl":"89891/v2/content/23292782v2_fig4.tif","mediaType":"image/tiff","meta":{"inline":false}}]},{"type":"Paragraph","content":["With this structural model as a basis, we highlighted the location of all UBA5 variants (",{"type":"Link","relation":"fig","target":"#fig4","content":["Figure 4A"]},", red spheres). Variants at positions Asp389 and Ala371 lie outside of the regions with determined structure, so their locations are modeled based on all available data. All Group IA variants localize in proximity of the UBS in protein sequence. The p.Asp389Gly and p.Asp389Tyr variants affect Asp389 which is two amino acids upstream of the structurally-resolved UBS. For p.Ala371Thr, although there is no structure of this region, previous biochemical and crosslinking data have demonstrated its proximity to the UFC1 active site (",{"type":"Cite","target":"c23","content":["Kumar ",{"type":"Emphasis","content":["et al"]},"., 2021"]},"). Four variants, p.Tyr53Phe, p.Arg55His, p.Met57Val, and p.Arg72Cys, affect residues near the ATP-binding site (",{"type":"Link","relation":"fig","target":"#fig4","content":["Figure 4B"]},"). The side chain of Arg55 makes direct contacts to the bound ATP, while Met57 and Tyr53 make secondary contacts behind this site, and Arg72 makes more distant tertiary contacts. Substitutions at these positions, therefore, may affect the affinity of UBA5 toward ATP. Residue Leu254 is four amino acids downstream of the active site Cys250, contained within a loop region that must undergo conformational changes to support UFM1 activation and subsequent transthiolation (",{"type":"Link","relation":"fig","target":"#fig4","content":["Figures 4A"]}," and ",{"type":"Link","relation":"fig","target":"#fig4","content":["4B"]},"). The Pro substitution within the p.Leu254Pro variant may constrain the required flexibility of the Cys250 loop, thus impacting ATP binding, UFM1 activation, and UFM1 transthiolation. Val260 is buried within the UBA5 homodimeric interface, opposing residue Val260 of the second protomer (",{"type":"Link","relation":"fig","target":"#fig4","content":["Figure 4B"]},"). The increased size of the p.Val260Met variant may cause a steric clash that reduces UBA5 dimerization, which would decrease ATP binding, UFM1 activation, and UFM1 transthiolation as a result. Positions Cys303 and Gly168 are fully buried, making structural contacts to support the fold of the adenylation domain (",{"type":"Link","relation":"fig","target":"#fig4","content":["Figure 4C"]},"). The increased size and charge associated with the p.Cys303Arg and p.Gly168Glu variants would most likely cause significant defects in UBA5 folding and stability. Lastly, the site of the novel p.Gln312Leu variant reported here is partially buried, making structural contacts to a loop region underneath the UFM1-binding site, and thus substitutions at this site may also cause structural instability (",{"type":"Link","relation":"fig","target":"#fig4","content":["Figure 4C"]},")."]},{"type":"Heading","id":"s2e","depth":2,"content":["Generation and characterization of purified UBA5 variant proteins"]},{"type":"Paragraph","content":["To determine the functional capacity of the UBA5 variants, we expressed and purified reference and variant UBA5 proteins from ",{"type":"Emphasis","content":["Escherichia coli"]}," for biochemical assays. Two severe LoF (Group III) variants p.Gly168Glu and p.Cys303Arg were insoluble in the protein purification process, indicating that the variants influence the stability and/or folding of these proteins. We were able to obtain pure and homogeneous samples of all other UBA5 constructs (",{"type":"Link","relation":"fig","target":"#fig5","content":["Figure 5A"]},"). For our first measure of UBA5 function, we measured the effects of each variant on protein stability using a thermal shift assay. Under our assay conditions, reference UBA5 demonstrated a melting temperature (Tm) of 46 °C. While most UBA5 variants exhibited little-to-no change in Tm, several showed a subtle destabilization by ≥1 °C, including p.Arg72Cys, p.Leu254Pro, p.Val260Met, and p.Ala371Thr (",{"type":"Link","relation":"fig","target":"#fig5","content":["Figure 5B"]},"). Interestingly, the Group IB variant p.Gln312Leu exhibited a minor unfolding at 36 °C before fully melting at 48 °C. This could indicate destabilization in the local structure surrounding the Gln312Leu substitution, while leaving the remaining protein structure intact."]},{"type":"Figure","id":"fig5","caption":[{"type":"Heading","depth":1,"content":["Preparation and stability of UBA5 variant proteins"]},{"type":"Paragraph","content":["(A) Coomassie-stained SDS-PAGE analysis of all purified UBA5 variant proteins. (B) Thermal shift assay measuring the melting temperature (Tm) of all UBA5 variant proteins, with the exception of p.Gly168Glu and p.Cys303Arg which could not be produced. The p.Gln312Leu variant displayed two melting curves. Experiments were performed in triplicate over three biological replicates. (C) Change in melting temperature for all UBA5 variants in the presence of 5 mM ATP. Upon ATP addition, the p.Gln312Leu variant transitioned to a single melting curve. Experiments were performed in triplicate over three biological replicates. (B-C) Statistical analyses were performed via unpaired Student’s t-test. ns, not significant; *p\u003c0.05; **p\u003c0.01; ***p\u003c0.001; ****p\u003c0.0001."]}],"label":"Figure 5.","content":[{"type":"ImageObject","contentUrl":"89891/v2/content/23292782v2_fig5.tif","mediaType":"image/tiff","meta":{"inline":false}}]},{"type":"Paragraph","content":["Ligand binding can stabilize protein structure and lead to a shift in Tm toward higher temperatures. This has been shown previously in the case of UBA5 binding to ATP, where it was determined to interact with a K",{"type":"Subscript","content":["D"]}," of ∼700 µM (",{"type":"Cite","target":"c33","content":["Mashahreh ",{"type":"Emphasis","content":["et al"]},"., 2018"]},"). The ATP-dependent stabilization of UBA5 allowed us to assess mutational effects on ATP binding using the thermal shift assay. Whereas addition of 5 mM ATP led to a strong, 13 °C shift in the Tm of reference UBA5, many of the variants exhibited much weaker stabilization, indicative of a diminished capacity to bind ATP (",{"type":"Link","relation":"fig","target":"#fig5","content":["Figure 5C"]},"). The other two Group III variants and one Group II variant p.Tyr53Phe showed the strongest defect, with only 4-5 °C shifts in Tm upon addition of ATP. The Group II variants p.Met57Val and p.Val260Met as well as one Group IB variant p.Gln312Leu showed a milder effect with a 6-8 °C shift in Tm. One Group IB variant p.Arg72Cys and all Group IA variants showed similar ATP-dependent stabilization to reference UBA5. Unlike the melting trend observed in the absence of ATP, in the presence of ATP the p.Gln312Leu variant displayed a single unfolding profile, suggesting that ATP binding corrected the local instability caused by the substitution."]},{"type":"Paragraph","content":["These results show that not all tested variants strongly affect the stability of UBA5 protein. However, many variants impair the ATP binding capability of the protein. The levels of impairment correlate well with the phenotypic observations ",{"type":"Emphasis","content":["in vivo"]}," (",{"type":"Link","relation":"table","target":"#tbl1","content":["Table 1"]}," and 2), suggesting that the defect in ATP binding is a major contributor to the LoF associated with the variants. Consistent with their severe LoF ",{"type":"Emphasis","content":["in vivo"]},", variants p.Gly168Glu and p.Cys303Arg exhibited impaired protein folding and could not be included in our ",{"type":"Emphasis","content":["in vitro"]}," analyses."]},{"type":"Heading","id":"s2f","depth":2,"content":["Visualizing mutational effects on UFM1 activation and transthiolation"]},{"type":"Paragraph","content":["Previous functional characterization of UBA5 activity has relied upon gel-based assays that often lack kinetic information and are less sensitive to subtle changes. We sought to address this problem by developing a real-time, fluorescence polarization (FP) assay for UBA5 activity based upon a method we coined “UbiReal” (",{"type":"Cite","target":"c13","content":["Franklin \u0026 Pruneda, 2019"]},", ",{"type":"Cite","target":"c14","content":["2023"]},"). The approach leverages the large changes in molecular weight that occur as UFM1 is activated by UBA5 and transferred to UFC1 (",{"type":"Link","relation":"fig","target":"#fig6","content":["Figure 6A"]},"), which are read out as changes in FP of fluorescently-labeled UFM1. Indeed, upon addition of UBA5 we observed a large shift in FP of Alexa488-labeled UFM1, which reached a plateau over the course of ∼20 minutes under these conditions (",{"type":"Link","relation":"fig","target":"#fig6","content":["Figure 6B"]},"). Addition of UFC1 to the reaction caused a concomitant downward shift in FP that reached a new plateau within ∼5 minutes. To validate the molecular species observed in this assay, we ran samples from each stage of the reaction on non-reducing SDS-PAGE and were able to visualize free UFM1, UBA5∼UFM1, and UFC1∼UFM1 as predicted (",{"type":"Link","relation":"fig","target":"#fig6","content":["Figure 6C"]},")."]},{"type":"Figure","id":"fig6","caption":[{"type":"Heading","depth":1,"content":["Measuring UFM1 activation and transthiolation with UbiReal"]},{"type":"Paragraph","content":["(A) Cartoon schematic illustrating the complexes formed during UFM1 activation and transthiolation, as well as their expected molecular weights. The fluorescent group attached to UFM1 is denoted by an orange star. The expected molecular weight for the UBA5∼UFM1 intermediate is based on a UBA5 homodimer with one UFM1 molecule. (B) Proof-of-concept UbiReal assay monitoring the fluorescence polarization (FP) of Alexa488-labeled UFM1 alone (species 1), following addition of UBA5 (species 2), and following addition of UFC1 (species 3). (C) Fluorescence scan of samples described in (B) separated by SDS-PAGE, illustrating the formation of activated UFM1 complexes. Each species is labeled with the analogous cartoon schematic presented in (A). (D) UbiReal assay tracking UFM1 activation by reference and variant UBA5 proteins over time. (E) Area Under the Curve quantification of UFM1 activation performed at 22 °C. Experiments were performed in triplicate over three biological replicates. Statistical analyses were performed using a Welch’s t test with comparison to the reference UBA5 data. (F) As in (E), for reactions performed at 37 °C. (G) UbiReal assay tracking UFM1 transthiolation for reference UBA5 and variants that showed little or no effect on activation. (H) Area Under the Curve quantification of UFM1 transthiolation performed at 22 °C. Experiments were performed in triplicate over three biological replicates. Statistical analyses were performed using a Welch’s t test with comparison to the reference UBA5 data. (I) As in (H), for reactions performed at 37 °C. (E-F, H-I) Statistical analyses were performed via Welch’s t-test. *p\u003c0.05; **p\u003c0.01; ***p\u003c0.001; ****p\u003c0.0001."]}],"label":"Figure 6.","content":[{"type":"ImageObject","contentUrl":"89891/v2/content/23292782v2_fig6.tif","mediaType":"image/tiff","meta":{"inline":false}}]},{"type":"Paragraph","content":["With the UFM1 UbiReal assay in hand, we proceeded to assess the effects of UBA5 variant on the first step of the reaction: UFM1 activation. As anticipated, addition of reference UBA5 caused a rapid shift in FP over time, whereas the enzyme-dead p.Cys250Ala variant remained at baseline (",{"type":"Link","relation":"fig","target":"#fig6","content":["Figure 6D"]},"). We quantified these kinetic data with Area Under the Curve (AUC) analysis using data collected just before addition of UBA5 to establish a baseline. The panel of UBA5 variants displayed a wide range of effects. The two Group III variants p.Arg55His and p.Leu254Pro remained near the baseline, indicating a severe impairment in UFM1-activating function. An intermediate, statistically significant effect was observed with the p.Val260Met variant (Group II), while the remaining variants showed mild or, in the case of p.Ala371Thr (Group IA), no decrease in the rate of UFM1 activation (",{"type":"Link","relation":"fig","target":"#fig6","content":["Figure 6E"]},"). Similar trends were observed at both 22 °C and 37 °C, though interestingly the effect of p.Val260Met substitution was less severe at higher temperature (",{"type":"Link","relation":"fig","target":"#fig6","content":["Figure 6F"]},"). The results show that a defect in UFM1 activation contributes to the LoF in all variants except for p.Ala371Thr. The severity of LoF in UFM1 activation correlates with our phenotypic observations ",{"type":"Emphasis","content":["in vivo"]}," (",{"type":"Link","relation":"table","target":"#tbl1","content":["Table 1"]}," and 2)."]},{"type":"Paragraph","content":["Having observed defects in UFM1 activation for many of the UBA5 variants, we next analyzed those that exhibited mild or no effect for their ability to complete the second enzymatic role of UBA5: UFM1 transthiolation onto UFC1. After forming the activated UBA5∼UFM1 intermediates, we added UFC1 to the reactions and monitored the decay in FP over time (",{"type":"Link","relation":"fig","target":"#fig6","content":["Figure 6G"]},"). Though many of the UBA5 variants showed similar trends for transthiolation, the p.Ala371Thr variant immediately stood out for having no effect on UFM1 activation (",{"type":"Link","relation":"fig","target":"#fig6","content":["Figures 6D-6F"]},"), but a greatly impaired ability to transfer UFM1 onto UFC1 (",{"type":"Link","relation":"fig","target":"#fig6","content":["Figure 6G"]},"). We quantified the kinetic data using AUC analysis of the inverted curve and observed a remarkable defect in the ability of the p.Ala371Thr variant to catalyze UFM1 transthiolation (",{"type":"Link","relation":"fig","target":"#fig6","content":["Figure 6H"]},"). Interestingly, this defect is much more pronounced at 22 °C than at 37°C (",{"type":"Link","relation":"fig","target":"#fig6","content":["Figure 6I"]},"). These results suggest that aside from a minor decrease in UBA5 stability (",{"type":"Link","relation":"fig","target":"#fig5","content":["Figure 5B"]},"), UFM1 transthiolation is the only possible defect caused by the p.Ala371Thr variant. Transthiolation could be defective in other variants as well, such as p.Leu254Pro (Group III), but this effect is likely overshadowed by upstream effects on UBA5 stability, ATP binding, and/or UFM1 activation."]},{"type":"Heading","id":"s3","depth":1,"content":["Discussion"]},{"type":"Paragraph","content":["In this study, we assessed the strength and properties of variants identified in individuals with DEE44 using a humanization strategy in fruit flies. Germline knockout of ",{"type":"Emphasis","content":["Uba5"]}," causes embryonic lethality in both flies (this study) and mice (",{"type":"Cite","target":"c51","content":["Tatsumi ",{"type":"Emphasis","content":["et al"]},"., 2011"]},"), and no individuals have been identified with biallelic null variants in humans. The lethality of ",{"type":"Emphasis","content":["Uba5"]}," knockout mice is caused by hematopoietic defects (",{"type":"Cite","target":"c51","content":["Tatsumi ",{"type":"Emphasis","content":["et al"]},"., 2011"]},"), however, the clinical presentations in DEE44 patients are predominantly related to the central nervous system (",{"type":"Cite","target":"c1","content":["Arnadottir ",{"type":"Emphasis","content":["et al"]},"., 2017"]},"; ",{"type":"Cite","target":"c5","content":["Briere ",{"type":"Emphasis","content":["et al"]},"., 2021"]},"; ",{"type":"Cite","target":"c8","content":["Colin ",{"type":"Emphasis","content":["et al"]},"., 2016"]},"; ",{"type":"Cite","target":"c9","content":["Daida ",{"type":"Emphasis","content":["et al"]},"., 2018"]},"; ",{"type":"Cite","target":"c29","content":["Low ",{"type":"Emphasis","content":["et al"]},"., 2019"]},"; ",{"type":"Cite","target":"c34","content":["Mignon-Ravix ",{"type":"Emphasis","content":["et al"]},"., 2018"]},"; ",{"type":"Cite","target":"c37","content":["Muona ",{"type":"Emphasis","content":["et al"]},"., 2016"]},"). These findings suggest that DEE44 is caused by partial LoF of ",{"type":"Emphasis","content":["UBA5"]},", and that ",{"type":"Emphasis","content":["Uba5"]}," knockout models are not suitable to study disease pathogenesis. We generated a ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}]}," allele that corresponds to a severe LoF allele but also leads to expression of GAL4 in the same spatial and temporal expression pattern of ",{"type":"Emphasis","content":["Uba5"]},", which can then drive expression of the human ",{"type":"Emphasis","content":["UBA5"]}," cDNA (",{"type":"Link","relation":"fig","target":"#fig1","content":["Figure 1D"]},"). Expression of reference ",{"type":"Emphasis","content":["UBA5"]}," cDNA fully rescues the loss of ",{"type":"Emphasis","content":["Uba5"]},", showing that the proteins are functionally similar. This allowed us to assess the properties of the known ",{"type":"Emphasis","content":["UBA5"]}," variants and establish an allelic series ",{"type":"Emphasis","content":["in vivo"]},". We measured an array of phenotypes in flies that relate to the phenotypes observed in affected individuals, including developmental delay, motor defects, and bang sensitivity (seizure-like behavior). Based on the ",{"type":"Emphasis","content":["in vivo"]}," data we establish groups of variants with different strengths from least severe to most severe: Groups IA, IB, II, and III (",{"type":"Link","relation":"table","target":"#tbl1","content":["Table 1"]},"). To facilitate the discussion, hereafter we also refer to the deletion, nonsense, frameshift, and splicing variants observed in affected individuals as Group IV variants, although they were not functionally tested in this study."]},{"type":"Paragraph","content":["To correlate the allelic strength with the functional defects caused by the variants, we first examined the stability of UBA5 variants and assessed their activity in three key steps involved in UBA5 enzyme function: ATP binding, UFM1 activation, and UFM1 transthiolation. Two variants were not tested due to instability during protein purification, while all remaining tested variants exhibited defects in at least one assay, suggesting that they cause protein LoF (",{"type":"Link","relation":"table","target":"#tbl2","content":["Table 2"]},")."]},{"type":"Figure","id":"tbl2","caption":[{"type":"Heading","depth":2,"content":["Summary of protein stability and functions of UBA5 variants"]}],"label":"Table 2.","content":[{"type":"ImageObject","contentUrl":"89891/v2/content/23292782v2_tbl2.tif","mediaType":"image/tiff","meta":{"inline":false}}]},{"type":"Paragraph","content":["Group IA includes three variants, p.Asp389Gly, p.Asp389Tyr, and p.Ala371Thr. The three variants fully rescued the defects caused by the loss of ",{"type":"Emphasis","content":["Uba5"]}," in flies, indicating that they do not affect UBA5 function or only cause a mild LoF of UBA5. The biochemical assays show that p.Asp389Gly and p.Asp389Tyr only cause mild, but statistically insignificant defects in UFM1 activation, consistent with the complete rescue of the loss of ",{"type":"Emphasis","content":["Uba5"]}," in humanized flies (",{"type":"Link","relation":"fig","target":"#fig3","content":["Figure 3"]},"). The other variant, p.Ala371Thr, has a minor allele frequency (MAF) of 0.0019 (517/274744 alleles) in general population and is more frequent in Finnish population (MAF=0.0059, 149/24996 alleles) in gnomAD v2.1.1. It is also the most commonly observed variant in affected individuals (Table S1). Individuals homozygous for this variant have been identified in the Finnish and Icelandic population but they do not present with obvious symptoms related to DEE44 (",{"type":"Cite","target":"c1","content":["Arnadottir ",{"type":"Emphasis","content":["et al"]},"., 2017"]},"; ",{"type":"Cite","target":"c8","content":["Colin ",{"type":"Emphasis","content":["et al"]},"., 2016"]},"; ",{"type":"Cite","target":"c37","content":["Muona ",{"type":"Emphasis","content":["et al"]},"., 2016"]},"), consistent with our observations in flies. Interestingly, although the biochemical assays showed no dramatic effect of Ala371Thr on UBA5 stability, ATP binding, or UFM1 activation, the transthiolation of UFM1 onto UFC1 is impaired. While it may seem intuitive that defective UFM1 activation or transthiolation would be equally detrimental, formation of the activated UBA5∼UFM1 intermediate is the rate-limiting step of the reaction and hence more sensitive to perturbations (",{"type":"Cite","target":"c15","content":["Gavin ",{"type":"Emphasis","content":["et al"]},"., 2014"]},"). Importantly, the defect is observed at 22 °C but not at 37 °C ",{"type":"Emphasis","content":["in vitro"]},", indicating that p.Ala371Thr is a very weak allele, consistent with all the ",{"type":"Emphasis","content":["in vivo"]}," and human genetics data."]},{"type":"Paragraph","content":["Groups IB and II include variants that have an intermediate effect on the protein function ",{"type":"Emphasis","content":["in vivo"]},". They rescued the lethality of ",{"type":"Emphasis","content":["Uba5"]}," mutant flies, but cause phenotypes of various levels of severity in adult flies. In biochemical assays, Group II variants exhibit a decreased capacity to bind ATP and a mild loss in the ability to activate UFM1, though the limitations of our assay precluded statistically significant effects among several variants. In Group IB, the p.Arg72Cys only causes a mild defect in UFM1 activation, consistent with it being near but not directly involved in ATP binding. The novel Group 1B variant reported herein, p.Gln312Leu, exhibited virtually no biochemical phenotype aside from signs of local instability in the UBA5 structure, which is stabilized in the presence of ATP. Among the sites of Group IB and II variants, only the Val260 residue lies at the homodimeric interface while no others lie immediately at a key interface for UBA5 function. This is consistent with p.Val260Met being the only variant among this set that exhibited severe activity defects ",{"type":"Emphasis","content":["in vitro"]},". Despite this, all Groups IB and II variants caused phenotypes in flies. It is possible that the subtle effects of these substitutions are exacerbated in certain cellular conditions, such as ER stress."]},{"type":"Paragraph","content":["Group III variants failed to rescue the lethality of the ",{"type":"Emphasis","content":["Uba5"]}," mutants, suggesting that they correspond to severe LoF alleles. This group includes four variants, p.Arg55His, p.Gly168Glu, p.Leu254Pro, and p.Cys303Arg. Two of the affected sites, Gly168 and Cys303, are buried in the UBA5 structure. Interestingly, neither of these variants are soluble when produced in ",{"type":"Emphasis","content":["E. coli"]},", indicating compromised protein folding. The two remaining variants, p.Arg55His and p.Leu254Pro are in very close proximity of the UBA5 active site (",{"type":"Link","relation":"fig","target":"#fig4","content":["Figure 4B"]},") and may affect ATP binding and cause decreased conformational dynamics of the active site Cys. Both variants show a diminished capacity to bind ATP, and are incapable of activating UFM1, consistent with the observations that they are very severe LoF alleles in the fly. Hence, in Group III two alleles severely disrupt UBA5 protein stability while two others affect enzyme catalysis."]},{"type":"Paragraph","content":["Using our variant classification, we retrospectively analyzed the allelic combinations in reported DEE44 cases. The most severely affected individual is homozygous for a Group II variant p.Tyr53Phe. However, this individual was from a consanguineous family so other variants may correspond to the phenotypic presentation of this individual (",{"type":"Cite","target":"c6","content":["Cabrera-Serrano ",{"type":"Emphasis","content":["et al"]},"., 2020"]},"). Most (21/25) individuals are compound heterozygous for one allele from Group IA or IB and another allele from Group III or IV (Table S1). This strongly suggests that the pairing of a mild LoF with a severe LoF allele is required to allow individuals to survive and manifest the disease. However, two individuals from a previous report (IA/II) and this study (IB/II) show that the disease is also associated with a combination of two partial LoF alleles (Table S1). Finally, no affected individual is free of alleles from Group II/III/IV, indicating that combinations of IA/IB alleles may not cause disease. This is also supported by the observation that homozygous p.Ala371Thr (Group IA) individuals are not affected (see above) (",{"type":"Cite","target":"c1","content":["Arnadottir ",{"type":"Emphasis","content":["et al"]},"., 2017"]},"; ",{"type":"Cite","target":"c8","content":["Colin ",{"type":"Emphasis","content":["et al"]},"., 2016"]},"; ",{"type":"Cite","target":"c37","content":["Muona ",{"type":"Emphasis","content":["et al"]},"., 2016"]},"). Our results provide compelling evidence for the interpretation of existing and future variants as well as the prediction of pathogenicity of allelic combinations in clinical genetic analyses, especially considering the very limited number of reported individuals and the partial LoF mechanism of the disease."]},{"type":"Paragraph","content":["Three other genes in the UFMylation pathway are associated with diseases that share symptoms with DEE44. Variants in ",{"type":"Emphasis","content":["UFSP2"]}," (OMIM: #611482) cause another DEE (DEE106, OMIM: #620028) (",{"type":"Cite","target":"c40","content":["Ni ",{"type":"Emphasis","content":["et al"]},", 2021"]},"). ",{"type":"Emphasis","content":["UFM1"]}," (OMIM: #610553) is associated with hypomyelinating leukodystrophy 14 (HLD14, OMIM: #617899) (",{"type":"Cite","target":"c18","content":["Hamilton ",{"type":"Emphasis","content":["et al"]},", 2017"]},"; ",{"type":"Cite","target":"c39","content":["Nahorski ",{"type":"Emphasis","content":["et al"]},", 2018"]},"). Variants in ",{"type":"Emphasis","content":["UFC1"]}," (OMIM: #610554) cause a neurodevelopmental disorder with spasticity and poor growth (NEDSG, OMIM: #618076) (",{"type":"Cite","target":"c39","content":["Nahorski ",{"type":"Emphasis","content":["et al"]},"., 2018"]},"). All these disorders cause global developmental delay, hypotonia, spasticity, seizures, delayed myelination, and microcephaly, consistent with them sharing a similar etiology. The UbiReal system developed herein can be easily adapted to test the variants in these other UFMylation genes in future work. In addition, given that the genes are also highly conserved in flies, the allelic strengths of the variants in these genes could also be established ",{"type":"Emphasis","content":["in vivo"]}," using our fruit fly model."]},{"type":"Heading","id":"s4","depth":1,"content":["Material and Methods"]},{"type":"Heading","id":"s4a","depth":2,"content":["Human genetics"]},{"type":"Paragraph","content":["The proband was recruited through the Doernbecher Children’s Hospital and informed consent was obtained from legal guardians of the proband. The human study was approved by the Institutional Review Board at Oregon Health \u0026 Science University. The legal guardians of the proband consent to have the results of this research work published."]},{"type":"Paragraph","content":["Trio exome sequencing was conducted by GeneDx using DNA extracted from blood. DNA was enriched using a proprietary capture system developed by GeneDx for next-generation sequencing. The enriched targets were simultaneously sequenced with paired-end reads on an Illumina platform. Bi-directional sequence reads were assembled and aligned to Human Genome Sequencing Center (HGSC) build 37, human reference genome 19. Reported variants were confirmed, if necessary, by an appropriate orthogonal method."]},{"type":"Heading","id":"s4b","depth":2,"content":["Drosophila strains and genetics"]},{"type":"Paragraph","content":["All fruit fly strains used in this study were cultured using standard fly food in a 25°C incubator unless a different culturing temperature was specifically indicated. The ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["KO"]}]}," mutant and the human ",{"type":"Emphasis","content":["UAS-UBA5"]}," transgenic fly lines were generated in the Bellen lab (for methods, see below). The ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["T2A-Gal4"]}]}," (#78928), ",{"type":"Emphasis","content":["UAS-mCherry.nls"]}," (#38424), ",{"type":"Emphasis","content":["UAS-FLP"]}," (#4540), ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["GR"]}]}," (#30359), ",{"type":"Emphasis","content":["da-Gal4"]}," (#5460), ",{"type":"Emphasis","content":["Act-Gal4"]}," (#4414), ",{"type":"Emphasis","content":["elav-Gal4"]}," (#8765), and ",{"type":"Emphasis","content":["repo-Gal4"]}," (#7415) lines were obtained from the Bloomington Drosophila Stock Center (BDSC)."]},{"type":"Heading","id":"s4c","depth":2,"content":["Generation of Uba5",{"type":"Superscript","content":["KO"]}," allele"]},{"type":"Paragraph","content":["The ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["KO"]}]}," allele was generated using CRISPR/Cas9 genome engineering technology as previously described (",{"type":"Cite","target":"c44","content":["Port ",{"type":"Emphasis","content":["et al"]},", 2014"]},"). A TKO transgenic line expressing a ",{"type":"Emphasis","content":["Uba5"]},"-targeting single guide RNA (sgRNA) is available from the BDSC (BDSC #81448) (",{"type":"Cite","target":"c63","content":["Zirin ",{"type":"Emphasis","content":["et al"]},", 2020"]},"). The sgRNA (CAATCCGTACAGCCGCCTGA) targets the coding region in the Exon 1 of the only ",{"type":"Emphasis","content":["Uba5"]}," transcript. To generate indel variants, the TKO flies were crossed to ",{"type":"Emphasis","content":["nos-Cas9"]}," transgenic flies (BDSC #78781) and then the first generation (F1) female progenies carrying both sgRNA and Cas9 were crossed with 1st chromosome balancer flies. Single F2 females were crossed with balancer flies again to establish ∼20 individual stocks with potential indel variants. Due to the lethality of ",{"type":"Emphasis","content":["Uba5"]}," mutants, the stocks without unbalanced flies were screened for ",{"type":"Emphasis","content":["Uba5"]}," indel variant by genomic PCR and Sanger sequencing. One mutant line with NM_132494.3 (",{"type":"Emphasis","content":["Uba5"]},"):c.164_174del (p.Arg55ProfsTer87) varaint was isolated and designated as ",{"type":"Emphasis","content":["Uba5",{"type":"Superscript","content":["KO"]}]}," allele in this study."]},{"type":"Heading","id":"s4d","depth":2,"content":["Generation of UAS-UBA5 transgenic stocks"]},{"type":"Paragraph","content":["Human ",{"type":"Emphasis","content":["UAS-UBA5"]}," transgenic fly lines were generated as previously described (",{"type":"Cite","target":"c19","content":["Harnish ",{"type":"Emphasis","content":["et al"]},", 2019"]},"). In brief, the human ",{"type":"Emphasis","content":["UBA5"]}," cDNA sequences were cloned into the pGW-UAS-HA.attB vector (",{"type":"Cite","target":"c4","content":["Bischof ",{"type":"Emphasis","content":["et al"]},", 2013"]},") using the Gateway Cloning system (Thermo Fisher) and validated by sequencing. The cDNA vectors were then injected into fly embryos and inserted into the VK37 (BDSC #24872) docking site by φC31-mediated transgenesis (",{"type":"Cite","target":"c54","content":["Venken ",{"type":"Emphasis","content":["et al"]},", 2006"]},"). The human ",{"type":"Emphasis","content":["UBA5"]}," cDNA clone corresponding to Genebank transcript NM_024818.6 was obtained from the Ultimate ORF Clones library (Thermo Fisher). The ",{"type":"Emphasis","content":["UBA5"]}," variants were introduced into the reference cDNA using Q5 site-directed mutagenesis (NEB) before the cDNA was cloned into the pGW-UAS-HA.attB vector."]},{"type":"Heading","id":"s4e","depth":2,"content":["Immunostaining and confocal microscopy"]},{"type":"Paragraph","content":["Larval and adult flies were dissected in 1X PBS and the specimens were processed for immunostaining. Briefly, the tissues were fixed in 4% paraformaldehyde followed by normal goat serum blocking and incubation in the primary antibody (Rat anti-Elav, Developmental Studies Hybridoma Bank (DSHB) #7E8A10, 1:500; Mouse anti-Repo, DSHB #8D12, 1:50; Mouse anti-CSP, DSHB #6D6, 1:200; FITC-conjugated anti-HRP, Jackson ImmunoResearch, 1:200). Cy5-conjugated secondary antibodies were used to detect the primary antibodies. Samples were mounted on slides using RapidClear (SUNJin Lab) and the images were captured using a confocal microscope (Zeiss 710). For NMJ morphology analysis, the NMJs from larval muscle 4 of abdominal segments 2, 3, or 4 were imaged and the bouton numbers and sizes were quantified using ImageJ software."]},{"type":"Heading","id":"s4f","depth":2,"content":["Drosophila lifespan assay"]},{"type":"Paragraph","content":["For the measurement of lifespan, freshly eclosed flies were collected in separate vials and maintained at 25°C. Flies were transferred every day to fresh food in the first six days and every other day afterward. Survival was determined during every transfer. The results are represented as Kaplan-Meier curves."]},{"type":"Heading","id":"s4g","depth":2,"content":["Drosophila behavioral assay"]},{"type":"Paragraph","content":["To measure negative geotaxis, flies were transferred to a clean vial for at least 20 minutes prior to the experiment. During the test, flies were tapped to the bottom of the vial and their negative geotaxis climbing ability was measured. In each measurement, flies were allowed to climb for 30 seconds, after which the climbing distances were measured (18 cm is maximum). To perform bang-sensitive paralytic analyses, adult flies were transferred to a clean vial and vortexed at maximum speed for 10 seconds, after which the time required for flies to stand on their feet was counted (30 seconds is maximum)."]},{"type":"Heading","id":"s4h","depth":2,"content":["Protein expression and purification"]},{"type":"Paragraph","content":["The reference UBA5 gene and UFM1 cloned into pET15b and UFC1 cloned into pET32a were kind gifts from R. Wiener (The Institute for Medical Research Israel-Canada). The UBA5 p.Met57Val and p.Gln312Leu substitutions were cloned into this background by Quikchange PCR using Phusion DNA polymerase. All other UBA5 variant substitutions were subcloned into pOPIN-B using the constructs described above as templates. All of these constructs encoded N-terminal His-tags, and were purified in a similar manner. After plasmid transformation into ",{"type":"Emphasis","content":["E. coli"]}," Rosetta (DE3) cells, cultures were grown at 37 °C in Luria Broth containing 35 µg/mL chloramphenicol and 50 µg/mL of kanamycin. Once an optical density (600 nm) between 0.4-0.6 was reached, cultures were cooled to 18 °C and protein expression was induced with 0.5 mM IPTG. Cells were harvested by centrifugation after 24 hours of expression and resuspended in 50 mM NaPO",{"type":"Subscript","content":["4"]},", 500 mM NaCl, 2 mM ß-mercaptoethanol, pH 8.0 (Buffer A). The cell pellet was then subjected to a freeze-thaw cycle before adding DNase, PMSF, lysozyme and SigmaFAST Protease Inhibitor Cocktail (MiliporeSigma) and allowed to incubate on ice for 30 min. The cell pellets were then lysed by either french press or sonication, depending on the volume to be lysed. Lysates were then centrifuged at 35,000 xg, and the clarified lysate was added to a column containing HisPur Cobalt affinity resin (ThermoFisher), allowed to bind for 10 min, and washed with 1 L of Buffer A + 10 mM Imidazole. Proteins were then eluted with 5 mL of Buffer A + 350 mM Imidazole in a stepwise manner for a total elution volume of 25 mL. Purity of the fractions were analyzed via SDS-PAGE and those with highest purity were pooled and dialyzed overnight into 25 mM Tris, 100 mM NaCl, 2 mM DTT, pH 8.0 (Buffer B) at 4 °C. After 24 hrs of dialysis, UBA5 proteins were further purified on a RESOURCE Q (Cytivia) anion exchange chromatography column equilibrated in Buffer B. The protein was eluted over a 20 column volume gradient against Buffer B + 1 M NaCl. Peak protein fractions were pooled and concentrated using Amicon centrifugal filters (MiliporeSigma) before being applied to a HiLoad Superdex 75 16/600 pg size exclusion chromatography column (Cytivia) equilibrated in Buffer B. Following affinity purification, the His-tags of UFM1 and UFC1 were removed by TEV cleavage during overnight dialysis into Buffer B at 4 °C. Proteins were then concentrated using Amicon centrifugal filters and applied to a HiLoad Superdex 75 16/600 pg as above. Peak fractions were evaluated for purity via SDS-PAGE, pooled, and concentrated before being quantified by absorbance at 280 nm and flash frozen above 10X their working stock concentration. All protein samples were stored at −80 °C."]},{"type":"Heading","id":"s4i","depth":2,"content":["Fluorescence-based UBA5 activity assays"]},{"type":"Paragraph","content":["UFM1-Alexa 488 substrates were prepared using an Alexa Fluor 488 TFP ester (ThermoFisher). Labeling was performed at room temperature for 1 hr in 0.1 M sodium bicarbonate buffer at pH 7.5, which directs labeling toward the N-terminus. Following labeling, excess fluorophore was quenched with addition of 150 mM Tris pH 7.4 and separated by size exclusion chromatography on a HiLoad Superdex 75 16/600 pg as above. Transfer and activation of UFM1 onto UBA5 and further transthiolation to UFC1 was monitored by fluorescence polarization (FP) based on published methods from the ubiquitin system (",{"type":"Cite","target":"c13","content":["Franklin \u0026 Pruneda, 2019"]},", ",{"type":"Cite","target":"c14","content":["2023"]},"). FP was measured using a BMG LabTech CLARIOstar plate reader at an excitation wavelength of 482 nm, an LP 504 nm dichroic mirror, and an emission wavelength of 530 nm. Free UFM1 was used as a reference with a target FP of 190. All assays were performed in black Greiner 384-well small-volume HiBase, low protein-binding microplates. UFM1 and UBA5 stocks were prepared at 2X assay conditions in 25 mM NaPO",{"type":"Subscript","content":["4"]},", 150 mM NaCl, 10 mM MgCl",{"type":"Subscript","content":["2"]},", pH 7.4 (Buffer C). UFM1 was prepared at 100 nM in Buffer C + 20 mM ATP (pH 7); UBA5 variants were prepared at 1 µM in Buffer C. UFC1 was prepared at 3 µM (10X assay concentration) in Buffer C. Final assay conditions in 20 µL volumes were 50 nM UFM1, 500 nM UBA5 variants, and 300 nM UFC1 in Buffer C + 10 mM ATP. FP data was first collected for the substrate only to establish a baseline before addition of UBA5 variants at 1:1 ratio to reach the described assay conditions. FP values were collected in 45-second intervals until the reference UBA5 readings plateaued, at which point UFC1 was added at 1:10 ratio to achieve final assay conditions. Reactions were performed in triplicate for each of three experimental replicates, both at 22 °C and 37 °C. AUC calculations were performed using Prism 9.5, with baseline values calculated from data collected prior to addition of UBA5/UFC1. For the UFM1 activation stage, AUC was determined over a 45-minute window following addition of UBA5. For the UFM1 transthiolation stage, AUC was determined over a 20-minute window following addition of UFC1."]},{"type":"Heading","id":"s4j","depth":2,"content":["Gel-based UBA5 activation and transthiolation assay"]},{"type":"Paragraph","content":["Conditions for the gel-based assay were identical to those described above for the 22 °C FP assays. Parallel reactions were prepared, one to be read out by FP using the CLARIOstar plate reader and the other was left in a low light environment at room temperature. After 15 minutes of establishing a baseline FP reading for UFM1 alone, a 20 µL sample was taken from the parallel reaction and quenched using non-reducing sample buffer. FP readings were paused and reference UBA5 was added to both reactions before continuing FP data collection. The FP values were allowed to plateau before another 20 µL sample was collected from the parallel reaction and quenched with non-reducing sample buffer. FP readings were then paused and UFC1 was added to both reactions before continuing FP data collection. The FP values were allowed to plateau before taking a final 20 µL sample from the parallel reaction and quenching with non-reducing sample buffer. Gel samples were run on a TGX 4-20% SDS-PAGE gradient gel (Bio-Rad). The resulting gel was imaged using a Sapphire Biomolecular Imager (Azure Biosystems). This experiment was performed in triplicate."]},{"type":"Heading","id":"s4k","depth":2,"content":["Thermal shift assay"]},{"type":"Paragraph","content":["The thermal shift assay was conducted in MicroAmp Fast 96-Well Reaction Plates (Applied Biosystems) with SYPRO Orange Protein Gel Stain (MiliporeSigma) using a QuantStudio 3 Real-Time PCR system (Applied Biosystems). Assays were performed in 20 µL volumes containing 5 µM UBA5 variants and 20X SYPRO dye (diluted from a 5000X stock) in 25 mM NaPO",{"type":"Subscript","content":["4"]},", 150 mM NaCl, 10 mM MgCl",{"type":"Subscript","content":["2"]},", pH 7.4 with or without 5 mM ATP. The protocol ramped temperature from 22 °C to 99°C over a gradient of 0.1 °C every 5 seconds, and fluorescence was monitored using an excitation wavelength of 580 ± 10 nm and an emission wavelength of 623 ± 14 nm."]},{"type":"Heading","id":"s4l","depth":2,"content":["Statistical analysis"]},{"type":"Paragraph","content":["Statistical analyses were carried out using the Student’s unpaired two-tailed t test for comparison of two groups or the Welch’s t test for data normalized to reference UBA5. Multiple comparisons within the group were tested against the corresponding control. Kaplan-Meier survival curves were analyzed using Gehan-Breslow-Wilcoxon test and log-rank test. Calculated p values of less than 0.05 were considered significant. All statistical analyses were performed using GraphPad Prism, version 9.5.0 (GraphPad Software)."]},{"type":"Heading","id":"d1e1950","depth":1,"content":["Supporting information"]},{"type":"Paragraph","content":[{"type":"Link","id":"d1e2103","target":"89891/v2/content/supplements/292782_file08.pdf","title":"Supplemental Information","content":[{"type":"Strong","content":["Supplemental Information"]}]}]},{"type":"Paragraph","content":[{"type":"Link","id":"d1e2110","target":"89891/v2/content/supplements/292782_file09.xlsx","title":"Supplemental Table 2","content":[{"type":"Strong","content":["Supplemental Table 2"]}]}]},{"type":"ThematicBreak"},{"type":"Heading","id":"d1e1972","depth":1,"content":["Data Availability"]},{"type":"Paragraph","content":["All data produced in the present study are available upon reasonable request to the authors."]},{"type":"ThematicBreak"},{"type":"Heading","depth":1,"content":["Acknowledgements"]},{"type":"Paragraph","content":["We thank the proband and his family for agreeing to participate in this study. We thank the Bellen and Yamamoto lab members for their discussion and suggestions in this study. We thank Ms. Hongling Pan for the injection of transgenic fly lines. We thank the BDSC for fly stocks, the DSHB for antibodies, and R. Wiener (The Institute for Medical Research Israel-Canada) for sharing plasmids. H.J.B., O.K. and S.Y. were supported by the Office of Research Infrastructure Programs (ORIP) of the NIH (award U54 OD030165). H.J.B. was also supported by the ORIP of the NIH (awards R24 OD022005 and R24 OD031447), the Huffington Foundation, and the Jan \u0026 Dan Duncan Neurological Research Institute at Texas Children’s Hospital. The work was also supported by the Baylor College of Medicine IDDRC P50HD103555 from the Eunice Kennedy Shriver National Institute of Child Health and Human Development for use of the Microscopy Core facilities. J.N.P. and R.J.N. were supported by the OHSU Molecular Microbiology and Immunology Interdisciplinary Pilot Award and the Oregon Clinical and Translational Research Institute’s Biomedical Innovation Program NCATS UL1TR002369 from the NIH. J.N.P. was also supported by an NIGMS R35 grant (R35 GM142486), and R.J.N. was also supported by a VA CDA2 grant (5IK2BX004523). D.A.S. and L.C.B. were supported by the NIH common fund through the Office of Strategic Coordination/Office of the NIH Direction (award U01 HG007690), the Hill Family Fund for the Diagnosis, Management of Rare and Undiagnosed Diseases at Mass General, and American Institute for Neuro Integrative Development Inc (AIND)."]},{"type":"ThematicBreak"},{"type":"Heading","id":"s5","depth":1,"content":["Declaration of interests"]},{"type":"Paragraph","content":["The authors declare no competing interests."]},{"type":"ThematicBreak"},{"type":"Heading","id":"s6","depth":1,"content":["Web resources"]},{"type":"Paragraph","content":["OMIM, ",{"type":"Link","target":"https://omim.org/","content":["https://omim.org/"]}]},{"type":"Paragraph","content":["DIOPT, ",{"type":"Link","target":"https://www.flyrnai.org/cgi-bin/DRSC_orthologs.pl/gnomAD","content":["https://www.flyrnai.org/cgi-bin/DRSC_orthologs.pl/gnomAD"]},", ",{"type":"Link","target":"https://gnomad.broadinstitute.org/","content":["https://gnomad.broadinstitute.org/"]}]},{"type":"Paragraph","content":["CADD, ",{"type":"Link","target":"https://cadd.gs.washington.edu/SIFT","content":["https://cadd.gs.washington.edu/SIFT"]},", ",{"type":"Link","target":"https://sift.bii.a-star.edu.sg/","content":["https://sift.bii.a-star.edu.sg/"]}]},{"type":"Paragraph","content":["PolyPhen2, ",{"type":"Link","target":"http://genetics.bwh.harvard.edu/pph2/MutationTaster","content":["http://genetics.bwh.harvard.edu/pph2/MutationTaster"]},", ",{"type":"Link","target":"https://www.mutationtaster.org/PROVEAN","content":["https://www.mutationtaster.org/PROVEAN"]},", ",{"type":"Link","target":"http://provean.jcvi.org/","content":["http://provean.jcvi.org/"]}]}],"references":[{"type":"Article","id":"c1","authors":[{"type":"Person","familyNames":["Arnadottir"],"givenNames":["GA"]},{"type":"Person","familyNames":["Jensson"],"givenNames":["BO"]},{"type":"Person","familyNames":["Marelsson"],"givenNames":["SE"]},{"type":"Person","familyNames":["Sulem"],"givenNames":["G"]},{"type":"Person","familyNames":["Oddsson"],"givenNames":["A"]},{"type":"Person","familyNames":["Kristjansson"],"givenNames":["RP"]},{"type":"Person","familyNames":["Benonisdottir"],"givenNames":["S"]},{"type":"Person","familyNames":["Gudjonsson"],"givenNames":["SA"]},{"type":"Person","familyNames":["Masson"],"givenNames":["G"]},{"type":"Person","familyNames":["Thorisson"],"givenNames":["GA"]},{"type":"Person","familyNames":["et","al"]}],"datePublished":{"type":"Date","value":"2017-01-01T00:00:00.000Z"},"identifiers":[{"type":"PropertyValue","name":"elocation-id","value":"103"}],"isPartOf":{"type":"PublicationVolume","isPartOf":{"type":"Periodical","name":"BMC Med Genet"},"volumeNumber":"18"},"title":"Compound heterozygous mutations in UBA5 causing early-onset epileptic encephalopathy in two sisters","meta":{"yearPublished":"2017","publicationType":"journal"}},{"type":"Article","id":"c2","authors":[{"type":"Person","familyNames":["Bacik"],"givenNames":["JP"]},{"type":"Person","familyNames":["Walker"],"givenNames":["JR"]},{"type":"Person","familyNames":["Ali"],"givenNames":["M"]},{"type":"Person","familyNames":["Schimmer"],"givenNames":["AD"]},{"type":"Person","familyNames":["Dhe-Paganon"],"givenNames":["S"]}],"datePublished":{"type":"Date","value":"2010-01-01T00:00:00.000Z"},"isPartOf":{"type":"PublicationVolume","isPartOf":{"type":"Periodical","name":"J Biol Chem"},"volumeNumber":"285"},"pageEnd":20280,"pageStart":20273,"title":"Crystal structure of the human ubiquitin-activating enzyme 5 (UBA5) bound to ATP: mechanistic insights into a minimalistic E1 enzyme","meta":{"yearPublished":"2010","publicationType":"journal"}},{"type":"Article","id":"c3","authors":[{"type":"Person","familyNames":["Bellen"],"givenNames":["HJ"]},{"type":"Person","familyNames":["Yamamoto"],"givenNames":["S"]}],"datePublished":{"type":"Date","value":"2015-01-01T00:00:00.000Z"},"isPartOf":{"type":"PublicationVolume","isPartOf":{"type":"Periodical","name":"Cell"},"volumeNumber":"163"},"pageEnd":14,"pageStart":12,"title":"Morgan’s legacy: fruit flies and the functional annotation of conserved genes","meta":{"yearPublished":"2015","publicationType":"journal"}},{"type":"Article","id":"c4","authors":[{"type":"Person","familyNames":["Bischof"],"givenNames":["J"]},{"type":"Person","familyNames":["Bjorklund"],"givenNames":["M"]},{"type":"Person","familyNames":["Furger"],"givenNames":["E"]},{"type":"Person","familyNames":["Schertel"],"givenNames":["C"]},{"type":"Person","familyNames":["Taipale"],"givenNames":["J"]},{"type":"Person","familyNames":["Basler"],"givenNames":["K"]}],"datePublished":{"type":"Date","value":"2013-01-01T00:00:00.000Z"},"isPartOf":{"type":"PublicationVolume","isPartOf":{"type":"Periodical","name":"Development"},"volumeNumber":"140"},"pageEnd":2442,"pageStart":2434,"title":"A versatile platform for creating a comprehensive UAS-ORFeome library in Drosophila","meta":{"yearPublished":"2013","publicationType":"journal"}},{"type":"Article","id":"c5","authors":[{"type":"Person","familyNames":["Briere"],"givenNames":["LC"]},{"type":"Person","familyNames":["Walker"],"givenNames":["MA"]},{"type":"Person","familyNames":["High"],"givenNames":["FA"]},{"type":"Person","familyNames":["Cooper"],"givenNames":["C"]},{"type":"Person","familyNames":["Rogers"],"givenNames":["CA"]},{"type":"Person","familyNames":["Callahan"],"givenNames":["CJ"]},{"type":"Person","familyNames":["Ishimura"],"givenNames":["R"]},{"type":"Person","familyNames":["Ichimura"],"givenNames":["Y"]},{"type":"Person","familyNames":["Caruso"],"givenNames":["PA"]},{"type":"Person","familyNames":["Sharma"],"givenNames":["N"]},{"type":"Person","familyNames":["et","al"]}],"datePublished":{"type":"Date","value":"2021-01-01T00:00:00.000Z"},"identifiers":[{"type":"PropertyValue","name":"elocation-id","value":"7"}],"isPartOf":{"type":"Periodical","name":"Cold Spring Harb Mol Case Stud"},"title":"A description of novel variants and review of phenotypic spectrum in UBA5-related early epileptic encephalopathy","meta":{"yearPublished":"2021","publicationType":"journal"}},{"type":"Article","id":"c6","authors":[{"type":"Person","familyNames":["Cabrera-Serrano"],"givenNames":["M"]},{"type":"Person","familyNames":["Coote"],"givenNames":["DJ"]},{"type":"Person","familyNames":["Azmanov"],"givenNames":["D"]},{"type":"Person","familyNames":["Goullee"],"givenNames":["H"]},{"type":"Person","familyNames":["Andersen"],"givenNames":["E"]},{"type":"Person","familyNames":["McLean"],"givenNames":["C"]},{"type":"Person","familyNames":["Davis"],"givenNames":["M"]},{"type":"Person","familyNames":["Ishimura"],"givenNames":["R"]},{"type":"Person","familyNames":["Stark"],"givenNames":["Z"]},{"type":"Person","familyNames":["Vallat"],"givenNames":["JM"]},{"type":"Person","familyNames":["et","al"]}],"datePublished":{"type":"Date","value":"2020-01-01T00:00:00.000Z"},"isPartOf":{"type":"PublicationVolume","isPartOf":{"type":"Periodical","name":"J Med Genet"},"volumeNumber":"57"},"pageEnd":842,"pageStart":835,"title":"A homozygous UBA5 pathogenic variant causes a fatal congenital neuropathy","meta":{"yearPublished":"2020","publicationType":"journal"}},{"type":"Article","id":"c7","authors":[{"type":"Person","familyNames":["Cappadocia"],"givenNames":["L"]},{"type":"Person","familyNames":["Lima"],"givenNames":["CD"]}],"datePublished":{"type":"Date","value":"2018-01-01T00:00:00.000Z"},"isPartOf":{"type":"PublicationVolume","isPartOf":{"type":"Periodical","name":"Chem Rev"},"volumeNumber":"118"},"pageEnd":918,"pageStart":889,"title":"Ubiquitin-like Protein Conjugation: Structures, Chemistry, and Mechanism","meta":{"yearPublished":"2018","publicationType":"journal"}},{"type":"Article","id":"c8","authors":[{"type":"Person","familyNames":["Colin"],"givenNames":["E"]},{"type":"Person","familyNames":["Daniel"],"givenNames":["J"]},{"type":"Person","familyNames":["Ziegler"],"givenNames":["A"]},{"type":"Person","familyNames":["Wakim"],"givenNames":["J"]},{"type":"Person","familyNames":["Scrivo"],"givenNames":["A"]},{"type":"Person","familyNames":["Haack"],"givenNames":["TB"]},{"type":"Person","familyNames":["Khiati"],"givenNames":["S"]},{"type":"Person","familyNames":["Denomme"],"givenNames":["AS"]},{"type":"Person","familyNames":["Amati-Bonneau"],"givenNames":["P"]},{"type":"Person","familyNames":["Charif"],"givenNames":["M"]},{"type":"Person","familyNames":["et","al"]}],"datePublished":{"type":"Date","value":"2016-01-01T00:00:00.000Z"},"isPartOf":{"type":"PublicationVolume","isPartOf":{"type":"Periodical","name":"Am J Hum Genet"},"volumeNumber":"99"},"pageEnd":703,"pageStart":695,"title":"Biallelic Variants in UBA5 Reveal that Disruption of the UFM1 Cascade Can Result in Early-Onset Encephalopathy","meta":{"yearPublished":"2016","publicationType":"journal"}},{"type":"Article","id":"c9","authors":[{"type":"Person","familyNames":["Daida"],"givenNames":["A"]},{"type":"Person","familyNames":["Hamano"],"givenNames":["SI"]},{"type":"Person","familyNames":["Ikemoto"],"givenNames":["S"]},{"type