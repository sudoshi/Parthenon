    $("body").on("click", ".article-metrics-wrapper:not(.js-is-preview)", function (e) {
        var pdfWrapper = $("#pdf-object-container"),
            ieDivWidth = pdfWrapper.outerWidth(),
            ieDivHeight = pdfWrapper.outerHeight(),
            ieDiv = $("<div></div>", {
                "class": "js-replace-iframe-ie",
                "css": {
                    "width": ieDivWidth + "px",
                    "height": ieDivHeight + "px",
                    "background-color": "rgba(0, 0, 0, 0.3)"
                }
            });
        if ($(".is-iebrowser").size()) {
            pdfWrapper.hide();
            ieDiv.insertAfter(pdfWrapper);
        }
    });
});
