93e759f39faa0670&q;,&q;confidence&q;:600},{&q;uuid&q;:&q;ec316f73-e6f4-492e-9046-8d303f676667&q;,&q;language&q;:null,&q;value&q;:&q;Higgins, Maree&q;,&q;place&q;:12,&q;authority&q;:&q;022ad631e439f27c6f14578d80156685617607d7&q;,&q;confidence&q;:600},{&q;uuid&q;:&q;0f9087bd-2815-4628-a265-a37e231230da&q;,&q;language&q;:null,&q;value&q;:&q;Murad, M&q;,&q;place&q;:13,&q;authority&q;:&q;9a0969511c3ecafa446fbd83fc5fa7ddd5c19d33&q;,&q;confidence&q;:600},{&q;uuid&q;:&q;7a8a2000-2614-49ef-987c-8a465d04fd76&q;,&q;language&q;:null,&q;value&q;:&q;Barry, J&q;,&q;place&q;:14,&q;authority&q;:null,&q;confidence&q;:600},{&q;uuid&q;:&q;9dfec5f1-85f9-45f6-bce2-b77865dbac92&q;,&q;language&q;:null,&q;value&q;:&q;Mohammad, Yasir&q;,&q;place&q;:15,&q;authority&q;:null,&q;confidence&q;:600},{&q;uuid&q;:&q;943f4d1d-05e7-4c53-9f80-f36b079a5ffa&q;,&q;language&q;:null,&q;value&q;:&q;Bibby, Helen&q;,&q;place&q;:16,&q;authority&q;:&q;ba1231a59b28f59d9e65fc8396580c24ebbe266e&q;,&q;confidence&q;:600}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;b125adee-395d-4f7b-a431-d17b3a78ae50&q;,&q;language&q;:null,&q;value&q;:&q;2024-03-25T18:58:42Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;565c6bf1-e8fb-4062-b6bb-029d1a7d250d&q;,&q;language&q;:null,&q;value&q;:&q;2024-03-25T18:58:42Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;3c487d8a-305d-44bd-8386-2e2511f98a18&q;,&q;language&q;:null,&q;value&q;:&q;2020-12-14&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.submitted&q;:[{&q;uuid&q;:&q;5f3a1bd2-1760-41f3-92f0-aa47d58c0ebf&q;,&q;language&q;:null,&q;value&q;:&q;2024-03-25T18:58:42Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;dfe1522e-4863-42f5-b008-3188fe48ee8f&q;,&q;language&q;:null,&q;value&q;:&q;In 2015, the Australian government committed to take an additional 12,000 refugees from Syria and Iraq prioritizing those considered most vulnerable including people with disability. The aim of this preliminary study was to understand, from multiple stakeholder perspectives, the experiences of settling in Australia for people with disability from Syrian and Iraqi refugee backgrounds living in Sydney. Interviews were conducted with nine family members of 11 people with disability from Iraqi and Syrian refugee backgrounds; eight Iraqi and Syrian community organization leaders; and seven community and health refugee service practitioners. Interviews were transcribed and analysed using the thematic analysis. Three themes were identified that contribute to understandings of disability based on the perceptions of the multiple stakeholders interviewed: Iraqi and Syrian perceptions of ‘disability’; beliefs about who is ‘responsible for’ the disability; and comparisons between Iraqi/Syrian and Australian views, attitudes, and approaches to disability. Understandings of disability are shaped by fluid and dynamic factors, including culture. It is essential that services are offered to people with disability and their family members using a whole-of-person, culturally informed approach to community support.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;uuid&q;:&q;369857a6-c39f-4e3e-a962-646e0da59d00&q;,&q;language&q;:null,&q;value&q;:&q;0951-6328&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1},{&q;uuid&q;:&q;366991ff-9162-44c2-a6ce-c4b5464f673a&q;,&q;language&q;:null,&q;value&q;:&q;1471-6925&q;,&q;place&q;:1,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;1a4ac92d-3274-4316-b4f8-46f698c308b4&q;,&q;language&q;:null,&q;value&q;:&q;http://hdl.handle.net/1959.4/unsworks_73570&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;53c2249b-1221-4942-99ff-e883dfaddf7c&q;,&q;language&q;:null,&q;value&q;:&q;Oxford University Press (OUP)&q;,&q;place&q;:0,&q;authority&q;:null,&