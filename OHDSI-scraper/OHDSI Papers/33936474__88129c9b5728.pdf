<div class="d-panels font-secondary-light">
<div id="aip_a" class="d-panel p" style="display: none">
<div class="p" id="af1-134_3416797">
<sup>1</sup>Columbia University, New York, NY, USA;</div>
<div id="af2-134_3416797">
<sup>2</sup>IQVIA, Cambridge, MA, USA;</div>
<div id="af3-134_3416797">
<sup>3</sup>Janssen Epidemiology Analytics, Janssen Research &amp; Development, Titusville, NJ, USA;</div>
<div id="af4-134_3416797">
<sup>4</sup>University of New South Wales Sydney, Australia;</div>
<div id="af5-134_3416797">
<sup>5</sup>Ajou University Graduate School of Medicine, Suwon, Gyeonggi-do, Republic of Korea;</div>
<div id="af6-134_3416797">
<sup>6</sup>Tufts Medical Center, Institute for Clinical Research and Health Policy Studies, Boston, MA, USA;</div>
<div id="af7-134_3416797">
<sup>7</sup>O’Brien Centre for Population Health, Faculty of Medicine, University of Calgary, Canada;</div>
<div id="af8-134_3416797">
<sup>8</sup>Stanford Center for Biomedical Informatics Research, Stanford, CA, USA;</div>
<div id="af9-134_3416797">
<sup>9</sup>Medical Informatics Services, New York-Presbyterian Hospital, New York, NY, USA</div>
