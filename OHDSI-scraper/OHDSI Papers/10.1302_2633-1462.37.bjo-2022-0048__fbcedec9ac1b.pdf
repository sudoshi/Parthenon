<style nonce="Ftb7PRn84Y&#x2B;T4DD6pyV0PXrBz&#x2B;GuQEhFlymmGzWEvzY=">
    #ulYears button,
    #divDecades button {
        background: none;
        border: none;
        color: #5B6571;
        font-weight: 400;
    }

    #ulYears button:hover,
    #divDecades button:hover {
        text-decoration: underline;
    }
    
    #ulYears button.active,
    #divDecades button.active {
        color: var(--bs-primary);
        font-weight: 600;
    }

    #divIssues p {
        font-size: 0.9rem;
        color: #5B6571;
    }
    
    #mobileArchiveModal .modal-content {
        background-color: #fbf9fa;
    }

    #mobileArchiveModal .modal-header {
        border-bottom: 0px;
    }

    #mobileArchiveModal li.active,
    #mobileArchiveModal .collapse-button.active {
        font-weight: 600;
    }

    #mobileArchiveModal .loading-spinner {
        position: absolute;
        z-index: 1;
        width: 100vw;
        height: 100vh;
        background-color: #fff;
        opacity: 0.5;
    }

    /* Remove the animation, as for the Archive decade header it jumps about with height */
    #mobileArchiveModal .collapsing {
        -webkit-transition: none;
        transition: none;
        display: none;
    }
</style>

<script type="text/javascript" nonce="Ftb7PRn84Y&#x2B;T4DD6pyV0PXrBz&#x2B;GuQEhFlymmGzWEvzY=">
    archiveCache = {};

    window.addEventListener('DOMContentLoaded', e => {
        document.getElementById('collapseArchiveMenuButton').addEventListener('click', (e) => {
            var decade = this.getLatestDecade();
            this.loadYearsForDecade(decade);
        });

        document.getElementById('mobileCollapseArchiveMenuButton').addEventListener('click', (e) => {
            this.collapseAllYearsModal();
            this.hideLoadingSpinnerModal();
            var decade = this.getLatestDecade();
            this.loadYearsForDecadeModal(decade);
        });

        document.querySelectorAll('#divDecades li button').forEach(btn => {
            btn.addEventListener('click', e => {
                this.loadYearsForDecade(e.currentTarget.getAttribute('data-decade'));
            });
        });
        
        document.querySelectorAll('#mobileArchiveModal div[data-decade]').forEach(a => {
            a.addEventListener('click', e => {
                var decade = e.target.getAttribute('data-decade');
                // If the arrow is clicked instead of the label
                if (decade == null) {
                    decade = e.target.parentElement.parentElement.getAttribute('data-decade');
                }
                this.loadYearsForDecadeModal(decade);
            });
        });
    });

    function getLatestDecade() {
        return document.querySelectorAll('#divDecades li button')[0].getAttribute('data-decade');
    }

    function loadYearsForDecade(decade) {
        this.setDecadeAsActive(decade);

        document.getElementById('yearsLoadingSpinner').style.display = 'block';

        if (this.archiveCache[`years-${decade}`]) {
            var data = this.archiveCache[`years-${decade}`];
            document.getElementById('yearsLoadingSpinner').style.display = 'none';
            this.populateYears(data);
            return;
        }

        document.getElementById('ulYears').innerHTML = '';
 
        this.getYearsForDecade(decade, (data) => {
            document.getElementById('yearsLoadingSpinner').style.display = 'none';
            this.populateYears(data);
        });
    }

    function populateYears(decadeData) {
        var yearElement = document.getElementById('ulYears');
        yearElement.innerHTML = '';

        decadeData.forEach((yearData) => {
            var li = document.createElement('li');
            li.className = 'nav-item col-6 col-md-auto d-flex';

            var btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'nav-link bjp-gray mx-auto';
            btn.setAttribute('data-year', yearData.year);
            btn.innerText = yearData.year;

            var arrow = document.createElement('span');
            arrow.className = 'icon-mask icon-arrow-right icon-colour-gray icon-size-75 ms-2';

            btn.appendChild(arrow);
            li.appendChild(btn);
            yearElement.appendChild(li);

            btn.addEventListener('click', () => this.loadIssuesForYear(yearData.year));
        });

        yearElement.querySelector('li button').click();
    }

    function loadIssuesForYear(year) {
        this.setYearAsActive(year);
        document.getElementById('selectedYear').innerText = year;
        document.getElementById('issuesLoadingSpinner').style.display = 'block';

        if (this.archiveCache[`issues-${year}`]) {
            var data = this.archiveCache[`issues-${year}`];
            document.getElementById('issuesLoadingSpinner').style.display = 'none';
            this.populateIssuesData(data);
            return;
        }
        
        document.getElementById('divIssues').innerHTML = '';

        this.getIssuesForYear(year, (data) => {
            document.getElementById('issuesLoadingSpinner').style.display = 'none';
            this.populateIssuesData(data);
        });
    }

    function populateIssuesData(issuesData) {
        var issues = document.getElementById('divIssues');
        issues.innerHTML = '';

        issuesData.forEach(issueData => {
            var divCol = document.createElement('div');
            divCol.className = 'col mb-4';

            var divIssue = document.createElement('div');
            divIssue.className = 'h5 fw-bold bjp-gray';
            divIssue.innerText = issueData.month;

            if (issueData.issues.some(issue => issue.journalCode == "BJJ") && issueData.issues.some(issue => issue.volumeCode == "105-B") && issueData.issues.some(issue => issue.issueCode == "4")) {
                divIssue.innerText = "April";
            }

            divCol.appendChild(divIssue);

            issueData.issues.forEach(issue => {
                var divVolIssue = document.createElement('div');

                var a = document.createElement('a');
                a.href = `/journal/${issue.journalCode}/toc/${issue.volumeCode}/${issue.issueCode}`;
                a.innerText = `Vol. ${issue.volumeCode}, Issue ${issue.issueCode}`;

                var p = document.createElement('p');
                var divPages = document.createElement('div');
                divPages.innerText = `Pages ${issue.fPage} - ${issue.lPage}`;
                p.appendChild(divPages);
                
                if ('bjo' === 'procs') {
                    var divMeeting = document.createElement('div');
                    divMeeting.innerText = issue.articleViewModels[0].subTitle;
                    p.appendChild(divMeeting);
                }


                divVolIssue.appendChild(a);
                divVolIssue.appendChild(p);
                divCol.appendChild(divVolIssue);
            });

            issues.appendChild(divCol);
        });
    }

    function setDecadeAsActive(decade) {
        document.querySelector(`#divDecades li button[data-decade="${decade}"]`).classList.add('active');
        document.querySelectorAll(`#divDecades li button:not([data-decade="${decade}"])`).forEach(btn => btn.classList.remove('active'));
    }

    function setYearAsActive(year) {
        document.querySelector(`#ulYears li button[data-year="${year}"]`).classList.add('active');
        document.querySelectorAll(`#ulYears li button:not([data-year="${year}"])`).forEach(btn => btn.classList.remove('active'));
    }

    /* Modal */
    function loadYearsForDecadeModal(decade) {
        this.setDecadeAsActiveModal(decade);
        this.showLoadingSpinnerModal();

        if (this.archiveCache[`years-${decade}`]) {
            this.populateYearsModal(decade, this.archiveCache[`years-${decade}`]);
            this.hideLoadingSpinnerModal();
            return;
        }

        document.querySelector(`#mobileArchiveModal #yearsCollapse${decade} ul`).innerHTML = '';
 
        this.getYearsForDecade(decade, (data) => {
            this.populateYearsModal(decade, data);
            this.hideLoadingSpinnerModal();
        });
    }

    function populateYearsModal(decade, decadeData) {
        document.querySelector(`#mobileArchiveModal div[data-bs-target='#yearsCollapse${decade}']`).click();

        var yearElement = document.querySelector(`#mobileArchiveModal #yearsCollapse${decade} ul`);
        yearElement.innerHTML = '';

        decadeData.forEach((yearData) => {
            var li = document.createElement('li');
            li.setAttribute('data-year', yearData.year)
            li.className = 'fst-italic bjp-gray';
            li.innerText = yearData.year;
            
            yearElement.appendChild(li);

            li.addEventListener('click', e => {
                var year = e.target.getAttribute('data-year');
                this.loadIssuesForYearModal(yearData.year);
            })
        });

        yearElement.childNodes[0].click();
    }

    function loadIssuesForYearModal(year) {
        this.setYearAsActiveModal(year);
        document.getElementById('selectedYearModal').innerText = year;

        if (this.archiveCache[`issues-${year}`]) {
            this.populateIssuesDataModal(this.archiveCache[`issues-${year}`]);
            return;
        }
        
        document.getElementById('divIssuesModal').innerHTML = '';

        this.getIssuesForYear(year, (data) => {
            this.populateIssuesDataModal(data);
        });
    }

    function populateIssuesDataModal(issuesData) {
        var issues = document.getElementById('divIssuesModal');
        issues.innerHTML = '';

        issuesData.forEach(issueData => {
            var divCol = document.createElement('div');
            divCol.className = 'col mb-4';

            var divIssue = document.createElement('div');
            divIssue.className = 'h6 mb-0 fw-bold bjp-gray';

            divIssue.innerText = issueData.month;

            if (issueData.issues.some(issue => issue.journalCode == "BJJ") && issueData.issues.some(issue => issue.volumeCode == "105-B") && issueData.issues.some(issue => issue.issueCode == "4")) {
                divIssue.innerText = "April";
            }

            divCol.appendChild(divIssue);

            issueData.issues.forEach(issue => {
                var divVolIssue = document.createElement('div');

                var a = document.createElement('a');
                a.href = `/journal/${issue.journalCode}/toc/${issue.volumeCode}/${issue.issueCode}`;
                a.innerText = `Vol. ${issue.volumeCode}, Issue ${issue.issueCode}`;

                var p = document.createElement('p');
                p.className = 'mb-3 bjp-gray';

                var divPages = document.createElement('div');
                divPages.innerText = `Pages ${issue.fPage} - ${issue.lPage}`;
                p.appendChild(divPages);

                if ('bjo' === 'procs') {
                    var divMeeting = document.createElement('div');
                    divMeeting.innerText = issue.articleViewModels[0].subTitle;
                    p.appendChild(divMeeting);
                }

                divVolIssue.appendChild(a);
                divVolIssue.appendChild(p);
                divCol.appendChild(divVolIssue);
            });

            issues.appendChild(divCol);
        });
    }

    function setDecadeAsActiveModal(decade) {
        document.querySelector(`#mobileArchiveModal div[data-decade="${decade}"]`).classList.add('active');

        document.querySelectorAll(`#mobileArchiveModal div:not([data-decade="${decade}"])`).forEach(a => a.classList.remove('active'));
    }

    function setYearAsActiveModal(year) {
        document.querySelector(`#mobileArchiveModal ul li[data-year="${year}"]`).classList.add('active');

        document.querySelectorAll(`#mobileArchiveModal ul li:not([data-year="${year}"])`).forEach(a => a.classList.remove('active'));
    }

    function collapseAllYearsModal() {
        document.querySelectorAll('#mobileArchiveModal div[aria-expanded="true"]').forEach(node => node.click());
    }

    function showLoadingSpinnerModal() {
        document.querySelector('#mobileArchiveModal .loading-spinner').style.display = 'inline-block';
    }

    function hideLoadingSpinnerModal() {
        document.querySelector('#mobileArchiveModal .loading-spinner').style.display = 'none';
    }

    /* Generic */
    function getIssuesForYear(year, callback) {
        fetch('/api/journal/BJO/issues/' + year)
            .then(response => response.json())
            .then(data => {
                this.archiveCache[`issues-${year}`] = data;
                callback(data);
            })
    }

    function getYearsForDecade(decade, callback) {
        fetch('/api/journal/BJO/years/' + decade)
            .then(response => response.json())
            .then(data => {
                this.archiveCache[`years-${decade}`] = data;
                callback(data);
            });
    }
</script>

