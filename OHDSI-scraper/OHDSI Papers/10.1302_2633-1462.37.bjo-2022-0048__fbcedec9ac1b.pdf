<script nonce="Ftb7PRn84Y+T4DD6pyV0PXrBz+GuQEhFlymmGzWEvzY=" src="//cdn.jsdelivr.net/npm/@theidentityselector/thiss-ds"></script>
<script nonce="Ftb7PRn84Y+T4DD6pyV0PXrBz+GuQEhFlymmGzWEvzY=" type="text/javascript">
    var e=encodeURIComponent;
    var shortcode='boneandjoint';
    var ll_base='https://connect.liblynx.com';
    var wayfless_base=ll_base+'/wayfless/'+shortcode;
    var wayf_base=ll_base+'/go/'+shortcode;
    var target=window.location;
    var prod = true;
    var my_context = 'thiss.io';
    var service_url = prod ? 'https://service.seamlessaccess.org/ps/' : 'https://use.thiss.io/ps/';
    var ps = new thiss.PersistenceService(service_url);
    var f = document.getElementById.bind(document); 
              
    f('ra21-link').setAttribute('href', 'https://connect.liblynx.com/go/boneandjoint?sachoose=1&target='+e(target));
    ps.entities(my_context)
        .then(function(res) {
            var myObjects = res.data;
            if (Array.isArray(myObjects) && (myObjects.length>0)){
                var last=myObjects[0];
                var name = last.entity.title;
                var entityId = last.entity.entity_id;
                var wayfless_url=wayfless_base+'?entityID='+e(entityId)+
                    '&target='+e(target);
                var wayf_url=wayf_base+'?target='+e(target)+
                    '&sachoose=1';

                f('ra21-headline').innerHTML='Access through';
                f('ra21-title').innerHTML=name;
                f('ra21-link').setAttribute('title','Access through '+name);
                f('ra21-link').setAttribute('href', wayfless_url);
                f('ra21-cta').classList.remove('llh');
                f('ra21-cta-anchor').setAttribute('href', wayf_url);
            }

        }, function(err) {
            console.log(err);
        });

</script>
