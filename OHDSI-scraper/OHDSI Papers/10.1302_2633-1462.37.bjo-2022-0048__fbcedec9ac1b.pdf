</div>

<div id="mobileNavWrapper" class="row p-0 d-none">
    <div id="mobileNavContent" class="pt-1">
        <button id="mobileNavCloser" type="button" class="btn btn-close float-end m-2 pt-2" aria-label="Close"></button>
        <div id="mobileNavContentInner"></div>
    </div>
</div>

<script nonce="Ftb7PRn84Y&#x2B;T4DD6pyV0PXrBz&#x2B;GuQEhFlymmGzWEvzY=">
    // An advanced apology, this entire component is very tightly coupled with the sidebar and scrollspy component
    // I could not work out a neater way of managing this cludge of state and UX with plain JS
    // Fundamentally it takes the sidebar content and renders it in an overlay layer, this at least reduces duplication
    window.addEventListener('DOMContentLoaded', function () {
        const mobNavWrapper = document.getElementById('mobileNavWrapper');
        const mobTabEl = document.getElementById('mobileNavContent');
        const mobTabInnerEl = document.getElementById('mobileNavContentInner');

        document.getElementById('mobile-nav-vc').addEventListener('click', function (e) {
            const targetSelector = e.target.getAttribute('data-baj-mobile-nav');
            if (!targetSelector) {
                return;
            }

            e.preventDefault();

            // Copy the nav content and make it visible
            const tabToCopy = document.querySelector(targetSelector);
            mobTabInnerEl.innerHTML = tabToCopy.outerHTML;
            mobNavWrapper.classList.remove('d-none');

            // Prevent the body from scrolling behind the pop over
            document.body.classList.add('overflow-hidden');

            // Click the tab on the tab navigation so it is active (if it exists which scrollspy does not)
            // TODO: Don't click again if it is already active
            document.querySelector(`a[data-bs-target="${targetSelector}"]`)?.click();

            mobTabInnerEl.querySelector(targetSelector).classList.add('show');
            
            // NOTE: the DOM is destroyed on tab change, so it's safe to bind events each time 
            if (targetSelector == '#tabFigures') {
                bindImageGallaryButtons();
            } else if (targetSelector == '#tabInformation') {
                bindAuthorButtons();
            }
        }, false);

        // Add click events to force scrolling the top mobile bar into view if it's not at the top, this prevents incorrect scrolling within the container
        document.querySelectorAll('#mobile-nav-vc a').forEach(function (a) {
            a.addEventListener('click', function (e) {
                var rect = document.getElementById('mobile-nav-vc').getBoundingClientRect();
                if (rect.y > 0) {
                    scrollIntoViewWithoutOffset('#mobile-nav-vc');
                }
            });
        });

        const scrollIntoViewWithoutOffset = function (selector) {
            window.scrollTo({
                behavior: 'instant',
                top:
                    document.querySelector(selector).getBoundingClientRect().top -
                    document.body.getBoundingClientRect().top
            })
        }


        const closeNavOverlay = function () {
            mobTabInnerEl.innerHTML = '';
            mobNavWrapper.classList.add('d-none');
            document.body.classList.remove('overflow-hidden');
        }

        document.querySelector('#mobileNavCloser').addEventListener('click', function (e) {
            e.preventDefault();
            closeNavOverlay();
        }, false);
        
        mobTabInnerEl.addEventListener('click', function(e) {
            const clickIsForAnchorWithinDocument = e.target?.nodeName == 'A' && e.target?.getAttribute('href')?.startsWith('#')
            if (clickIsForAnchorWithinDocument) {
                closeNavOverlay();
            }
        });

        window.addEventListener('resize', function (e) {
            const largerThanBootstrapXs = 576 < window.innerWidth;
            if (largerThanBootstrapXs) {
                closeNavOverlay();
            }
        }, true);
    });
</script>
