<script nonce="Ftb7PRn84Y&#x2B;T4DD6pyV0PXrBz&#x2B;GuQEhFlymmGzWEvzY=">
    /*
    The scite badge has a menu that appear on mouseover. The location of the element menu is calculated based 
    upon the position of the Scite badge. This calculation breaks when the Scite badge is hidden.

    Reload the badge when the metrics tab is selected to correctly set the menu's position.
    */
    window.addEventListener('load', function(event) {
        document.querySelector('a[data-bs-target="#tabMetrics"]').addEventListener('show.bs.tab', function (e) {
            window.__SCITE.insertBadges({forceReload: true})
        })
    })
</script>

