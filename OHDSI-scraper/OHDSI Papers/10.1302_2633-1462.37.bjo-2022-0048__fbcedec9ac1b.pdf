<script nonce="Ftb7PRn84Y&#x2B;T4DD6pyV0PXrBz&#x2B;GuQEhFlymmGzWEvzY=">
document
    .querySelector('#citationCopy')
    .addEventListener('click', function(event) {
        const citationEl = document.querySelector("#citationContent > div.show.active");
        const citationText = citationEl.textContent.trim();
        navigator.clipboard.writeText(citationText);

            const copied = document.getElementById('divCopied');
            copied.classList.remove("d-none");

            const copy = document.getElementById('divCopy');
            copy.classList.add("d-none");

        setTimeout(function () {
                copied.classList.add("d-none");
                copy.classList.remove("d-none");
        }, 1000);

        event.preventDefault(); // prevent document from jumping
    });
</script>


