<script nonce="Ftb7PRn84Y&#x2B;T4DD6pyV0PXrBz&#x2B;GuQEhFlymmGzWEvzY=">
    window.addEventListener('DOMContentLoaded', function () {
        bindAuthorButtons();
    });

    function bindAuthorButtons() {
        document.getElementById('expand-all-authors-btn').addEventListener('click', e => expandOrCollapseAuthors(true));
        document.getElementById('collapse-all-authors-btn').addEventListener('click', e => expandOrCollapseAuthors(false));
    }

    function expandOrCollapseAuthors(expand) {
        if (expand) {
            document.getElementById('collapse-all-authors-btn').style.display = 'block';
            document.getElementById('expand-all-authors-btn').style.display = 'none';
        } else {
            document.getElementById('collapse-all-authors-btn').style.display = 'none';
            document.getElementById('expand-all-authors-btn').style.display = 'block';
        }

        var expandButtons = document.querySelectorAll('#collapseAuthors div.collapse-author');
        expandButtons.forEach(expandButton => {
            var bsCollapse = new bootstrap.Collapse(expandButton, { toggle: false });
            if (expand) {
                bsCollapse.show();
            } else {
                bsCollapse.hide();
            }
        });
    }
</script>


