<script type="text/javascript" nonce="Ftb7PRn84Y&#x2B;T4DD6pyV0PXrBz&#x2B;GuQEhFlymmGzWEvzY=">

    function transferChildNodes(sourceId, destId) {
        var source = document.querySelector('#' + sourceId);
        var dest = document.querySelector('#' + destId);
        while (source.childNodes.length > 0) {
            dest.appendChild(source.childNodes[0]);
        };
    }

    function setUpToggle(offCanvas, source, dest) {
        document.getElementById(offCanvas).addEventListener('shown.bs.offcanvas', function () {
            transferChildNodes(source, dest);
        });
        document.getElementById(offCanvas).addEventListener('hidden.bs.offcanvas', function () {
            transferChildNodes(dest, source);
        });
    }

    window.addEventListener('load', function (event) {
        setUpToggle('offcanvasScrollSpy', 'divDesktopScrollSpy', 'divOffCanvasScrollSpy');
        setUpToggle('offcanvasInformation', 'tabInformation', 'offcanvasInformationBody');
        setUpToggle('offcanvasShare', 'tabShare', 'offcanvasShareBody');
        setUpToggle('offcanvasFigures', 'tabFigures', 'offcanvasFiguresBody');
        setUpToggle('offcanvasFigures', 'tabFigures', 'offcanvasFiguresBody');
        setUpToggle('offcanvasMetrics', 'tabMetrics', 'offcanvasMetricsBody');
        setUpToggle('offcanvasReferences', 'tabReferences', 'offcanvasReferencesBody');
    });

</script>
                            </div>
                            
