<style nonce="Ftb7PRn84Y&#x2B;T4DD6pyV0PXrBz&#x2B;GuQEhFlymmGzWEvzY=">
    .figures-buttons {
        margin-bottom: 16px;
        display: flex;
        justify-content: space-between;
    }

    #tabFigures h2 {
        font-size: 24px;
        font-weight: 600;
    }

    .go-to-article {
        font-size: 14px;
    }

    .full-screen {
        font-size: 14px;
    }
</style>

<script nonce="Ftb7PRn84Y&#x2B;T4DD6pyV0PXrBz&#x2B;GuQEhFlymmGzWEvzY=">
    const isHidden = function (el) {
        return el.offsetParent === null;
    }

    window.addEventListener('DOMContentLoaded', function () {
        bindImageGallaryButtons();
    });

    function bindImageGallaryButtons() {
        document.querySelectorAll('#divFigures .go-to-article').forEach(function (a) {
            a.addEventListener('click', function (e) {
                goToArticleFigureButton(e);
            });
        });
        document.querySelectorAll('#divFigures .full-screen').forEach(function (a) {
            a.addEventListener('click', function (e) {
                fullScreenFigureButton(e);
            });
        });
    }

    function goToArticleFigureButton(e) {
        const expandFigureAttr = e.target?.getAttribute("data-baj-figure-expand")
        const offCanvas = document.querySelector('#btnOffcanvasFiguresClose');

        if (expandFigureAttr) {
            const image = document.querySelector(`${expandFigureAttr} img`)
            if (isHidden(image)) {
                document.querySelector(`${expandFigureAttr} button`)?.click();
            }
            if (offCanvas) offCanvas.click();
        }
    }

    function fullScreenFigureButton(e) {
        const fullscreenFigureRef = e.target?.getAttribute("data-baj-figure-fullscreen");
        const offCanvas = document.querySelector('#btnOffcanvasFiguresClose');

        if (fullscreenFigureRef) {
            document.querySelector(`${fullscreenFigureRef} img`)?.click();
            if (offCanvas) offCanvas.click();
        }
    }
</script>

