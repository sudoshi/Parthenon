    <script nonce="Ftb7PRn84Y&#x2B;T4DD6pyV0PXrBz&#x2B;GuQEhFlymmGzWEvzY=">
        function removeElementIfExists(id) {
            var e = document.getElementById(id);
            if (e !== null) e.remove();
        }

        function removeJournalFilter() {
            removeElementIfExists('Journal'); // hidden input for search
            removeElementIfExists('pJournalFilter'); // text
            removeElementIfExists('removeJournalCodeFilter'); // button
        }

        const shouldDisplayLifeFeatures = "True" === "True";
        let hereFromLife = false;
        window.addEventListener('load', e => {
            let queryParams = Object.keys(Object.fromEntries(new URLSearchParams(window.location.search).entries()));
            let isLoggedIn = "False" === "True";

            if (queryParams.indexOf('registered') > -1  && isLoggedIn) {
                document.body.classList.add('hide-login-modal');
                new bootstrap.Modal('#registeredModal').show();
            } else if (queryParams.indexOf('registeredFromLife') > -1 && isLoggedIn && shouldDisplayLifeFeatures) {
                document.getElementById("registeredModalText").insertAdjacentHTML('beforeend', " When closing this" +
                  " modal, you will be redirected back to BJJ LIFE.");
                hereFromLife = true;
                document.body.classList.add('hide-login-modal');
                new bootstrap.Modal('#registeredModal').show();
            }
            if (queryParams.indexOf('registerFromLife') > -1 && shouldDisplayLifeFeatures) {
                hereFromLife = true;
                new bootstrap.Modal('#registerModal').show();
            }
            if (queryParams.indexOf('loginFromLife') > -1 && shouldDisplayLifeFeatures) {
                hereFromLife = true;
                new bootstrap.Modal('#loginModal').show();
            }

            if (!window.googletag || typeof (window.googletag.pubads) !== 'function') {
                // Blocked
                document.getElementById("adTopBanner_backup").classList.remove("d-none");
                document.getElementById("adTopBanner").classList.add("d-none");
            }
            else {
                // Defer asking Google for ad content until now so that the required attributes are available
                var journalId = document.getElementById('hiddenJournalId');
                if (journalId) {
                    googletag.pubads().setTargeting('JournalCode', [journalId.value]);
                }
                var specialty = document.getElementById('hiddenSpecialty');
                if (specialty) {
                    googletag.pubads().setTargeting('Specialty', [specialty.value]);
                }
            }

            googletag.cmd.push(function () { googletag.display('div-gpt-ad-1667833408955-0'); });

        });

        window.addEventListener('DOMContentLoaded', e => {
            this.registerLogoutButton();

            document.getElementById('registeredModal').addEventListener('hide.bs.modal', () => {
                window.location.href = window.location.origin + window.location.pathname;
            })

            document.getElementById('searchModal').addEventListener('shown.bs.modal', () => {
                document.getElementById('SearchTerm').focus()
            })

            var journalId = document.getElementById('hiddenJournalId');
            if (journalId) {
                var form = document.getElementById('modalSearchForm');
                document.getElementById('Journal').value = journalId.value;
                document.getElementById('pJournalFilter').innerText = 'within ' + document.getElementById('hiddenJournalTitle').value;
            } else {
                removeElementIfExists('Journal');
                document.getElementById('pJournalFilter').innerHTML = '';
                document.getElementById('removeJournalCodeFilter').style.display = 'none';
            }

            document.getElementById('removeJournalCodeFilter').addEventListener('click', e => removeJournalFilter());

            var mainLogoName = 'Bone_Joint_Orthopaedics';
            var mainLogoExtension = '.svg';
            if (journalId && ['BJR', 'BJ360', 'BJO'].indexOf(journalId.value) > -1) {
                mainLogoName = 'Bone_Joint_' + journalId.value;
            }
            document.querySelectorAll('.navbar-logo img').forEach(img => img.src = '/images/' + mainLogoName + mainLogoExtension);
            document.querySelectorAll('.navbar-logo img').forEach(img => img.classList.remove('d-none'));

            var wayflessLink = document.getElementById('wayflessLink');
            wayflessLink.href+= "?target=" + window.location;

            this.moveJournalMobileNavMenu();

            this.bindPasswordChangeInput('registerPassword');
            this.bindPasswordChangeInput('newPassword');
        });

        function moveJournalMobileNavMenu() {
            var journalMobileNavSource = document.getElementById('mobileJournalNavMenu');
            var journalMobileNavDestination = document.querySelector('.journal-modal-section');

            if (!journalMobileNavSource) {
                return;
            }

            while (journalMobileNavSource.childNodes.length > 0) {
                journalMobileNavDestination.appendChild(journalMobileNavSource.childNodes[0]);
            }
        }

        document.getElementById('switchFromLoginToRegister').addEventListener('click', e => {
            new bootstrap.Modal('#registerModal').show();
        })

        // Display the institutional login options
        // When we access the login modal via the regular login button in the navbar, we want to show both institutional
        // and account login
        const loginFromNavbarElements = document.getElementsByClassName('login-from-navbar')
        for (const el of loginFromNavbarElements) {
            el.addEventListener('click', e => {
                const institutionalLoginElements = document.getElementsByClassName("institutional-login")
                for (const ilEl of institutionalLoginElements) {
                    ilEl.classList.remove("d-none")
                }
                const accountLoginElements = document.getElementsByClassName("account-login")
                for (const alEl of accountLoginElements) {
                    alEl.classList.remove("px-5")
                }
            })
        }

        document.getElementById("btnLogin")
            .addEventListener('click', function (e) {
                const model = {
                    EmailAddress: document.getElementById('loginEmailAddress').value,
                    Password: document.getElementById('loginPassword').value
                }

                const options = {
                    method: 'POST',
                    body: JSON.stringify(model),
                    headers: { 'Content-Type': 'application/json' }
                }

                // If the user is currently logged in, log them out first.
                // This will currently only happen in the case where the user is signed in as an institution and wants
                // to sign in as an individual to access a collection PDF.
                // TODO Can we improve the UX for this so it's more predictable for the user?
                let isLoggedIn = "False" === "True";
                const logoutPromise = isLoggedIn ? fetch('/api/account/logout') : Promise.resolve()

                logoutPromise.then(() => {
                    fetch('/api/account/login', options)
                        .then(response => response.json()
                            .then(function (json) {
                                if (!response.ok) {
                                    handleFormErrors(json, '#loginModal', 'login', new Map())
                                }
                                else {
                                    if (hereFromLife && shouldDisplayLifeFeatures) {
                                        // If the user is here from LIFE, we want to redirect back once login is complete
                                        window.location.href = "/life";
                                    } else {
                                        location.reload(true);
                                    }
                                }
                            }));
                })
            });

        function registerLogoutButton() {
            let btnLogouts = document.querySelectorAll(
                "#btnLogoutDesktop, #btnLogoutMobile, #btnLogoutInstitutional, #btnLogoutInstitutionalCheckout");
            if (btnLogouts != null && btnLogouts.length > 0) {
                btnLogouts.forEach(function (btnLogout) {
                    btnLogout.addEventListener('click', function (e) {
                        fetch('/api/account/logout')
                            .then(txt => {
                                location.reload();
                            });
                    });
                })
            }
        }

        function resendConfirmationEmail() {
            var emailAddress = document.getElementById('EmailAddress').value;

            const model = {
                EmailAddress: emailAddress
            }

            const options = {
                method: 'POST',
                body: JSON.stringify(model),
                headers: {
                    'Content-Type': 'application/json'
                }
            }

            fetch('/api/account/resendConfirmationEmail', options)
                .then(response => {
                    resendConfirmationLink.disabled = true;
                    resendConfirmationLink.textContent = "Email confirmation sent";
                    setTimeout(function () { resendConfirmationLink.classList.add("d-none") }, 2000);
                });
        }
        
        document.getElementById("btnRegister")
            .addEventListener('click', function (e) {
                const model = {
                    EmailAddress: document.getElementById('registerEmailAddress').value,
                    Password: document.getElementById('registerPassword').value,
                    FirstName: document.getElementById('registerFirstName').value,
                    LastName: document.getElementById('registerLastName').value,
                    TermsAndConditions: document.getElementById('registerTermsAndConditions').checked
                }

                const options = {
                    method: 'POST',
                    body: JSON.stringify(model),
                    headers: { 'Content-Type': 'application/json' }
                }

                fetch('/api/account/register', options)
                    .then(response => response.json()
                        .then(function (json) {
                            if (!response.ok) {
                                handleFormErrors(json, '#registerModal', 'register',
                                    new Map([['Email address is already registered', '<div class="d-flex">Email address is already registered. Please <a id="registerLoginText" class="px-1" type="button" href="" data-bs-toggle="modal" data-bs-target="#loginModal">Sign in</a> instead</div>']])
                                )
                            }
                            else if (window.location.pathname.toLowerCase() === "/register") {
                                window.location.href = window.location.protocol + "//" + window.location.host + "/account/managepersonal";
                            }
                            else {
                                var url = new URL(window.location.href);
                                if (hereFromLife && shouldDisplayLifeFeatures) {
                                    // If a user got here from LIFE, we should remove the `registerFromLife` query param
                                    // so we stop showing the modal once the page refreshes, and enter the registered state
                                    url.searchParams.delete("registerFromLife");
                                    url.searchParams.append("registeredFromLife", "true");
                                } else {
                                    url.searchParams.append("registered", "true");
                                }

                                window.location.href = url;
                            }
                        }));
            });

        function bindPasswordChangeInput(id) {
            var elementId = id;
            var element = document.getElementById(elementId);
            if (!element) return;
            // User typing
            element.addEventListener('keyup', function (e) {
                debounce(function (password) {
                    sendPasswordValidation(password);
                })(e.currentTarget.value);
            });

            // Auto fill
            element.addEventListener('paste', function (e) {
                debounce(function (password) {
                    sendPasswordValidation(password);
                })(e.clipboardData.getData('Text'));
            });
        }
        
        function sendPasswordValidation(password) {
            const model = {
                Password: password,
            }

            const options = {
                method: 'POST',
                body: JSON.stringify(model),
                headers: { 'Content-Type': 'application/json' }
            }

            fetch('/api/account/passwordStrengthValidation', options)
                .then(response => response.json())
                .then(function (json) {
                    if (json.passed) {
                        this.setErrorText('');
                        setInputAsValid('registerPassword');
                        return;
                    }

                    var errors = '';
                    json.errorMessages.forEach(function (error) { errors += error + '</br>'; });
                    this.setErrorText(errors);
                    setInputAsInvalid('registerPassword');
                });
        }

        function setErrorText(errors) {
            document.querySelector('#registerPasswordFeedback').innerHTML = errors;
        }

        var timer = null;
        function debounce(func, timeout = 500){
            return (...args) => {
                if (timer)
                    clearTimeout(timer);
                timer = setTimeout(() => { func.apply(this, args); }, timeout);
            };
        }

        document.getElementById("closeRegisteredModal").addEventListener('click', function (e) {
            if (hereFromLife && shouldDisplayLifeFeatures) {
                window.location.href = "/life";
            }
        });

        document.getElementById("closeRegisteredModalX").addEventListener('click', function (e) {
            if (hereFromLife && shouldDisplayLifeFeatures) {
                window.location.href = "/life";
            }
        });

        document.getElementById("registrationSuccessfulGoToAccountButton").addEventListener('click', function (e) {
            window.location.href = "/Account/ManagePersonal";
        })
    </script>

</header>


