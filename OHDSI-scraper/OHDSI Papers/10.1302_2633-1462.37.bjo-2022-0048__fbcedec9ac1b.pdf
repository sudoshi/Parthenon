<script nonce="Ftb7PRn84Y&#x2B;T4DD6pyV0PXrBz&#x2B;GuQEhFlymmGzWEvzY=">

    function PostEtocSubscription() {
        document.getElementById('alertCreated').textContent = "";
        bootstrap.Popover.getOrCreateInstance('#poAlerts').hide();
        updateSubscribedDivs();
    }

    document.addEventListener('click', function (e) {
        if (e.target.id == 'idSubmitEtocLoggedIn') {
            fetch('/api/subscriptions/etoc/BJO', { method: 'POST' })
                .then(response => response.json())
                .then(data => {
                    e.target.disabled = true;
                    var d = document.getElementById('alertCreated');
                    d.textContent = "Alert created";
                    setTimeout(PostEtocSubscription, 2000);
                });
        }

        if (e.target.id == 'idSubmitEtocEmailAddress') {
            var emailAddress = document.querySelectorAll('#inputEtocEmailAddress')[1].value;
            fetch('/api/subscriptions/etoc/BJO?emailAddress=' + emailAddress, { method: 'POST' })
                .then(response => response.json())
                .then(data => {
                    e.target.disabled = true;
                    var d = document.getElementById('alertCreated');
                    d.textContent = "Alert created";
                    setTimeout(PostEtocSubscription, 2000);
                });
        }
    });

    function showCorrectSubscribedDiv(isSubscribed) {
        document.querySelectorAll('[data-subscribed="' + isSubscribed + '"]')
            .forEach((el) => el.classList.remove("d-none"));
        document.querySelectorAll('[data-subscribed="' + !isSubscribed + '"]')
            .forEach((el) => el.classList.add("d-none"));
    }

    function updateSubscribedDivs() {
        fetch(`/Account/ManagePersonal?handler=FetchEtocSubscriptions`)
            .then(resp => resp.json())
            .then(resp => {
                showCorrectSubscribedDiv(resp.includes('BJO'));
            });
    }

    function clickOutsideCollapses(querySelector) {
        // Close opened menu when user clicks outside the menu
        document.addEventListener('click', function (event) {
            const openMenuClass = querySelector;

            if (document.querySelector(openMenuClass) === null)
                return;

            // If the click happened inside the modal, do nothing
            if (event.target.closest(openMenuClass))
                return;

            // Close modals
            const collapseElementList = document.querySelectorAll(openMenuClass)
            const collapseList = [...collapseElementList].map(collapseEl => new bootstrap.Collapse(collapseEl))
        }, false);
    }

    clickOutsideCollapses('.journal-menu-collapse.show');
    clickOutsideCollapses('.media-menu-collapse.show');
    clickOutsideCollapses('.archive-collapse.show');

    function clickOutsidePopovers(querySelector, caller) {
        // Close opened popover when user clicks outside the popover
        document.addEventListener('click', function (event) {
            const openPopoverClass = querySelector;

            if (document.querySelector(openPopoverClass) === null)
                return;

            // If the click happened inside the popover, do nothing
            if (event.target.closest(openPopoverClass))
                return;

            // Close modals
            bootstrap.Popover.getOrCreateInstance(caller).hide();
        }, false);
    }
    clickOutsidePopovers('.alerts-popover.show', '#poAlerts');
    clickOutsidePopovers('.socialmedia-popover.show', '#poSocialMedia');
</script>




