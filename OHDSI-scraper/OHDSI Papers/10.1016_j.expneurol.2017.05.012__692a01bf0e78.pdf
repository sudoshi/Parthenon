:[{"#name":"organization","_":"Center for Brain and Spinal Cord Repair"},{"#name":"organization","_":"The Neurological Institute"},{"#name":"organization","_":"Ohio State University Wexner Medical Center"},{"#name":"city","_":"Columbus"},{"#name":"state","_":"OH"},{"#name":"postal-code","_":"43210"},{"#name":"country","_":"USA"}]}]},"af0055":{"#name":"affiliation","$":{"id":"af0055"},"$$":[{"#name":"label","_":"k"},{"#name":"textfn","$":{"id":"tn0060"},"_":"Department of Neuroscience, The Neurological Institute, Ohio State University Wexner Medical Center, Columbus 43210, OH, USA"},{"#name":"affiliation","$":{"xmlns:sa":true},"$$":[{"#name":"organization","_":"Department of Neuroscience"},{"#name":"organization","_":"The Neurological Institute"},{"#name":"organization","_":"Ohio State University Wexner Medical Center"},{"#name":"city","_":"Columbus"},{"#name":"state","_":"OH"},{"#name":"postal-code","_":"43210"},{"#name":"country","_":"USA"}]}]},"af0060":{"#name":"affiliation","$":{"id":"af0060"},"$$":[{"#name":"label","_":"l"},{"#name":"textfn","$":{"id":"tn0065"},"_":"Department of Neurology, The Neurological Institute, Ohio State University Wexner Medical Center, Columbus 43210, OH, USA"},{"#name":"affiliation","$":{"xmlns:sa":true},"$$":[{"#name":"organization","_":"Department of Neurology"},{"#name":"organization","_":"The Neurological Institute"},{"#name":"organization","_":"Ohio State University Wexner Medical Center"},{"#name":"city","_":"Columbus"},{"#name":"state","_":"OH"},{"#name":"postal-code","_":"43210"},{"#name":"country","_":"USA"}]}]},"af0065":{"#name":"affiliation","$":{"id":"af0065"},"$$":[{"#name":"label","_":"m"},{"#name":"textfn","$":{"id":"tn0070"},"_":"Department of Physical Medicine and Rehabilitation, The Neurological Institute, Ohio State University Wexner Medical Center, Columbus 43210, OH, USA"},{"#name":"affiliation","$":{"xmlns:sa":true},"$$":[{"#name":"organization","_":"Department of Physical Medicine and Rehabilitation"},{"#name":"organization","_":"The Neurological Institute"},{"#name":"organization","_":"Ohio State University Wexner Medical Center"},{"#name":"city","_":"Columbus"},{"#name":"state","_":"OH"},{"#name":"postal-code","_":"43210"},{"#name":"country","_":"USA"}]}]}},"correspondences":{"cr0005":{"#name":"correspondence","$":{"id":"cr0005"},"$$":[{"#name":"label","_":"⁎"},{"#name":"text","$":{"id":"tx0010"},"_":"Corresponding author."}]}},"attachments":[],"scopusAuthorIds":{},"articles":{}},"authorMetadata":[],"banner":{"expanded":false},"biographies":{},"body":{},"chapters":{"toc":[],"isLoading":false},"changeViewLinks":{"showFullTextLink":true,"showAbstractLink":false},"citingArticles":{"hitCount":45,"viewMoreUrl":"http://www.scopus.com/scopus/inward/citedby.url?partnerID=10&rel=3.0.0&eid=2-s2.0-85020470282&md5=5b7959c142412137893e2d77df8e83b","articles":[{"articleTitle":"Translating promising strategies for bowel and bladder management in spinal cord injury","accessTypeLabel":"Open access","authors":"Wheeler T.L., de Groat W.C., Kleitman N.","doi":"10.1016/j.expneurol.2018.05.006","documentTypeLabel":"Review article","externalArticle":false,"issn":"00144886","openAccess":1,"page":"169-176","pii":"S0014488618301122","publicationDate":"2018-08-01","publicationTitle":"Experimental Neurology","publicationYear":"2018","scopusArticleUrl":"http://www.scopus.com/scopus/inward/record.url?partnerID=10&rel=3.0.0&view=basic&eid=2-s2.0-85047266329&md5=20eea424c0c24f683895a346ccda9d8","scopusEid":"2-s2.0-85047266329","snippets":["These Centers, funded through 5-year awards from the National Institute on Disability, Independent Living, and Rehabilitation Research (NIDILRR), are recognized for their leadership in medical research and patient care. Other large data resources include the Rick Hansen SCI Registry (RHSCIR) (Fehlings et al., 2017), and a new effort to coordinate data sharing in SCI research in a “FAIR” Findable, Accessible, Interoperable and Reusable manner (Callahan, et al., 2017). Utilization of common data elements for clinical documentation as well as research (Biering-Sørensen et al., 2015) would also support efforts in another important thematic area, bowel physiology."],"thirdParty":false,"volume":"Volume 306","abstract":{"$$":[{"$$":[{"$":{"id":"st0005"},"#name":"section-title","_":"Abstract"},{"$$":[{"$":{"view":"all","id":"sp0005"},"#name":"simple-para","_":"Loss of control over voiding following spinal cord injury (SCI) impacts autonomy, participation and dignity, and can cause life-threatening complications. The importance of SCI bowel and bladder dysfunction warrants significantly more attention from researchers in the field. To address this gap, key SCI clinicians, researchers, government and private funding organizations met to share knowledge and examine emerging approaches. This report reviews recommendations from this effort to identify and prioritize near-term treatment, investigational and translational approaches to addressing the pressing needs of people with SCI."}],"$":{"view":"all","id":"as0005"},"#name":"abstract-sec"}],"$":{"view":"all","id":"ab0005","lang":"en","class":"author"},"#name":"abstract"},{"$$":[{"$":{"id":"st0010"},"#name":"section-title","_":"Highlights"},{"$$":[{"$$":[{"$$":[{"$$":[{"#name":"label","_":"•"},{"$":{"view":"all","id":"p0005"},"#name":"para","_":"Educational resources and clinical care standards require updating."}],"$":{"id":"li0005"},"#name":"list-item"},{"$$":[{"#name":"label","_":"•"},{"$":{"view":"all","id":"p0010"},"#name":"para","_":"Bowel physiology poorly understood limiting advancement."}],"$":{"id":"li0010"},"#name":"list-item"},{"$$":[{"#name":"label","_":"•"},{"$":{"view":"all","id":"p0015"},"#name":"para","_":"Provision of sensory awareness to foster independence and health maintenance"}],"$":{"id":"li0015"},"#name":"list-item"},{"$$":[{"#name":"label","_":"•"},{"$":{"view":"all","id":"p0020"},"#name":"para","_":"Emerging neuromodulation techniques to regain functional control"}],"$":{"id":"li0020"},"#name":"list-item"},{"$$":[{"#name":"label","_":"•"},{"$":{"view":"all","id":"p0025"},"#name":"para","_":"Link between physical movement and system function unclear"}],"$":{"id":"li0025"},"#name":"list-item"}],"$":{"id":"l0005"},"#name":"list"}],"$":{"view":"all","id":"sp0010"},"#name":"simple-para"}],"$":{"view":"all","id":"as0010"},"#name":"abstract-sec"}],"$":{"view":"all","id":"ab0010","lang":"en","class":"author-highlights"},"#name":"abstract"}],"$":{"xmlns:ce":true,"xmlns:dm":true,"xmlns:sb":true},"#name":"abstracts"}},{"articleTitle":"Brain changes after spinal cord injury, a quantitative meta-analysis and review","authors":"Solstrand Dahlberg L., Becerra L.R., Linnman C.N.","doi":"10.1016/j.neubiorev.2018.04.018","documentTypeLabel":"Review article","externalArticle":false,"issn":"01497634","openAccess":0,"page":"272-293","pii":"S0149763417307091","publicationDate":"2018-07-01","publicationTitle":"Neuroscience and Biobehavioral Reviews","publicationYear":"2018","scopusArticleUrl":"http://www.scopus.com/scopus/inward/record.url?partnerID=10&rel=3.0.0&view=basic&eid=2-s2.0-85046650362&md5=52f9d8349a781cb477d823e35fa2f0d4","scopusEid":"2-s2.0-85046650362","snippets":["The neuroimaging community response to these challenges has been to begin synchronizing protocols and sharing data more openly (Poldrack and Gorgolewski, 2014). Such efforts are ongoing in the pre-clinical SCI community (Callahan et al., 2017). In clinical studies, pioneered by dementia- and psychiatric-neuroimaging groups, there are now very large data depositories with phenotypic, genotypic and multi-modal neuroimaging data, made freely available to other researchers after rigorous de-identification."],"thirdParty":false,"volume":"Volume 90","abstract":{"$$":[{"$$":[{"$":{"id":"sect0005"},"#name":"section-title","_":"Highlights"},{"$$":[{"$$":[{"$$":[{"$$":[{"#name":"label","_":"•"},{"$":{"view":"all","id":"par0005"},"#name":"para","_":"There was sufficient homogeneity for meta-analysis of fMRI motor and motor imagery tasks."}],"$":{"id":"lsti0005"},"#name":"list-item"},{"$$":[{"#name":"label","_":"•"},{"$":{"view":"all","id":"par0010"},"#name":"para","_":"Results indicate consistently elevated motor, parietal and cerebellar responses in SCI."}],"$":{"id":"lsti0010"},"#name":"list-item"},{"$$":[{"#name":"label","_":"•"},{"$":{"view":"all","id":"par0015"},"#name":"para","_":"Studies report structural and functional alterations with diffusion and metabolite changes."}],"$":{"id":"lsti0015"},"#name":"list-item"},{"$$":[{"#name":"label","_":"•"},{"$":{"view":"all","id":"par0020"},"#name":"para","_":"Findings suggest adaptive plasticity following injury can be affected by pain."}],"$":{"id":"lsti0020"},"#name":"list-item"},{"$$":[{"#name":"label","_":"•"},{"$":{"view":"all","id":"par0025"},"#name":"para","_":"Standardized protocols should be emphasized to minimize heterogeneity in studies."}],"$":{"id":"lsti0025"},"#name":"list-item"}],"$":{"id":"lis0005"},"#name":"list"}],"$":{"view":"all","id":"spar0075"},"#name":"simple-para"}],"$":{"view":"all","id":"abst0005"},"#name":"abstract-sec"}],"$":{"view":"all","id":"abs0005","class":"author-highlights"},"#name":"abstract"},{"$$":[{"$":{"id":"sect0010"},"#name":"section-title","_":"Abstract"},{"$$":[{"$":{"view":"all","id":"spar0080"},"#name":"simple-para","_":"Spinal Cord Injuries (SCI) lead to alterations in brain structure and brain function by direct effects of nerve damage, by secondary mechanisms, and also by longer term injury consequences such as paralysis and neuropathic pain. Here, we review neuroimaging studies of patients with traumatic spinal cord injuries, perform a quantitative meta-analysis of motor and motor imagery studies, summarize structural studies, evidence of cortical reorganization, and provide an overview of diffusion and spectroscopy studies. The meta-analysis showed significantly altered motor cortex, as well as cerebellar and parietal lobe changes, and qualitatively consistent reports of alterations in somatosensory brain structure, cortical reorganization, white matter diffusion and thalamic metabolites. Larger samples in combination with standardized imaging protocols and data sharing will further our understanding of brain changes after SCI and help in defining short and long-term changes in brain systems in SCI patients. Such data would provide a basis for clinical trials, treatment outcomes, and guide novel interventions."}],"$":{"view":"all","id":"abst0010"},"#name":"abstract-sec"}],"$":{"view":"all","id":"abs0010","class":"author"},"#name":"abstract"}],"$":{"xmlns:ce":true,"xmlns:dm":true,"xmlns:sb":true},"#name":"abstracts"}},{"articleNumber":"802","articleTitle":"Considerations for Studying Sex as a Biological Variable in Spinal Cord Injury","accessTypeLabel":"Open access","authors":"Stewart A.N., MacLean S.M., Wilson M.E.","doi":"10.3389/fneur.2020.00802","documentTypeLabel":"Research article","externalArticle":true,"issn":"16642295","openAccess":1,"pii":"S1664229520007413","publicationDate":"2020-01-01","publicationTitle":"Frontiers in Neurology","publicationYear":"2020","scopusArticleUrl":"http://www.scopus.com/scopus/inward/record.url?partnerID=10&rel=3.0.0&view=basic&eid=2-s2.0-85089805868&md5=c659cb725fd362e5e639f4451eb5e57d","scopusEid":"2-s2.0-85089805868","thirdParty":true,"volume":"Volume 11","abstract":{"$$":[{"$$":[{"$$":[{"$":{"view":"all"},"#name":"simple-para","_":"In response to NIH initiatives to investigate sex as a biological variable in preclinical animal studies, researchers have increased their focus on male and female differences in neurotrauma. Inclusion of both sexes when modeling neurotrauma is leading to the identification of novel areas for therapeutic and scientific exploitation. Here, we review the organizational and activational effects of sex hormones on recovery from injury and how these changes impact the long-term health of spinal cord injury (SCI) patients. When determining how sex affects SCI it remains imperative to expand outcomes beyond locomotor recovery and consider other complications plaguing the quality of life of patients with SCI. Interestingly, the SCI field predominately utilizes female rodents for basic science research which contrasts most other male-biased research fields. We discuss the unique caveats this creates to the translatability of preclinical research in the SCI field. We also review current clinical and preclinical data examining sex as biological variable in SCI. Further, we report how technical considerations such as housing, size, care management, and age, confound the interpretation of sex-specific effects in animal studies of SCI. We have uncovered novel findings regarding how age differentially affects mortality and injury-induced anemia in males and females after SCI, and further identified estrus cycle dysfunction in mice after injury. Emerging concepts underlying sexually dimorphic responses to therapy are also discussed. Through a combination of literature review and primary research observations we present a practical guide for considering and incorporating sex as biological variable in preclinical neurotrauma studies."}],"$":{"view":"all","id":"aep-abstract-sec-id12"},"#name":"abstract-sec"}],"$":{"view":"all","id":"aep-abstract-id11","class":"author"},"#name":"abstract"}],"$":{"xmlns:ce":true,"xmlns:dm":true,"xmlns:sb":true},"#name":"abstracts"}},{"articleNumber":"18","articleTitle":"Credibility, replicability, and reproducibility in simulation for biomedicine and clinical applications in neuroscience","accessTypeLabel":"Open access","authors":"Mulugeta L., Drach A., Lytton W.W.","doi":"10.3389/fninf.2018.00018","documentTypeLabel":"Review article","externalArticle":true,"issn":"16625196","openAccess":1,"pii":"S1662519618000570","publicationDate":"2018-01-01","publicationTitle":"Frontiers in Neuroinformatics","publicationYear":"2018","scopusArticleUrl":"http://www.scopus.com/scopus/inward/record.url?partnerID=10&rel=3.0.0&view=basic&eid=2-s2.0-85049105743&md5=9418211079314f8d0d1d112c21c2950","scopusEid":"2-s2.0-85049105743","thirdParty":true,"volume":"Volume 12","abstract":{"$$":[{"$$":[{"$$":[{"$":{"view":"all"},"#name":"simple-para","_":"Modeling and simulation in computational neuroscience is currently a research enterprise to better understand neural systems. It is not yet directly applicable to the problems of patients with brain disease. To be used for clinical applications, there must not only be considerable progress in the field but also a concerted effort to use best practices in order to demonstrate model credibility to regulatory bodies, to clinics and hospitals, to doctors, and to patients. In doing this for neuroscience, we can learn lessons from long-standing practices in other areas of simulation (aircraft, computer chips), from software engineering, and from other biomedical disciplines. In this manuscript, we introduce some basic concepts that will be important in the development of credible clinical neuroscience models: reproducibility and replicability; verification and validation; model configuration; and procedures and processes for credible mechanistic multiscale modeling. We also discuss how garnering strong community involvement can promote model credibility. Finally, in addition to direct usage with patients, we note the potential for simulation usage in the area of Simulation-Based Medical Education, an area which to date has been primarily reliant on physical models (mannequins) and scenario-based simulations rather than on numerical simulations."}],"$":{"view":"all","id":"aep-abstract-sec-id13"},"#name":"abstract-sec"}],"$":{"view":"all","id":"aep-abstract-id12","class":"author"},"#name":"abstract"}],"$":{"xmlns:ce":true,"xmlns:dm":true,"xmlns:sb":true},"#name":"abstracts"}},{"articleTitle":"The neuroanatomical–functional paradox in spinal cord injury","authors":"Fouad K., Popovich P.G., Schwab J.M.","doi":"10.1038/s41582-020-00436-