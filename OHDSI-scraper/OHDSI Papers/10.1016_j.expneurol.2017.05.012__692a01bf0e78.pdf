      <script src='/us-east-1/prod/b5d02fe3412326475f6fc7d7c0b3e2006ff0d5f2/arp.js' async type="7b98531e86768d06cd08880f-text/javascript"></script>
      <script type="7b98531e86768d06cd08880f-text/javascript">
		
		function getTTLItem(key) {
	const itemStr = localStorage.getItem(key);
	let item;
	try {
		item = JSON.parse(itemStr);
	} catch {
		console.warn(`[getTTLItem(${key})] failed to parse ${itemStr}`);
		return null;
	}

	const expired = typeof item?.ttl !== 'number' || item?.ttl < Date.now();
	if (expired) {
		return null;
	}
