<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Sherif%20NA"[Author]' class="usa-link"><span class="name western">Noha A Sherif</span></a>
</div>
</div>
<sup>1</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Chew%20EY"[Author]' class="usa-link" aria-describedby="id2"><span class="name western">Emily Y Chew</span></a><div hidden="hidden" id="id2">
<h3><span class="name western">Emily Y Chew</span></h3>
<div class="p">
<sup>1</sup>National Eye Institute, National Institutes of Health, Bethesda, MD USA</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Chew%20EY"[Author]' class="usa-link"><span class="name western">Emily Y Chew</span></a>
</div>
</div>
<sup>1</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Chiang%20MF"[Author]' class="usa-link" aria-describedby="id3"><span class="name western">Michael F Chiang</span></a><div hidden="hidden" id="id3">
<h3><span class="name western">Michael F Chiang</span></h3>
<div class="p">
<sup>1</sup>National Eye Institute, National Institutes of Health, Bethesda, MD USA</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Chiang%20MF"[Author]' class="usa-link"><span class="name western">Michael F Chiang</span></a>
</div>
</div>
<sup>1</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Hribar%20MR"[Author]' class="usa-link" aria-describedby="id4"><span class="name western">Michelle R Hribar</span></a><div hidden="hidden" id="id4">
<h3><span class="name western">Michelle R Hribar</span></h3>
<div class="p">
<sup>2</sup>Oregon Health &amp; Science University, Portland, OR, USA</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Hribar%20MR"[Author]' class="usa-link"><span class="name western">Michelle R Hribar</span></a>
</div>
</div>
<sup>2</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Gao%20J"[Author]' class="usa-link" aria-describedby="id5"><span class="name western">James Gao</span></a><div hidden="hidden" id="id5">
<h3><span class="name western">James Gao</span></h3>
<div class="p">
<sup>1</sup>National Eye Institute, National Institutes of Health, Bethesda, MD USA</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Gao%20J"[Author]' class="usa-link"><span class="name western">James Gao</span></a>
</div>
</div>
<sup>1</sup>, <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Goetz%20KE"[Author]' class="usa-link" aria-describedby="id6"><span class="name western">Kerry E Goetz</span></a><div hidden="hidden" id="id6">
<h3><span class="name western">Kerry E Goetz</span></h3>
<div class="p">
<sup>1</sup>National Eye Institute, National Institutes of Health, Bethesda, MD USA</div>
<div class="p">Find articles by <a href='https://pubmed.ncbi.nlm.nih.gov/?term="Goetz%20KE"[Author]' class="usa-link"><span class="name western">Kerry E Goetz</span></a>
</div>
</div>
<sup>1</sup>
</div>
<ul class="d-buttons inline-list">
<li><button class="d-button" aria-controls="aip_a" aria-expanded="false">Author information</button></li>
<li><button class="d-button" aria-controls="anp_a" aria-expanded="false">Article notes</button></li>
