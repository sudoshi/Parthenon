ogram, NIH"}], "familyName": "Schully", "givenName": "Sheri", "name": "Schully, Sheri"}, {"@id": "https://orcid.org/0000-0002-9821-7704", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "National Eye Institute, NIH"}], "familyName": "Goetz", "givenName": "Kerry E.", "name": "Goetz, Kerry E."}], "contentSize": "377.64 KB", "creator": [{"@type": "Person", "affiliation": [{"@type": "Organization", "name": "Rose Li \u0026 Associates, Inc."}], "familyName": "Weixelbaum", "givenName": "Jay", "name": "Weixelbaum, Jay"}, {"@type": "Person", "affiliation": [{"@type": "Organization", "name": "Rose Li \u0026 Associates, Inc."}], "familyName": "Beezley", "givenName": "Kelly E.", "name": "Beezley, Kelly E."}, {"@type": "Person", "affiliation": [{"@type": "Organization", "name": "Rose Li \u0026 Associates, Inc."}], "familyName": "Tuvesson", "givenName": "Nancy", "name": "Tuvesson, Nancy"}, {"@id": "https://orcid.org/0000-0001-8249-0581", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "National Eye Institute, NIH"}], "familyName": "Reed", "givenName": "Amberlynn", "name": "Reed, Amberlynn"}, {"@id": "https://orcid.org/0009-0004-1429-983X", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "National Eye Institute, NIH"}], "familyName": "Haqqani", "givenName": "Syed", "name": "Haqqani, Syed"}, {"@id": "https://orcid.org/0000-0001-7626-6540", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "All of Us Research Program, NIH"}], "familyName": "Giannini", "givenName": "John", "name": "Giannini, John"}, {"@id": "https://orcid.org/0000-0003-3773-0659", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "All of Us Research Program, NIH"}], "familyName": "Landis", "givenName": "Erica", "name": "Landis, Erica"}, {"@type": "Person", "affiliation": [{"@type": "Organization", "name": "National Institute of Biomedical Imaging and Bioengineering, NIH"}], "familyName": "Anderson", "givenName": "Afrouz", "name": "Anderson, Afrouz"}, {"@id": "https://orcid.org/0000-0003-1550-9224", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "All of Us Research Program, NIH"}], "familyName": "Schully", "givenName": "Sheri", "name": "Schully, Sheri"}, {"@id": "https://orcid.org/0000-0002-9821-7704", "@type": "Person", "affiliation": [{"@type": "Organization", "name": "National Eye Institute, NIH"}], "familyName": "Goetz", "givenName": "Kerry E.", "name": "Goetz, Kerry E."}], "dateCreated": "2023-10-02T20:28:37.449447+00:00", "dateModified": "2024-07-11T04:58:06.631716+00:00", "datePublished": "2023-10-02", "description": "\u003cp\u003eThe potential inclusion of ocular imaging data into the \u003cem\u003eAll of Us\u003c/em\u003e Research Program (\u003cem\u003eAll of Us\u003c/em\u003e) dataset provides a unique opportunity to address many of these issues and empower new opportunities for research. To discuss the opportunities and challenges surrounding incorporating ocular imaging data, NIH partners at NEI, NIBIB, and the \u003cem\u003eAll of Us\u003c/em\u003e Research Program organized a workshop with experts in vision science, ophthalmology, imaging technology, data science, and health disparities research. This workshop explored the current state of imaging informatics in the vision research field, opportunities to expand research with large retinal imaging cohorts, and the data and analytical tools needed to advance this research. This document will summarize the presentations, panel discussions, and key findings from the workshop.\u003c/p\u003e", "identifier": "https://doi.org/10.5281/zenodo.8384372", "inLanguage": {"@type": "Language", "alternateName": "eng", "name": "English"}, "keywords": "ocular imaging", "license": "https://creativecommons.org/licenses/by/4.0/legalcode", "name": "Opportunities for Ophthalmology Research in Large Research Cohorts: A National Eye Institute, National Institute of Biomedical Imaging and Bioengineering, and All of Us Research Program Workshop", "publisher": {"@type": "Organization", "name": "Zenodo"}, "size": "377.64 KB", "url": "https://zenodo.org/records/8384372", "version": "1"}</script>

