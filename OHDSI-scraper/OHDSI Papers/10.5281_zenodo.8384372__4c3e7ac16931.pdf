family_name": "Weixelbaum", "given_name": "Jay", "name": "Weixelbaum, Jay", "type": "personal"}}, {"affiliations": [{"name": "Rose Li \u0026 Associates, Inc."}], "person_or_org": {"family_name": "Beezley", "given_name": "Kelly E.", "name": "Beezley, Kelly E.", "type": "personal"}}, {"affiliations": [{"name": "Rose Li \u0026 Associates, Inc."}], "person_or_org": {"family_name": "Tuvesson", "given_name": "Nancy", "name": "Tuvesson, Nancy", "type": "personal"}}, {"affiliations": [{"name": "National Eye Institute, NIH"}], "person_or_org": {"family_name": "Reed", "given_name": "Amberlynn", "identifiers": [{"identifier": "0000-0001-8249-0581", "scheme": "orcid"}], "name": "Reed, Amberlynn", "type": "personal"}}, {"affiliations": [{"name": "National Eye Institute, NIH"}], "person_or_org": {"family_name": "Haqqani", "given_name": "Syed", "identifiers": [{"identifier": "0009-0004-1429-983X", "scheme": "orcid"}], "name": "Haqqani, Syed", "type": "personal"}}, {"affiliations": [{"name": "All of Us Research Program, NIH"}], "person_or_org": {"family_name": "Giannini", "given_name": "John", "identifiers": [{"identifier": "0000-0001-7626-6540", "scheme": "orcid"}], "name": "Giannini, John", "type": "personal"}}, {"affiliations": [{"name": "All of Us Research Program, NIH"}], "person_or_org": {"family_name": "Landis", "given_name": "Erica", "identifiers": [{"identifier": "0000-0003-3773-0659", "scheme": "orcid"}], "name": "Landis, Erica", "type": "personal"}}, {"affiliations": [{"name": "National Institute of Biomedical Imaging and Bioengineering, NIH"}], "person_or_org": {"family_name": "Anderson", "given_name": "Afrouz", "name": "Anderson, Afrouz", "type": "personal"}}, {"affiliations": [{"name": "All of Us Research Program, NIH"}], "person_or_org": {"family_name": "Schully", "given_name": "Sheri", "identifiers": [{"identifier": "0000-0003-1550-9224", "scheme": "orcid"}], "name": "Schully, Sheri", "type": "personal"}}, {"affiliations": [{"name": "National Eye Institute, NIH"}], "person_or_org": {"family_name": "Goetz", "given_name": "Kerry E.", "identifiers": [{"identifier": "0000-0002-9821-7704", "scheme": "orcid"}], "name": "Goetz, Kerry E.", "type": "personal"}}], "description": "\u003cp\u003eThe potential inclusion of ocular imaging data into the \u003cem\u003eAll of Us\u003c/em\u003e Research Program (\u003cem\u003eAll of Us\u003c/em\u003e) dataset provides a unique opportunity to address many of these issues and empower new opportunities for research. To discuss the opportunities and challenges surrounding incorporating ocular imaging data, NIH partners at NEI, NIBIB, and the \u003cem\u003eAll of Us\u003c/em\u003e Research Program organized a workshop with experts in vision science, ophthalmology, imaging technology, data science, and health disparities research. This workshop explored the current state of imaging informatics in the vision research field, opportunities to expand research with large retinal imaging cohorts, and the data and analytical tools needed to advance this research. This document will summarize the presentations, panel discussions, and key findings from the workshop.\u003c/p\u003e", "languages": [{"id": "eng", "title": {"en": "English"}}], "publication_date": "2023-10-02", "publisher": "Zenodo", "resource_type": {"id": "publication-report", "title": {"de": "Bericht", "en": "Report"}}, "rights": [{"description": {"en": "The Creative Commons Attribution license allows re-distribution and re-use of a licensed work on the condition that the creator is appropriately credited."}, "icon": "cc-by-icon", "id": "cc-by-4.0", "props": {"scheme": "spdx", "url": "https://creativecommons.org/licenses/by/4.0/legalcode"}, "title": {"en": "Creative Commons Attribution 4.0 International"}}], "subjects": [{"subject": "ocular imaging"}], "title": "Opportunities for Ophthalmology Research in Large Research Cohorts: A National Eye Institute, National Institute of Biomedical Imaging and Bioengineering, and All of Us Research Program Workshop", "version": "1"}, "parent": {"access": {"owned_by": {"user": "158975"}, "settings": {"accept_conditions_text": null, "allow_guest_requests": false, "allow_user_requests": false, "secret_link_expiration": 0}}, "communities": {}, "id": "8384371", "pids": {"doi": {"client": "datacite", "identifier": "10.5281/zenodo.8384371", "provider": "datacite"}}}, "pids": {"doi": {"client": "datacite", "identifier": "10.5281/zenodo.8384372", "provider": "datacite"}, "oai": {"identifier": "oai:zenodo.org:8384372", "provider": "oai"}}, "revision_id": 6, "stats": {"all_versions": {"data_volume": 427692412.0, "downloads": 1106, "unique_downloads": 989, "unique_views": 1572, "views": 1701}, "this_version": {"data_volume": 346098290.0, "downloads": 895, "unique_downloads": 793, "unique_views": 1371, "views": 1465}}, "status": "published", "swh": {}, "ui": {"access_status": {"description_l10n": "The record and files are publicly accessible.", "embargo_date_l10n": null, "icon": "unlock", "id": "open", "message_class": "", "title_l10n": "Open"}, "created_date_l10n_long": "October 2, 2023", "creators": {"affiliations": [[1, "Rose Li \u0026 Associates, Inc.", null], [2, "National Eye Institute, NIH", null], [3, "All of Us Research Program, NIH", null], [4, "National Institute of Biomedical Imaging and Bioengineering, NIH", null]], "creators": [{"affiliations": [[1, "Rose Li \u0026 Associates, Inc."]], "person_or_org": {"family_name": "Weixelbaum", "given_name": "Jay", "name": "Weixelbaum, Jay", "type": "personal"}}, {"affiliations": [[1, "Rose Li \u0026 Associates, Inc."]], "person_or_org": {"family_name": "Beezley", "given_name": "Kelly E.", "name": "Beezley, Kelly E.", "type": "personal"}}, {"affiliations": [[1, "Rose Li \u0026 Associates, Inc."]], "person_or_org": {"family_name": "Tuvesson", "given_name": "Nancy", "name": "Tuvesson, Nancy", "type": "personal"}}, {"affiliations": [[2, "National Eye Institute, NIH"]], "person_or_org": {"family_name": "Reed", "given_name": "Amberlynn