				<script type="text/javascript">
					$(document).ready(function($) {
						$(".maintenanceClose").click(function(){
							$(this).parent().hide();
					        var superdomain = location.hostname.replace(/^[^.]+\./g, ".");
					        var expiry = new Date("May 14, 2016 00:00:00");
					        document.cookie = "maintenanceClosed=1; expires=" + expiry.toString() + ";domain=" + superdomain + ";";
						});
						//copied from w3school
					function getCookie(cname) {
					    var name = cname + "=";
					    var ca = document.cookie.split(';');
					    for(var i = 0; i < ca.length; i++) {
					        var c = ca[i];
					        while (c.charAt(0) == ' ') {
					            c = c.substring(1);
					        }
					        if (c.indexOf(name) == 0) {
					            return c.substring(name.length, c.length);
					        }
					    }
					    return "";
					}

					function checkCookie() {
					    var maintenanceClose = getCookie("maintenanceClosed");
					    console.log(maintenanceClose);
					    if (maintenanceClose == 1) {
					    	$(".messageMaintenance").hide();
					    } else {
					    	$(".messageMaintenance").show();
					    }
					}
					checkCookie();

					});
				</script>
				<style type="text/css">
					.messageMaintenance{
						position:fixed;
						background:#FFF;
						border:5px solid #FF9900;
						box-sizing: border-box;
						padding:12px 12px;
						bottom:0px;
						left:0px;
						right:0px;
					}
					.maintenanceClose{
						position:absolute;
						top:0px;
						right:0px;
						background:none;
						font-size: 32px;
					}
				</style>
			
		</header>

		
<style>
#maintenance {
    display: none;
    background: rgba(16, 100, 154, 1);
    box-shadow: 0 0 5px #999;
    max-width: 550px;
    width: 100%;
    position: fixed;
    left: 20px;
    bottom: 20px;
    z-index: 100000;
    font-size: 14px;
    line-height: 18px;
    box-sizing: border-box;
    color: #ffffff !important;
    font-family: Roboto !important;
}

#maintenance a{
    color: orange;
}
#maintenance__container p.h3 {
    padding-bottom: 5px;
    font-size: 16px;
    margin: 10px 0 4px 0 !important;
    font-weight: 800;
    color: white !important;
}
#maintenance__container {
    text-align: left;
    padding: 12px;
}
#maintenance__container p {
    margin-top: 0 !important;
}
#maintenance__header p.h3 {
    font-weight: 800;
    font-size: 18px;
    color: white !important;
    border-bottom: 1px solid #ffffff;
    padding: 12px 12px 11px 26px;
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    line-height: 1.1 !important;
}
#maintenance__header .orange {
    padding: 20.75px 7px;
    background-color: orange;
    position: absolute;
    left: 0;
}
#maintenance__container ul li {
    margin-bottom: 3px;
}
#maintenance__icon {
    width: 79px;
    height: 78px;
    margin-bottom: 20px;
}
#maintenance__close {
    position: absolute;
    top: 12px;
    right: 20px;
    cursor: pointer;
}
#maintenance__close-icon {
    font-size: 18px;
    color: #ffffff;
}
@media (max-width: 400px) {
    #maintenance {
        left: 0;
    }
}
</style>
<script type="text/javascript">
    var jNoConflict;
    if (typeof j != 'undefined') {
        jNoConflict = j;
    } else {
        jNoConflict = $;
    }
    // uncomment to enable maintenance note, comment to disable
    jNoConflict(document).ready(function() {
        var today = new Date();
        var expire = new Date(2019, 07, 2, 0, 0, 0, 0);

        if (today < expire) {
            checkCookie();

            jNoConflict('body').on('click', '#maintenance__close, #maintenance__bg', function() {
                jNoConflict('#maintenance, #maintenance__bg').hide();
                var superdomain = location.hostname;

                determineExpiryTime(function(expireTime) {
                    var expiry = new Date(expireTime);
                    document.cookie = "maintenanceHide=1; expires=" + expiry.toGMTString() + ";domain=" + superdomain + ";path=/";
                })

            })
        }
    });
    function determineExpiryTime(callback) {
        var sid = getCookie("OJSSID");
        var u_ids = [104788, 14789, 104790, 104791, 106675, 113817];
        var now = new Date();
        var expireTime = now.getTime() + 1000 * 60 * 60 * 48;

        $.ajax({
            url: "/user/restrictUsers",
            type: "POST",
            data: {
                users: u_ids
            },
            success: function(data) {
                if(data > 0) {
                    expireTime = now.getTime() * 30;
                }
                callback(expireTime);
            }
        });
    }
    function checkCookie() {
        var maintenanceClose = getCookie("maintenanceHide");
        if (maintenanceClose) {
            jNoConflict('#maintenance, #maintenance__bg').hide();
        } else {
            jNoConflict('#maintenance, #maintenance__bg').show();
        }
    }
    function getCookie(cname) {
        var name = cname + "=";
        var ca = document.cookie.split(';');
        for(var i = 0; i < ca.length; i++) {
            var c = ca[i];
            while (c.charAt(0) == ' ') {
                c = c.substring(1);
            }
            if (c.indexOf(name) == 0) {
                return c.substring(name.length, c.length);
            }
        }
        return "";
    }
</script>

