$\",\"p\",null,{\"className\":\"ypMWA hLQIGS\",\"children\":\"Publication\"}],[\"$\",\"div\",null,{\"className\":\"cYdhWw frQMtr pvuga gEYBWy gfOwFt\",\"children\":[\"$\",\"div\",null,{\"className\":\"fPSBzf iRgpoQ pnxsH\",\"children\":[[\"$\",\"h1\",null,{\"ref\":\"$undefined\",\"className\":\"dNxFtD dOmCsa jdmOYL\",\"children\":[\"$undefined\",\"01 - BD2K ThinkTank on EHR data semantic harmonization, definition, content, ontologies: OHDSI, CDRNs, NLP\",\"$undefined\"]}],[\"$\",\"div\",null,{\"className\":\"fPSBzf iRgpoQ\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"creators-list\",\"ref\":\"$undefined\",\"className\":\"gRVYOk Vsxgj\",\"children\":[\"$undefined\",\"Authors:\",\"$undefined\"]}],[\"$\",\"$L2f\",null,{\"people\":[{\"person_or_org\":{\"type\":\"personal\",\"name\":\"Hripcsak, George\",\"given_name\":\"George\",\"family_name\":\"Hripcsak\"}}]}]]}],[\"$\",\"div\",null,{\"className\":\"fPSBzf pKjuE gasSYy bYPztT\",\"children\":[[\"$\",\"p\",null,{\"className\":\"bCwpFb\",\"children\":[\"Published: \",[\"$\",\"time\",\"time0\",{\"dateTime\":\"2014-12-11\",\"children\":[\"Dec 11, 2014\"]}]]}],[\"$\",\"$L30\",null,{\"variant\":\"surface\",\"children\":\"Version 1\"}]]}]]}]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"cYdhWw ghdHEA jShLkw gfOwFt\",\"children\":[[\"$\",\"div\",null,{\"className\":\"fPSBzf iRgpoQ jSqJiD ddBxiD\",\"children\":[[\"$\",\"$L31\",null,{\"title\":\"Description\",\"children\":[\"$\",\"$L20\",null,{\"children\":[[\"$\",\"p\",\"work-description-714313051\",{\"style\":{\"whiteSpace\":\"pre-line\"},\"children\":\"This December 11, 2014 think tank discussed issues around the methodologies for optimizing the robustness and use of Electronic Health Records (EHR) data for a variety of clinical research purposes. Experts in both accessing EHR data and study design and analysis methodology using EHR data for research highlighted the challenges, solutions, and needs in this area.  Given the potential broad scope of this topic, participants were asked to focus primarily on issues related to the use of EHR on the back end (i.e. the imperfect data as currently collected), rather than strategies to improve the quality of EHR data collected on the ‘front end’ (e.g., data entered by clinicians).\"}]]}]}],\"$L32\",\"$L33\",\"$L34\",\"$L35\",\"$L36\"]}],\"$L37\"]}]]}]}]}]}]}],\"$L38\"]}]]\n"])</script><script>self.__next_f.push([1,"b:null\n"])</script><script>self.__next_f.push([1,"10:[[\"$\",\"title\",\"0\",{\"children\":\"01 - BD2K ThinkTank on EHR data semantic harmonization, definition, content, ontologies: OHDSI, CDRNs, NLP | Anschutz Colorado Repository\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"This December 11, 2014 think tank discussed issues around the methodologies for optimizing the robustness and use of Electronic Health Records (EHR) data for a variety of clinical research purposes. Experts in both accessing EHR data and study design and analysis methodology using EHR data for research highlighted the challenges, solutions, and needs in this area.  Given the potential broad scope of this topic, participants were asked to focus primarily on issues related to the use of EHR on the back end (i.e. the imperfect data as currently collected), rather than strategies to improve the quality of EHR data collected on the ‘front end’ (e.g., data entered by clinicians).\"}],[\"$\",\"meta\",\"2\",{\"name\":\"citation_title\",\"content\":\"01 - BD2K ThinkTank on EHR data semantic harmonization, definition, content, ontologies: OHDSI, CDRNs, NLP\"}],[\"$\",\"meta\",\"3\",{\"name\":\"citation_publisher\",\"content\":\"Ubiquity Repositories\"}],[\"$\",\"meta\",\"4\",{\"name\":\"citation_publication_date\",\"content\":\"2014-12-11\"}],[\"$\",\"meta\",\"5\",{\"name\":\"citation_doi\",\"content\":\"10.25677/94n67-3ak56\"}],[\"$\",\"meta\",\"6\",{\"name\":\"citation_pdf_url\",\"content\":\"https://dashboard.digitalcollections.cuanschutz.edu/api/records/94n67-3ak56/files/CUHSLBDK_M103.pdf/content\"}],[\"$\",\"meta\",\"7\",{\"name\":\"citation_abstract_html_url\",\"content\":\"https://digitalcollections.cuanschutz.edu/works/publication/94n67-3ak56\"}],[\"$\",\"meta\",\"8\",{\"name\":\"citation_author\",\"content\":\"Hripcsak, George\"}],[\"$\",\"meta\",\"9\",{\"name\":\"citation_keywords\",\"content\":\"Biomedical Research\"}],[\"$\",\"meta\",\"10\",{\"name\":\"citation_keywords\",\"content\":\"Data Collection\"}],[\"$\",\"link\",\"11\",{\"rel\":\"canonical\",\"href\":\"https://digitalcollections.cuanschutz.edu/works/publication/94n67-3ak56\"}],[\"$\",\"link\",\"12\",{\"rel\":\"alternate\",\"hrefLang\":\"en\",\"href\":\"https://digitalcollections.cuanschutz.edu/works/publication/94n67-3ak56\"}],[\"$\",\"link\",\"13\",{\"rel\":\"alternate\",\"hrefLang\":\"x-default\",\"href\":\"https://digitalcollections.cuanschutz.edu/works/publication/94n67-3ak56\"}],[\"$\",\"meta\",\"14\",{\"property\":\"og:title\",\"content\":\"01 - BD2K ThinkTank on EHR data semantic harmonization, definition, content, ontologies: OHDSI, CDRNs, NLP | Anschutz Colorado Repository\"}],[\"$\",\"meta\",\"15\",{\"property\":\"og:description\",\"content\":\"This December 11, 2014 think tank discussed issues around the methodologies for optimizing the robustness and use of Electronic Health Records (EHR) data for a variety of clinical research purposes. Experts in both accessing EHR data and study design and analysis methodology using EHR data for research highlighted the challenges, solutions, and needs in this area.  Given the potential broad scope of this topic, participants were asked to focus primarily on issues related to the use of EHR on the back end (i.e. the imperfect data as currently collected), rather than strategies to improve the quality of EHR data collected on the ‘front end’ (e.g., data entered by clinicians).\"}],[\"$\",\"meta\",\"16\",{\"property\":\"og:url\",\"content\":\"https://digitalcollections.cuanschutz.edu/works/publication/94n67-3ak56\"}],[\"$\",\"meta\",\"17\",{\"proper