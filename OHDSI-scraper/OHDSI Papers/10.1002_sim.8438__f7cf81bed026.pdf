<strong>0.97</strong>
</td>
<td align="right" valign="top" rowspan="1" colspan="1">
<strong>5</strong>
</td>
<td align="right" valign="top" rowspan="1" colspan="1">0</td>
<td align="center" valign="top" rowspan="1" colspan="1">
<strong>83 266.47</strong>
</td>
</tr>
<tr>
<td align="left" valign="top" rowspan="1" colspan="1">mCox-LASSO (BIC)</td>
<td align="center" valign="top" rowspan="1" colspan="1">2.93</td>
<td align="right" valign="top" rowspan="1" colspan="1">12</td>
<td align="right" valign="top" rowspan="1" colspan="1">0</td>
<td align="center" valign="top" rowspan="1" colspan="1">84 479.47</td>
</tr>
<tr>
<td align="left" valign="top" rowspan="1" colspan="1">mCox-LASSO (CV)</td>
<td align="center" valign="top" rowspan="1" colspan="1">2.12</td>
<td align="right" valign="top" rowspan="1" colspan="1">963</td>
<td align="right" valign="top" rowspan="1" colspan="1">0</td>
