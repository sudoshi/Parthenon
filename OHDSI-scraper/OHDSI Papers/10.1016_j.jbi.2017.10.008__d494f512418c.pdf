</tr>
<tr>
<td align="left" rowspan="1" colspan="1">428.xx</td>
<td align="left" rowspan="1" colspan="1">Logistic Calibration</td>
<td align="left" rowspan="1" colspan="1">0.90 (0.84,0.96)</td>
<td align="left" rowspan="1" colspan="1">0.04 (0.03,0.04)</td>
<td align="left" rowspan="1" colspan="1">−2.14 (−3.73, −0.55)</td>
<td align="left" rowspan="1" colspan="1">3.3e-02</td>
</tr>
<tr>
<td align="left" rowspan="1" colspan="1">428.xx</td>
<td align="left" rowspan="1" colspan="1">Platt Scaling</td>
<td align="left" rowspan="1" colspan="1">0.90 (0.84,0.96)</td>
