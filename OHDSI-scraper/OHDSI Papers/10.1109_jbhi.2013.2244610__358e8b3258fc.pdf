<td align="left" valign="top" rowspan="1" colspan="1">−211</td>
</tr>
<tr>
<td align="left" valign="top" rowspan="1" colspan="1">Disseminated Intravascular Coagulation</td>
<td align="left" valign="top" rowspan="1" colspan="1">392</td>
<td align="left" valign="top" rowspan="1" colspan="1">Acute</td>
