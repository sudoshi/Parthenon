sArchiveFiles":377,"propertyOptions":378,"property_Channel":383,"property_Sub-Type":385,"property_Asset_Type":387,"activeOriginalFocusPoint":389,"property_Office_Department":392},"8A76404F-30D6-4D90-82D0C98AB95F2CBC","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/8A76404F-30D6-4D90-82D0C98AB95F2CBC/webimage-D20C6B6E-7D1A-4986-ACA9AF87494B2A6C.jpg","FDSFR_Main Visual_Orange_Website",[308,309,310,311,312,313,314,315,316,317,318,319,320,321,322,323,324,325,326,327,328,329,330,331,332,333,334,335,336,337,338,339,340,341,342,343,344,345,346,347,348,349,350,351,352],"instructions","apothecary","medical","smiling","reading","storage","care","concentrating","pharmaceutical","choice","prescription","information","pharmacology","pharmacist","tablet","aisle","health","chemist","guide","retail","female","working","woman","person","standing","young","drugstore","drug","medication","expertise","pill","occupation","healthcare","shelf","examining","medicine","confident","product","prescribed","rack","pharmacy","indoor","box","holding","service","image",5682,3790,"44a103354c4b6dad",0,"22C10171-81B3-4DA6-99342F272A32E8BB",8788698,1,"https://brand.frontiersin.org/m/44a103354c4b6dad/original/FDSFR_Main-Visual_Orange_Website.jpeg",[363],"jpeg",{"mini":365,"thul":366,"webimage":305,"Guidelines":367,"WebsiteJpg_XL":368,"WebsiteWebP_L":369,"WebsiteWebP_M":370,"WebsiteWebP_XL":371},"https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/8A76404F-30D6-4D90-82D0C98AB95F2CBC/mini-6C38B530-E859-4A40-AED9D698143F05AE.jpg","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/8A76404F-30D6-4D90-82D0C98AB95F2CBC/thul-719299B5-9D62-4560-9E0033F337B6EADA.jpg","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/8A76404F-30D6-4D90-82D0C98AB95F2CBC/075F2CC0-F10D-41B4-B5106C2A2012DFF8/Guidelines-FDSFR_Main Visual_Orange_Website.png","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/8A76404F-30D6-4D90-82D0C98AB95F2CBC/075F2CC0-F10D-41B4-B5106C2A2012DFF8/WebsiteJpg_XL-FDSFR_Main Visual_Orange_Website.jpg","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/8A76404F-30D6-4D90-82D0C98AB95F2CBC/075F2CC0-F10D-41B4-B5106C2A2012DFF8/WebsiteWebP_L-FDSFR_Main Visual_Orange_Website.webp","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/8A76404F-30D6-4D90-82D0C98AB95F2CBC/075F2CC0-F10D-41B4-B5106C2A2012DFF8/WebsiteWebP_M-FDSFR_Main Visual_Orange_Website.webp","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/8A76404F-30D6-4D90-82D0C98AB95F2CBC/075F2CC0-F10D-41B4-B5106C2A2012DFF8/WebsiteWebP_XL-FDSFR_Main Visual_Orange_Website.webp","2022-06-27T09:59:23Z","Young female pharmacist reading instructions on medicine box standing in aisle of chemist; Shutterstock ID 1954122598; purchase_order: Journal Launches; job: ; client: ; other:","landscape","Caroline Sutter","2021-09-06T09:55:40Z",[],[379,380,381,382],"414FB2D4-2283-43FD-BE14E534ECA67928","6C18119B-14BD-4951-B437696F4357BD33","7C692885-DB25-4858-B1FB4FF47B241E9B","D88C0047-EC30-4506-A7DF28A4D765E1CF",[384],"frontiersin_org",[386],"Main_Visual",[388],"Photography",{"x":390,"y":391},2841,1895,[393],"Publishing","Explore research in pharmacovigilance, pharmacoepidemiology, and policy to support evidence‑based decision‑making.","\u003Cp>Frontiers in Drug Safety and Regulation is a PubMed Central and Scopus-indexed multidisciplinary journal that aims to address potentially emerging issues concerning pharmacovigilance, with special emphasis on how the post-marketing surveillance drives informed regulatory decision process and vice versa.\u003C/p>\n\n\u003Cp>Led by Field Chief Editor Prof Gianluca Trifirò (University of Verona, Italy), Frontiers in Drug Safety and Regulation publishes epidemiological, clinical and translational original articles, editorials and reviews across the fields of clinical pharmacology, pharmacovigilance, pharmacoepidemiology, drug policy, public health and regulatory science. Topics of interest include:\u003C/p>\n\u003Cul>\n  \u003Cli>advanced methods in pharmacovigilance and pharmacoepidemiology\u003C/li>\n  \u003Cli>clinical drug safety\u003C/li>\n  \u003Cli>maternal-fetal medicine\u003C/li>\n  \u003Cli>pharmaceutical policy and regulation\u003C/li>\n  \u003Cli>substance-based medical devices\u003C/li>\n  \u003Cli>vaccine safety and regulation\u003C/li>\n\u003C/ul>\n\n\u003Cp>Drug safety monitoring is an essential element for the effective and safe use of medicines and for high quality medical care and it is the process of detection, assessment, understanding and prevention of side effects, allowing an in-depth knowledge of the benefit-risk profile of conventional drugs and vaccines as well as advanced therapy medicinal products (ATMPs, e.g. gene therapy medicinal products, somatic cell therapy medicinal products, tissue engineered medicinal products, medicinal products for combined advanced therapies,), dietary supplements/nutraceuticals and medical devices.\u003C/p>\n\n\u003Cp>Regulatory science refers to the range of scientific disciplines aimed at assessing the quality, safety and efficacy/effectiveness of medicinal products and informing regulatory decision-making throughout the lifecycle of a medicine. It comprises basic and applied biomedical and social sciences and contributes to the development of regulatory standards and tools.\u003C/p>\n\n\u003Cp>In particular, the journal welcomes submissions which support and advance the UN’s Sustainable Development Goals (SDGs), notably SDG 3: ensure healthy lives and promote well-being for all at all ages.\u003C/p>\n\n\u003Cp>Collaboration between clinicians and basic scientists is strongly encouraged by the editors and papers issued from a collaborative strategy between the academic and the private industrial sectors are welcome.\u003C/p>\n\n\u003Cp>Manuscripts which do not relate to conventional drugs, vaccines, ATMPs, nutraceuticals and dietary supplements or medical devices, as well as isolated in vitro or in vivo studies that are not linked to clinical evaluations, are not suitable for publication in this journal.\u003C/p>\n\n\u003Cp>Frontiers’ journals require that manuscripts primarily comprising computational studies of public data, must include appropriate validation. Please refer to \u003Ca href=\"https://www.frontiersin.org/guidelines/policies-and-publication-ethics#standards-for-research-methodology:~:text=complaints%20and%20allegations.-,Standards%20for%20research%20methodology,-Experiments\">Frontiers' standards for research methodology policy\u003C/a>, for more information. Manuscripts not adhering to these standards will not be considered.\u003Cp>\n\n\u003Cp>Frontiers in Drug Safety and Regulation is committed to contributing to elevating regulatory sciences with a patient-oriented approach addressing emerging issues concerning drug safety while taking together clinician, regulatory, academic, patient as well as industry perspective. The journal advances developments in the field of drug safety and regulation research by allowing unrestricted access to articles, and communicating scientific knowledge to researchers and the public alike, to enable the scientific breakthroughs of the future.\u003C/p>\n\n\u003Cp>Join us at \u003Cstrong>World Patient Safety Congress Europe\u003C/strong> in Amsterdam on 22 - 24 September 2026 and and \u003Cstrong>World Patient Safety Congress Americas\u003C/strong> in Boston on 13 - 15 October, where key communities and industries connect to define the future of patient safety: from pharmaceutical drugs, animal health, over the counter drugs, to cosmetics and dietary supplements. Register now:\n\u003Cbr>\n\u003Cul>\n\u003Cli>\u003Ca href=\"https://secure.terrapinn.com/V5/step1.aspx?E=11043&p=1&_gl=1*ycqs6z*sgtm_ga*MTU0Mjc5OTA4OC4xNzczMjM2ODU2*sgtm_ga_8ZVPFLKW76*czE3NzQ0NDI5ODkkbzE0JGcxJHQxNzc0NDQzMzgwJGo2MCRsMCRoMTA5MDMyNTAwOA..*_fplc*RkpSZ0hHcE5lSWtBYnFPNXJSOFdwME12TjlCSmZ5b0xsZmk0YlNSbTNhS1IwTm9qSUJWTVZEdFZpcHlRWWprT3ZLbHkzcHV4cXVNWk5XaFg0UjY3T24lMkI2aHZYYjFON0NiQUEwSTVVVGR2c0lpdyUyRm5jVHc0ZEl6UWc5RHZ1QSUzRCUzRA..\">Europe congress\u003C/a>\n\u003Cli>\u003Ca href=\"https://secure.terrapinn.com/V5/step1.aspx?E=11063&p=1&_gl=1*ekp5gq*sgtm_ga*MTU0Mjc5OTA4OC4xNzczMjM2ODU2*sgtm_ga_8ZVPFLKW76*czE3NzQ0NDI5ODkkbzE0JGcxJHQxNzc0NDQzMzIyJGo1NiRsMCRoMTA5MDMyNTAwOA..*_fplc*YXQwb0V5eDE4dCUyQmlKQ0FpR2tJc1N5ejFmQW9ZNWpkdWk0a0lkWmlTYmdJUFJucnRZck0lMkJhdyUyQjFlWk5zeXBNTXJMdFRVVm5lZmY0cDlLcjJvOWxDeUhVQWFoSmdUUXA0c0RvTXNxNGRxZXFYdVpVeTBYTmpsTmt1RmZUemNnJTNEJTNE\">Americas congress\u003C/a>\u003C/ul>\n\u003Cbr>\n\u003Cbr>\n\u003C/p> ","orange","nan","587","@FrontDrugDDS",{"id":118,"name":119,"slug":120,"abbreviation":401,"isOnline":13,"isOpenForSubmissions":13,"citeScore":402,"impactFactor":28},"fdsfr",2.1,{"displayTitlePillLabels":13,"displayRelatedArticlesBox":13,"showEditors":13,"showReviewers":13,"showLoopImpactLink":13,"enableFigshare":299},{"isPublic":299,"allowCompanyUsers":299,"whiteListEmails":405,"enableAllJournals":299,"whiteListJournals":406},[],[],{"spaceId":360,"name":360,"availableJournalPages":408,"announcement":412,"useJournalPalettes":299},[206,211,208,409,410,411],"volumes","about","community-reviewers",{"__typename":413,"sys":414,"preHeader":416,"title":417,"description":418,"image":419,"link":441},"Announcement",{"id":415},"2IPv1l2IAkUt7RUrh3yJzz","Frontiers' quality","How do we build trust in science?","Behind each Frontiers journal is an editorial board committed to upholding research integrity and scientific quality",[420],{"id":421,"src":422,"name":423,"tags":424,"type":353,"width":425,"height":426,"archive":357,"brandId":358,"limited":357,"fileSize":427,"isPublic":357,"original":28,"copyright":28,"extension":428,"thumbnails":430,"dateCreated":437,"description":28,"orientation":374,"watermarked":357,"dateModified":437,"selectedFile":28,"datePublished":438,"videoPreviewURLs":439,"textMetaproperties":440},"1C167ADA-64D7-41F6-B87288EAF1BEC484","https://brand.frontiersin.org/m/47cd35867c2ab214/webimage-Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.png","Horizontal-Scientist looking at 3D rendered graphic scans from Magnetic Resonance Imaging (MRI) scanner, close up",[],1920,1080,2419221,[429],"png",{"mini":431,"thul":432,"webimage":422,"Guidelines":433,"WebsiteJpg_XL":434,"WebsiteWebP_L":435,"WebsiteWebP_M":436},"https://brand.frontiersin.org/m/47cd35867c2ab214/mini-Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.png","https://brand.frontiersin.org/m/47cd35867c2ab214/thul-Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.png","https://brand.frontiersin.org/asset/1c167ada-64d7-41f6-b872-88eaf1bec484/Guidelines/Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.png","https://brand.frontiersin.org/asset/1c167ada-64d7-41f6-b872-88eaf1bec484/WebsiteJpg_XL/Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.jpg","https://brand.frontiersin.org/asset/1c167ada-64d7-41f6-b872-88eaf1bec484/WebsiteWebP_L/Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.webp","https://brand.frontiersin.org/asset/1c167ada-64d7-41f6-b872-88eaf1bec484/WebsiteWebP_M/Horizontal-Scientist-looking-at-3D-rendered-graphic-scans-from-Magnetic-Resonance-Imaging-MRI-scanner-close-up.webp","2026-03-06T11:24:30Z","2026-03-06T11:24:07Z",[],[],{"text":442,"url":443,"target":27,"ariaLabel":28},"Learn more","https://www.frontiersin.org/about/quality",{"loggedUserInfo":-1},{"currentArticle":446,"isPreviewPage":299,"hasSupplementalData":299,"showCrossmarkWidget":13,"articleTemplate":578,"currentArticlePageMetaInfo":579,"xmlParsedArticleContent":700,"xmlParsingError":-1},{"id":447,"doi":448,"title":449,"acceptanceDate":450,"receptionDate":451,"publicationDate":452,"lastModifiedDate":453,"isPublished":13,"abstract":454,"researchTopic":28,"articleType":455,"stage":458,"keywords":460,"authors":466,"editors":507,"reviewers":517,"journal":536,"section":543,"impactMetrics":545,"volume":548,"articleVolume":549,"relatedArticles":550,"isPublishedV2":299,"contents":551,"files":552},1034677,"10.3389/fdsfr.2022.1034677","Putting external validation performance of major bleeding risk models into context",["Date","2022-09-22T08:31:04.000Z"],["Date","2022-09-01T19:58:17.000Z"],["Date","2022-10-19T00:00:00.000Z"],["Date","2026-04-06T03:48:29.041Z"],"When developing predictive models, model simplicity and performance often need to be balanced. We propose a novel methodology to put the performance of bleeding risk prediction models ORBIT, ATRIA, HAS-BLED, CHADS2 and CHA2DS2-VASc into perspective.  Instead of comparing the existing models’ performance against the 0.5-1 AUROC scale, we suggest estimating a prediction task specific AUROC scale, lower bound AUROC (lbAUROC) and upper bound AUROC (ubAUROC), to help assess the balance between model simplicity and performance and determine whether more complex models could significantly improve the ability to predict the outcome.  We validate the existing bleeding risk prediction models by applying them to a cohort of new users of warfarin and a cohort of new users of direct oral anticoagulants (DOACs) separately, across a set of four observational databases. Then, we develop the lbAUROC-ubAUROC scale by using the validation data to train regularized logistic regression models. The internal validation AUROC of the model that includes only age and gender variables was used to estimate the lbAUROC.  The internal validation AUROC of the model that includes thousands of candidate variables was used to estimate the ubAUROC.  The age and gender only models achieved AUROCs between 0.50 and 0.56 (lower bound) and the large-scale models achieved AUROCs between 0.67 and 0.72 and between 0.70 and 0.77 (upper bound) within the target cohorts of warfarin new users and DOACs new users, respectively.  The AUROC of existing bleeding risk prediction models fall between the upper-bound and lower-bound of predictive models. Our study showed that this context of the predictability of the outcome is essential when evaluating risk prediction models to be administered in actual practice.",{"id":456,"name":457},24,"Original Research",{"id":459,"name":19},18,[461,462,463,464,465],"Prediction  model","bleeding","Atrial Fibrillation","OMOP CDM","Validation",[467,479,487,493,501],{"id":468,"firstName":469,"middleName":19,"lastName":470,"givenNames":471,"isCorresponding":299,"isProfilePublic":13,"userId":468,"email":-1,"affiliations":472},1889055,"Clair","Blacketer","Clair ",[473,476],{"organizationName":474,"countryName":475,"cityName":19,"stateName":19,"zipCode":19},"Janssen Research and Development","United States",{"organizationName":477,"countryName":478,"cityName":19,"stateName":19,"zipCode":19},"Department of Medical Informatics","Netherlands",{"id":480,"firstName":481,"middleName":19,"lastName":482,"givenNames":483,"isCorresponding":299,"isProfilePublic":13,"userId":480,"email":-1,"affiliations":484},1535872,"Jenna M.","Reps","Jenna M. ",[485,486],{"organizationName":474,"countryName":475,"cityName":19,"stateName":19,"zipCode":19},{"organizationName":477,"countryName":478,"cityName":19,"stateName":19,"zipCode":19},{"id":357,"firstName":488,"middleName":19,"lastName":489,"givenNames":490,"isCorresponding":299,"isProfilePublic":299,"userId":357,"email":-1,"affiliations":491},"Lu","Wang","Lu ",[492],{"organizationName":474,"countryName":475,"cityName":19,"stateName":19,"zipCode":19},{"id":357,"firstName":494,"middleName":19,"lastName":495,"givenNames":496,"isCorresponding":299,"isProfilePublic":299,"userId":357,"email":-1,"aff