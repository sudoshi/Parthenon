{"#text":1115},{"#text":1115},{"tr":1881},[1882,1883,1888,1889,1892,1893,1896,1897,1900,1901,1904,1905,1909],{"#text":1119},{"td":1884,":@":1887},[1885],{"#text":1886},"Female",{"@_align":1125},{"#text":1119},{"td":1890,":@":1891},[],{"@_align":1125},{"#text":1119},{"td":1894,":@":1895},[],{"@_align":1125},{"#text":1119},{"td":1898,":@":1899},[],{"@_align":1125},{"#text":1119},{"td":1902,":@":1903},[],{"@_align":1125},{"#text":1119},{"td":1906,":@":1908},[1907],{"#text":1833},{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":1912},[1913,1914,1919,1920,1924,1925,1929,1930,1933,1934,1938,1939,1943],{"#text":1119},{"td":1915,":@":1918},[1916],{"#text":1917},"Anemia",{"@_align":1125},{"#text":1119},{"td":1921,":@":1923},[1922],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":1926,":@":1928},[1927],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":1931,":@":1932},[],{"@_align":1125},{"#text":1119},{"td":1935,":@":1937},[1936],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":1940,":@":1942},[1941],{"#text":1833},{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":1946},[1947,1948,1953,1954,1957,1958,1961,1962,1965,1966,1970,1971,1974],{"#text":1119},{"td":1949,":@":1952},[1950],{"#text":1951},"CHF",{"@_align":1125},{"#text":1119},{"td":1955,":@":1956},[],{"@_align":1125},{"#text":1119},{"td":1959,":@":1960},[],{"@_align":1125},{"#text":1119},{"td":1963,":@":1964},[],{"@_align":1125},{"#text":1119},{"td":1967,":@":1969},[1968],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":1972,":@":1973},[],{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":1977},[1978,1979,1984,1985,1989,1990,1994,1995,1999,2000,2004,2005,2009],{"#text":1119},{"td":1980,":@":1983},[1981],{"#text":1982},"Prior Hemorrhage",{"@_align":1125},{"#text":1119},{"td":1986,":@":1988},[1987],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":1991,":@":1993},[1992],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":1996,":@":1998},[1997],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":2001,":@":2003},[2002],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":2006,":@":2008},[2007],{"#text":1833},{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":2012},[2013,2014,2019,2020,2023,2024,2028,2029,2033,2034,2038,2039,2043],{"#text":1119},{"td":2015,":@":2018},[2016],{"#text":2017},"Hypertension",{"@_align":1125},{"#text":1119},{"td":2021,":@":2022},[],{"@_align":1125},{"#text":1119},{"td":2025,":@":2027},[2026],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":2030,":@":2032},[2031],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":2035,":@":2037},[2036],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":2040,":@":2042},[2041],{"#text":1833},{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":2046},[2047,2048,2053,2054,2057,2058,2062,2063,2067,2068,2071,2072,2075],{"#text":1119},{"td":2049,":@":2052},[2050],{"#text":2051},"eGFR\u003C45 or ESRD",{"@_align":1125},{"#text":1119},{"td":2055,":@":2056},[],{"@_align":1125},{"#text":1119},{"td":2059,":@":2061},[2060],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":2064,":@":2066},[2065],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":2069,":@":2070},[],{"@_align":1125},{"#text":1119},{"td":2073,":@":2074},[],{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":2078},[2079,2080,2085,2086,2089,2090,2093,2094,2097,2098,2101,2102,2106],{"#text":1119},{"td":2081,":@":2084},[2082],{"#text":2083},"Vascular disease",{"@_align":1125},{"#text":1119},{"td":2087,":@":2088},[],{"@_align":1125},{"#text":1119},{"td":2091,":@":2092},[],{"@_align":1125},{"#text":1119},{"td":2095,":@":2096},[],{"@_align":1125},{"#text":1119},{"td":2099,":@":2100},[],{"@_align":1125},{"#text":1119},{"td":2103,":@":2105},[2104],{"#text":1833},{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":2109},[2110,2111,2116,2117,2120,2121,2124,2125,2128,2129,2132,2133,2137],{"#text":1119},{"td":2112,":@":2115},[2113],{"#text":2114},"CHF or LV disease",{"@_align":1125},{"#text":1119},{"td":2118,":@":2119},[],{"@_align":1125},{"#text":1119},{"td":2122,":@":2123},[],{"@_align":1125},{"#text":1119},{"td":2126,":@":2127},[],{"@_align":1125},{"#text":1119},{"td":2130,":@":2131},[],{"@_align":1125},{"#text":1119},{"td":2134,":@":2136},[2135],{"#text":1833},{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":2140},[2141,2142,2147,2148,2151,2152,2155,2156,2159,2160,2163,2164,2167],{"#text":1119},{"td":2143,":@":2146},[2144],{"#text":2145},"Diabetes",{"@_align":1125},{"#text":1119},{"td":2149,":@":2150},[],{"@_align":1125},{"#text":1119},{"td":2153,":@":2154},[],{"@_align":1125},{"#text":1119},{"td":2157,":@":2158},[],{"@_align":1125},{"#text":1119},{"td":2161,":@":2162},[],{"@_align":1125},{"#text":1119},{"td":2165,":@":2166},[],{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":2170},[2171,2172,2177,2178,2181,2182,2185,2186,2190,2191,2194,2195,2198],{"#text":1119},{"td":2173,":@":2176},[2174],{"#text":2175},"Prior Stroke",{"@_align":1125},{"#text":1119},{"td":2179,":@":2180},[],{"@_align":1125},{"#text":1119},{"td":2183,":@":2184},[],{"@_align":1125},{"#text":1119},{"td":2187,":@":2189},[2188],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":2192,":@":2193},[],{"@_align":1125},{"#text":1119},{"td":2196,":@":2197},[],{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":2201},[2202,2203,2208,2209,2213,2214,2217,2218,2222,2223,2226,2227,2230],{"#text":1119},{"td":2204,":@":2207},[2205],{"#text":2206},"Chronic renal disease",{"@_align":1125},{"#text":1119},{"td":2210,":@":2212},[2211],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":2215,":@":2216},[],{"@_align":1125},{"#text":1119},{"td":2219,":@":2221},[2220],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":2224,":@":2225},[],{"@_align":1125},{"#text":1119},{"td":2228,":@":2229},[],{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":2233},[2234,2235,2240,2241,2244,2245,2248,2249,2253,2254,2257,2258,2261],{"#text":1119},{"td":2236,":@":2239},[2237],{"#text":2238},"Chronic liver disease",{"@_align":1125},{"#text":1119},{"td":2242,":@":2243},[],{"@_align":1125},{"#text":1119},{"td":2246,":@":2247},[],{"@_align":1125},{"#text":1119},{"td":2250,":@":2252},[2251],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":2255,":@":2256},[],{"@_align":1125},{"#text":1119},{"td":2259,":@":2260},[],{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":2264},[2265,2266,2271,2272,2276,2277,2280,2281,2284,2285,2288,2289,2292],{"#text":1119},{"td":2267,":@":2270},[2268],{"#text":2269},"Treatment with antiplatelets",{"@_align":1125},{"#text":1119},{"td":2273,":@":2275},[2274],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":2278,":@":2279},[],{"@_align":1125},{"#text":1119},{"td":2282,":@":2283},[],{"@_align":1125},{"#text":1119},{"td":2286,":@":2287},[],{"@_align":1125},{"#text":1119},{"td":2290,":@":2291},[],{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":2295},[2296,2297,2302,2303,2306,2307,2310,2311,2315,2316,2319,2320,2323],{"#text":1119},{"td":2298,":@":2301},[2299],{"#text":2300},"Labile INR",{"@_align":1125},{"#text":1119},{"td":2304,":@":2305},[],{"@_align":1125},{"#text":1119},{"td":2308,":@":2309},[],{"@_align":1125},{"#text":1119},{"td":2312,":@":2314},[2313],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":2317,":@":2318},[],{"@_align":1125},{"#text":1119},{"td":2321,":@":2322},[],{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":2326},[2327,2328,2333,2334,2337,2338,2341,2342,2346,2347,2350,2351,2354],{"#text":1119},{"td":2329,":@":2332},[2330],{"#text":2331},"Alcohol abuse",{"@_align":1125},{"#text":1119},{"td":2335,":@":2336},[],{"@_align":1125},{"#text":1119},{"td":2339,":@":2340},[],{"@_align":1125},{"#text":1119},{"td":2343,":@":2345},[2344],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":2348,":@":2349},[],{"@_align":1125},{"#text":1119},{"td":2352,":@":2353},[],{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":2357},[2358,2359,2364,2365,2368,2369,2372,2373,2377,2378,2381,2382,2385],{"#text":1119},{"td":2360,":@":2363},[2361],{"#text":2362},"Antiplatelet or NSAID use",{"@_align":1125},{"#text":1119},{"td":2366,":@":2367},[],{"@_align":1125},{"#text":1119},{"td":2370,":@":2371},[],{"@_align":1125},{"#text":1119},{"td":2374,":@":2376},[2375],{"#text":1833},{"@_align":1125},{"#text":1119},{"td":2379,":@":2380},[],{"@_align":1125},{"#text":1119},{"td":2383,":@":2384},[],{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":2388},[2389,2390,2399,2400,2405,2406,2411,2412,2417,2418,2423,2424,2429],{"#text":1119},{"td":2391,":@":2398},[2392,2393,2397],{"#text":1670},{"bold":2394},[2395],{"#text":2396},"Internal AUROC",{"#text":1119},{"@_align":1125},{"#text":1119},{"td":2401,":@":2404},[2402],{"#text":2403},"0.67",{"@_align":1125},{"#text":1119},{"td":2407,":@":2410},[2408],{"#text":2409},"0.74",{"@_align":1125},{"#text":1119},{"td":2413,":@":2416},[2414],{"#text":2415},"0.72",{"@_align":1125},{"#text":1119},{"td":2419,":@":2422},[2420],{"#text":2421},"0.82 (Stroke)",{"@_align":1125},{"#text":1119},{"td":2425,":@":2428},[2426],{"#text":2427},"0.61 (TE)",{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":2432},[2433,2434,2437,2438,2441,2442,2445,2446,2449,2450,2453,2454,2457],{"#text":1119},{"td":2435,":@":2436},[],{"@_align":1125},{"#text":1119},{"td":2439,":@":2440},[],{"@_align":1125},{"#text":1119},{"td":2443,":@":2444},[],{"@_align":1125},{"#text":1119},{"td":2447,":@":2448},[],{"@_align":1125},{"#text":1119},{"td":2451,":@":2452},[],{"@_align":1125},{"#text":1119},{"td":2455,":@":2456},[],{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":2460},[2461,2462,2471,2472,2475,2476,2479,2480,2483,2484,2487,2488,2491],{"#text":1119},{"td":2463,":@":2470},[2464,2465,2469],{"#text":1670},{"bold":2466},[2467],{"#text":2468},"External AUROCs",{"#text":1119},{"@_align":1125},{"#text":1119},{"td":2473,":@":2474},[],{"@_align":1125},{"#text":1119},{"td":2477,":@":2478},[],{"@_align":1125},{"#text":1119},{"td":2481,":@":2482},[],{"@_align":1125},{"#text":1119},{"td":2485,":@":2486},[],{"@_align":1125},{"#text":1119},{"td":2489,":@":2490},[],{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":2494},[2495,2496,2500,2501,2504,2505,2510,2511,2516,2517,2520,2521,2524],{"#text":1119},{"td":2497,":@":2499},[2498],{"#text":1619},{"@_align":1125},{"#text":1119},{"td":2502,":@":2503},[],{"@_align":1125},{"#text":1119},{"td":2506,":@":2509},[2507],{"#text":2508},"0.66",{"@_align":1125},{"#text":1119},{"td":2512,":@":2515},[2513],{"#text":2514},"0.64",{"@_align":1125},{"#text":1119},{"td":2518,":@":2519},[],{"@_align":1125},{"#text":1119},{"td":2522,":@":2523},[],{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":2527},[2528,2529,2534,2535,2540,2541,2546,2547,2552,2553,2556,2557,2560],{"#text":1119},{"td":2530,":@":2533},[2531],{"#text":2532},"ROCKET-AF",{"@_align":1125},{"#text":1119},{"td":2536,":@":2539},[2537],{"#text":2538},"0.62",{"@_align":1125},{"#text":1119},{"td":2542,":@":2545},[2543],{"#text":2544},"0.60",{"@_align":1125},{"#text":1119},{"td":2548,":@":2551},[2549],{"#text":2550},"0.59",{"@_align":1125},{"#text":1119},{"td":2554,":@":2555},[],{"@_align":1125},{"#text":1119},{"td":2558,":@":2559},[],{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":2563},[2564,2565,2570,2571,2574,2575,2578,2579,2584,2585,2588,2589,2592],{"#text":1119},{"td":2566,":@":2569},[2567],{"#text":2568},"Lip, et al",{"@_align":1125},{"#text":1119},{"td":2572,":@":2573},[],{"@_align":1125},{"#text":1119},{"td":2576,":@":2577},[],{"@_align":1125},{"#text":1119},{"td":2580,":@":2583},[2581],{"#text":2582},"0.65",{"@_align":1125},{"#text":1119},{"td":2586,":@":2587},[],{"@_align":1125},{"#text":1119},{"td":2590,":@":2591},[],{"@_align":1125},{"#text":1115},{"#text":1115},{"tr":2595},[2596,2597,2602,2603,2607,2608,2612,2613,2617,2618,2623,2624,2629],{"#text":1119},{"td":2598,":@":2601},[2599],{"#text":2600},"Yao, et al",{"@_align":1125},{"#text":1119},{"td":2604,":@":2606},[2605],{"#text":2403},{"@_align":1125},{"#text":1119},{"td":2609,":@":2611},[2610],{"#text":2508},{"@_align":1125},{"#text":1119},{"td":2614,":@":2616},[2615],{"#text":2508},{"@_align":1125},{"#text":1119},{"td":2619,":@":2622},[2620],{"#text":2621},"0.65 (MB)",{"@_align":1125},{"#text":1119},{"td":2625,":@":2628},[2626],{"#text":2627},"0.68 (MB)",{"@_align":1125},{"#text":1115},{"#text":779},{"@_valign":1159},{"#text":738},{"#text":753},{"@_id":1582,"@_position":1328},{"#text":753},{"p":2637},[2638,2640,2645],{"#text":2639},"The complete definitions for each variable (sets of SNOMED-CT or RxNorm codes) are provided in the study package available on GitHub (",{"ext-link":2641,":@":2644},[2642],{"#text":2643},"https://github.com/ohdsi-studies/validationInContext",{"@_ext-link-type":747,"@_xlink:href":2643},{"#text":1357},{"#text":858},{"@_id":2648},"s2-3",{"#text":858},{"sec":2651,":@":2756},[2652,2653,2657,2658,2670,2671,2675,2676,2680,2681,2685,2686,2690,2691,2695,2696,2700,2701,2705,2706,2710,2711,2715,2716,2728,2729,2740,2741,2745,2746,2755],{"#text":753},{"title":2654},[2655],{"#text":2656},"2.4 Development of models used for upper and lower-bound AUROC estimation",{"#text":753},{"p":2659},[2660,2662,2668],{"#text":2661},"We applied the Observational Healthcare and Data Science Informatics (OHDSI) Patient Level Prediction framework to develop and validate the age/gender only models (hypothetical lower-bound AUROC) and large-scale LASSO regularized regression models with thousands of candidate predictors (hypothetical upper bound AUROC) (",{"xref":2663,":@":2666},[2664],{"#text":2665},"Reps et al., 2018",{"@_ref-type":879,"@_rid":2667},"B16",{"#text":2669},"). The framework is available as an open-source R package and implements a process for developing patient-level prediction models while addressing existing best practices towards ensuring models are clinically useful and transparent.",{"#text":753},{"p":2672},[2673],{"#text":2674},"The benchmark age/gender models (hypothetical lower-bound AUROC) only used the covariates age (in 5-years groups) and sex.",{"#text":753},{"p":2677},[2678],{"#text":2679},"The large-scale models (hypothetical upper-bound AUROC) are comprised of more than 30-thousand baseline covariates, including.",{"#text":753},{"p":2682},[2683],{"#text":2684},"Age in 5-years groups (e.g., 0–5, 5–10).",{"#text":753},{"p":2687},[2688],{"#text":2689},"Sex.",{"#text":753},{"p":2692},[2693],{"#text":2694},"Conditions (grouped using vocabulary hierarchy).",{"#text":753},{"p":2697},[2698],{"#text":2699},"Drugs (grouped into ingredients),",{"#text":753},{"p":2702},[2703],{"#text":2704},"Procedures.",{"#text":753},{"p":2707},[2708],{"#text":2709},"Measurements.",{"#text":753},{"p":2712},[2713],{"#text":2714},"Observations,",{"#text":753},{"p":2717},[2718,2720,2726],{"#text":2719},"And use of Devices all-time prior to the index date. The models’ calibration-in-the-large values are presented in ",{"xref":2721,":@":2724},[2722],{"#text":2723},"Table A3",{"@_ref-type":1065,"@_rid":2725},"TA3",{"#text":2727},". None of the existing models were well calibrated.",{"#text":753},{"p":2730},[2731,2733,2739],{"#text":2732},"Models were trained on each of the four databases, which was split into a training set (75% of the data) and a testing set (25% of the data) to perform internal validation. Two models were created per database, one for each target population (warfarin new users or DOACs new users), resulting in a total of 8 models: 2 target cohorts x 4 databases. The chosen classifier was a regularized logistic regression with Least Absolute Shrinkage and Selection Operator (LASSO) regularization and the hyper-parameter controlling the amount of regularization. Models were developed an adaptive search and 10-fold cross validation on the training set (",{"xref":2734,":@":2737},[2735],{"#text":2736},"Suchard et al., 2013",{"@_ref-type":879,"@_rid":2738},"B17",{"#text":1357},{"#text":753},{"p":2742},[2743],{"#text":2744},"To internally evaluate the models, the model discrimination on the test set was assessed using the AUROC and the model calibration was assessed by inspecting a calibration plot generated by binning the patients into 10 groups based on their predicted MB risk and comparing the observed fraction of the group with a MB record by the end of observation vs. the mean predicted MB risk for the group.",{"#text":753},{"p":2747},[2748,2750,2754],{"#text":2749},"All code used to develop and train all models in this study are provided in the study package available on GitHub (",{"ext-link":2751,":@":2753},[2752],{"#text":2643},{"@_ext-link-type":747,"@_xlink:href":2643},{"#text":1357},{"#text":858},{"@_id":2757},"s2-4",{"#text":861},{"@_id":2760},"s2",{"#text":861},{"sec":2763,":@":3459},[2764,2765,2769,2770,2803,2804,3424,3425,3448,3449,3458],{"#text":858},{"title":2766},[2767],{"#text":2768},"3 Results",{"#text":858},{"p":2771},[2772,2774,2780,2782,2785,2786,2789,2790,2793,2795,2801],{"#text":2773},"The discriminative ability of the five existing models, the large-scale models, and age/gender only models on predicting the MB events across the four datasets are presented in ",{"xref":2775,":@":2778},[2776],{"#text":2777},"Table 3",{"@_ref-type":1065,"@_rid":2779},"T3",{"#text":2781},". For both cohorts of warfarin new users and DOACs new users, within any database investigated, the performance of all existing models did not differ substantially. The existing models achieved AUROC values between 0.6–0.7 across databases, generally on the lower end, though the values varied by database. The large-scale models performed better than the existing models with AUROCs in the low 0.7 s and the age/gender only models performed the worst, only predicting slightly better than random guessing (with all AUROC \u003C0.6). The best performing existing models, based on AUROC, differed across databases. Compared to other models, CHADS",{"sub":2783},[2784],{"#text":616},{"#text":846},{"sub":2787},[2788],{"#text":616},{"#text":851},{"sub":2791},[2792],{"#text":616},{"#text":2794},"VASc performed relatively better in CCAE (AUROCs 0.65–0.67) but worse in MDCD (AUROCs 0.54–0.61). In MDCR and Optum DOD, the existing models performed similarly. The ROC plots for the large-scale models (hypothetical upper bound AUROC), the existing models, and age/gender only models (hypothetical lower bound AUROC) are presented in ",{"xref":2796,":@":2799},[2797],{"#text":2798},"Figure 2",{"@_ref-type":1354,"@_rid":2800},"F2",{"#text":2802},". As expected, the existing models’ performance fell somewhere between the hypothetical upper and lower bounds AUROC.",{"#text":858},{"table-wrap":2805,":@":3423},[2806,2807,2811,2812,2820,2821,3422],{"#text":753},{"label":2808},[2809],{"#text":2810},"TABLE 3",{"#text":753},{"caption":2813},[2814,2815,2819],{"#text":738},{"p":2816},[2817],{"#text":2818},"Discriminative ability of the five existing bleeding risk prediction models, the LASSO logistic regression models, and age/gender model across four databases. * indicates that no covariates were picked in the model resulting in everyone being assigned the same risk.",{"#text":753},{"#text":753},{"table":2822},[2823,2824,2868,2869,3421],{"#text":738},{"thead":2825,":@":2867},[2826,2827,2866],{"#text":779},{"tr":2828},[2829,2830,2835,2836,2841,2842,2847,2848,2853,2854,2859,2860,2865],{"#text":1115},{"th":2831,":@":2834},[2832],{"#text":2833},"Target population",{"@_align":1125},{"#text":1115},{"th":2837,":@":2840},[2838],{"#text":2839},"Model",{"@_align":1125},{"#text":1115},{"th":2843,":@":2846},[2844],{"#text":2845},"CCAE AUROC (95% CI)",{"@_align":1125},{"#text":1115},{"th":2849,":@":2852},[2850],{"#text":2851},"MDCD AUROC (95% CI)",{"@_align":1125},{"#text":1115},{"th":2855,":@":2858},[2856],{"#text":2857},"MDCR AUROC (95% CI)",{"@_align":1125},{"#text":1115},{"th":2861,":@":2864},[2862],{"#text":2863},"Optum DOD AUROC (95%CI)",{"@_align":1125},{"#text":779},{"#text":738},{"@_valign":1159},{"#text":738},{"tbody":2870,":@":3420},[2871,2872,2911,2912,2948,2949,2985,2986,3022,3023,3062,3063,3107,3108,3147,3148,3186,3187,3223,3224,3260,3261,3297,3298,3337,3338,3382,3383,3419],{"#text":779},{"tr":2873},[2874,2875,2880,2881,2886,2887,2892,2893,2898,2899,2904,2905,2910],{"#text":1115},{"td":2876,":@":2879},[2877],{"#text":2878},"T1: New users of warfarin with prior atrial fibrillation",{"@_align":1125},{"#text":1115},{"td":2882,":@":2885},[2883],{"#text":2884},"Large-scale model trained on database",{"@_align":1125},{"#text":1115},{"td":2888,":@":2891},[2889],{"#text":2890},"0.72 (0.683–0.751)",{"@_align":1125},{"#text":1115},{"td":2894,":@":2897},[2895],{"#text":2896},"0.71 (0.664–0.755)",{"@_align":1125},{"#text":1115},{"td":2900,":@":2903},[2901],{"#text":2902},"0.67 (0.653–0.693)",{"@_align":1125},{"#text":1115},{"td":2906,":@":2909},[2907],{"#text":2908},"0.70 (0.687–0.718)",{"@_align":1125},{"#text":779},{"#text":779},{"tr":2913},[2914,2915,2918,2919,2923,2924,2929,2930,2935,2936,2941,2942,2947],{"#text":1115},{"td":2916,":@":2917},[],{"@_align":1125},{"#text":1115},{"td":2920,":@":2922},[2921],{"#text":1619},{"@_align":1125},{"#text":1115},{"td":2925,":@":2928},[2926],{"#text":2927},"0.60 (0.589–0.621)",{"@_align":1125},{"#text":1115},{"td":2931,":@":2934},[2932],{"#text":2933},"0.61 (0.588–0.638)",{"@_align":1125},{"#text":1115},{"td":2937,":@":2940},[2938],{"#text":2939},"0.60 (0.589–0.609)",{"@_align":1125},{"#text":1115},{"td":2943,":@":2946},[2944],{"#text":2945},"0.63 (0.622–0.638)",{"@_align":1125},{"#text":779},{"#text":779},{"tr":2950},[2951,2952,2955,2956,2960,2961,2966,2967,2972,2973,2978,2979,2984],{"#text":1115},{"td":2953,":@":2954},[],{"@_align":1125},{"#text":1115},{"td":2957,":@":2959},[2958],{"#text":1625},{"@_align":1125},{"#text":1115},{"td":2962,":@":2965},[2963],{"#text":2964},"0.61 (0.597–0.630)",{"@_align":1125},{"#text":1115},{"td":2968,":@":2971},[2969],{"#text":2970},"0.61 (0.583–0.63)",{"@_align":1125},{"#text":1115},{"td":2974,":@":2977},[2975],{"#text":2976},"0.60 (0.589–0.608)",{"@_align":1125},{"#text":1115},{"td":2980,":@":2983},[2981],{"#text":2982},"0.63 (0.619–0.635)",{"@_align":1125},{"#text":779},{"#text":779},{"tr":2987},[2988,2989,2992,2993,2997,2998,3003,3004,3009,3010,3015,3016,3021],{"#text":1115},{"td":2990,":@":2991},[],{"@_align":1125},{"#text":1115},{"td":2994,":@":2996},[2995],{"#text":1631},{"@_align":1125},{"#text":1115},{"td":2999,":@":3002},[3000],{"#text":3001},"0.65 (0.635–0.671)",{"@_align":1125},{"#text":1115},{"td":3005,":@":3008},[3006],{"#text":3007},"0.61 (0.588–0.640)",{"@_align":1125},{"#text":1115},{"td":3011,":@":3014},[3012],{"#text":3013},"0.61 (0.600–0.620)",{"@_align":1125},{"#text":1115},{"td":3017,":@":3020},[3018],{"#text":3019},"0.64 (0.628–0.644)",{"@_align":1125},{"#text":779},{"#text":779},{"tr":3024},[3025,3026,3029,3030,3037,3038,3043,3044,3049,3050,3055,3056,3061],{"#text":1115},{"td":3027,":@":3028},[],{"@_align":1125},{"#text":1115},{"td":3031,":@":3036},[3032,3033],{"#text":1637},{"sub":3034},[3035],{"#text":616},{"@_align":1125},{"#text":1115},{"td":3039,":@":3042},[3040],{"#text":3041},"0.66 (0.644–0.679)",{"@_align":1125},{"#text":1115},{"td":3045,":@":3048},[3046],{"#text":3047},"0.56 (0.532–0.583)",{"@_align":1125},{"#text":1115},{"td":3051,":@":3054},[3052],{"#text":3053},"0.60 (0.590–0.610)",{"@_align":1125},{"#text":1115},{"td":3057,":@":3060},[3058],{"#text":3059},"0.63 (0.623–0.638)",{"@_align":1125},{"#text":779},{"#text":779},{"tr":3064},[3065,3066,3069,3070,3082,3083,3088,3089,3094,3095,3100,3101,3106],{"#text":1115},{"td":3067,":@":3068},[],{"@_align":1125},{"#text":1115},{"td":3071,":@":3081},[3072,3073,3076,3077,3080],{"#text":1646},{"sub":3074},[3075],{"#text":616},{"#text":851},{"sub":3078},[3079],{"#text":616},{"#text":1655},{"@_align":1125},{"#text":1115},{"td":3084,":@":3087},[3085],{"#text":3086},"0.66 (0.646–0.680)",{"@_align":1125},{"#text":1115},{"td":3090,":@":3093},[3091],{"#text":3092},"0.54 (0.513–0.565)",{"@_align":1125},{"#text":1115},{"td":3096,":@":3099},[3097],{"#text":3098},"0.61 (0.600–620)",{"@_align":1125},{"#text":1115},{"td":3102,":@":3105},[3103],{"#text":3104