rowspan=\"1\" colspan=\"1\"\u003E\u003Cbr\u003E\u003C\u002Ftd\u003E\u003Ctd rowspan=\"1\" colspan=\"1\"\u003EResearchers\u003C\u002Ftd\u003E\u003Ctd colspan=\"2\" rowspan=\"1\"\u003E2.887\u003C\u002Ftd\u003E\u003Ctd rowspan=\"1\" colspan=\"1\"\u003E1.467-5.842\u003C\u002Ftd\u003E\u003Ctd colspan=\"2\" rowspan=\"1\"\u003E.003\u003C\u002Ftd\u003E\u003Ctd colspan=\"3\" rowspan=\"1\"\u003E5.893\u003C\u002Ftd\u003E\u003Ctd colspan=\"2\" rowspan=\"1\"\u003E1.520-9.469\u003C\u002Ftd\u003E\u003Ctd colspan=\"2\" rowspan=\"1\"\u003E.02\u003C\u002Ftd\u003E\u003C\u002Ftr\u003E\u003Ctr valign=\"top\"\u003E\u003Ctd rowspan=\"1\" colspan=\"1\"\u003E\u003Cbr\u003E\u003C\u002Ftd\u003E\u003Ctd rowspan=\"1\" colspan=\"1\"\u003EExecutives\u003C\u002Ftd\u003E\u003Ctd colspan=\"2\" rowspan=\"1\"\u003E0.467\u003C\u002Ftd\u003E\u003Ctd rowspan=\"1\" colspan=\"1\"\u003E1.148-5.426\u003C\u002Ftd\u003E\u003Ctd colspan=\"2\" rowspan=\"1\"\u003E.02\u003C\u002Ftd\u003E\u003Ctd colspan=\"3\" rowspan=\"1\"\u003E5.716\u003C\u002Ftd\u003E\u003Ctd colspan=\"2\" rowspan=\"1\"\u003E1.179-9.844\u003C\u002Ftd\u003E\u003Ctd colspan=\"2\" rowspan=\"1\"\u003E.04\u003C\u002Ftd\u003E\u003C\u002Ftr\u003E\u003Ctr valign=\"top\"\u003E\u003Ctd rowspan=\"1\" colspan=\"1\"\u003E\u003Cbr\u003E\u003C\u002Ftd\u003E\u003Ctd rowspan=\"1\" colspan=\"1\"\u003EMedical professionals\u003C\u002Ftd\u003E\u003Ctd colspan=\"2\" rowspan=\"1\"\u003E0.893\u003C\u002Ftd\u003E\u003Ctd rowspan=\"1\" colspan=\"1\"\u003E0.447-1.810\u003C\u002Ftd\u003E\u003Ctd colspan=\"2\" rowspan=\"1\"\u003E.75\u003C\u002Ftd\u003E\u003Ctd colspan=\"3\" rowspan=\"1\"\u003E4.964\u003C\u002Ftd\u003E\u003Ctd colspan=\"2\" rowspan=\"1\"\u003E1.984-8.162\u003C\u002Ftd\u003E\u003Ctd colspan=\"2\" rowspan=\"1\"\u003E.008\u003C\u002Ftd\u003E\u003C\u002Ftr\u003E\u003Ctr valign=\"top\"\u003E\u003Ctd rowspan=\"1\" colspan=\"1\"\u003E\u003Cbr\u003E\u003C\u002Ftd\u003E\u003Ctd rowspan=\"1\" colspan=\"1\"\u003ETeachers\u003C\u002Ftd\u003E\u003Ctd colspan=\"2\" rowsp