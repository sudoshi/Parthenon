-bd11-543354ce7b1b/thumbnail&q;},&q;self&q;:{&q;href&q;:&q;https://dr.lib.iastate.edu/server/api/core/items/d2bcee6c-7cba-4fa7-bd11-543354ce7b1b&q;},&q;atmireAvsConfig&q;:{&q;href&q;:&q;https://dr.lib.iastate.edu/server/api/core/item/d2bcee6c-7cba-4fa7-bd11-543354ce7b1b/atmire-avs-config&q;}},&q;_name&q;:&q;Iowa State University Digital Repository&q;,&q;id&q;:&q;d2bcee6c-7cba-4fa7-bd11-543354ce7b1b&q;,&q;uuid&q;:&q;d2bcee6c-7cba-4fa7-bd11-543354ce7b1b&q;,&q;type&q;:&q;item&q;,&q;metadata&q;:{&q;dc.date&q;:[{&q;uuid&q;:&q;99fc9ac8-e872-43bb-8848-7c246971b02d&q;,&q;language&q;:null,&q;value&q;:&q;2021-02-26T23:03:36.604&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;624eaed1-15cf-4d4f-a156-07b85fedc91b&q;,&q;language&q;:null,&q;value&q;:&q;2021-02-27T15:58:37Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;5f0d2037-6d2c-4972-9c47-a3ed94e17b10&q;,&q;language&q;:null,&q;value&q;:&q;2021-02-27T15:58:37Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description&q;:[{&q;uuid&q;:&q;afe68727-39fb-4559-8598-ea13917cb5a5&q;,&q;language&q;:null,&q;value&q;:&q;The Iowa State University Digital Repository is the open access institutional repository for the university to collect, manage, share, and preserve free, worldwide access to research and scholarship of Iowa State faculty, staff, and students.  \n\nMaterial in the Digital Repository covers a wide range of disciplines from engineering to social sciences to arts and humanities.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;e31ec930-0680-4298-9e86-3da7e58a4dd7&q;,&q;language&q;:null,&q;value&q;:&q;The Iowa State University Digital Repositories is a platform for Iowa State&s;s faculty, staff and students to share their research and scholarship with the world. Content in the Digital Repository is organized according to Iowa State&s;s organization: first, by college, then by department, program, or center.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier&q;:[{&q;uuid&q;:&q;8b115647-b784-4fd3-84a6-916b0067a4a9&q;,&q;language&q;:null,&q;value&q;:&q;repository&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;88b0785c-e7f2-4398-a360-47a738d7f51d&q;,&q;language&q;:null,&q;value&q;:&q;https://dr.lib.iastate.edu/handle/20.500.12876/99074&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title&q;:[{&q;uuid&q;:&q;11f996d0-f820-4e77-9b0f-aa220e40ab14&q;,&q;language&q;:null,&q;value&q;:&q;Iowa State University Digital Repository&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.type&q;:[{&q;uuid&q;:&q;baedbbba-26db-4365-86f8-cfdb264d54d5&q;,&q;language&q;:null,&q;value&q;:&q;ir_community&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dspace.entity.type&q;:[{&q;uuid&q;:&q;526e3d02-ec56-4432-bcc6-9092446b94b2&q;,&q;language&q;:null,&q;value&q;:&q;OrgUnit&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;organization.legalName&q;:[{&q;uuid&q;:&q;26d18485-bb58-498e-92c6-d288966f7173&q;,&q;language&q;:null,&q;value&q;:&q;Iowa State University Digital Repository&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;relation.isSeriesOfOrgUnit&q;:[{&q;uuid&q;:&q;32086ee6-db48-4133-b86d-a076fa1bd61c&q;,&q;language&q;:null,&q;value&q;:&q;a91a72c8-addb-4c6e-b562-4b1845bf68be&q;,&q;place&q;:0,&q;authority&q;:&q;virtual::57393&q;,&q;confidence&q;:-1},{&q;uuid&q;:&q;747bd84f-7dac-41e4-8f40-90ab3281956b&q;,&q;language&q;:null,&q;value&q;:&q;cb0cb3c2-00b5-4555-8f5c-bf3ffd0bbc5b&q;,&q;place&q;:1,&q;authority&q;:&q;virtual::57395&q;,&q;confidence&q;:-1},{&q;uuid&q;:&q;4438cd80-fd69-40ac-bf5d-4c6f361c612d&q;,&q;language&q;:null,&q;value&q;:&q;5b3cde11-556c-49c3-ae52-a858c1130cd9&q;,&q;place&q;:2,&q;authority&q;:&q;virtual::57415&q;,&q;confidence&q;:-1},{&q;uuid&q;:&q;55d1662d-2ef0-45ca-864