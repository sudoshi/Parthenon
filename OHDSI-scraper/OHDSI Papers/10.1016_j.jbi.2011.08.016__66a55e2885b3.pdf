<tr>
<td align="left" rowspan="1" colspan="1">Control Sample</td>
<td align="right" rowspan="1" colspan="1">111</td>
<td align="right" rowspan="1" colspan="1">14</td>
<td align="right" rowspan="1" colspan="1">0.13</td>
<td align="right" rowspan="1" colspan="1">14</td>
