<td align="left" rowspan="1" colspan="1">Incorrect parent</td>
<td align="right" rowspan="1" colspan="1">22</td>
</tr>
<tr>
<td align="left" rowspan="1" colspan="1">Missing child</td>
<td align="right" rowspan="1" colspan="1">6</td>
