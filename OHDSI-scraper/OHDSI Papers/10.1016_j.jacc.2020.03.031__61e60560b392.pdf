<li id="u0325"><p id="p0525">Apixaban</p></li>
<li id="u0330"><p id="p0530">Rivaroxaban</p></li>
<li id="u0335"><p id="p0535">Warfarin</p></li>
</ul>Antiplatelets<ul id="ulist0200" class="list" style="list-style-type:none">
<li id="u0340"><p id="p0540">Ticagrelor</p></li>
<li id="u0345"><p id="p0545">Clopidogrel</p></li>
</ul>Statins<ul id="ulist0205" class="list" style="list-style-type:none">
<li id="u0350"><p id="p0550">Simvastatin</p></li>
<li id="u0355"><p id="p0555">Atorvastatin</p></li>
<li id="u0360"><p id="p0560">Lovastatin</p></li>
</ul>Beta-blockers<ul id="ulist0210" class="list" style="list-style-type:none"><li id="u0365"><p id="p0565">Metoprolol, carvedilol, propranolol, labetalol</p></li></ul>Antiarrhythmics<ul id="ulist0215" class="list" style="list-style-type:none"><li id="u0370"><p id="p0570">Amiodarone</p></li></ul>
</td>
