</tr>
<tr>
<td colspan="1" rowspan="1">Ribavirin</td>
<td colspan="1" rowspan="1">Anticoagulants<ul id="ulist0160" class="list" style="list-style-type:none"><li id="u0265"><p id="p0465">Warfarin</p></li></ul>
</td>
<td colspan="1" rowspan="1">Unknown mechanism of action:<ul id="ulist0165" class="list" style="list-style-type:none"><li id="u0270"><p id="p0470">Increased dose may be needed</p></li></ul>
</td>
<td colspan="1" rowspan="1">Monitor INR</td>
</tr>
<tr>
<td colspan="1" rowspan="1">Sarilumab</td>
<td colspan="1" rowspan="1">Anticoagulants<ul id="ulist0170" class="list" style="list-style-type:none">
<li id="u0275"><p id="p0475">Apixaban</p></li>
<li id="u0280"><p id="p0480">Rivaroxaban</p></li>
<li id="u0285"><p id="p0485">Warfarin</p></li>
</ul>Antiplatelets<ul id="ulist0175" class="list" style="list-style-type:none">
<li id="u0290"><p id="p0490">Ticagrelor</p></li>
